    function setLoading(isLoading, title = "Working", detail = "Preparing request") {{
      document.body.classList.toggle("busy", isLoading);
      // UIB-1: render title + detail into the global activity strip so
      // users see what the spinner is doing. Use querySelector so the
      // helper stays compatible with the existing Node JSDOM-light shim
      // used by tests (which implements querySelector but not
      // getElementById).
      const activity = document.querySelector("#globalActivity");
      const titleEl = document.querySelector("#globalActivityTitle");
      const detailEl = document.querySelector("#globalActivityDetail");
      if (activity) {{
        activity.setAttribute("aria-busy", isLoading ? "true" : "false");
      }}
      if (isLoading) {{
        if (titleEl) titleEl.textContent = title;
        if (detailEl) detailEl.textContent = detail;
      }}
    }}

