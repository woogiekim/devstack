def execute_doctor_cancel(workspace: "Workspace", params: Dict[str, List[str]]) -> Dict[str, Any]:
    run_id = first_param(params, "doctor_run_id", "").strip()
    if not run_id:
        return ui_error("missing doctor run id")

    force_raw = first_param(params, "force", "").strip().lower()
    force = force_raw in {"1", "true", "yes", "on"}

    state_path = doctor_state_path(workspace, run_id)
    state = read_json_file(state_path)
    if not state:
        return ui_error(f"unknown doctor run: {run_id}")

    current_state = str(state.get("doctor_state") or "")
    if current_state not in {"spawned", "running"}:
        return {
            "ok": True,
            "returncode": state.get("returncode"),
            "status": doctor_status_label(current_state or "unknown"),
            "doctor_state": current_state,
            "doctor_outcome": state.get("doctor_outcome"),
            "status_class": doctor_status_class(current_state),
            "elapsed": state.get("elapsed", 0),
            "command": state.get("display_command", "devstack doctor"),
            "pid": state.get("pid"),
            "host_pid": state.get("host_pid"),
            "doctor_run_id": run_id,
            "output": f"doctor run {run_id} is not running ({current_state or 'unknown'}); nothing to cancel.\n",
            "signalled": False,
            "already_terminal": True,
        }

    signalled = cancel_doctor_run(workspace, run_id, force=force)
    state = read_json_file(state_path) or state
    state["log_tail"] = read_log_tail(state.get("log_path"))
    return {
        "ok": True,
        "returncode": state.get("returncode"),
        "status": doctor_status_label(str(state.get("doctor_state") or "cancelled")),
        "doctor_state": state.get("doctor_state"),
        "doctor_outcome": state.get("doctor_outcome"),
        "status_class": doctor_status_class(str(state.get("doctor_state") or "")),
        "elapsed": state.get("elapsed", 0),
        "command": state.get("display_command", "devstack doctor"),
        "pid": state.get("pid"),
        "host_pid": state.get("host_pid"),
        "doctor_run_id": run_id,
        "output": format_doctor_status_output(state),
        "signalled": signalled,
        "force": force,
    }


def execute_doctor_workflow(workspace: "Workspace", params: Dict[str, List[str]]) -> Dict[str, Any]:
    prepared = doctor_prompt(workspace, params)
    if not prepared.get("ok"):
        return prepared

    ai_agent = str(prepared["ai_agent"])
    prompt = str(prepared["output"])
    host_command, display_command = ai_doctor_command(ai_agent, workspace, prompt)
    executable = shutil.which(host_command[0])
    if not executable:
        return ui_error(f"AI CLI host command not found: {host_command[0]}")
    host_command[0] = executable

    stamp = datetime.datetime.now(datetime.timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    run_id = f"{AI_DOCTOR_LOG_PREFIX}_{ai_agent}_{stamp}"
    prompt_dir = workspace.state_dir / "doctor-prompts"
    prompt_path = prompt_dir / f"{AI_DOCTOR_LOG_PREFIX}_{ai_agent}_{stamp}.md"
    log_path = workspace.log_dir / f"{AI_DOCTOR_LOG_PREFIX}_{ai_agent}_{stamp}.log"
    state_path = doctor_state_path(workspace, run_id)
    prompt_dir.mkdir(parents=True, exist_ok=True)
    log_path.parent.mkdir(parents=True, exist_ok=True)
    prompt_path.write_text(prompt + "\n", encoding="utf-8")

    started = time.time()
    # Export the doctor environment under the new ``DEVSTACK_*`` names. Also
    # populate the legacy ``CCSTACK_*`` names for one release so any AI host
    # prompts / agent rules still expecting the old spelling continue to read
    # the same values. Both naming families resolve to identical paths, so
    # consumers can migrate independently.
    devstack_home = str(prepared["devstack_home"])
    instruction_paths_value = os.pathsep.join(prepared["doctor_instruction_paths"])
    doctor_env = {
        "DEVSTACK_HOME": devstack_home,
        "DEVSTACK_DOCTOR_PROMPT_PATH": str(prompt_path),
        "DEVSTACK_DOCTOR_INSTRUCTION_PATHS": instruction_paths_value,
        # Legacy aliases (Shim 1) — same values, deprecated next release.
        "CCSTACK_HOME": devstack_home,
        "CCSTACK_DOCTOR_PROMPT_PATH": str(prompt_path),
        "CCSTACK_DOCTOR_INSTRUCTION_PATHS": instruction_paths_value,
    }
    header = "\n".join(
        [
            f"devstack doctor started at {stamp}",
            f"workspace: {workspace.name}",
            f"project root: {workspace.root}",
            f"ai cli host: {ai_agent}",
            f"scope: {prepared['doctor_scope']}",
            f"targets: {', '.join(prepared['doctor_targets']) or 'none'}",
            f"devstack home: {prepared['devstack_home']}",
            f"instructions: {doctor_env['DEVSTACK_DOCTOR_INSTRUCTION_PATHS']}",
            f"prompt: {prompt_path}",
            f"command: {display_command}",
            "",
        ]
    )
    state = {
        "run_id": run_id,
        "doctor_state": "spawned",
        "status": doctor_status_label("spawned"),
        "ai_agent": ai_agent,
        "doctor_scope": prepared["doctor_scope"],
        "doctor_targets": prepared["doctor_targets"],
        "failed_services": prepared["failed_services"],
        "prompt_path": str(prompt_path),
        "log_path": str(log_path),
        "state_path": str(state_path),
        "display_command": display_command,
        "command": host_command,
        "cwd": str(workspace.root),
        "env": doctor_env,
        "returncode": None,
        "created_at": datetime.datetime.now(datetime.timezone.utc).isoformat(),
    }
    write_json_file(state_path, state)

    try:
        log_file = log_path.open("ab")
        try:
            log_file.write(header.encode("utf-8"))
            log_file.flush()
            runner = [sys.executable, str(Path(__file__).resolve()), AI_DOCTOR_RUNNER_COMMAND, str(state_path)]
            process = subprocess.Popen(
                runner,
                cwd=workspace.root,
                stdin=subprocess.DEVNULL,
                stdout=log_file,
                stderr=subprocess.STDOUT,
                env={**os.environ, **doctor_env},
                start_new_session=True,
            )
        finally:
            log_file.close()
    except OSError as error:
        state["doctor_state"] = "spawn_failed"
        state["status"] = doctor_status_label("spawn_failed")
        state["error"] = str(error)
        write_json_file(state_path, state)
        return ui_error(f"doctor workflow failed to start: {error}")

    state["pid"] = process.pid
    write_json_file(state_path, state)

    target_lines = "\n".join(f"  - {name}" for name in prepared["doctor_targets"]) or "  - none"
    return {
        "ok": True,
        "returncode": None,
        "status": doctor_status_label("spawned"),
        "doctor_state": "spawned",
        "status_class": doctor_status_class("spawned"),
        "elapsed": round(time.time() - started, 1),
        "command": display_command,
        "pid": process.pid,
        "doctor_run_id": run_id,
        "ai_agent": ai_agent,
        "doctor_scope": prepared["doctor_scope"],
        "doctor_targets": prepared["doctor_targets"],
        "failed_services": prepared["failed_services"],
        "prompt_path": str(prompt_path),
        "log_path": str(log_path),
        "state_path": str(state_path),
        "output": (
            "Doctor workflow spawned through the selected AI CLI host.\n"
            f"AI CLI host: {ai_agent}\n"
            f"Scope: {prepared['doctor_scope']}\n"
            "Targets:\n"
            f"{target_lines}\n"
            f"PID: {process.pid}\n"
            f"Prompt: {prompt_path}\n"
            f"Log: {log_path}\n"
            f"State: {state_path}\n"
            f"devstack home: {prepared['devstack_home']}\n"
            f"Doctor instructions: {doctor_env['DEVSTACK_DOCTOR_INSTRUCTION_PATHS']}\n"
            "devstack is not running service-specific recovery logic; the selected host is executing the project doctor instructions."
        ),
    }


def pick_directory(initial_path: str = "") -> Optional[Path]:
    if sys.platform == "darwin":
        return pick_directory_macos(initial_path)
    if sys.platform.startswith("win"):
        return pick_directory_windows(initial_path)
    return pick_directory_linux(initial_path)


def pick_directory_macos(initial_path: str = "") -> Optional[Path]:
    default_location = applescript_default_location(initial_path)
    script = (
        f"POSIX path of (choose folder with prompt {applescript_quote('Select devstack workspace folder')}"
        f"{default_location})"
    )
    result = subprocess.run(
        ["osascript", "-e", script],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    if result.returncode != 0:
        if "User canceled" in result.stderr:
            return None
        raise DevstackError(result.stderr.strip() or "folder picker failed")

    return Path(result.stdout.strip()).expanduser().resolve()


def applescript_default_location(initial_path: str) -> str:
    if not initial_path.strip():
        return ""

    path = Path(initial_path).expanduser()
    if not path.exists() or not path.is_dir():
        return ""

    return f" default location POSIX file {applescript_quote(str(path.resolve()))}"


def applescript_quote(value: str) -> str:
    return '"' + value.replace("\\", "\\\\").replace('"', '\\"') + '"'


def pick_directory_windows(initial_path: str = "") -> Optional[Path]:
    script = [
        "Add-Type -AssemblyName System.Windows.Forms",
        "$dialog = New-Object System.Windows.Forms.FolderBrowserDialog",
        "$dialog.Description = 'Select devstack workspace folder'",
    ]
    if initial_path.strip():
        script.append(f"$dialog.SelectedPath = {powershell_quote(str(Path(initial_path).expanduser()))}")
    script.extend(
        [
            "if ($dialog.ShowDialog() -eq [System.Windows.Forms.DialogResult]::OK) {",
            "  [Console]::WriteLine($dialog.SelectedPath)",
            "} else {",
            "  exit 2",
            "}",
        ]
    )
    result = subprocess.run(
        ["powershell", "-NoProfile", "-STA", "-Command", "; ".join(script)],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    if result.returncode == 2:
        return None
    if result.returncode != 0:
        raise DevstackError(result.stderr.strip() or "folder picker failed")

    return Path(result.stdout.strip()).expanduser().resolve()


def powershell_quote(value: str) -> str:
    return "'" + value.replace("'", "''") + "'"


def pick_directory_linux(initial_path: str = "") -> Optional[Path]:
    command = linux_directory_picker_command(initial_path)
    if not command:
        raise DevstackError("folder picker is not supported on this platform; type the path manually")

    result = subprocess.run(
        command,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    if result.returncode != 0:
        return None

    return Path(result.stdout.strip()).expanduser().resolve()


def linux_directory_picker_command(initial_path: str = "") -> List[str]:
    initial = str(Path(initial_path).expanduser()) if initial_path.strip() else ""
    if shutil.which("zenity"):
        command = ["zenity", "--file-selection", "--directory", "--title=Select devstack workspace folder"]
        if initial:
            command.append(f"--filename={initial}/")
        return command
    if shutil.which("kdialog"):
        return ["kdialog", "--getexistingdirectory", initial or str(Path.home())]
    return []


def workspace_meta(workspace: "Workspace", registry: Optional["WorkspaceRegistry"] = None) -> Dict[str, Any]:
    workspaces = registered_workspace_catalog(registry)
    workspace_bound = not workspace.config.get("workspace_setup")
    selected_workspace = workspace.name if workspace_bound else NEW_WORKSPACE_ID
    if workspace_bound and not any(entry["id"] == workspace.name for entry in workspaces):
        workspaces.insert(
            0,
            {
                "id": workspace.name,
                "label": workspace.name,
                "registered": True,
                "root": str(workspace.root),
                "default": False,
            },
        )
    workspaces.append(
        {
            "id": NEW_WORKSPACE_ID,
            "label": "Add workspace",
            "registered": False,
            "root": "",
            "default": False,
        }
    )
    # Surface workspace-level readiness warnings (machine-readable). Today
    # the only emitter is the seed-drift persisted record (see
    # SEED_DRIFT_FILENAME); the array is always returned so UI / counter
    # consumers can iterate uniformly. A bound workspace with no drift file
    # yields an empty list (= healthy).
    warnings: List[Dict[str, Any]] = []
    if workspace_bound:
        drift_state = read_seed_drift_state(workspace.name)
        if drift_state:
            warnings.append(seed_drift_warning_entry(drift_state))

    # Grey-zone counter mirror — same four-key contract as the CLI status
    # parseable line; rendered alongside `warnings` so a UI / tooling
    # consumer can pick either path without re-parsing the text output.
    # An unbound workspace gets all-zero counters (no readiness story yet).
    counters = (
        count_workspace_grey_zone(workspace) if workspace_bound else empty_grey_zone_counters()
    )

    return {
        "workspace": selected_workspace,
        "workspace_label": workspace.name if workspace_bound else "Add workspace",
        "workspace_bound": workspace_bound,
        "root": str(workspace.root) if workspace_bound else "",
        "suggested_root": "",
        "workspaces": workspaces,
        "profiles": sorted(workspace.profiles.keys()),
        "services": sorted(workspace.services.keys()),
        "warnings": warnings,
        "counters": counters,
    }


def ui_base_targets(workspace: "Workspace") -> List[str]:
    profiles = workspace.profiles
    base_profiles = [
        name for name in sorted(profiles.keys())
        if (
            not name.endswith("-light")
            and not looks_execution_task_name(name)
            and not is_legacy_auto_run_bundle_name(name)
        )
    ]
    targets = ["all"]
    for name in base_profiles:
        if name == "default":
            continue
        targets.append(name)
    return targets


def looks_execution_task_name(name: str) -> bool:
    return name.strip().startswith(":")


def ui_light_target(workspace: "Workspace", target: str) -> Optional[str]:
    profiles = workspace.profiles
    base_target = "default" if target == "all" else target or "default"
    light_profile = f"{base_target}-light"
    if light_profile in profiles:
        return base_target

    matching_light_profiles = [
        name[:-6] for name in sorted(profiles.keys())
        if name.endswith("-light")
        and profiles.get(name[:-6]) == profiles.get(base_target)
    ]
    if matching_light_profiles:
        return matching_light_profiles[0]

    light_bases = [name[:-6] for name in sorted(profiles.keys()) if name.endswith("-light")]
    if target in {"", "all", "default"} and len(light_bases) == 1:
        return light_bases[0]

    return None


def ui_service_catalog(workspace: "Workspace") -> List[Dict[str, str]]:
    catalog: List[Dict[str, str]] = []
    for name in sorted(workspace.services.keys()):
        service = workspace.services[name]
        catalog.append({
            "name": name,
            "type": str(service.get("type") or "-"),
            "role": ui_service_role(service),
            "port": str(service.get("port") or "-"),
            "health": str(service.get("health") or "-"),
        })
    return catalog


def ui_service_role(service: Dict[str, Any]) -> str:
    service_type = service.get("type")
    if service_type == "compose":
        return "infra"
    if service_type == "gradle":
        return "server" if service.get("port") or service.get("health") else "task"
    if service_type == "command":
        return "process"
    return str(service_type or "service")


def ui_service_cards(service_catalog: List[Dict[str, str]]) -> str:
    if not service_catalog:
        return '<div class="empty-board">No services detected.</div>'

    cards: List[str] = []
    for item in service_catalog:
        name = html.escape(item["name"])
        role = html.escape(item["role"])
        port = html.escape(item["port"])
        health = html.escape(item["health"])
        service_type = html.escape(item["type"])
        action = "Start"
        if role == "infra":
            action = "Inspect"
        elif role in {"server", "process"}:
            action = "Restart"
        meta = f"{role} / {service_type}"
        if port != "-":
            meta += f" / :{port}"
        if health != "-":
            meta += " / health"
        cards.append(
            f'<button class="service-card" type="button" data-service-card="{name}" data-service-name="{name}" '
            f'data-role="{role}" data-type="{service_type}" data-port="{port}" data-health="{health}" '
            f'data-action-cue="{html.escape(action)}" title="{name}">'
            f'<span class="service-card-main">'
            f'<span class="service-card-indicator" aria-hidden="true">'
            f'<span class="service-dot" data-service-dot></span>'
            f'<span class="service-card-spinner" data-service-spinner></span>'
            f'</span>'
            f'<span class="service-card-copy">'
            f'<strong>{name}</strong>'
            f'<span>{html.escape(meta)}</span>'
            f'</span>'
            f'</span>'
            f'<span class="service-card-state-wrap">'
            f'<span class="service-card-state" data-service-state>checking</span>'
            f'<span class="service-card-cue" data-service-cue>{html.escape(action)}</span>'
            f'</span>'
            f'</button>'
        )
    return "\n".join(cards)


def ui_service_summary(service_catalog: List[Dict[str, str]]) -> Dict[str, int]:
    summary = {"total": len(service_catalog), "server": 0, "infra": 0, "process": 0, "task": 0}
    for item in service_catalog:
        role = item.get("role") or "service"
        if role in summary:
            summary[role] += 1

    return summary


def ui_doctor_service_targets(service_catalog: List[Dict[str, str]]) -> str:
    if not service_catalog:
        return '<span class="doctor-empty">No services detected.</span>'

    targets: List[str] = []
    for item in service_catalog:
        name = html.escape(item["name"])
        targets.append(
            f'<label class="doctor-service-target" data-doctor-service="{name}" hidden>'
            f'<input type="checkbox" value="{name}">'
            f'<span>{name}</span>'
            f'</label>'
        )
    targets.append('<span class="doctor-empty" id="doctorNoFailedServices">No failed services detected.</span>')
    return "\n".join(targets)


def ui_log_lines(value: str) -> str:
    return value if value.isdigit() else "120"


def ui_log_follow_command(workspace: "Workspace", service: str, lines: str) -> List[str]:
    if service not in workspace.services:
        raise DevstackError(f"unknown service: {service}")

    return [
        sys.executable,
        str(Path(__file__).resolve()),
        "--workspace",
        workspace.name,
        "--root",
        str(workspace.root),
        "logs",
        service,
        "-f",
        "-n",
        ui_log_lines(lines),
    ]


def execute_ui_action(workspace: "Workspace", params: Dict[str, List[str]]) -> Dict[str, Any]:
    action = first_param(params, "action", "status")
    target = first_param(params, "target", "all")
    service = first_param(params, "service", "")
    only = first_param(params, "only", "")
    lines = first_param(params, "lines", "120")
    light = first_param(params, "light", "") == "1"
    no_deps = first_param(params, "no_deps", "") == "1"

    command: List[str]
    if action == "workspace_analyze":
        try:
            draft = analyze_workspace_draft(first_param(params, "workspace_root", ""))
        except DevstackError as error:
            return ui_error(str(error))
        return {
            "ok": True,
            "returncode": 0,
            "output": format_workspace_draft(draft),
            "elapsed": 0,
            "command": f"devstack workspace analyze {draft['root']}",
            "draft": draft,
            "draft_id": draft["draft_id"],
            "status": "review",
        }
    if action == "workspace_apply":
        try:
            apply_recreate_volumes = first_param(params, "recreate_volumes", "") == "1"
            applied = apply_workspace_draft(
                first_param(params, "draft_id", ""),
                recreate_volumes=apply_recreate_volumes,
            )
        except DevstackError as error:
            return ui_error(str(error))
        managed_lines = format_managed_environment_apply(applied.get("managed_environment", {}))
        seed_changed_line = ""
        if applied.get("seed_changed"):
            named = ", ".join(applied.get("named_volumes", []) or [])
            seed_changed_line = (
                f"seed change detected — affected named volumes: {named or '(none)'}\n"
                "run with recreate_volumes=1 to recreate docker named volumes (opt-in; data will be deleted)\n"
            )
        recreation = applied.get("volume_recreation") or {}
        recreation_line = ""
        if recreation.get("performed"):
            removed = ", ".join(recreation.get("removed", []) or [])
            recreation_line = f"recreated docker named volumes: {removed or '(none)'}\n"
            if recreation.get("errors"):
                recreation_line += "volume recreation errors: " + "; ".join(recreation["errors"]) + "\n"
        return {
            "ok": True,
            "returncode": 0,
            "output": (
                f"registered workspace: {applied['name']} -> {applied['root']}\n"
                f"config: {applied['config']}\n"
                f"{managed_lines}"
                f"{seed_changed_line}"
                f"{recreation_line}"
                f"default workspace: {applied['name']}\n"
            ),
            "elapsed": 0,
            "command": f"devstack workspace apply {applied['name']}",
            "workspace": applied["name"],
            "status": "applied",
            "seed_changed": applied.get("seed_changed", False),
            "named_volumes": applied.get("named_volumes", []),
            "volume_recreation": recreation,
            "warnings": list(applied.get("warnings", []) or []),
        }
    if action == "workspace_recreate_volumes":
        # Explicit opt-in entry point for the destructive named-volume rebuild.
        # The caller MUST have already gotten user confirmation (the UI action
        # exists separately from workspace_apply to make the destructive
        # boundary obvious).
        try:
            applied = apply_workspace_draft(
                first_param(params, "draft_id", ""),
                recreate_volumes=True,
            )
        except DevstackError as error:
            return ui_error(str(error))
        recreation = applied.get("volume_recreation") or {}
        removed = ", ".join(recreation.get("removed", []) or [])
        return {
            "ok": True,
            "returncode": 0,
            "output": (
                f"workspace: {applied['name']}\n"
                f"recreated docker named volumes: {removed or '(none)'}\n"
                + ("errors: " + "; ".join(recreation.get("errors", [])) + "\n" if recreation.get("errors") else "")
            ),
            "elapsed": 0,
            "command": f"devstack workspace apply {applied['name']} --recreate-volumes",
            "workspace": applied["name"],
            "status": "recreated",
            "volume_recreation": recreation,
            "warnings": list(applied.get("warnings", []) or []),
        }
    if action == "workspace_delete":
        try:
            purge_workspace = first_param(params, "purge", "") == "1"
            removed = delete_registered_workspace(workspace.name, purge=purge_workspace)
        except DevstackError as error:
            return ui_error(str(error))
        verb = "purged" if purge_workspace else "removed"
        purged_output = "".join(f"purged state: {path}\n" for path in removed.get("purged", []))
        return {
            "ok": True,
            "returncode": 0,
            "output": (
                f"{verb} workspace: {removed['name']}\n"
                f"root preserved: {removed['root']}\n"
                f"{purged_output}"
                "project files were not deleted\n"
            ),
            "elapsed": 0,
            "command": f"devstack workspace {'purge' if purge_workspace else 'remove'} {removed['name']}",
            "workspace": NEW_WORKSPACE_ID,
            "status": "purged" if purge_workspace else "removed",
        }
    if action == "workspace_setup":
        try:
            draft = analyze_workspace_draft(first_param(params, "workspace_root", ""))
            applied = apply_workspace_draft(draft["draft_id"])
        except DevstackError as error:
            return ui_error(str(error))
        managed_lines = format_managed_environment_apply(applied.get("managed_environment", {}))
        return {
            "ok": True,
            "returncode": 0,
            "output": format_workspace_draft(draft)
            + f"\nregistered workspace: {applied['name']} -> {applied['root']}\n"
            + managed_lines,
            "elapsed": 0,
            "command": f"devstack workspace setup {applied['root']} --name {applied['name']} --default",
            "workspace": applied["name"],
            "status": "applied",
        }
    if workspace.config.get("workspace_setup"):
        return ui_error("workspace is not applied. Set up the path, Analyze, and Apply first.")
    if action == "status":
        command = ["status", target or "all"]
        # UIB-9 (engine half): build a structured service_states map alongside
        # the existing text output so the client can prefer the structured
        # form over fragile line.startsWith parsing. Purely additive — the
        # 'output' field is unchanged so older clients still work.
        result = run_devstack_command(workspace, command)
        result["command"] = "devstack " + " ".join(command)
        result["service_states"] = parse_service_states_from_status_text(
            result.get("output", ""),
            list(workspace.services.keys()),
        )
        return result
    elif action == "doctor":
        return execute_doctor_workflow(workspace, params)
    elif action == "doctor_status":
        return execute_doctor_status(workspace, params)
    elif action == "doctor_cancel":
        return execute_doctor_cancel(workspace, params)
    elif action == "up":
        if light:
            command_target = ui_light_target(workspace, target)
            if not command_target:
                return ui_error(f"no light profile for target: {target or 'default'}")
        else:
            command_target = target or "default"

        command = ["up", command_target]
        if light:
            command.append("--light")
        if no_deps:
            command.append("--no-deps")
        if only:
            only_services = [name.strip() for name in only.split(",") if name.strip()]
            unknown_services = [name for name in only_services if name not in workspace.services]
            if unknown_services:
                return ui_error(f"unknown service: {', '.join(unknown_services)}")
            command.extend(["--only", ",".join(only_services)])

        result = run_devstack_command_background(workspace, command)
        result["command"] = "devstack " + " ".join(command)
        return result
    elif action == "down":
        if only:
            only_services = [name.strip() for name in only.split(",") if name.strip()]
            unknown_services = [name for name in only_services if name not in workspace.services]
            if unknown_services:
                return ui_error(f"unknown service: {', '.join(unknown_services)}")
            if len(only_services) != 1:
                return ui_error("stop requires exactly one selected service")
            command = ["stop", only_services[0]]
        else:
            command = ["down", target or "default"]

        # UIB-3: down is potentially slow (multi-service shutdown can exceed
        # 30s); route through the background path so the UI doesn't hang on
        # the synchronous subprocess.
        result = run_devstack_command_background(workspace, command, label="shutdown")
        result["command"] = "devstack " + " ".join(command)
        return result
    elif action == "restart":
        if service not in workspace.services:
            return ui_error(f"unknown service: {service}")
        command = ["restart", service]
        if no_deps:
            command.append("--no-deps")

        # UIB-10 (partial): restart can pin the UI when a service is wedged;
        # mirror the up/down background dispatch contract.
        result = run_devstack_command_background(workspace, command, label="restart")
        result["command"] = "devstack " + " ".join(command)
        return result
    elif action == "logs":
        if service not in workspace.services:
            return ui_error(f"unknown service: {service}")
        command = ["logs", service, "-n", ui_log_lines(lines)]
    elif action == "follow_logs":
        if service not in workspace.services:
            return ui_error(f"unknown service: {service}")
        return ui_error("follow logs uses the live stream endpoint")
    elif action == "clear_logs":
        if service not in workspace.services:
            return ui_error(f"unknown service: {service}")
        try:
            log_path = workspace.clear_logs(service)
        except DevstackError as error:
            return ui_error(str(error))
        return {
            "ok": True,
            "returncode": 0,
            "output": f"cleared log: {log_path}\n",
            "elapsed": 0,
            "command": f"devstack clear-logs {service}",
        }
    elif action == "recover":
        if service not in workspace.services:
            return ui_error(f"unknown service: {service}")
        # UIB-10 deferred for recover: the in-process recover_failed_service
        # path runs API verification + reads workspace state in the same
        # interpreter as the UI. Routing it through a subprocess would lose
        # the in-memory workspace context (mtime checks, draft state) and
        # break the contract that `recover.assert_called_once_with(...)`
        # in the existing pre-recover-test suite relies on. Restart and
        # down get the background routing; recover stays in-process.
        try:
            output = workspace.recover_failed_service(service)
        except DevstackError as error:
            return ui_error(str(error))
        return {
            "ok": True,
            "returncode": 0,
            "output": output,
            "elapsed": 0,
            "command": f"devstack recover {service}",
            "status": "recovered",
        }
    else:
        return ui_error(f"unsupported action: {action}")

    result = run_devstack_command(workspace, command)
    result["command"] = "devstack " + " ".join(command)
    return result


def run_devstack_command_background(
    workspace: "Workspace",
    command: List[str],
    label: str = "startup",
) -> Dict[str, Any]:
    cmd = [sys.executable, str(Path(__file__).resolve()), "--root", str(workspace.root), *command]
    started = time.time()
    log_path = workspace.log_dir / "ui-actions.log"
    log_path.parent.mkdir(parents=True, exist_ok=True)

    try:
        log_file = log_path.open("ab")
        try:
            process = subprocess.Popen(
                cmd,
                cwd=workspace.root,
                stdout=log_file,
                stderr=subprocess.STDOUT,
                start_new_session=True,
            )
        finally:
            log_file.close()
        output = (
            f"devstack UI: {label} is running in the background.\n"
            f"pid: {process.pid}\n"
            f"Stop it with: kill {process.pid}"
        )
        if label == "startup":
            output += (
                "\nRun Status to check readiness."
                "\nIf startup stalls, run Status and inspect the failed service diagnostics."
            )
        return {
            "ok": True,
            "returncode": None,
            "status": "started",
            "output": output,
            "elapsed": round(time.time() - started, 1),
        }
    except OSError as error:
        return {
            "ok": False,
            "returncode": 1,
            "output": f"devstack UI: command failed: {error}",
            "elapsed": round(time.time() - started, 1),
        }


def run_devstack_command(workspace: "Workspace", command: List[str]) -> Dict[str, Any]:
    cmd = [sys.executable, str(Path(__file__).resolve()), "--root", str(workspace.root), *command]
    started = time.time()
    try:
        result = subprocess.run(
            cmd,
            cwd=workspace.root,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=180,
            check=False,
        )
        output = clean_ui_command_output(result.stdout)
        return {
            "ok": result.returncode == 0,
            "returncode": result.returncode,
            "output": output,
            "elapsed": round(time.time() - started, 1),
        }
    except subprocess.TimeoutExpired as error:
        output = error.stdout or ""
        return {
            "ok": False,
            "returncode": 124,
            "output": output + "\ndevstack UI: command timed out after 180s",
            "elapsed": round(time.time() - started, 1),
        }
    except OSError as error:
        return {
            "ok": False,
            "returncode": 1,
            "output": f"devstack UI: command failed: {error}",
            "elapsed": round(time.time() - started, 1),
        }


def clean_ui_command_output(output: str) -> str:
    if "Traceback (most recent call last):" in output and "ConnectionResetError" in output:
        return (
            "devstack UI: service health check connection was reset while the "
            "service was starting. Retry the action or run Status once startup settles."
        )
    return output


def parse_service_states_from_status_text(
    text: str,
    service_names: List[str],
) -> Dict[str, Dict[str, Any]]:
    """Convert the human-readable ``devstack status`` output into a structured
    ``{name: {state, port, health, log}}`` map (UIB-9).

    The existing client-side parser (rendered HTML around line 12845 of
    ``devstack``) walks the status text line by line, matches each known
    service name via ``line.startsWith(name + ' ')`` and extracts the first
    whitespace-separated token after the name as the state. We mirror that
    contract on the server so the response carries both the legacy text
    output AND a structured map — purely additive: the ``output`` field is
    untouched and any client unaware of ``service_states`` keeps working.

    Args:
      text: The raw stdout from ``devstack status``.
      service_names: The workspace's known service names (used to anchor the
        per-line parse; same convention the client uses).

    Returns:
      A dict mapping each service name to a small state dict. Services that
      don't appear in the status text default to ``state == "idle"`` to match
      the client's fallback behavior.
    """
    states: Dict[str, Dict[str, Any]] = {
        name: {"state": "idle", "port": None, "health": None, "log": None}
        for name in service_names
    }
    if not text:
        return states

    for raw_line in text.splitlines():
        line = raw_line.strip()
        if not line:
            continue
        matched_name = None
        for candidate in service_names:
            if line.startswith(candidate + " ") or line == candidate:
                # Pick the longest match to disambiguate prefix collisions
                # (e.g. "api" vs "api-v2"). Same heuristic as the client.
                if matched_name is None or len(candidate) > len(matched_name):
                    matched_name = candidate
        if not matched_name:
            continue
        remainder = line[len(matched_name):].strip()
        tokens = remainder.split()
        if not tokens:
            continue
        state = tokens[0]
        entry: Dict[str, Any] = {
            "state": state,
            "port": None,
            "health": None,
            "log": None,
        }
        if len(tokens) >= 2:
            try:
                entry["port"] = int(tokens[1])
            except (TypeError, ValueError):
                entry["port"] = None
        if len(tokens) >= 3:
            entry["health"] = tokens[2]
        if len(tokens) >= 4:
            # Last token is conventionally the log path; rejoin in case the
            # path itself contained spaces (rare but defensible).
            entry["log"] = " ".join(tokens[3:])
        states[matched_name] = entry

    return states


def first_param(params: Dict[str, List[str]], name: str, default: str) -> str:
    values = params.get(name)
    if not values:
        return default
    return values[0]


def int_param(params: Dict[str, List[str]], name: str, default: int) -> int:
    try:
        value = int(first_param(params, name, str(default)))
    except (TypeError, ValueError):
        return default
    return value if value > 0 else default


def ui_error(message: str) -> Dict[str, Any]:
    return {"ok": False, "returncode": 2, "output": message, "elapsed": 0}


def default_bin_dir() -> Path:
    return Path(env_read("BIN_DIR", str(Path.home() / ".local" / "bin"))).expanduser()


def default_codex_home() -> Path:
    return Path(os.environ.get("CODEX_HOME", Path.home() / ".codex")).expanduser()


def default_claude_home() -> Path:
    return Path(os.environ.get("CLAUDE_HOME", Path.home() / ".claude")).expanduser()


def path_lexists(path: Path) -> bool:
    return os.path.lexists(str(path))


def same_resolved_path(left: Path, right: Path) -> bool:
    try:
        return left.resolve() == right.resolve()
    except OSError:
        return False


def uninstall_targets(
    *,
    script_path: Optional[Path] = None,
    bin_dir: Optional[Path] = None,
    codex_home: Optional[Path] = None,
    claude_home: Optional[Path] = None,
    registry_path: Optional[Path] = None,
    state_home: Optional[Path] = None,
    purge_state: bool = False,
) -> List[Dict[str, Any]]:
    script = (script_path or Path(__file__)).resolve()
    resolved_bin_dir = bin_dir or default_bin_dir()
    targets: List[Dict[str, Any]] = []

    # Both the canonical ``devstack`` command symlink AND the legacy
    # ``ccstack`` alias symlink are installed by ``./install`` (and
    # ``install-ai-skills`` mirrors the same dual-link approach for the AI
    # skill assets). ``uninstall_targets`` enumerates both so a single
    # ``devstack uninstall`` removes the full install footprint.
    for command_name in ("devstack", "ccstack"):
        command_path = resolved_bin_dir / command_name
        command_removable = (
            path_lexists(command_path)
            and command_path.is_symlink()
            and same_resolved_path(command_path, script)
        )
        command_reason = ""
        if not path_lexists(command_path):
            command_reason = "not installed"
        elif not command_path.is_symlink():
            command_reason = "not a symlink; left untouched"
        elif not same_resolved_path(command_path, script):
            command_reason = "points to another devstack checkout; left untouched"
        targets.append({
            "label": f"command ({command_name})" if command_name != "devstack" else "command",
            "path": command_path,
            "kind": "file",
            "removable": command_removable,
            "reason": command_reason,
        })

    # AI skill assets — install-ai-skills now installs both ``devstack`` and
    # ``ccstack`` (legacy) skill paths; uninstall mirrors that.
    targets.extend([
        {
            "label": "Codex skill",
            "path": (codex_home or default_codex_home()) / "skills" / "devstack",
            "kind": "dir",
            "removable": True,
            "reason": "",
        },
        {
            "label": "Codex skill (legacy ccstack)",
            "path": (codex_home or default_codex_home()) / "skills" / "ccstack",
            "kind": "dir",
            "removable": True,
            "reason": "",
        },
        {
            "label": "Claude skill",
            "path": (claude_home or default_claude_home()) / "agents" / "skills" / "devstack.md",
            "kind": "file",
            "removable": True,
            "reason": "",
        },
        {
            "label": "Claude skill (legacy ccstack)",
            "path": (claude_home or default_claude_home()) / "agents" / "skills" / "ccstack.md",
            "kind": "file",
            "removable": True,
            "reason": "",
        },
    ])

    if purge_state:
        targets.extend([
            {
                "label": "workspace registry",
                "path": registry_path or REGISTRY_PATH,
                "kind": "file",
                "removable": True,
                "reason": "",
            },
            {
                "label": "workspace state",
                "path": state_home or STATE_HOME,
                "kind": "dir",
                "removable": True,
                "reason": "",
            },
        ])

    return targets


def apply_uninstall_targets(targets: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    results: List[Dict[str, Any]] = []
    for target in targets:
        path = Path(target["path"])
        result = dict(target)
        if not path_lexists(path):
            result["status"] = "skipped"
            result["reason"] = target.get("reason") or "not installed"
        elif not target.get("removable", False):
            result["status"] = "skipped"
        else:
            if path.is_dir() and not path.is_symlink():
                shutil.rmtree(path)
            else:
                path.unlink()
            result["status"] = "removed"
        results.append(result)
    return results


def print_uninstall_targets(targets: List[Dict[str, Any]], dry_run: bool) -> None:
    action = "Would uninstall" if dry_run else "Uninstall plan"
    print(f"{action}:")
    for target in targets:
        path = Path(target["path"])
        marker = "remove" if target.get("removable", False) else "skip"
        if not path_lexists(path):
            marker = "skip"
        suffix = f" ({target['reason']})" if target.get("reason") else ""
        print(f"  {marker:6} {target['label']}: {path}{suffix}")


def print_uninstall_results(results: List[Dict[str, Any]]) -> None:
    print("Uninstall result:")
    for result in results:
        suffix = f" ({result['reason']})" if result.get("reason") else ""
        print(f"  {result['status']:7} {result['label']}: {result['path']}{suffix}")


