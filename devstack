# Environment variable used to declare additional private Gradle repository host
# substrings that should be treated as "private" by
# `inspect_gradle_private_repository_requirements`. Value is a comma-separated
# list of host substrings (whitespace-stripped, empty entries discarded).
#
# Examples (deploy-time):
#   # Single host (the legacy default this knob replaces)
#   export DEVSTACK_PRIVATE_GRADLE_HOSTS="artifacts.example.com"
#   # Multiple hosts
#   export DEVSTACK_PRIVATE_GRADLE_HOSTS="artifacts.example.com,nexus.internal.corp"
#
# When unset or empty, the host list is empty and devstack relies solely on the
# generic "artifactory" / "credentials" substring fallback inside gradle build
# files to recognize a private-repository configuration. The generic fallback
# is unaffected by this env var, so projects whose gradle files mention
# `artifactory` or `credentials` continue to be detected as before.
#
# Compat shim 1 — the legacy CCSTACK_PRIVATE_GRADLE_HOSTS spelling is honored
# via env_read() with a one-time deprecation warning. The exported
# ``*_ENV`` constant is renamed to the new canonical name (legacy alias
# preserved as a separate constant for any external consumer that imported
# it directly).
DEVSTACK_PRIVATE_GRADLE_HOSTS_ENV = "DEVSTACK_PRIVATE_GRADLE_HOSTS"
CCSTACK_PRIVATE_GRADLE_HOSTS_ENV = "CCSTACK_PRIVATE_GRADLE_HOSTS"  # legacy alias


def private_gradle_repository_hosts() -> Tuple[str, ...]:
    """Return the configured private Gradle repository host substrings.

    Reads ``DEVSTACK_PRIVATE_GRADLE_HOSTS`` (comma-separated) — falling back
    to ``CCSTACK_PRIVATE_GRADLE_HOSTS`` via the shim — from the process
    environment on every call so tests and deploy-time configuration can
    override the empty default without re-importing the module. Returns an
    empty tuple when the variable is unset or empty.
    """
    raw = env_read("PRIVATE_GRADLE_HOSTS", "") or ""
    if not raw:
        return ()
    parts = [piece.strip() for piece in raw.split(",")]
    return tuple(piece for piece in parts if piece)


