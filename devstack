    async function run(button) {{
      const action = button.dataset.action;
      if (action === "workspace_delete") {{
        const purge = button.dataset.purge === "1";
        const message = purge
          ? "Purge workspace " + workspace.value + " from devstack? Project files will not be deleted, but devstack state/logs/generated config for this workspace will be removed."
          : "Remove workspace " + workspace.value + " from devstack? Project files and devstack state will not be deleted.";
        if (!window.confirm(message)) {{
          return;
        }}
      }}
      const forceLight = button.dataset.light === "1";
      const useMode = button.dataset.useMode === "1";
      const mode = document.querySelector("#mode").value;
      const service = currentServiceName();
      const serviceOnly = button.dataset.serviceOnly === "1";
      if (action === "logs") {{
        followLogs();
        if (workspaceReady) {{
          window.setTimeout(() => refreshStatus(false), 400);
        }}
        return;
      }}
      const params = new URLSearchParams({{
        action,
        workspace: workspace.value,
        target: target.value,
        service,
        only: serviceOnly ? service : "",
        lines: "120",
        draft_id: currentDraftId || draftId.value,
        workspace_root: workspaceRoot.value || selectedWorkspace().root || "",
        light: forceLight || (useMode && mode === "light") ? "1" : "",
        purge: button.dataset.purge === "1" ? "1" : "",
        no_deps: document.querySelector("#noDeps").checked ? "1" : ""
      }});
      const loadingMessage = actionLoadingMessage(action, button);
      if (shouldOpenDrawerForAction(action)) {{
        openOutputPanelForAction(action, button);
      }}
      const actionServices = setActionServiceProgress(action, button);
      activeActionServices = new Set(actionServices);
      activeAction = action;
      if (action === "workspace_analyze") {{
        setDraftStatus("Analyzing...");
        setWorkspaceProgressState("Analyzing");
        setWorkspaceProgressRunning(true);
        revealWorkspaceProgress();
      }} else if (action === "workspace_apply") {{
        setDraftStatus("Applying...");
        setWorkspaceProgressState("Applying");
        setWorkspaceProgressRunning(false);
      }}
      setBusy(true);
      setLoading(true, loadingMessage[0], loadingMessage[1]);
      if (shouldOpenDrawerForAction(action)) {{
        result.textContent = "running";
        result.className = "";
        streamState.textContent = "running";
        output.textContent = "";
        outputMode = action;
      }}
      if (action === "workspace_analyze") {{
        await streamWorkspaceAnalyze(params);
        return;
      }}
      let actionSucceeded = true;
      try {{
        const response = await fetch("/api/run", {{
          method: "POST",
          headers: {{ "Content-Type": "application/x-www-form-urlencoded" }},
          body: params.toString()
        }});
        const data = await response.json();
        actionSucceeded = Boolean(data && data.ok);
        if (action !== "recover") {{
          applyActionResult(action, data);
        }}
      }} catch (error) {{
        actionSucceeded = false;
        if (action !== "recover") {{
          command.textContent = action;
          output.textContent = String(error);
          result.textContent = "failed";
          result.className = "fail";
          streamState.textContent = "failed";
        }}
      }} finally {{
        if (workspaceReady && isLifecycleAction(action)) {{
          await delay(400);
          await refreshStatus(false, {{ resolveProgress: true }});
        }}
        if (isLifecycleAction(action) && !actionSucceeded) {{
          markServiceCardsFailed(actionServices, "failed");
        }}
        setLoading(false);
        if (!isLifecycleAction(action)) {{
          clearActiveServiceProgress();
        }}
        activeActionServices.clear();
        activeAction = "";
        setBusy(false);
        if (workspaceReady && !isLifecycleAction(action) && !action.startsWith("workspace_")) {{
          window.setTimeout(() => refreshStatus(false), 400);
        }}
      }}
    }}

