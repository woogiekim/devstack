    function applyActionResult(action, data, appendOutput = false) {{
      command.textContent = data.command || action;
      outputMode = action;
      if (appendOutput) {{
        if (data.output) {{
          output.textContent += "\\nAnalysis result:\\n" + data.output;
          scrollOutput();
        }}
      }} else {{
        output.textContent = data.output || "";
      }}
      const status = data.status || (data.ok ? "ok" : "failed");
      result.textContent = status + " · " + (data.elapsed || 0) + "s";
      result.className = data.ok ? "ok" : "fail";
      streamState.textContent = status;
      updateConsoleToggleState();
      if (action === "workspace_analyze" && data.ok && data.draft_id) {{
        currentDraftId = data.draft_id;
        draftId.value = data.draft_id;
        const confidence = data.draft && data.draft.analysis ? data.draft.analysis.confidence : "";
        setDraftStatus(confidence ? "Review " + confidence : "Review ready");
        setWorkspaceProgressState("Review ready");
        setWizardStep("review");
      }} else if (action === "workspace_analyze" && !data.ok) {{
        currentDraftId = "";
        draftId.value = "";
        setDraftStatus("Analyze failed");
        setWorkspaceProgressState("Analyze failed");
        setWizardStep("bind");
      }}
      if (action === "workspace_apply" && data.ok) {{
        setDraftStatus("Applied");
        setWorkspaceProgressState("Applied");
        markWorkspaceApplied(data.workspace || workspace.value);
      }} else if (action === "workspace_apply" && !data.ok) {{
        setDraftStatus("Apply failed");
        setWorkspaceProgressState("Apply failed");
      }}
      if (action === "workspace_apply" && data.ok && data.workspace) {{
        window.setTimeout(() => {{
          window.location.search = "?workspace=" + encodeURIComponent(data.workspace);
        }}, 650);
      }}
      if (action === "workspace_delete" && data.ok) {{
        setDraftStatus("Removed");
        window.location.search = "?workspace={NEW_WORKSPACE_ID}";
      }}
      if (action === "status" && data.output) {{
        updateServiceBoardFromStatusOutput(data.output);
      }}
    }}

    function applyStatusSnapshot(data, writeOutput = false, options = {{}}) {{
      if (data.output) {{
        updateServiceBoardFromStatusOutput(data.output, options);
      }} else if (!data.ok) {{
        setAllServiceCardsUnavailable("status unavailable", {{ preserveProgress: isBusy }});
      }}
      const status = data.status || (data.ok ? "ok" : "failed");
      const canWriteOutput = writeOutput || outputMode === "status";
      if (!isBusy && outputMode !== "doctor") {{
        streamState.textContent = data.ok ? "live status" : "status failed";
        if (canWriteOutput) {{
          command.textContent = data.command || "devstack status " + (target.value || "all");
          output.textContent = data.output || "";
          outputMode = "status";
          result.textContent = status + " · " + (data.elapsed || 0) + "s";
          result.className = data.ok ? "ok" : "fail";
        }}
      }}
    }}

    async function refreshStatus(writeOutput = false, options = {{}}) {{
      if (!workspaceReady || statusPollInFlight) {{
        return null;
      }}
      statusPollInFlight = true;
      if (!serviceStatusLoaded) {{
        setAllServiceCardsChecking();
      }}
      const params = new URLSearchParams({{
        action: "status",
        workspace: workspace.value,
        target: target.value || "all",
        service: currentServiceName(),
        lines: "120"
      }});
      try {{
        const response = await fetch("/api/run", {{
          method: "POST",
          headers: {{ "Content-Type": "application/x-www-form-urlencoded" }},
          body: params.toString()
        }});
        const data = await response.json();
        const resolveProgress = options.resolveProgress ?? !isBusy;
        applyStatusSnapshot(data, writeOutput, {{ resolveProgress }});
        return data;
      }} catch (error) {{
        setAllServiceCardsUnavailable("status unavailable", {{ preserveProgress: isBusy }});
        if (serviceBoardStatus) {{
          serviceBoardStatus.textContent = "status unavailable";
        }}
        if (writeOutput && !isBusy) {{
          command.textContent = "devstack status " + (target.value || "all");
          output.textContent = String(error);
          outputMode = "status";
          result.textContent = "failed";
          result.className = "fail";
          streamState.textContent = "status failed";
        }}
        return null;
      }} finally {{
        statusPollInFlight = false;
      }}
    }}

    function streamWorkspaceAnalyze(params) {{
      return new Promise(resolve => {{
        const rootValue = params.get("workspace_root") || "";
        const source = new EventSource("/api/workspace/analyze/stream?" + params.toString());
        let settled = false;

        function finishWorkspaceAnalyze() {{
          if (settled) {{
            return;
          }}
          settled = true;
          source.close();
          setWorkspaceProgressRunning(false);
          setLoading(false);
          activeActionServices.clear();
          activeAction = "";
          setBusy(false);
          resolve();
        }}

        function failWorkspaceAnalyze(message = "workspace analysis stream failed") {{
          command.textContent = "devstack workspace analyze " + rootValue;
          result.textContent = "failed";
          result.className = "fail";
          streamState.textContent = "failed";
          if (!output.textContent) {{
            output.textContent = message;
          }}
          currentDraftId = "";
          draftId.value = "";
          setDraftStatus("Analyze failed");
          setWorkspaceProgressState("Analyze failed");
          appendWorkspaceProgress("\\n" + message + "\\n");
          setWizardStep("bind");
        }}

        command.textContent = "devstack workspace analyze " + rootValue;
        output.textContent = "";
        outputMode = "workspace_analyze";
        resetWorkspaceProgress("Starting analysis...\\n");
        setWorkspaceProgressState("Analyzing");
        setWorkspaceProgressRunning(true);
        revealWorkspaceProgress();

        function appendWorkspaceAnalyzeEvent(event) {{
          try {{
            const data = JSON.parse(event.data);
            const chunk = workspaceAnalyzeProgressChunk(data);
            output.textContent += chunk;
            appendWorkspaceProgress(chunk);
            scrollOutput();
          }} catch (error) {{
            failWorkspaceAnalyze("workspace analysis stream failed");
            finishWorkspaceAnalyze();
          }}
        }}
        source.addEventListener("log", appendWorkspaceAnalyzeEvent);
        source.addEventListener("progress", appendWorkspaceAnalyzeEvent);
        source.addEventListener("done", event => {{
          try {{
            const data = JSON.parse(event.data);
            appendWorkspaceAnalyzeResult(data);
            applyActionResult("workspace_analyze", data);
            setWorkspaceProgressState(data.ok ? "Review ready" : "Analyze failed");
          }} catch (error) {{
            failWorkspaceAnalyze("workspace analysis stream failed");
          }} finally {{
            finishWorkspaceAnalyze();
          }}
        }});
        source.addEventListener("error", () => {{
          failWorkspaceAnalyze("workspace analysis stream failed");
          finishWorkspaceAnalyze();
        }});
      }});
    }}

