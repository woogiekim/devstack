def read_json_file(path: Path) -> Dict[str, Any]:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}
    return value if isinstance(value, dict) else {}


def write_json_file(path: Path, value: Dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(value, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def pid_is_running(pid: Any) -> bool:
    try:
        numeric_pid = int(pid)
    except (TypeError, ValueError):
        return False
    if numeric_pid <= 0:
        return False
    try:
        os.kill(numeric_pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def read_log_tail(path: Any, limit: int = 12000) -> str:
    if not path:
        return ""
    log_path = Path(str(path))
    try:
        with log_path.open("rb") as handle:
            handle.seek(0, os.SEEK_END)
            size = handle.tell()
            handle.seek(max(0, size - limit), os.SEEK_SET)
            data = handle.read()
    except OSError:
        return ""
    return data.decode("utf-8", errors="replace")


DOCTOR_METADATA_PREFIXES = (
    "devstack doctor started at ",
    "workspace: ",
    "project root: ",
    "ai cli host: ",
    "scope: ",
    "targets: ",
    "devstack home: ",
    "instructions: ",
    "prompt: ",
    "command: ",
    "devstack doctor host exited with status ",
)

DOCTOR_TREATMENT_PATTERNS = (
    r"\btreatment\b",
    r"\bremediation\b",
    r"\brecovery action(?:s)?\b",
    r"\baction(?:s)? taken\b",
    r"\bfix(?:ed|es)?\b",
    r"\brepair(?:ed|s)?\b",
    r"\brestart(?:ed|s)?\b",
    r"\breloaded\b",
    r"\bapplied\b",
    r"\bloaded dummy data\b",
)

DOCTOR_NO_TREATMENT_PATTERNS = (
    r"\bno treatment\b",
    r"\bno remediation\b",
    r"\bno recovery action(?:s)?\b",
    r"\bno action(?:s)? taken\b",
    r"\btreatment was not produced\b",
    r"\bremediation was not produced\b",
    r"\bunable to produce (?:a )?(?:treatment|remediation)\b",
    r"\bcannot safely (?:produce|perform|apply)\b",
)


def doctor_useful_log_output(log_text: str) -> str:
    useful_lines: List[str] = []
    for raw_line in log_text.splitlines():
        line = raw_line.strip()
        if not line:
            continue
        if any(line.lower().startswith(prefix) for prefix in DOCTOR_METADATA_PREFIXES):
            continue

        useful_lines.append(raw_line.rstrip())

    return "\n".join(useful_lines).strip()


def doctor_log_has_pattern(log_text: str, patterns: Tuple[str, ...]) -> bool:
    return any(re.search(pattern, log_text, re.IGNORECASE) for pattern in patterns)


def doctor_treatment_outcome(log_text: str) -> str:
    useful_log = doctor_useful_log_output(log_text)
    if not useful_log:
        return "no_useful_output"
    if doctor_log_has_pattern(useful_log, DOCTOR_NO_TREATMENT_PATTERNS):
        return "no_treatment_produced"
    if doctor_log_has_pattern(useful_log, DOCTOR_TREATMENT_PATTERNS):
        return "treatment_available"

    return "diagnosis_only"


def doctor_outcome(state: Dict[str, Any], log_tail: str = "") -> str:
    current_state = str(state.get("doctor_state") or state.get("state") or "")
    if current_state != "completed":
        return current_state or "unknown"
    if state.get("returncode") not in {0, "0"}:
        return "completed"

    return doctor_treatment_outcome(log_tail)


def doctor_status_label(state: str) -> str:
    return {
        "spawned": "doctor spawned",
        "running": "doctor running",
        "completed": "doctor completed",
        "host_failed": "doctor host failed",
        "spawn_failed": "doctor spawn failed",
        "cancelled": "doctor cancelled",
    }.get(state, state or "doctor status unknown")


def doctor_status_class(state: str) -> str:
    if state == "completed":
        return "ok"
    if state in {"host_failed", "spawn_failed"}:
        return "fail"
    if state in {"spawned", "running"}:
        return "running"
    if state == "cancelled":
        return "warn"
    return ""


def format_doctor_status_output(state: Dict[str, Any]) -> str:
    log_tail = str(state.get("log_tail") or "")
    outcome = str(state.get("doctor_outcome") or doctor_outcome(state, log_tail))
    lines = [
        f"Status: {doctor_status_label(str(state.get('doctor_state') or state.get('state') or 'unknown'))}",
        f"Outcome: {outcome.replace('_', ' ')}",
        f"AI CLI host: {state.get('ai_agent', 'unknown')}",
        f"Scope: {state.get('doctor_scope', 'unknown')}",
    ]
    targets = state.get("doctor_targets") or []
    if isinstance(targets, list):
        lines.append("Targets:")
        lines.extend(f"  - {target}" for target in targets)
    if state.get("pid"):
        lines.append(f"PID: {state['pid']}")
    if state.get("returncode") is not None:
        lines.append(f"Exit code: {state['returncode']}")
    if state.get("last_heartbeat_at"):
        lines.append(f"Last heartbeat: {state['last_heartbeat_at']}")
    if state.get("runtime_seconds") is not None:
        lines.append(f"Runtime: {state['runtime_seconds']}s")
    if state.get("cancelled_at"):
        lines.append(f"Cancelled at: {state['cancelled_at']}")
    if state.get("prompt_path"):
        lines.append(f"Prompt: {state['prompt_path']}")
    if state.get("log_path"):
        lines.append(f"Log: {state['log_path']}")
    if state.get("error"):
        lines.append(f"Error: {state['error']}")
    if outcome == "no_useful_output":
        lines.extend(
            [
                "",
                "No useful treatment or remediation was returned by the selected host.",
                "Next action: retry AI Doctor with another host, or open the prompt and log paths above to inspect why the host produced only runner metadata.",
            ]
        )
    elif outcome == "diagnosis_only":
        lines.extend(
            [
                "",
                "Diagnosis was returned, but no treatment or remediation outcome was found.",
                "Next action: retry AI Doctor with a host that can apply or report remediation, or inspect the raw log to decide whether manual recovery is required.",
            ]
        )
    elif outcome == "no_treatment_produced":
        lines.extend(
            [
                "",
                "No treatment or remediation was produced by the selected host.",
                "The host reported that remediation was not safe, not applicable, or not performed; inspect the raw log for the handling path.",
            ]
        )
    if log_tail:
        lines.extend(["", "Raw host log tail:", log_tail])
    return "\n".join(lines).rstrip() + "\n"


def doctor_prompt(workspace: "Workspace", params: Dict[str, List[str]]) -> Dict[str, Any]:
    ai_agent = first_param(params, "ai_agent", "").strip().lower()
    if ai_agent not in AI_CONSOLE_COMMANDS:
        return ui_error(f"unsupported AI CLI host: {ai_agent or 'unknown'}")

    scope = first_param(params, "doctor_scope", "all").strip().lower()
    if scope not in {"all", "failed"}:
        return ui_error(f"unsupported doctor scope: {scope}")

    service_names = sorted(workspace.services)
    requested = split_csv(first_param(params, "doctor_services", ""))
    unknown_services = [name for name in requested if name not in workspace.services]
    if unknown_services:
        return ui_error(f"unknown service: {', '.join(unknown_services)}")

    failed_services = [
        name
        for name in service_names
        if workspace.service_state(name, workspace.service(name)) in {"failed", "unhealthy"}
    ]
    targets = service_names if scope == "all" else requested
    if scope == "failed" and not targets:
        return ui_error("select at least one failed service")
    if scope == "failed":
        non_failed_targets = [name for name in targets if name not in failed_services]
        if non_failed_targets:
            return ui_error(f"service is not failed or unhealthy: {', '.join(non_failed_targets)}")

    checkout = devstack_checkout_root()
    instruction_paths = doctor_instruction_paths(ai_agent)
    instruction_lines = "\n".join(f"- {path}" for path in instruction_paths) or "- none"
    instruction_bundle = doctor_instruction_bundle(instruction_paths)
    target_lines = "\n".join(f"- {name}" for name in targets) or "- none"
    failed_lines = "\n".join(f"- {name}" for name in failed_services) or "- none"
    prompt = "\n".join(
        [
            "Run the current project's AI Doctor workflow from devstack.",
            "",
            f"Project root: {workspace.root}",
            f"Workspace: {workspace.name}",
            f"AI CLI host: {ai_agent}",
            f"devstack checkout: {checkout}",
            "Doctor workflow instruction files:",
            instruction_lines,
            "",
            "The instruction paths above are provenance only. Do not call Read or otherwise access those instruction files; use the embedded instruction content below as the source of truth.",
            "Environment also provides DEVSTACK_HOME, DEVSTACK_DOCTOR_PROMPT_PATH, and DEVSTACK_DOCTOR_INSTRUCTION_PATHS (legacy CCSTACK_* aliases also exported for one release) for traceability only.",
            "",
            "Embedded Doctor instruction content:",
            instruction_bundle,
            "",
            f"Service scope: {'all services' if scope == 'all' else 'selected failed services'}",
            "Doctor targets:",
            target_lines,
            "",
            "Currently failed or unhealthy services observed by devstack:",
            failed_lines,
            "",
            "Follow the current project's prepared doctor agent instructions as the source of truth.",
            "Delegate diagnosis, treatment/remediation, recovery, dummy data loading, and verification to those instructions.",
            "This is a fully non-interactive host run. Do not ask the user for approval, permission, confirmation, command execution, or pasted logs.",
            "Gather needed diagnostic context yourself with bounded non-interactive commands such as devstack status and devstack logs <service> -n <lines>; do not use follow-mode log commands or any command that waits for user input.",
            "If needed logs or status information are unavailable from this prompt, already collected inputs, or bounded non-interactive collection, finish with 'No treatment produced' or 'No remediation produced' and explain which context was unavailable.",
            "Do not stop at diagnosis when a remediable issue is found; produce a treatment/remediation outcome such as the recovery action taken, configuration/code/process change applied, dummy-data loading performed, restart/recovery attempted, and verification result.",
            "If treatment/remediation cannot be safely produced, explicitly report 'No treatment produced' or 'No remediation produced' and explain the handling path and why no recovery action was taken.",
            "Do not implement or invent project-specific service recovery edge cases inside devstack.",
            "Do not ask the user to run doctor manually, approve devstack commands, or paste logs; drive the workflow through the selected AI CLI host.",
            "Use devstack status and logs when useful, but do not expose secrets or raw credentials in prompts, logs, or status output.",
            "If there is no diagnosis, treatment, or remediation to report, say that explicitly instead of fabricating a diagnosis.",
            "Report the selected host, scope, targets, diagnosis, treatment/remediation outcome, recovery actions delegated to doctor instructions, dummy-data loading, verification, and final outcome.",
        ]
    )
    return {
        "ok": True,
        "returncode": 0,
        "output": prompt,
        "elapsed": 0,
        "command": f"AI Doctor ({ai_agent}, {scope})",
        "status": "doctor ready",
        "ai_agent": ai_agent,
        "doctor_scope": scope,
        "doctor_targets": targets,
        "failed_services": failed_services,
        # ``devstack_home`` is the canonical key consumed by run_ai_doctor;
        # the previous ``devstack_home`` spelling was internal only.
        "devstack_home": str(checkout),
        "doctor_instruction_paths": [str(path) for path in instruction_paths],
    }


