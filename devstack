def devstack_checkout_root() -> Path:
    return Path(__file__).resolve().parent


def doctor_instruction_paths(ai_agent: str) -> List[Path]:
    checkout = devstack_checkout_root()
    paths = [
        checkout / "skills" / "claude" / "devstack.md",
        checkout / "skills" / "codex" / "SKILL.md",
    ]
    if ai_agent == "claude":
        paths.insert(0, checkout / "skills" / "claude" / "devstack.md")
    elif ai_agent == "codex":
        paths.insert(0, checkout / "skills" / "codex" / "SKILL.md")
    return unique(paths)


def doctor_instruction_bundle(instruction_paths: List[Path]) -> str:
    sections = []
    for path in instruction_paths:
        try:
            content = path.read_text(encoding="utf-8").strip()
        except OSError as error:
            content = f"Instruction content unavailable: {error}"

        sections.extend(
            [
                f"### Embedded instruction: {path}",
                f"BEGIN CCSTACK DOCTOR INSTRUCTION {path}",
                content,
                f"END CCSTACK DOCTOR INSTRUCTION {path}",
            ]
        )

    return "\n".join(sections) if sections else "No embedded doctor instructions were found."


