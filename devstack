DOCTOR_HEARTBEAT_INTERVAL_SECONDS = 5.0


def _doctor_heartbeat_loop(
    state_path: Path,
    started: float,
    stop_event: "threading.Event",
    interval: float = DOCTOR_HEARTBEAT_INTERVAL_SECONDS,
) -> None:
    """Background loop that stamps last_heartbeat_at + runtime_seconds.

    Stops as soon as ``stop_event`` is set, so the foreground terminal write
    always wins over any heartbeat-only write.
    """
    # Re-check the stop flag in short sleeps so the thread can exit promptly
    # when the main thread sets it before the final state write.
    poll_step = 0.5
    while not stop_event.is_set():
        try:
            current = read_json_file(state_path)
            # Only emit heartbeat while the run is still "running". If a
            # terminal state slipped through in a race, do not resurrect it.
            if current and current.get("doctor_state") == "running":
                current["last_heartbeat_at"] = datetime.datetime.now(
                    datetime.timezone.utc
                ).isoformat()
                current["runtime_seconds"] = int(time.time() - started)
                write_json_file(state_path, current)
        except Exception:  # pragma: no cover - heartbeat is best-effort
            pass

        elapsed = 0.0
        while elapsed < interval and not stop_event.is_set():
            time.sleep(poll_step)
            elapsed += poll_step


def cancel_doctor_run(workspace: "Workspace", run_id: str, force: bool = False) -> bool:
    """Cancel an in-flight doctor run.

    Signals the recorded ``pid`` (and ``host_pid`` if different) and rewrites
    the state JSON with ``doctor_state=cancelled``. Idempotent: a run that is
    already in a terminal state (``completed``/``host_failed``/``spawn_failed``
    /``cancelled``) returns ``False`` without further side effects.
    """
    state_path = doctor_state_path(workspace, run_id)
    state = read_json_file(state_path)
    if not state:
        return False

    current_state = str(state.get("doctor_state") or "")
    if current_state not in {"spawned", "running"}:
        return False

    sig = signal.SIGKILL if force else signal.SIGTERM
    signalled = False

    seen: Set[int] = set()
    for key in ("pid", "host_pid"):
        raw = state.get(key)
        try:
            pid_value = int(raw) if raw is not None else 0
        except (TypeError, ValueError):
            continue
        if pid_value <= 0 or pid_value in seen:
            continue
        seen.add(pid_value)
        if not pid_is_running(pid_value):
            continue
        try:
            terminate_pid_or_group(pid_value, sig, f"doctor {run_id}")
            signalled = True
        except DevstackError:
            # Permission error or otherwise un-signal-able pid; record but
            # continue so the state file still flips to cancelled.
            pass

    cancelled_at = datetime.datetime.now(datetime.timezone.utc).isoformat()
    state["doctor_state"] = "cancelled"
    state["status"] = doctor_status_label("cancelled")
    state["cancelled_at"] = cancelled_at
    state["returncode"] = -9 if force else -15
    state["doctor_outcome"] = "cancelled"
    if not signalled:
        state.setdefault(
            "error",
            "doctor run was already not running when cancel was requested",
        )
    write_json_file(state_path, state)
    return signalled


def run_ai_doctor_host(state_path_value: str) -> int:
    state_path = Path(state_path_value)
    state = read_json_file(state_path)
    command = string_list(state.get("command"))
    log_path = Path(str(state.get("log_path", "")))
    cwd = str(state.get("cwd") or os.getcwd())

    started = time.time()
    state["doctor_state"] = "running"
    state["status"] = doctor_status_label("running")
    state["started_at"] = datetime.datetime.now(datetime.timezone.utc).isoformat()
    state["last_heartbeat_at"] = state["started_at"]
    state["runtime_seconds"] = 0
    write_json_file(state_path, state)

    env = os.environ.copy()
    env.update({str(key): str(value) for key, value in (state.get("env") or {}).items()})

    stop_event = threading.Event()
    heartbeat_thread = threading.Thread(
        target=_doctor_heartbeat_loop,
        args=(state_path, started, stop_event),
        name="devstack-doctor-heartbeat",
        daemon=True,
    )
    heartbeat_thread.start()

    returncode = 1
    error = ""
    try:
        with log_path.open("ab") as log_file:
            process = subprocess.Popen(
                command,
                cwd=cwd,
                stdin=subprocess.DEVNULL,
                stdout=log_file,
                stderr=subprocess.STDOUT,
                env=env,
                start_new_session=True,
            )
            state["host_pid"] = process.pid
            write_json_file(state_path, state)
            returncode = process.wait()
    except OSError as exc:
        error = str(exc)
        returncode = 127
    finally:
        # Stop the heartbeat BEFORE the terminal state write so the thread
        # cannot resurrect "running" on top of the terminal write.
        stop_event.set()
        heartbeat_thread.join(timeout=2.0)

    completed_at = datetime.datetime.now(datetime.timezone.utc).isoformat()
    state = read_json_file(state_path) or state
    # Honor a cancellation that landed while we were running: if the state
    # file was already flipped to "cancelled" by cancel_doctor_run, do not
    # overwrite it. The runner is winding down via signal anyway.
    if str(state.get("doctor_state") or "") == "cancelled":
        return 0
    state["returncode"] = returncode
    state["elapsed"] = round(time.time() - started, 1)
    state["completed_at"] = completed_at
    state["runtime_seconds"] = int(time.time() - started)
    if error:
        state["error"] = error
    state["doctor_state"] = "completed" if returncode == 0 else "host_failed"
    state["doctor_outcome"] = doctor_outcome(state, read_log_tail(log_path))
    state["status"] = doctor_status_label(str(state["doctor_state"]))
    write_json_file(state_path, state)

    try:
        with log_path.open("ab") as log_file:
            log_file.write(f"\ndevstack doctor host exited with status {returncode} at {completed_at}\n".encode("utf-8"))
            if error:
                log_file.write(f"startup error: {error}\n".encode("utf-8"))
    except OSError:
        pass

    return 0


def execute_doctor_status(workspace: "Workspace", params: Dict[str, List[str]]) -> Dict[str, Any]:
    run_id = first_param(params, "doctor_run_id", "").strip()
    if not run_id:
        return ui_error("missing doctor run id")

    state_path = doctor_state_path(workspace, run_id)
    state = read_json_file(state_path)
    if not state:
        return ui_error(f"unknown doctor run: {run_id}")

    current_state = str(state.get("doctor_state") or "spawned")
    if current_state in {"spawned", "running"}:
        state["doctor_state"] = "running" if pid_is_running(state.get("pid")) else "host_failed"
        state["status"] = doctor_status_label(str(state["doctor_state"]))
        if state["doctor_state"] == "host_failed" and state.get("returncode") is None:
            state["error"] = state.get("error") or "doctor host runner exited before recording completion"
            write_json_file(state_path, state)

    state["log_tail"] = read_log_tail(state.get("log_path"))
    state["doctor_outcome"] = doctor_outcome(state, str(state["log_tail"]))
    return {
        "ok": True,
        "returncode": state.get("returncode"),
        "status": doctor_status_label(str(state.get("doctor_state") or "unknown")),
        "doctor_state": state.get("doctor_state"),
