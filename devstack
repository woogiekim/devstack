# ---------------------------------------------------------------------------
# Compat shim 6 — Persisted JSON keys (dual-read / new-write)
# ---------------------------------------------------------------------------
# Existing workspace config files store the materialized managed-environment
# block under ``devstack_managed_environment`` and per-service status notes
# under ``devstack_status_notes``. Post-rename writers use the new
# ``devstack_*`` keys; readers accept either. The new key wins when both are
# present.

MANAGED_ENVIRONMENT_KEY = "devstack_managed_environment"
LEGACY_MANAGED_ENVIRONMENT_KEY = "ccstack_managed_environment"
STATUS_NOTES_KEY = "devstack_status_notes"
LEGACY_STATUS_NOTES_KEY = "ccstack_status_notes"


def read_managed_environment(config: Dict[str, Any]) -> Any:
    """Return the managed-environment block from ``config`` (new key wins)."""
    if not isinstance(config, dict):
        return None
    if MANAGED_ENVIRONMENT_KEY in config:
        return config.get(MANAGED_ENVIRONMENT_KEY)
    if LEGACY_MANAGED_ENVIRONMENT_KEY in config:
        return config.get(LEGACY_MANAGED_ENVIRONMENT_KEY)
    return None


def write_managed_environment(config: Dict[str, Any], value: Any) -> None:
    """Persist ``value`` under the canonical devstack key.

    The legacy devstack key is intentionally NOT deleted — operators may have
    other consumers that still read the legacy key, and leaving it in place
    is safe (subsequent reads prefer the devstack key).
    """
    if not isinstance(config, dict):
        return
    config[MANAGED_ENVIRONMENT_KEY] = value


def read_status_notes(service: Dict[str, Any]) -> Any:
    """Return the per-service status-notes list (new key wins)."""
    if not isinstance(service, dict):
        return None
    if STATUS_NOTES_KEY in service:
        return service.get(STATUS_NOTES_KEY)
    if LEGACY_STATUS_NOTES_KEY in service:
        return service.get(LEGACY_STATUS_NOTES_KEY)
    return None


# ---------------------------------------------------------------------------
# Compat shim 7 — Dual local-yml emit
# ---------------------------------------------------------------------------
# Existing user app jars import ``classpath:devstack-local.yml`` (the
# LOCAL_CONFIG_IMPORT constant before this release). New apps will import the
# canonical ``classpath:devstack-local.yml``. To keep both audiences working
# for one release, ``write_managed_local_yml_dual`` writes both files with
# identical content under ``managed_infra_dir``. The byte-identical writer
# ``write_managed_local_yml`` remains the underlying single-file writer used
# by the existing SHA-256 byte-identity tests and by the Gradle/Spring
# strategy.
DUAL_LOCAL_YML_NEW = "devstack-local.yml"
DUAL_LOCAL_YML_LEGACY = "ccstack-local.yml"


def write_managed_local_yml_dual(infra_dir: Path) -> None:
    """Materialize BOTH ``devstack-local.yml`` and ``devstack-local.yml``
    under ``infra_dir`` with byte-identical content.

    Subsequent processResources copy steps (see write_managed_gradle_init)
    pick up either name on the classpath. The legacy name is documented as a
    one-release deprecation; the canonical (devstack) name is the long-term
    contract for new apps.
    """
    infra_dir_p = Path(infra_dir)
    new_path = infra_dir_p / DUAL_LOCAL_YML_NEW
    legacy_path = infra_dir_p / DUAL_LOCAL_YML_LEGACY
    write_managed_local_yml(new_path)
    write_managed_local_yml(legacy_path)


# ---------------------------------------------------------------------------
# Docker legacy resource detection guidance
# ---------------------------------------------------------------------------
# When a workspace's new ``devstack_<ws>`` project has no containers but
# legacy ``devstack_<ws>`` containers / volumes / networks still exist on the
# host, devstack prints structured guidance — never a free-text yes/no
# question. The guidance is informational; the operator runs the adoption /
# cleanup commands manually. ``format_docker_legacy_guidance`` returns the
# rendered notice text (empty when nothing legacy is found). Callers should
# print the return value verbatim.


def format_docker_legacy_guidance(
    workspace_name: str,
    legacy_containers: List[str],
    legacy_volumes: List[str],
    legacy_networks: List[str],
) -> str:
    """Render structured guidance for legacy devstack_<ws>* docker resources.

    The guidance follows option-list format. It MUST NOT use free-text
    yes/no approval phrasing ("Shall I…?", "할까요?", "Do you want me to…?",
    "OK to proceed?", "y/n"); a PostToolUse hook on the developer's host
    rejects such text. Operators run the printed docker commands on their
    own when they wish to adopt or remove the resources.

    Returns an empty string when every legacy list is empty.
    """
    containers = [c for c in (legacy_containers or []) if c]
    volumes = [v for v in (legacy_volumes or []) if v]
    networks = [n for n in (legacy_networks or []) if n]
    if not containers and not volumes and not networks:
        return ""

    lines: List[str] = []
    lines.append(
        f"devstack: legacy docker resources detected for workspace {workspace_name!r}."
    )
    lines.append(
        "These resources were created by the previous devstack-named tool. "
        "devstack does NOT auto-migrate them. The list below is informational; "
        "review the listed adoption / cleanup commands and run the ones you want."
    )
    if containers:
        lines.append("")
        lines.append("Legacy containers:")
        for name in containers:
            lines.append(f"  - {name}")
    if volumes:
        lines.append("")
        lines.append("Legacy volumes:")
        for name in volumes:
            lines.append(f"  - {name}")
    if networks:
        lines.append("")
        lines.append("Legacy networks:")
        for name in networks:
            lines.append(f"  - {name}")

    lines.append("")
    lines.append("Options (run manually, one per line):")
    new_project = f"devstack_{workspace_name}"
    if containers:
        lines.append("  [keep legacy data, adopt under devstack project]")
        for name in containers:
            adopted = name.replace("ccstack_", "devstack_", 1)
            if adopted == name:
                continue
            lines.append(f"    docker rename {name} {adopted}")
    if volumes:
        lines.append("  [keep legacy data, adopt under devstack project]")
        for name in volumes:
            adopted = name.replace("ccstack_", "devstack_", 1)
            if adopted == name:
                continue
            # docker volumes cannot be renamed directly; suggest the
            # data-copy + remove pattern, then point at the canonical name.
            lines.append(
                f"    docker volume create {adopted} && "
                f"docker run --rm -v {name}:/from -v {adopted}:/to alpine "
                f"sh -c 'cd /from && cp -a . /to'"
            )
    if networks:
        lines.append("  [keep legacy data, adopt under devstack project]")
        for name in networks:
            adopted = name.replace("ccstack_", "devstack_", 1)
            if adopted == name:
                continue
            lines.append(
                f"    docker network create {adopted} && "
                f"docker network connect {adopted} <container> "
                f"# move each container, then: docker network rm {name}"
            )

    lines.append("  [discard legacy data entirely]")
    for name in containers:
        lines.append(f"    docker rm -f {name}")
    for name in volumes:
        lines.append(f"    docker volume rm {name}")
    for name in networks:
        lines.append(f"    docker network rm {name}")

    lines.append("")
    lines.append(
        f"After cleanup, devstack will create its own resources under the "
        f"{new_project} project on the next workspace start."
    )
    return "\n".join(lines)
