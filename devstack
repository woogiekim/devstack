    return {property_key_to_env_name(key): f"http://localhost:{target_port}"}


def resolve_external_http_candidate_port(
    candidate: Dict[str, str],
    fallback_port: int,
    services: Dict[str, Any],
) -> int:
    """Map an external HTTP candidate to a sibling gradle service's port.

    When the candidate's URL host/port or property key identifies a sibling
    gradle service defined in the SAME workspace manifest, always route to that
    sibling's real local port (user-confirmed: "always route to sibling app").
    Returns the managed mockserver port (``fallback_port``) only when no
    sibling match is found.
    """
    sibling_port = sibling_gradle_service_port(candidate, services)
    if sibling_port is not None:
        return sibling_port
    return fallback_port


# Service types whose manifest entry can carry an explicit local port and
# which therefore participate in sibling routing. Gradle apps are the
# canonical case (Spring Boot apps); command-style entries (``type: command``)
# and compose-style entries (``type: compose``) are included when they declare
# a positive integer port. Managed infra services (whose name starts with
# ``MANAGED_INFRA_PREFIX``) are excluded — those are the mock/db/cache target
# of sibling routing, never a sibling themselves.
SIBLING_ROUTABLE_SERVICE_TYPES = ("gradle", "command", "compose")


def sibling_gradle_service_port(
    candidate: Dict[str, str],
    services: Dict[str, Any],
) -> Optional[int]:
    """Return the local port of a sibling runtime service that matches the
    candidate's URL (host, port) or property key, or None when no match.

    The name preserves the original "gradle" wording for backward
    compatibility — internally the helper now considers every runtime service
    type listed in ``SIBLING_ROUTABLE_SERVICE_TYPES`` (gradle, command,
    compose) that declares a positive integer port. The matching rules stay
    conservative — URL evidence wins over key heuristics so a candidate whose
    value already names the sibling does not get pre-empted by a coincidental
    key collision:

      1. URL hostname is a recognizable identifier of a runtime service
         (tail-segment match against the service name AND the service module).
      2. URL port equals a runtime service's configured port.
      3. Property key contains a tail-segment token from a runtime service
         name (or the service's module path's terminal segment).

    Excludes the owning service: a candidate whose ``path`` lives under the
    same module as service ``S`` never resolves to ``S`` (a service does not
    call itself). Managed infra services (mockserver/mock-http/database/etc.)
    are excluded from the index entirely.
    """
    return sibling_runtime_service_port(candidate, services)


def sibling_runtime_service_port(
    candidate: Dict[str, str],
    services: Dict[str, Any],
) -> Optional[int]:
    """Generic sibling routing across all runtime service types.

    See ``sibling_gradle_service_port`` (the legacy public name) for the
    contract — this function is its real implementation.
    """
    runtime_services = runtime_service_port_index(services)
    if not runtime_services:
        return None

    owning_module = external_http_candidate_owning_module(candidate)

    value = str(candidate.get("value") or "")
    if value:
        parsed = urllib.parse.urlparse(value)
        host = (parsed.hostname or "").lower()
        if host and host not in {"localhost", "127.0.0.1", "0.0.0.0"}:
            match = match_gradle_service_by_token(host, runtime_services, owning_module)
            if match is not None:
                return match
        if parsed.port:
            match = match_gradle_service_by_port(int(parsed.port), runtime_services, owning_module)
            if match is not None:
                return match

    key = str(candidate.get("key") or "")
    if key:
        match = match_gradle_service_by_key(key, runtime_services, owning_module)
        if match is not None:
            return match

    return None


def gradle_service_port_index(services: Dict[str, Any]) -> List[Dict[str, Any]]:
    """Legacy alias: returns ``runtime_service_port_index(services)``.

    The original name is preserved so external callers and existing tests
    keep working unchanged; internally the index now includes every runtime
    service type listed in ``SIBLING_ROUTABLE_SERVICE_TYPES`` that has a
    positive integer port.
    """
    return runtime_service_port_index(services)


def runtime_service_port_index(services: Dict[str, Any]) -> List[Dict[str, Any]]:
    """Index runtime services with a positive integer port.

    Each entry exposes ``name`` (service name), ``port`` (int), ``module``
    (module path or empty string), and ``tokens`` (lowercase identifier
    fragments mined from the service name + module — used for token-based
    matching against URL hosts and property keys).

    Eligibility rules:
      * ``service.type`` must be one of ``SIBLING_ROUTABLE_SERVICE_TYPES``
        (gradle, command, compose). Other types (custom plugins, registry-
        only entries, etc.) are excluded.
      * ``service.port`` must coerce to a positive integer; zero or
        unparseable values exclude the service from the index.
      * The service name must NOT start with ``MANAGED_INFRA_PREFIX + "."``.
        Managed infra services are the mock/db/cache target of sibling
        routing, never a sibling themselves; including them would create
        circular routing (a candidate that already pointed at mockserver
        would resolve back to mockserver).
    """
    index: List[Dict[str, Any]] = []
    for name, service in sorted(services.items()):
        if not isinstance(service, dict):
            continue
        if service.get("type") not in SIBLING_ROUTABLE_SERVICE_TYPES:
            continue
        # Shim 5 — managed-infra services use either the canonical
        # ``devstack.infra.*`` prefix or the legacy ``ccstack.infra.*``
        # alias; both are excluded from the sibling routing index.
        if is_managed_infra_service_name(str(name)):
            continue
        port = service.get("port")
        try:
            port_int = int(port) if port else 0
        except (TypeError, ValueError):
            continue
        if port_int <= 0:
            continue

        module = str(service.get("module") or "")
        index.append(
            {
                "name": str(name),
                "port": port_int,
                "module": module,
                "tokens": service_identifier_tokens(str(name), module),
            }
        )
    return index


def service_identifier_tokens(name: str, module: str) -> List[str]:
    """Mine lowercase identifier tokens from a service name and its module path.

    Tokens are the segments split on ``.``, ``/``, ``:``, ``-``, and ``_`` plus
    their original hyphenated form (e.g. ``fixity-contents``). Single-character
    fragments and well-known noise tokens (``apps``, ``app``, ``api``, ``main``,
    ``master``) are dropped so they cannot match arbitrary URLs.
    """
    raw_parts: List[str] = []
    for piece in re.split(r"[./:]", name):
        if piece:
            raw_parts.append(piece)
    for piece in re.split(r"[./:]", module):
        if piece:
            raw_parts.append(piece)

    tokens: List[str] = []
    noise = {"apps", "app", "api", "main", "master", "src", "module", "devstack"}
    for part in raw_parts:
        lowered = part.lower()
        if not lowered or lowered in noise or len(lowered) <= 1:
            continue
        if lowered not in tokens:
            tokens.append(lowered)
        for sub in re.split(r"[-_]", lowered):
            if not sub or sub in noise or len(sub) <= 1:
                continue
            if sub not in tokens:
                tokens.append(sub)
    return tokens


def match_gradle_service_by_token(
    needle: str,
    gradle_services: List[Dict[str, Any]],
    owning_module: str,
) -> Optional[int]:
    needle = needle.lower()
    if not needle:
        return None
    # Strongest signal first: the candidate's host/key contains the full
    # hyphenated form of a service token (e.g. "fixity-contents"). Prefer
    # the longest matching token so "fixity-contents" wins over "fixity".
    best: Optional[Dict[str, Any]] = None
    best_token_len = 0
    for service in gradle_services:
        if owning_module and service.get("module") == owning_module:
            continue
        for token in service.get("tokens", []):
            if "-" not in token:
                continue
            if token in needle and len(token) > best_token_len:
                best = service
                best_token_len = len(token)
    if best is not None:
        return int(best["port"])

    # Fall back to single-segment tokens — must appear as a recognizable
    # boundary-delimited fragment, not embedded inside another word.
    boundary_pat = re.compile(r"[^a-z0-9]+")
    fragments = [frag for frag in boundary_pat.split(needle) if frag]
    if not fragments:
        return None
    for service in gradle_services:
        if owning_module and service.get("module") == owning_module:
            continue
        for token in service.get("tokens", []):
            if "-" in token:
                continue
            if token in fragments:
                return int(service["port"])
    return None


def match_gradle_service_by_port(
    candidate_port: int,
    gradle_services: List[Dict[str, Any]],
    owning_module: str,
) -> Optional[int]:
    for service in gradle_services:
        if owning_module and service.get("module") == owning_module:
            continue
        if int(service.get("port") or 0) == candidate_port:
            return candidate_port
    return None


def match_gradle_service_by_key(
    key: str,
    gradle_services: List[Dict[str, Any]],
    owning_module: str,
) -> Optional[int]:
    return match_gradle_service_by_token(key, gradle_services, owning_module)


def external_http_candidate_owning_module(candidate: Dict[str, str]) -> str:
    """Return the module path that owns the candidate (e.g. ``apps/proxy/X``).

    Mirrors the prefix logic used by ``environment_override_entries`` so a
    candidate detected inside ``apps/proxy/.../resources/application.yml``
    never resolves to the proxy service itself.
    """
    path = str(candidate.get("path") or "").replace("\\", "/")
    if not path:
        return ""
    parts = path.split("/")
    # Strip everything from src/ onward — modules are the leading segments
    # of a gradle project layout.
    if "src" in parts:
        parts = parts[: parts.index("src")]
    if not parts:
        return ""
    return "/".join(parts).strip("/")


def existing_infra_services(services: Dict[str, Any], kind: str, technology: str) -> List[str]:
    terms = infra_match_terms(kind, technology)
    matches: List[str] = []
    for name, service in sorted(services.items()):
        if not isinstance(service, dict):
            continue
        if service.get("type") != "compose":
            continue
        haystack = " ".join(
            str(value)
            for value in (
                name,
                service.get("service", ""),
                service.get("compose", ""),
                service.get("image", ""),
                service.get("container", ""),
            )
        ).lower()
        if any(term in haystack for term in terms):
            matches.append(name)
    return matches


def existing_database_services(services: Dict[str, Any], engine: str) -> List[str]:
    terms = {
        "postgresql": ("postgres", "postgresql"),
        "mysql": ("mysql",),
        "mariadb": ("mariadb",),
        "mssql": ("mssql", "sqlserver"),
    }.get(engine, (engine,))
    matches: List[str] = []
    for name, service in sorted(services.items()):
        if not isinstance(service, dict):
            continue
        if service.get("type") != "compose":
            continue
        if normalize_database_engine(str(service.get("engine", ""))) == engine:
            matches.append(name)
            continue

        haystack = " ".join(
            str(value)
            for value in (
                name,
                service.get("service", ""),
                service.get("compose", ""),
                service.get("image", ""),
                service.get("container", ""),
            )
        ).lower()
        if any(term in haystack for term in terms):
            matches.append(name)
    return matches


def infra_match_terms(kind: str, technology: str) -> Tuple[str, ...]:
    tech = technology.lower()
    if kind == "database":
        base = {
            "postgresql": ("postgres", "postgresql", "pg", "db", "database"),
            "mysql": ("mysql", "db", "database"),
            "mariadb": ("mariadb", "mysql", "db", "database"),
            "oracle": ("oracle", "db", "database"),
            "mssql": ("mssql", "sqlserver", "db", "database"),
        }
        return base.get(tech, ("db", "database", tech))
    if kind == "redis":
        return ("redis",)
    if kind == "kafka":
        return ("kafka", "redpanda", "zookeeper")
    if kind == "mongo":
        return ("mongo", "mongodb")
    if kind == "search":
        return ("opensearch", "elasticsearch")
    if kind == "object_storage":
        return ("minio", "s3", "localstack")
    if kind == "config_server":
        return ("config-server", "spring-cloud-config")
    if kind == "external_http":
        return ("mockserver", "mock-http", "wiremock")
    return (tech,)


def environment_override_entries(
    config: Dict[str, Any],
    source_path: str,
    env: Dict[str, str],
    source_id: str,
) -> List[Dict[str, str]]:
    if not env:
        return []
    services = matching_runtime_services(config, source_path)
    return [
        {"service": service_name, "name": key, "value": str(value), "source": source_id}
        for service_name in services
        for key, value in sorted(env.items())
    ]


def application_argument_entries(
    config: Dict[str, Any],
    source_path: str,
    args: List[str],
    source_id: str,
) -> List[Dict[str, str]]:
    if not args:
        return []
    services = matching_runtime_services(config, source_path)
    return [
        {"service": service_name, "value": str(value), "source": source_id}
        for service_name in services
        for value in args
    ]


def matching_runtime_services(config: Dict[str, Any], source_path: str) -> List[str]:
    services = config.get("services", {})
    runtime = [
        (name, service)
        for name, service in sorted(services.items())
        if isinstance(service, dict) and service.get("type") in {"gradle", "command"}
    ]
    if not source_path:
        return [name for name, _ in runtime]

    source = source_path.replace("\\", "/").strip("/")
    matched = []
    for name, service in runtime:
        module = str(service.get("module") or module_from_gradle_task(str(service.get("task", "")))).strip("/")
        if module and (source == module or source.startswith(f"{module}/")):
            matched.append(name)
        elif not module and source.startswith("src/"):
            matched.append(name)
    return matched or [name for name, _ in runtime]


def module_from_gradle_task(task: str) -> str:
    if not task.startswith(":"):
        return ""
    parts = [part for part in task.split(":") if part]
    if parts and parts[-1] in {"bootRun", "run"}:
        parts = parts[:-1]
    return "/".join(parts)


def inspect_runtime_environment_signals(
    root: Path,
    scan_cache: Optional[WorkspaceScanCache] = None,
) -> Dict[str, List[Dict[str, str]]]:
    patterns = {
        "redis": (
            "spring.data.redis.cluster",
            "useclusterservers",
            "spring.data.redis",
            "spring.redis",
            "spring-boot-starter-data-redis",
            "data-redis",
            "redistemplate",
            "stringredistemplate",
            "redisson",
            "lettuce",
            "jedis",
        ),
        "kafka": ("spring.kafka", "kafkatemplate", "@kafkalistener", "spring-kafka", "kafka-clients"),
        "mongo": (
            "spring.data.mongodb",
            "spring-boot-starter-data-mongodb",
            "mongorepository",
            "mongotemplate",
            "mongodb",
        ),
        "search": ("elasticsearch", "opensearch", "elasticsearchrepository", "searchclient"),
        "object_storage": ("s3client", "amazons3", "spring.cloud.aws.s3", "aws.s3", "minio"),
        "config_server": ("configserver:", "spring.cloud.config", "spring_config_import"),
    }
    signals: Dict[str, List[Dict[str, str]]] = {key: [] for key in patterns}
    for path in runtime_scan_files(root, scan_cache=scan_cache):
        text = read_small_text(path, scan_cache=scan_cache).lower()
        if not text:
            continue
        for kind, tokens in patterns.items():
            marker = first_present_token(text, tokens)
            if marker and len(signals[kind]) < 20:
                signals[kind].append({"path": relative_to_root(root, path), "marker": marker})
    return signals


def inspect_spring_batch_requirements(
    root: Path,
    scan_cache: Optional[WorkspaceScanCache] = None,
) -> List[Dict[str, Any]]:
    requirements: List[Dict[str, Any]] = []
    seen_modules: Set[str] = set()
    tokens = (
        "spring-batch",
        "spring.batch",
        "@enablebatchprocessing",
        "jobbuilderfactory",
        "stepbuilderfactory",
        "batchautoconfiguration",
    )
    for path in runtime_scan_files(root, scan_cache=scan_cache):
        text = read_small_text(path, scan_cache=scan_cache).lower()
        marker = first_present_token(text, tokens)
        if not marker:
            continue
        module = source_module_path(root, path)
        if module in seen_modules:
            continue
        seen_modules.add(module)
        requirements.append(
            {
                "id": f"spring-batch-local-runtime-{len(requirements) + 1}",
                "kind": "runtime_config",
                "technology": "spring-batch",
                "status": "configure",
                "confidence": "medium",
                "source": module or relative_to_root(root, path),
                "reason": (
                    "Spring Batch was detected; devstack disables automatic local job execution "
                    "and batch schema initialization so generated local datasources can boot safely."
                ),
                "application_env": {
                    "SPRING_BATCH_JDBC_INITIALIZE_SCHEMA": "never",
                    "SPRING_BATCH_JOB_ENABLED": "false",
                },
                "application_args": [
                    "--spring.batch.jdbc.initialize-schema=never",
                    "--spring.batch.job.enabled=false",
                ],
            }
        )
    return requirements


def source_module_path(root: Path, path: Path) -> str:
    relative = relative_to_root(root, path)
    parts = Path(relative).parts
    for marker in ("src", "build.gradle", "build.gradle.kts"):
        if marker in parts:
            index = parts.index(marker)
            return "/".join(parts[:index])
    return str(Path(relative).parent).strip(".")


def inspect_external_http_candidates(
    root: Path,
    scan_cache: Optional[WorkspaceScanCache] = None,
) -> List[Dict[str, str]]:
    candidates: List[Dict[str, str]] = []
    for path in runtime_scan_files(root, scan_cache=scan_cache):
        if not should_scan_external_http(root, path):
            continue
        text = read_small_text(path, scan_cache=scan_cache)
        if not text:
            continue
        for key, value in config_http_values(path, text):
            if is_local_http_value(value) and not should_mock_local_http_value(key, value):
                continue
            if "artifactory" in value.lower():
                continue
            if is_build_repository_http_key(key, value):
                continue
            candidates.append(
                {
                    "path": relative_to_root(root, path),
                    "key": key,
                    "value": value,
                    "confidence": "medium",
                }
            )
        lower = text.lower()
        if any(token in lower for token in ("@feignclient", "webclient", "resttemplate")):
            candidates.append(
                {
                    "path": relative_to_root(root, path),
                    "marker": "http client",
                    "value": "",
                    "confidence": "low",
                }
            )
        if len(candidates) >= 30:
            return candidates[:30]
    return candidates[:30]


def should_mock_local_http_value(key: str, value: str) -> bool:
    haystack = f"{key} {value}".lower()
    parsed = urllib.parse.urlparse(value)
    if parsed.hostname not in {"localhost", "127.0.0.1", "0.0.0.0"}:
        return False
    if re.search(r"\b(service|client|api|backend)[-_.]?url\b", key, re.IGNORECASE):
        return True
    return any(token in haystack for token in ("feign", "external", "backend"))


def should_scan_external_http(root: Path, path: Path) -> bool:
    relative = relative_to_root(root, path).replace("\\", "/")
    parts = relative.split("/")
    if "src" in parts and "test" in parts:
        return False
    if parts and parts[0] in {"docs", "doc"}:
        return False
    if Path(relative).name.lower() in {"readme.md", "claude.md"}:
        return False
    return True


def inspect_environment_variables(
    root: Path,
    scan_cache: Optional[WorkspaceScanCache] = None,
) -> List[Dict[str, str]]:
    variables: List[Dict[str, str]] = []
    seen: Set[Tuple[str, str]] = set()
    for path in runtime_scan_files(root, scan_cache=scan_cache):
        text = read_small_text(path, scan_cache=scan_cache)
        if not text:
            continue
        for match in re.finditer(r"\$\{([A-Za-z_][A-Za-z0-9_]*)(?::([^}]*))?\}", text):
            name = match.group(1)
            key = (relative_to_root(root, path), name)
            if key in seen:
                continue
            seen.add(key)
            variables.append(
                {
                    "path": key[0],
                    "name": name,
                    "default": match.group(2) or "",
                }
            )
            if len(variables) >= 50:
                return variables
        for match in re.finditer(r"System\.getenv\(\s*[\"']([A-Za-z_][A-Za-z0-9_]*)[\"']\s*\)", text):
            name = match.group(1)
            key = (relative_to_root(root, path), name)
            if key in seen:
                continue
            seen.add(key)
            variables.append({"path": key[0], "name": name, "default": ""})
            if len(variables) >= 50:
                return variables
    return variables


def inspect_spring_profiles(
    root: Path,
    scan_cache: Optional[WorkspaceScanCache] = None,
) -> List[Dict[str, str]]:
    profiles: List[Dict[str, str]] = []
    seen: Set[Tuple[str, str]] = set()
    for path in runtime_scan_files(root, scan_cache=scan_cache):
        relative = relative_to_root(root, path)
        file_match = re.match(r"(?:.*/)?application-([A-Za-z0-9_.-]+)\.(?:properties|ya?ml)$", relative)
        if file_match:
            profile = file_match.group(1)
            key = (relative, profile)
            if key not in seen:
                seen.add(key)
                profiles.append({"path": relative, "profile": profile, "source": "filename"})

        text = read_small_text(path, scan_cache=scan_cache)
        for value in re.findall(r"(?m)^\s*spring\.profiles\.active\s*[:=]\s*([A-Za-z0-9_,.-]+)\s*$", text):
            for profile in split_csv(value):
                key = (relative, profile)
                if key not in seen:
                    seen.add(key)
                    profiles.append({"path": relative, "profile": profile, "source": "spring.profiles.active"})
        if len(profiles) >= 30:
            return profiles[:30]
    return profiles[:30]


def inspect_run_scripts(root: Path) -> List[Dict[str, str]]:
    candidates: List[Dict[str, str]] = []
    names = ("run", "start", "dev", "local", "boot", "compose")
    for path in sorted(root.rglob("*.sh")):
        if ignored_path(root, path) or not path.is_file():
            continue
        lowered = path.name.lower()
        if not any(name in lowered for name in names):
            continue
        candidates.append({"path": relative_to_root(root, path), "type": "shell"})
        if len(candidates) >= 30:
            return candidates
    for path in sorted(root.rglob("Makefile")):
        if ignored_path(root, path) or not path.is_file():
            continue
        text = read_small_text(path).lower()
        if any(target in text for target in ("run:", "start:", "dev:", "local:")):
            candidates.append({"path": relative_to_root(root, path), "type": "make"})
        if len(candidates) >= 30:
            return candidates
    return candidates


def runtime_scan_files(root: Path, scan_cache: Optional[WorkspaceScanCache] = None) -> List[Path]:
    if scan_cache:
        return scan_cache.runtime_files()
    return collect_runtime_scan_files(root)


def collect_runtime_scan_files(root: Path) -> List[Path]:
    files: List[Path] = []
    patterns = (
        "application*.properties",
        "application*.yml",
        "application*.yaml",
        "bootstrap*.properties",
        "bootstrap*.yml",
        "bootstrap*.yaml",
        "build.gradle",
        "build.gradle.kts",
        "*.java",
        "*.kt",
    )
    for pattern in patterns:
        for path in sorted(root.rglob(pattern)):
            if ignored_path(root, path) or not path.is_file() or path in files:
                continue
            files.append(path)
    return files


def read_small_text(path: Path, limit: int = 300000, scan_cache: Optional[WorkspaceScanCache] = None) -> str:
    if scan_cache:
        return scan_cache.read_small_text(path, limit)
    try:
        if path.stat().st_size > limit:
            return path.read_text(errors="ignore")[:limit]
        return path.read_text(errors="ignore")
    except OSError:
        return ""


def first_present_token(text: str, tokens: Tuple[str, ...]) -> str:
    for token in tokens:
        if token in text:
            return token
    return ""


def compatible_gradle_java_home(root: Path, env: Dict[str, str]) -> str:
    max_major = max_supported_java_for_gradle_wrapper(root)
    if not max_major:
        return ""

    preferred_major = preferred_java_major_for_gradle_project(root, max_major)
    current_major = current_java_major(env)
    if current_major and current_major == preferred_major:
        return ""

    for candidate in java_home_candidates(max_major, preferred_major=preferred_major):
        major = java_major_for_home(candidate)
        if major and major <= max_major:
            return str(candidate)
    return ""


def max_supported_java_for_gradle_wrapper(root: Path) -> Optional[int]:
    version = gradle_wrapper_version(root)
    if not version:
        return None
    major, minor = version
    if major == 8 and minor <= 5:
        return 21
    return None


def gradle_wrapper_version(root: Path) -> Optional[Tuple[int, int]]:
    text = read_small_text(root / "gradle" / "wrapper" / "gradle-wrapper.properties", limit=20000)
    match = re.search(r"gradle-([0-9]+)(?:\.([0-9]+))?", text)
    if not match:
        return None
    return int(match.group(1)), int(match.group(2) or "0")


def preferred_java_major_for_gradle_project(root: Path, max_major: int) -> int:
    detected = detected_gradle_project_java_major(root)
    if detected and detected <= max_major:
        return detected
    if max_major >= 17:
        return 17
    return max_major


def detected_gradle_project_java_major(root: Path) -> Optional[int]:
    majors: Set[int] = set()
    for path in gradle_build_files(root):
        majors.update(java_target_majors_from_gradle_text(read_small_text(path, limit=200000)))
    if not majors:
        return None
    return max(majors)


def gradle_build_files(root: Path) -> List[Path]:
    files: List[Path] = []
    for pattern in ("build.gradle", "build.gradle.kts", "gradle.properties"):
        path = root / pattern
        if path.is_file():
            files.append(path)
    for path in sorted(root.rglob("build.gradle*")):
        if ignored_path(root, path) or not path.is_file() or path in files:
            continue
        files.append(path)
    return files[:100]


def java_target_majors_from_gradle_text(text: str) -> Set[int]:
    majors: Set[int] = set()
    patterns = (
        r"\bjvmTarget\b\s*(?:=|\.set\()\s*[\"']?([0-9]{1,2})",
        r"\bjvmToolchain\s*\(?\s*([0-9]{1,2})",
        r"\bJavaLanguageVersion\.of\(\s*([0-9]{1,2})\s*\)",
        r"\b(?:sourceCompatibility|targetCompatibility)\b\s*(?:=|\.set\()\s*[\"']?([0-9]{1,2})",
        r"\bJavaVersion\.VERSION_([0-9]{1,2})\b",
    )
    for pattern in patterns:
        for match in re.finditer(pattern, text):
            try:
                majors.add(int(match.group(1)))
            except ValueError:
                continue
    return majors


def current_java_major(env: Dict[str, str]) -> Optional[int]:
    java_home = env.get("JAVA_HOME")
    if java_home:
        return java_major_for_home(Path(java_home).expanduser())
    return java_major_for_command(["java", "-version"])


def java_home_candidates(max_major: int, preferred_major: Optional[int] = None) -> List[Path]:
    candidates: List[Path] = []
    preferred_majors = [
        major
        for major in [preferred_major, max_major, 21, 17, 11, 8]
        if isinstance(major, int) and major <= max_major
    ]
    for major in unique(preferred_majors):
        macos_java_home = java_home_for_macos_version(major)
        if macos_java_home:
            candidates.append(macos_java_home)

    homes = [
        Path.home() / "Library" / "Java" / "JavaVirtualMachines",
        Path("/Library/Java/JavaVirtualMachines"),
        Path("/usr/lib/jvm"),
        Path.home() / ".sdkman" / "candidates" / "java",
    ]
    for home in homes:
        if not home.is_dir():
            continue
        for child in sorted(home.iterdir(), reverse=True):
            candidates.extend(jdk_home_paths(child))

    unique_candidates: List[Path] = []
    seen: Set[Path] = set()
    for candidate in candidates:
        resolved = candidate.expanduser()
        if resolved in seen:
            continue
        seen.add(resolved)
        unique_candidates.append(resolved)
    return unique_candidates


def java_home_for_macos_version(major: int) -> Optional[Path]:
    helper = Path("/usr/libexec/java_home")
    if not helper.exists():
        return None
    try:
        result = subprocess.run(
            [str(helper), "-v", str(major)],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            check=False,
        )
    except OSError:
        return None
    if result.returncode != 0:
        return None
    value = result.stdout.strip()
    return Path(value) if value else None


def jdk_home_paths(path: Path) -> List[Path]:
    if (path / "bin" / "java").exists():
        return [path]
    contents_home = path / "Contents" / "Home"
    if (contents_home / "bin" / "java").exists():
        return [contents_home]
    return []


def java_major_for_home(home: Path) -> Optional[int]:
    java = home / "bin" / "java"
    if not java.exists():
        return None
    return java_major_for_command([str(java), "-version"])


def java_major_for_command(command: List[str]) -> Optional[int]:
    try:
        result = subprocess.run(
            command,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            check=False,
        )
    except OSError:
        return None
    return parse_java_major(result.stderr + result.stdout)


def parse_java_major(text: str) -> Optional[int]:
    match = re.search(r'version\s+"([^"]+)"', text)
    if not match:
        return None
    version = match.group(1)
    if version.startswith("1."):
        parts = version.split(".")
        return int(parts[1]) if len(parts) > 1 and parts[1].isdigit() else None
    major = version.split(".", 1)[0]
    return int(major) if major.isdigit() else None


def config_property_entries(path: Path, text: str) -> List[Tuple[str, str]]:
    suffix = path.suffix.lower()
    if suffix in {".yml", ".yaml"}:
        return yaml_property_entries(text)
    return properties_property_entries(text)


def properties_property_entries(text: str) -> List[Tuple[str, str]]:
    entries: List[Tuple[str, str]] = []
    for raw_line in text.splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or line.startswith("!"):
            continue
        key, separator, value = line.partition("=")
        if not separator:
            key, separator, value = line.partition(":")
        if not separator:
            continue
        entries.append((clean_config_key(key), clean_config_value(value)))
    return entries


def yaml_property_entries(text: str) -> List[Tuple[str, str]]:
    entries: List[Tuple[str, str]] = []
    stack: List[Tuple[int, str]] = []
    for raw_line in text.splitlines():
        if not raw_line.strip() or raw_line.lstrip().startswith("#"):
            continue
        indent = len(raw_line) - len(raw_line.lstrip(" "))
        line = raw_line.strip()
        if line.startswith("- "):
            line = line[2:].strip()
        match = re.match(r"([\"']?[^:\"']+[\"']?)\s*:\s*(.*)$", line)
        if not match:
            continue
        key = clean_config_key(match.group(1))
        value = match.group(2).strip()
        while stack and indent <= stack[-1][0]:
            stack.pop()
        full_key = ".".join([item[1] for item in stack] + [key])
        if not value or value in {"|", ">"}:
            stack.append((indent, key))
            continue
        entries.append((full_key, clean_config_value(value)))
    return entries


def clean_config_key(value: str) -> str:
    return value.strip().strip('"').strip("'")


def clean_config_value(value: str) -> str:
    value = value.strip()
    if " #" in value:
        value = value.split(" #", 1)[0].strip()
    return value.strip().strip('"').strip("'")


def config_http_values(path: Path, text: str) -> List[Tuple[str, str]]:
    values: List[Tuple[str, str]] = []
    for key, value in config_property_entries(path, text):
        if "http" not in value.lower():
            continue
        if not re.search(r"(url|uri|endpoint|base[-_.]?url|host)", key, re.IGNORECASE):
            continue
        if "jdbc:" in value.lower():
            continue
        values.append((key, value))
    return values


def is_local_http_value(value: str) -> bool:
    lowered = value.lower()
    return any(token in lowered for token in ("localhost", "127.0.0.1", "0.0.0.0", "${"))


def is_build_repository_http_key(key: str, value: str) -> bool:
    haystack = f"{key} {value}".lower()
    return any(token in haystack for token in ("maven", "repository", "repo", "artifactory", "nexus"))


def inspect_persistence(root: Path, scan_cache: Optional[WorkspaceScanCache] = None) -> Dict[str, Any]:
    entities = inspect_jpa_entities(root, scan_cache=scan_cache)
    mappers = inspect_mybatis_mappers(root, scan_cache=scan_cache)
    exposed = inspect_exposed(root, scan_cache=scan_cache)
    jdbc = inspect_jdbc_sql(root, scan_cache=scan_cache)
    repositories = inspect_repositories(root, entities, scan_cache=scan_cache)
    datasources = inspect_datasource_configs(root, scan_cache=scan_cache)
    tables = merge_persistence_tables(entities, mappers, exposed, jdbc)

    return {
        "tables": tables,
        "entities": entities,
        "repositories": repositories,
        "mappers": mappers,
        "exposed": exposed,
        "jdbc": jdbc,
        "datasources": datasources,
    }


def merge_persistence_tables(
    entities: List[Dict[str, Any]],
    mappers: List[Dict[str, Any]],
    exposed: Dict[str, Any],
    jdbc: List[Dict[str, Any]],
) -> List[Dict[str, Any]]:
    tables: Dict[str, Dict[str, Any]] = {}
    for entity in entities:
        table_name = entity["table"]
        tables[table_name] = {
            "name": table_name,
            "source": "jpa",
            "path": entity["path"],
            "entity": entity["class"],
            "columns": entity["columns"],
        }

    for mapper in mappers:
        for table_name in mapper.get("tables", []):
            tables.setdefault(
                table_name,
                {
                    "name": table_name,
                    "source": "mapper",
                    "path": mapper["path"],
                    "entity": "",
                    "columns": [],
                },
            )

    for table in exposed.get("tables", []):
        table_name = table["table"]
        tables.setdefault(
            table_name,
            {
                "name": table_name,
                "source": "exposed",
                "path": table["path"],
                "entity": "",
                "object": table["object"],
                "columns": table["columns"],
            },
        )
        merge_table_columns(tables[table_name], table.get("columns", []))

    for statement in jdbc:
        table_columns = {
            str(table).lower(): columns
            for table, columns in statement.get("table_columns", {}).items()
            if isinstance(columns, list)
        }
        for table_name in statement.get("tables", []):
            tables.setdefault(
                table_name,
                {
                    "name": table_name,
                    "source": "jdbc",
                    "path": statement["path"],
                    "entity": "",
                    "columns": [],
                },
            )
            if table_columns:
                merge_table_columns(tables[table_name], table_columns.get(str(table_name).lower(), []))
            else:
                merge_table_columns(tables[table_name], statement.get("columns", []))

    return [tables[name] for name in sorted(tables)]


def merge_table_columns(table: Dict[str, Any], columns: List[Dict[str, Any]]) -> None:
    existing = {str(column.get("name", "")).lower(): column for column in table.setdefault("columns", [])}
    for column in columns:
        name = str(column.get("name", "")).strip()
        if not name:
            continue
        key = name.lower()
        if key in existing:
            existing[key].update({k: v for k, v in column.items() if v not in ("", None)})
        else:
            table["columns"].append(dict(column))
            existing[key] = table["columns"][-1]


def inspect_jpa_entities(root: Path, scan_cache: Optional[WorkspaceScanCache] = None) -> List[Dict[str, Any]]:
    entities = []
    for path in persistence_source_files(root, scan_cache=scan_cache):
        text = read_small_text(path, scan_cache=scan_cache)
        if "@Entity" not in text:
            continue

        class_name = java_class_name(text)
        if not class_name:
            continue

        table_name = annotation_named_value(text, "Table") or camel_to_snake(class_name.removesuffix("Entity"))
        entities.append(
            {
                "class": class_name,
                "table": table_name,
                "path": relative_to_root(root, path),
                "columns": inspect_entity_columns(text),
            }
        )
    return entities


def persistence_source_files(root: Path, scan_cache: Optional[WorkspaceScanCache] = None) -> List[Path]:
    if scan_cache:
        return sorted(scan_cache.persistence_files())
    files = []
    for suffix in ("*.java", "*.kt"):
        for path in root.rglob(suffix):
            if ignored_path(root, path) or not path.is_file():
                continue
            files.append(path)
    return sorted(files)


def inspect_entity_columns(text: str) -> List[Dict[str, Any]]:
    columns: List[Dict[str, Any]] = []
    pending_column = ""
    pending_id = False
    for raw_line in text.splitlines():
        line = raw_line.strip()
        if line.startswith("@Column"):
            pending_column = annotation_named_value(line, "Column")
            continue
        if line.startswith("@Id") or line.startswith("@EmbeddedId"):
            pending_id = True
            continue

        field_name = java_or_kotlin_field_name(line)
        if not field_name:
            continue

        column_name = pending_column or camel_to_snake(field_name)
        columns.append({"name": column_name, "field": field_name, "id": pending_id})
        pending_column = ""
        pending_id = False
    return columns


def inspect_repositories(
    root: Path,
    entities: List[Dict[str, Any]],
    scan_cache: Optional[WorkspaceScanCache] = None,
) -> List[Dict[str, str]]:
    entity_tables = {entity["class"]: entity["table"] for entity in entities}
    repositories = []
    for path in persistence_source_files(root, scan_cache=scan_cache):
        text = read_small_text(path, scan_cache=scan_cache)
        if not any(token in text for token in ("JpaRepository", "CrudRepository", "PagingAndSortingRepository", "@Repository")):
            continue

        name = java_class_name(text) or path.stem
        entity = ""
        match = re.search(r"(?:JpaRepository|CrudRepository|PagingAndSortingRepository)\s*<\s*([A-Za-z0-9_]+)", text)
        if match:
            entity = match.group(1)
        repositories.append(
            {
                "name": name,
                "entity": entity,
                "table": entity_tables.get(entity, ""),
                "path": relative_to_root(root, path),
            }
        )
    return repositories


def inspect_mybatis_mappers(root: Path, scan_cache: Optional[WorkspaceScanCache] = None) -> List[Dict[str, Any]]:
    mappers = []
    for path in sorted(root.rglob("*.xml")):
        if ignored_path(root, path) or not path.is_file():
            continue
        text = read_small_text(path)
        if "<mapper" not in text:
            continue

        namespace = xml_attr(text, "namespace")
        statements = inspect_mapper_statements(text)
        tables = sorted({table for statement in statements for table in statement["tables"]})
        mappers.append(
            {
                "namespace": namespace,
                "path": relative_to_root(root, path),
                "tables": tables,
                "statements": statements,
            }
        )

    for path in persistence_source_files(root, scan_cache=scan_cache):
        text = read_small_text(path, scan_cache=scan_cache)
        if "@Mapper" not in text:
            continue

        statements = inspect_annotation_sql_statements(text)
        tables = sorted({table for statement in statements for table in statement["tables"]})
        mappers.append(
            {
                "namespace": java_class_name(text) or path.stem,
                "path": relative_to_root(root, path),
                "tables": tables,
                "statements": statements,
            }
        )
    return mappers


def inspect_exposed(root: Path, scan_cache: Optional[WorkspaceScanCache] = None) -> Dict[str, Any]:
    tables = []
    queries = []
    table_by_object: Dict[str, str] = {}

    kotlin_paths = [
        item
        for item in persistence_source_files(root, scan_cache=scan_cache)
        if item.suffix.lower() == ".kt"
    ]
    for path in kotlin_paths:
        text = read_small_text(path, scan_cache=scan_cache)
        if not is_exposed_source(text):
            continue

        for table in inspect_exposed_tables(root, path, text):
            tables.append(table)
            table_by_object[table["object"]] = table["table"]

    for path in kotlin_paths:
        text = read_small_text(path, scan_cache=scan_cache)
        if not is_exposed_source(text):
            continue

        queries.extend(inspect_exposed_queries(root, path, text, table_by_object))

    return {"tables": tables, "queries": queries}


def is_exposed_source(text: str) -> bool:
    return "org.jetbrains.exposed" in text or any(
        token in text for token in ("IntIdTable", "LongIdTable", "UUIDTable", "IdTable", ": Table")
    )


def inspect_exposed_tables(root: Path, path: Path, text: str) -> List[Dict[str, Any]]:
    tables = []
    table_pattern = re.compile(
        r"object\s+([A-Za-z0-9_]+)\s*:\s*(?:[A-Za-z0-9_.]+\.)?"
        r"(IntIdTable|LongIdTable|UUIDTable|IdTable|Table)"
        r"(?:\s*\(([^)]*)\))?\s*\{(.*?)(?=\n\s*object\s+[A-Za-z0-9_]+\s*:|\Z)",
        re.DOTALL,
    )
    for match in table_pattern.finditer(text):
        object_name, table_type, args, body = match.groups()
        quoted_args = quoted_values(args or "")
        table_name = (quoted_args[0] if quoted_args else "") or exposed_default_table_name(object_name)
        columns = inspect_exposed_columns(body)
        id_column = exposed_id_column(table_type, quoted_args)
        if id_column:
            columns.insert(0, id_column)
        tables.append(
            {
                "object": object_name,
                "table": table_name,
                "type": table_type,
                "path": relative_to_root(root, path),
                "columns": columns,
            }
        )
    return tables


def inspect_exposed_columns(body: str) -> List[Dict[str, Any]]:
    columns = []
    column_pattern = re.compile(
        r"\bval\s+([A-Za-z0-9_]+)\s*=\s*(?:[A-Za-z0-9_.]+\.)?"
        r"(varchar|char|text|integer|long|short|byte|bool|decimal|double|float|date|datetime|timestampWithTimeZone|timestamp|"
        r"time|uuid|blob|binary|reference|optReference|enumeration|enumerationByName|enumerationByValue)"
        r"\s*(<[^>]+>)?\s*\(([^)]*)\)",
        re.IGNORECASE,
    )
    for match in column_pattern.finditer(body):
        field_name, column_type, generic_args, args = match.groups()
        effective_type = exposed_effective_column_type(column_type, generic_args or "")
        length = exposed_column_length(column_type, args)
        columns.append(
            {
                "name": first_quoted_value(args) or camel_to_snake(field_name),
                "field": field_name,
                "type": effective_type,
                "source_type": column_type,
                "id": field_name == "id",
                "length": length,
                "nullable": ".nullable()" in body[match.end(): match.end() + 80],
                "default": ".default(" in body[match.end(): match.end() + 120],
            }
        )
    return columns


def exposed_effective_column_type(column_type: str, generic_args: str) -> str:
    if column_type.lower() == "timestampwithtimezone":
        return "timestamp"
    if column_type.lower() != "enumerationbyvalue":
        return column_type
    generic_parts = [part.strip() for part in generic_args.strip("<>").split(",") if part.strip()]
    stored_type = generic_parts[1].lower() if len(generic_parts) > 1 else ""
    if stored_type in {"int", "integer"}:
        return "integer"
    if stored_type == "long":
        return "long"
    if stored_type in {"short", "byte"}:
        return stored_type
    if stored_type in {"float", "double"}:
        return stored_type
    return column_type


def exposed_id_column(table_type: str, quoted_args: List[str]) -> Dict[str, Any]:
    if table_type == "IntIdTable":
        return {"name": quoted_args[1] if len(quoted_args) > 1 else "id", "field": "id", "type": "integer", "id": True}
    if table_type == "LongIdTable":
        return {"name": quoted_args[1] if len(quoted_args) > 1 else "id", "field": "id", "type": "long", "id": True}
    if table_type == "UUIDTable":
        return {"name": quoted_args[1] if len(quoted_args) > 1 else "id", "field": "id", "type": "uuid", "id": True}
    return {}


def exposed_column_length(column_type: str, args: str) -> str:
    if column_type.lower() not in {"varchar", "char", "enumerationbyname", "enumerationbyvalue"}:
        return ""
    parts = [part.strip() for part in args.split(",")]
    for part in parts[1:]:
        if part.isdigit():
            return part
    match = re.search(r"\blength\s*=\s*(\d+)", args)
    return match.group(1) if match else ""


def inspect_exposed_queries(
    root: Path,
    path: Path,
    text: str,
    table_by_object: Dict[str, str],
) -> List[Dict[str, str]]:
    queries = []
    query_pattern = re.compile(
        r"\b([A-Z][A-Za-z0-9_]*)\s*\.\s*"
        r"(selectAll|select|insert|batchInsert|update|deleteWhere|replace|upsert)\s*(?:\(|\{)"
    )
    for match in query_pattern.finditer(text):
        object_name, operation = match.groups()
        table_name = table_by_object.get(object_name)
        if not table_name:
            continue
        queries.append(
            {
                "object": object_name,
                "table": table_name,
                "operation": operation,
                "path": relative_to_root(root, path),
            }
        )
    return queries


def exposed_default_table_name(object_name: str) -> str:
    for suffix in ("Table", "Tables"):
        if object_name.endswith(suffix):
            return camel_to_snake(object_name[: -len(suffix)])
    return camel_to_snake(object_name)


def first_quoted_value(value: str) -> str:
    match = re.search(r"[\"']([^\"']+)[\"']", value)
    return match.group(1) if match else ""


def quoted_values(value: str) -> List[str]:
    return re.findall(r"[\"']([^\"']+)[\"']", value)


def inspect_mapper_statements(text: str) -> List[Dict[str, Any]]:
    statements = []
    for statement_type in ("select", "insert", "update", "delete"):
        pattern = re.compile(rf"<{statement_type}\b([^>]*)>(.*?)</{statement_type}>", re.IGNORECASE | re.DOTALL)
        for match in pattern.finditer(text):
            attrs, body = match.groups()
            statement_id = xml_attr(attrs, "id")
            sql = strip_xml_tags(body)
            statements.append(
                {
                    "id": statement_id,
                    "type": statement_type,
                    "tables": extract_sql_tables(sql),
                }
            )
    return statements


def inspect_annotation_sql_statements(text: str) -> List[Dict[str, Any]]:
    statements = []
    for statement_type in ("Select", "Insert", "Update", "Delete"):
        pattern = re.compile(rf"@{statement_type}\s*\(\s*\"([^\"]+)\"", re.DOTALL)
        for index, match in enumerate(pattern.finditer(text), start=1):
            sql = match.group(1)
            statements.append(
                {
                    "id": f"{statement_type.lower()}#{index}",
                    "type": statement_type.lower(),
                    "tables": extract_sql_tables(sql),
                }
            )
    return statements


def inspect_jdbc_sql(root: Path, scan_cache: Optional[WorkspaceScanCache] = None) -> List[Dict[str, Any]]:
    statements = []
    for path in persistence_source_files(root, scan_cache=scan_cache):
        text = read_small_text(path, scan_cache=scan_cache)
        if not likely_jdbc_sql_source(text):
            continue
        for index, sql in enumerate(extract_source_sql_literals(text), start=1):
            tables = extract_sql_tables(sql)
            if not tables:
                continue
            statements.append(
                {
                    "id": f"sql#{index}",
                    "type": sql_statement_type(sql),
                    "path": relative_to_root(root, path),
                    "tables": tables,
                    "columns": extract_sql_columns(sql),
                    "table_columns": extract_sql_table_columns(sql),
                }
            )
    return statements[:500]


def likely_jdbc_sql_source(text: str) -> bool:
    lowered = text.lower()
    return (
        "jdbctemplate" in lowered
        or "namedparameterjdbctemplate" in lowered
        or any(token in lowered for token in ("select ", "insert into", "update ", "delete from", "merge into"))
    )


def extract_source_sql_literals(text: str) -> List[str]:
    literals = []
    for match in re.finditer(r'"""(.*?)"""', text, re.DOTALL):
        value = match.group(1)
        if looks_like_sql(value):
            literals.append(value)
    for match in re.finditer(r'"((?:\\.|[^"\\])*)"', text, re.DOTALL):
        value = bytes(match.group(1), "utf-8").decode("unicode_escape", errors="ignore")
        if looks_like_sql(value):
            literals.append(value)
    return literals


def looks_like_sql(value: str) -> bool:
    return bool(re.search(r"\b(select|insert\s+into|update|delete\s+from|merge\s+into)\b", value, re.IGNORECASE))


def sql_statement_type(sql: str) -> str:
    match = re.search(r"\b(select|insert|update|delete|merge)\b", sql, re.IGNORECASE)
    return match.group(1).lower() if match else "sql"


def extract_sql_columns(sql: str) -> List[Dict[str, Any]]:
    columns: Dict[str, Dict[str, Any]] = {}
    for name in extract_select_columns(sql):
        columns.setdefault(name.lower(), {"name": name})
    for name in extract_insert_columns(sql):
        columns.setdefault(name.lower(), {"name": name})
    for name in extract_update_columns(sql):
        columns.setdefault(name.lower(), {"name": name})
    for name in extract_predicate_columns(sql):
        columns.setdefault(name.lower(), {"name": name})
    return list(columns.values())


def extract_sql_table_columns(sql: str) -> Dict[str, List[Dict[str, Any]]]:
    aliases = extract_sql_table_aliases(sql)
    if len(set(aliases.values())) <= 1:
        return {}

    table_columns: Dict[str, Dict[str, Dict[str, Any]]] = {}
    for alias, table in aliases.items():
        if alias == table.lower():
            continue
        for column in re.findall(rf"\b{re.escape(alias)}\.([A-Za-z_][A-Za-z0-9_]*)\b", sql, re.IGNORECASE):
            if column.lower() in SQL_NON_COLUMN_TOKENS:
                continue
            table_columns.setdefault(table, {}).setdefault(column.lower(), {"name": column})
    return {table: list(columns.values()) for table, columns in table_columns.items()}


def extract_sql_table_aliases(sql: str) -> Dict[str, str]:
    aliases: Dict[str, str] = {}
    stop_words = {
        "where",
        "with",
        "left",
        "right",
        "inner",
        "outer",
        "full",
        "cross",
        "join",
        "on",
        "group",
        "order",
        "option",
    }
    pattern = re.compile(
        r"\b(?:from|join)\s+([`\"\[\]A-Za-z0-9_.$]+)(?:\s+(?:as\s+)?([A-Za-z_][A-Za-z0-9_]*))?",
        re.IGNORECASE,
    )
    for match in pattern.finditer(sql):
        table = match.group(1).strip("`\"[]").rsplit(".", 1)[-1]
        if not valid_sql_table_candidate(table):
            continue
        alias = (match.group(2) or table).strip("`\"[]")
        if alias.lower() in stop_words:
            alias = table
        aliases[alias.lower()] = table
        aliases[table.lower()] = table
    return aliases


def extract_select_columns(sql: str) -> List[str]:
    columns = []
    for match in re.finditer(r"\bselect\b(.*?)\bfrom\b", sql, re.IGNORECASE | re.DOTALL):
        body = re.sub(r"\b(top|distinct)\b\s*(?:\([^)]*\)|:[A-Za-z0-9_]+|\d+)?", " ", match.group(1), flags=re.IGNORECASE)
        for item in split_sql_list(body):
            column = sql_column_name(item)
            if column:
                columns.append(column)
    return columns


def extract_insert_columns(sql: str) -> List[str]:
    columns = []
    for match in re.finditer(r"\binsert\s+into\s+[`\"A-Za-z0-9_.$]+\s*\(([^)]*)\)", sql, re.IGNORECASE | re.DOTALL):
        columns.extend(sql_column_name(item) for item in split_sql_list(match.group(1)) if sql_column_name(item))
    return columns


def extract_update_columns(sql: str) -> List[str]:
    columns = []
    for match in re.finditer(r"\bset\b(.*?)(?:\bwhere\b|$)", sql, re.IGNORECASE | re.DOTALL):
        for item in split_sql_list(match.group(1)):
            left = item.split("=", 1)[0]
            column = sql_column_name(left)
            if column:
                columns.append(column)
    return columns


def extract_predicate_columns(sql: str) -> List[str]:
    columns = []
    for match in re.finditer(
        r"(?:\bwhere\b|\band\b|\bor\b)\s+([`\"A-Za-z_][`\"A-Za-z0-9_.$]*)\s*(?:=|<>|!=|<|>|<=|>=|\bin\b|\blike\b)",
        sql,
        re.IGNORECASE,
    ):
        column = sql_column_name(match.group(1))
        if column:
            columns.append(column)
    return columns


def split_sql_list(value: str) -> List[str]:
    parts = []
    current = []
    depth = 0
    quote = ""
    for char in value:
        if quote:
            current.append(char)
            if char == quote:
                quote = ""
            continue
        if char in {"'", '"'}:
            quote = char
            current.append(char)
            continue
        if char == "(":
            depth += 1
        elif char == ")" and depth:
            depth -= 1
        if char == "," and depth == 0:
            parts.append("".join(current).strip())
            current = []
        else:
            current.append(char)
    if current:
        parts.append("".join(current).strip())
    return parts


def sql_column_name(value: str) -> str:
    text = re.sub(r"--.*", " ", value).strip()
    text = re.sub(r"\s+as\s+[`\"A-Za-z0-9_]+$", "", text, flags=re.IGNORECASE).strip()
    if not text or text == "*" or "(" in text:
        return ""
    token = text.split()[-1] if " " in text else text
    token = token.strip("`\"[]")
    if "." in token:
        token = token.rsplit(".", 1)[-1].strip("`\"[]")
    if not re.match(r"^[A-Za-z_][A-Za-z0-9_]*$", token):
        return ""
    if token.lower() in SQL_NON_COLUMN_TOKENS:
        return ""
    return token


def inspect_datasource_configs(root: Path, scan_cache: Optional[WorkspaceScanCache] = None) -> List[Dict[str, str]]:
    datasources = []
    for pattern in ("*.properties", "*.yml", "*.yaml"):
        for path in sorted(root.rglob(pattern)):
            if ignored_path(root, path) or not path.is_file():
                continue
            text = read_small_text(path, scan_cache=scan_cache)
            for key, value in config_property_entries(path, text):
                if "jdbc:" not in value.lower():
                    continue
                datasources.append(
                    {
                        "path": relative_to_root(root, path),
                        "key": key,
                        "url": value,
                    }
                )

    for path in sorted(root.rglob(".env*")):
        if ignored_path(root, path) or not path.is_file():
            continue
        if path.suffix in {".example", ".sample", ".template"}:
            continue
        text = read_small_text(path, scan_cache=scan_cache)
        for key, value in properties_property_entries(text):
            if not value:
                continue
            if not dotenv_value_is_datasource(key, value):
                continue
            datasources.append(
                {
                    "path": relative_to_root(root, path),
                    "key": key,
                    "url": value,
                }
            )

    return datasources[:200]


_DOTENV_NON_JDBC_SCHEMES: Tuple[str, ...] = (
    "postgres://",
    "postgresql://",
    "mysql://",
    "mariadb://",
    "mongodb://",
    "mongodb+srv://",
    "redis://",
    "rediss://",
    "sqlserver://",
    "oracle://",
    "cockroachdb://",
)


def dotenv_value_is_datasource(key: str, value: str) -> bool:
    lowered_value = value.lower()
    if "jdbc:" in lowered_value:
        return True
    lowered_key = key.lower()
    if (
        lowered_key == "database_url"
        or lowered_key.endswith("_database_url")
        or lowered_key.endswith("_db_url")
        or lowered_key == "db_url"
    ):
        return True
    return any(lowered_value.startswith(scheme) for scheme in _DOTENV_NON_JDBC_SCHEMES)


def inspect_sql_files(root: Path) -> List[Dict[str, Any]]:
    files: List[Dict[str, Any]] = []
    for path in sorted(root.rglob("*.sql")):
        if ignored_path(root, path):
            continue
        if not path.is_file():
            continue
        text = path.read_text(errors="ignore")[:20000].lower()
        has_ddl = bool(re.search(r"\b(create|alter|drop|truncate)\b", text))
        has_dml = bool(re.search(r"\b(insert|update|delete|merge)\b", text))
        destructive = bool(re.search(r"\b(drop|truncate|delete|update)\b", text))
        kind = "mixed" if has_ddl and has_dml else "ddl" if has_ddl else "dml" if has_dml else "unknown"
        files.append(
            {
                "path": relative_to_root(root, path),
                "kind": kind,
                "destructive": destructive,
                "tables": extract_sql_tables(text),
            }
        )
    return files[:100]


def java_class_name(text: str) -> str:
    match = re.search(r"\b(?:class|interface|data\s+class)\s+([A-Za-z0-9_]+)", text)
    return match.group(1) if match else ""


def java_or_kotlin_field_name(line: str) -> str:
    if "(" in line or line.startswith("@"):
        return ""
    java_match = re.search(
        r"\b(?:private|protected|public)\s+(?:final\s+)?[A-Za-z0-9_<>, ?]+\s+([A-Za-z0-9_]+)\s*(?:=|;)",
        line,
    )
    if java_match:
        return java_match.group(1)

    kotlin_match = re.search(r"\b(?:var|val)\s+([A-Za-z0-9_]+)\s*:", line)
    return kotlin_match.group(1) if kotlin_match else ""


def annotation_named_value(text: str, annotation: str) -> str:
    match = re.search(rf"@{annotation}\s*\(([^)]*)\)", text, re.DOTALL)
    if not match:
        return ""
    body = match.group(1)
    name_match = re.search(r"\bname\s*=\s*[\"']([^\"']+)[\"']", body)
    if name_match:
        return name_match.group(1)
    value_match = re.search(r"^[\"']([^\"']+)[\"']", body.strip())
    return value_match.group(1) if value_match else ""


def extract_sql_tables(sql: str) -> List[str]:
    tables = set()
    for match in re.finditer(r"\b(?:from|join|into|update)\s+([`\"A-Za-z0-9_.$]+)", sql, re.IGNORECASE):
        table = match.group(1).strip("`\"")
        if valid_sql_table_candidate(table):
            tables.add(table)
    return sorted(tables)


def valid_sql_table_candidate(table: str) -> bool:
    candidate = str(table or "").strip().strip("`\"[]").rsplit(".", 1)[-1]
    if not candidate:
        return False
    if "$" in candidate or "{" in candidate or "}" in candidate or "#" in candidate:
        return False
    if candidate.lower() in SQL_NON_COLUMN_TOKENS:
        return False
    return bool(re.match(r"^[A-Za-z_][A-Za-z0-9_]*$", candidate))


def strip_xml_tags(value: str) -> str:
    return re.sub(r"<[^>]+>", " ", value)


def xml_attr(text: str, name: str) -> str:
    match = re.search(rf"\b{name}\s*=\s*[\"']([^\"']+)[\"']", text)
    return match.group(1) if match else ""


def camel_to_snake(value: str) -> str:
    first = re.sub("(.)([A-Z][a-z]+)", r"\1_\2", value)
    return re.sub("([a-z0-9])([A-Z])", r"\1_\2", first).lower()


def ignored_path(root: Path, path: Path) -> bool:
    return any(part in IGNORED_INSPECT_DIRS for part in path.relative_to(root).parts)


def format_workspace_draft(draft: Dict[str, Any]) -> str:
    analysis = draft.get("analysis", {})
    lines = [
        f"workspace draft: {draft['workspace']}",
        f"root: {draft['root']}",
        f"config source: {draft['config_source']}",
        f"confidence: {analysis.get('confidence', 'unknown')}",
        "",
        "Infrastructure:",
    ]
    infrastructure = analysis.get("infrastructure", [])
    lines.extend(f"  - {item['type']}: {item['path']}" for item in infrastructure)
    if not infrastructure:
        lines.append("  - none detected")

    lines.append("")
    lines.append("Services:")
    services = analysis.get("services", [])
    lines.extend(f"  - {item['name']} ({item['type']})" for item in services)
    if not services:
        lines.append("  - none detected")

    lines.append("")
    lines.append("Database candidates:")
    databases = analysis.get("databases", [])
    lines.extend(f"  - {item['name']}" for item in databases)
    if not databases:
        lines.append("  - none detected")

    environment = analysis.get("environment", {})
    lines.append("")
    lines.append("Local environment plan:")
    requirements = environment.get("requirements", [])
    for item in requirements:
        status = item.get("status", "unknown")
        kind = item.get("kind", "dependency")
        technology = item.get("technology", "unknown")
        source = item.get("source", "")
        reason = item.get("reason", "")
        prefix = f"  - {status} {kind} {technology}"
        if item.get("service_name"):
            prefix += f" as {item['service_name']}"
        if item.get("port"):
            prefix += f" on :{item['port']}"
        if source:
            prefix += f" from {source}"
        if reason:
            prefix += f" ({reason})"
        lines.append(prefix)
    if not requirements:
        lines.append("  - none detected")

    env_overrides = environment.get("env", [])
    if env_overrides:
        lines.append("")
        lines.append("Environment overrides:")
        for item in env_overrides:
            lines.append(f"  - {item['service']}: {item['name']}={item['value']}")

    ddl_plan = environment.get("ddl", {})
    dml_plan = environment.get("dml", {})
    if ddl_plan or dml_plan:
        lines.append("")
        lines.append("DDL/DML plan:")
        if ddl_plan.get("tables"):
            engines = ", ".join(ddl_plan.get("engines", [])) or "default"
            lines.append(
                f"  - DDL: infer {ddl_plan['tables']} table(s) from {ddl_plan.get('source', 'persistence')} for {engines}"
            )
        else:
            lines.append("  - DDL: none inferred")
        if dml_plan.get("statements"):
            engines = ", ".join(dml_plan.get("engines", [])) or "default"
            lines.append(
                f"  - DML: generate {dml_plan['statements']} local seed statement(s) for {engines}"
            )
        else:
            lines.append("  - DML: no local seed data inferred")

    variables = environment.get("variables", [])
    if variables:
        lines.append("")
        lines.append("Environment variables:")
        for item in variables:
            default = f" default={item['default']}" if item.get("default") else ""
            lines.append(f"  - {item['name']} from {item['path']}{default}")

    profiles = environment.get("profiles", [])
    if profiles:
        lines.append("")
        lines.append("Spring profiles:")
        for item in profiles:
            lines.append(f"  - {item['profile']} from {item['path']} ({item['source']})")

    run_scripts = environment.get("run_scripts", [])
    if run_scripts:
        lines.append("")
        lines.append("Run scripts:")
        for item in run_scripts:
            lines.append(f"  - {item['path']} ({item['type']})")

    external = environment.get("external", [])
    if external:
        lines.append("")
        lines.append("External/mock candidates:")
        for item in external:
            target = item.get("value") or item.get("marker", "")
            lines.append(f"  - {item['path']}: {target} ({item['confidence']})")

    lines.append("")
    lines.append("Persistence model:")
    tables = analysis.get("persistence", {}).get("tables", [])
    for table in tables:
        columns = ", ".join(column["name"] for column in table.get("columns", [])[:8])
        suffix = f" columns={columns}" if columns else ""
        source = table.get("entity") or table.get("object") or table.get("path") or table.get("source", "")
        lines.append(f"  - {table['name']} ({source}){suffix}")
    if not tables:
        lines.append("  - none detected")

    lines.append("")
    lines.append("Data access:")
    repositories = analysis.get("persistence", {}).get("repositories", [])
    mappers = analysis.get("persistence", {}).get("mappers", [])
    exposed_queries = analysis.get("persistence", {}).get("exposed", {}).get("queries", [])
    jdbc_statements = analysis.get("persistence", {}).get("jdbc", [])
    for repository in repositories:
        target = repository.get("table") or repository.get("entity") or "unknown"
        lines.append(f"  - repository {repository['name']} -> {target}")
    for mapper in mappers:
        namespace = mapper.get("namespace") or mapper["path"]
        statement_count = len(mapper.get("statements", []))
        tables_text = ", ".join(mapper.get("tables", [])) or "unknown tables"
        lines.append(f"  - mapper {namespace}: {statement_count} statement(s), tables={tables_text}")
    for query in exposed_queries:
        lines.append(f"  - exposed {query['object']}.{query['operation']} -> {query['table']}")
    for statement in jdbc_statements[:30]:
        tables_text = ", ".join(statement.get("tables", [])) or "unknown tables"
        lines.append(f"  - jdbc {statement['type']} from {statement['path']}: tables={tables_text}")
    if not repositories and not mappers and not exposed_queries and not jdbc_statements:
        lines.append("  - none detected")

    datasources = analysis.get("persistence", {}).get("datasources", [])
    if datasources:
        lines.append("")
        lines.append("Datasource config:")
        lines.extend(f"  - {item['path']}: {item['url']}" for item in datasources)

    sql_evidence = analysis.get("sql_evidence", [])
    if sql_evidence:
        lines.append("")
        lines.append("SQL file evidence (secondary):")
        lines.extend(f"  - {item['path']} ({item['kind']})" for item in sql_evidence)

    warnings = analysis.get("warnings", [])
    if warnings:
        lines.append("")
        lines.append("Warnings:")
        lines.extend(f"  - {warning}" for warning in warnings)

    lines.append("")
    lines.append("Review the draft, then Apply to register this workspace.")
    return "\n".join(lines) + "\n"


