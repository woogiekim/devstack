    function serviceStateKind(state, health) {{
      if (state === "checking") {{
        return "running";
      }}
      if (state === "status unavailable") {{
        return "unavailable";
      }}
      if (state === "external") {{
        return "external";
      }}
      if (health === "ok" || state === "ready" || state === "docker:up") {{
        return "up";
      }}
      if (state === "stopped" || state === "docker:down" || state === "docker:created" || state === "docker:exited") {{
        return "stopped";
      }}
      if (state === "unhealthy") {{
        return "unhealthy";
      }}
      if (state === "failed" || state.includes("dead")) {{
        return "failed";
      }}
      if (state === "running" || state === "docker") {{
        return "running";
      }}
      return "idle";
    }}

    function serviceStateLabel(state, health) {{
      if (state === "checking" || state === "status unavailable") {{
        return state;
      }}
      if (state === "docker:up") {{
        return "infra up";
      }}
      if (state === "external") {{
        return "unmanaged";
      }}
      if (health === "ok" && state !== "external") {{
        return "healthy";
      }}
      return state;
    }}

    function serviceProgressTarget(action) {{
      if (action === "down") {{
        return "stopped";
      }}
      if (["up", "restart", "recover"].includes(action)) {{
        return "up";
      }}
      return "";
    }}

    function isLifecycleAction(action) {{
      return ["up", "down", "restart", "recover"].includes(action);
    }}

    function serviceProgressTargetReached(targetKind, currentKind) {{
      if (!targetKind) {{
        return true;
      }}
      if (currentKind === "failed" || currentKind === "unhealthy") {{
        return true;
      }}
      if (targetKind === "up") {{
        return currentKind === "up" || currentKind === "external";
      }}
      if (targetKind === "stopped") {{
        return currentKind === "stopped";
      }}
      return currentKind === targetKind;
    }}

    function setServiceCardState(name, state, health, options = {{}}) {{
      const card = serviceCard(name);
      if (!card) {{
        return;
      }}
      const resolveProgress = options.resolveProgress !== false;
      const kind = serviceStateKind(state, health);
      card.dataset.stateKind = kind;
      const pending = card.classList.contains("is-pending");
      const targetKind = card.dataset.progressTargetKind || "";
      if (pending && !resolveProgress) {{
        return;
      }}
      if (pending && targetKind && !serviceProgressTargetReached(targetKind, kind)) {{
        return;
      }}
      card.classList.remove("status-up", "status-stopped", "status-failed", "status-unhealthy", "status-external", "status-running", "status-unavailable");
      if (kind !== "idle") {{
        card.classList.add("status-" + kind);
      }}
	      const stateLabel = card.querySelector("[data-service-state]");
	      const keepProgressLabel = card.classList.contains("is-pending") && card.dataset.progressClearOnStatus !== "1";
	      if (stateLabel && !keepProgressLabel) {{
	        stateLabel.textContent = serviceStateLabel(state, health);
	      }}
      if (card.dataset.progressClearOnStatus === "1") {{
        clearServiceCardProgress(name);
      }}
      updateSelectedServiceDetail();
      updateServiceStateOverview();
      updateDoctorTargets();
    }}

    function serviceCard(name) {{
      return serviceCards.find(item => item.dataset.serviceName === name);
    }}

    function setServiceCardProgress(name, label, clearOnStatus = true, targetKind = "") {{
      const card = serviceCard(name);
      if (!card) {{
        return;
      }}
      card.classList.add("is-pending");
      card.setAttribute("aria-busy", "true");
      card.dataset.progressClearOnStatus = clearOnStatus ? "1" : "0";
      if (targetKind) {{
        card.dataset.progressTargetKind = targetKind;
      }} else {{
        delete card.dataset.progressTargetKind;
      }}
      const stateLabel = card.querySelector("[data-service-state]");
      if (stateLabel) {{
        stateLabel.textContent = label;
      }}
      updateSelectedServiceDetail();
      activeProgressServices.add(name);
    }}

    function clearServiceCardProgress(name) {{
      const card = serviceCard(name);
      if (!card) {{
        return;
      }}
      card.classList.remove("is-pending");
      card.setAttribute("aria-busy", "false");
      delete card.dataset.progressClearOnStatus;
      delete card.dataset.progressTargetKind;
      activeProgressServices.delete(name);
      updateSelectedServiceDetail();
    }}

    function clearActiveServiceProgress() {{
      Array.from(activeProgressServices).forEach(name => clearServiceCardProgress(name));
    }}

    function markServiceCardFailed(name, label = "failed") {{
      const card = serviceCard(name);
      if (!card) {{
        return;
      }}
      card.dataset.stateKind = "failed";
      card.classList.remove("status-up", "status-stopped", "status-external", "status-running", "status-unhealthy", "status-unavailable");
      card.classList.add("status-failed");
      const stateLabel = card.querySelector("[data-service-state]");
      if (stateLabel) {{
        stateLabel.textContent = label;
      }}
      clearServiceCardProgress(name);
      updateSelectedServiceDetail();
      updateServiceStateOverview();
      updateDoctorTargets();
    }}

    function markServiceCardUnavailable(name, label = "status unavailable", options = {{}}) {{
      const card = serviceCard(name);
      if (!card) {{
        return;
      }}
      if (options.preserveProgress && activeProgressServices.has(name)) {{
        return;
      }}
      card.dataset.stateKind = "unavailable";
      card.classList.remove("status-up", "status-stopped", "status-failed", "status-unhealthy", "status-external", "status-running", "is-pending");
      card.classList.add("status-unavailable");
      card.setAttribute("aria-busy", "false");
      const stateLabel = card.querySelector("[data-service-state]");
      if (stateLabel) {{
        stateLabel.textContent = label;
      }}
      activeProgressServices.delete(name);
      updateSelectedServiceDetail();
      updateServiceStateOverview();
    }}

    function setAllServiceCardsUnavailable(label = "status unavailable", options = {{}}) {{
      serviceCards.forEach(card => markServiceCardUnavailable(card.dataset.serviceName, label, options));
      if (serviceBoardStatus) {{
        serviceBoardStatus.textContent = label;
      }}
      updateServiceStateOverview();
      updateDoctorTargets();
    }}

    async function startDoctorWorkflow() {{
      if (!workspaceReady || !startDoctorWorkflowButton) {{
        return;
      }}
      const selectedScope = doctorScope();
      const selectedServices = doctorSelectedServices();
      if (selectedScope === "failed" && selectedServices.length === 0) {{
        setDoctorStatus("select target", "fail");
        if (doctorOutcome) {{
          doctorOutcome.textContent = "No failed service selected";
        }}
        if (doctorRecommendation) {{
          doctorRecommendation.textContent = "Select at least one failed service, or switch the scope to all services.";
        }}
        if (doctorDetailsButton) {{
          doctorDetailsButton.hidden = true;
          doctorDetailsButton.disabled = true;
        }}
        return;
      }}
      const params = new URLSearchParams({{
        action: "doctor",
        workspace: workspace.value,
        ai_agent: activeAiAgent,
        doctor_scope: selectedScope,
        doctor_services: selectedServices.join(",")
      }});
      stopDoctorStatusPolling();
      doctorCurrentRunId = "";
      setConsoleMode("doctor", false);
      command.textContent = "$ " + selectedAiAgentLabel() + " doctor";
      resetOutput("Preparing doctor workflow...\\n");
      setDoctorTechnicalDetails({{ output: "Preparing doctor workflow...\\n" }});
      outputMode = "doctor";
      setDoctorStatus("preparing");
      if (doctorOutcome) {{
        doctorOutcome.textContent = "Diagnosis starting";
      }}
      if (doctorRecommendation) {{
        doctorRecommendation.textContent = selectedAiAgentLabel() + " is receiving the doctor prompt.";
      }}
      startDoctorWorkflowButton.disabled = true;
      doctorDetailsButton.hidden = false;
      doctorDetailsButton.disabled = false;
      try {{
        const response = await fetch("/api/run", {{
          method: "POST",
          headers: {{ "Content-Type": "application/x-www-form-urlencoded" }},
          body: params.toString()
        }});
        const data = await response.json();
        if (!data.ok) {{
          resetOutput(data.output || "doctor workflow failed");
          setDoctorTechnicalDetails(data);
          setDoctorStatus("failed", "fail");
          if (doctorOutcome) {{
            doctorOutcome.textContent = "Diagnosis failed to start";
          }}
          if (doctorRecommendation) {{
            doctorRecommendation.textContent = "Inspect the technical details below for the failure returned by the selected host.";
          }}
          return;
        }}
        resetOutput(data.output || "");
        setDoctorTechnicalDetails(data);
        setDoctorStatus(data.status || "doctor spawned", data.status_class || "running");
        if (doctorOutcome) {{
          doctorOutcome.textContent = "Diagnosis spawned";
        }}
        if (doctorRecommendation) {{
          doctorRecommendation.textContent = data.log_path
            ? "Waiting for running status from the selected host. Details include prompt and log paths."
            : "Monitor the selected host for diagnosis and recovery progress.";
        }}
        startDoctorStatusPolling(data.doctor_run_id || "");
      }} catch (error) {{
        resetOutput(String(error));
        setDoctorTechnicalDetails({{ output: String(error) }});
        setDoctorStatus("failed", "fail");
        if (doctorOutcome) {{
          doctorOutcome.textContent = "Diagnosis request failed";
        }}
        if (doctorRecommendation) {{
          doctorRecommendation.textContent = "Inspect the technical details below for the browser-side error.";
        }}
      }} finally {{
        updateDoctorTargets();
      }}
    }}

    function setAllServiceCardsChecking() {{
      serviceCards.forEach(card => setServiceCardState(card.dataset.serviceName, "checking", "-"));
      if (serviceBoardStatus) {{
        serviceBoardStatus.textContent = "checking status";
      }}
      updateServiceStateOverview();
