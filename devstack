            button.disabled = activeActionServices.has(selectedService);
          }} else {{
            button.disabled = isBusy;
          }}
        }}
      }});
      bindWorkspaceButton.disabled = isBusy;
      browseWorkspaceButton.disabled = isBusy;
      openAdvancedButton.disabled = isBusy;
      backAdvancedButton.disabled = isBusy;
      workspaceRoot.disabled = isBusy;
      followLogsButton.disabled = !selectedService || liveLogs !== null;
      stopLogsFollowButton.disabled = liveLogs === null;
      clearLogsButton.disabled = !selectedService || liveLogs !== null;
