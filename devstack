    if engine in {"mysql", "mariadb"}:
        return [f"devstack-{label}-data:/var/lib/mysql"]
    if engine == "mssql":
        return [f"devstack-{label}-data:/var/opt/mssql"]
    return []


def managed_data_volume_exists(engine: str, label: str) -> bool:
    """Return True when the managed named data volume for `(engine, label)`
    already exists in the local Docker engine.

    Drives the stale-volume warning in ``Workspace.initialize_managed_infra``:
    when a MySQL/PostgreSQL data volume already contains an initialized
    database from a prior run, the image silently skips
    ``/docker-entrypoint-initdb.d/`` on the next ``up`` and the bind-mounted
    seed scripts never execute. The user must be told this is happening.

    Defensive contract:

    - Engines outside ``MANAGED_DATABASES`` have no managed data volume —
      return ``False`` without shelling out (cheap, deterministic).
    - Any subprocess failure (docker missing, daemon down, OS error) is
      swallowed and ``False`` is returned. The caller treats absence as
      "no warning needed" — the worst-case outcome is a missed warning, never
      a broken ``devstack up``.
    """
    if engine not in MANAGED_DATABASES:
        return False
    volume_name = f"devstack-{label}-data"
    try:
        result = subprocess.run(
            ["docker", "volume", "inspect", volume_name],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
    except (FileNotFoundError, OSError):
        return False
    return result.returncode == 0


def database_driver_class(engine: str) -> str:
