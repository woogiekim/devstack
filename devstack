# ``.devstack.json`` preferred, ``.devstack.json`` accepted as fallback at
# each lookup site. CONFIG_NAME below holds the new canonical name for help
# text and "write a new manifest" paths; resolve_manifest_path(root)
# implements the per-project lookup.

CONFIG_NAME = ".devstack.json"
LEGACY_CONFIG_NAME = ".ccstack.json"


def resolve_manifest_path(root: Path) -> Optional[Path]:
    """Return the first manifest file present at ``root``, or None.

    Looks for ``.devstack.json`` first, then ``.devstack.json``.
    """
    root_p = Path(root)
    new_candidate = root_p / CONFIG_NAME
    if new_candidate.exists():
        return new_candidate
    legacy_candidate = root_p / LEGACY_CONFIG_NAME
    if legacy_candidate.exists():
        return legacy_candidate
    return None


