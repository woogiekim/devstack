        return dispatch(workspace, args)
    except DevstackError as error:
        print(f"devstack: {error}", file=sys.stderr)
        return 1


def dispatch(workspace: "Workspace", args: argparse.Namespace) -> int:
    command = args.command

    if command in {"up", "light"}:
        use_light = args.light if command == "up" else True
        target = f"{args.target}-light" if use_light else args.target
        services = workspace.resolve_target(target, only=args.only)
        try:
            workspace.start_many(
                services,
                include_deps=not args.no_deps,
                skip_recoverable=bool(getattr(args, "skip_recoverable", False)),
            )
        except DevstackError:
            workspace.print_status(services)
            raise
        workspace.print_status(services)
        return 0

    if command == "down":
        services = workspace.resolve_target(args.target)
        workspace.stop_many(services)
        return 0

    if command == "start":
        workspace.start_service(args.service, include_deps=not args.no_deps)
        workspace.print_status([args.service])
        return 0

    if command == "stop":
        workspace.stop_service(args.service, allow_port_owner=True)
        return 0

    if command == "restart":
        workspace.stop_service(args.service, allow_port_owner=True)
        workspace.start_service(args.service, include_deps=not args.no_deps)
        workspace.print_status([args.service])
        return 0

    if command == "logs":
        workspace.show_logs(args.service, follow=args.follow, lines=args.lines)
        return 0

    if command == "clear-logs":
        log_path = workspace.clear_logs(args.service)
        print(f"cleared log: {log_path}")
        return 0

    if command == "recover":
        print(workspace.recover_service(args.service, mode=args.mode, target=args.target, confirm=args.confirm))
        return 0

    if command in {"status", "ps"}:
        services = workspace.resolve_target(args.target)
        workspace.print_status(services)
        return 0

    if command == "ui":
        return run_ui(workspace, host=args.host, port=args.port, open_browser=not args.no_open)

    raise DevstackError(f"unsupported command: {command}")


