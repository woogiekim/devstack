def apply_auto_run_bundles(profiles: Dict[str, Any], services: Dict[str, Any]) -> List[str]:
    bundles = auto_run_bundle_candidates(services)
    default_services = set(default_profile_services(profiles))
    managed_bundle_names = {"fixity", "integration", "proxy"}
    for name in list(profiles.keys()):
        if is_legacy_auto_run_bundle_name(name):
            profiles.pop(name, None)

    added: List[str] = []
    for name, bundle_services in sorted(bundles.items()):
        if name in services or looks_execution_task_name(name):
            continue
        if len(bundle_services) < 2:
            continue
        if set(bundle_services) == default_services:
            continue
        if name in profiles and name not in managed_bundle_names:
            continue
        previous = profile_service_names(profiles.get(name))
        profiles[name] = {"services": bundle_services}
        if previous != bundle_services:
            added.append(name)
    return added


def profile_service_names(profile: Any) -> List[str]:
    if isinstance(profile, list):
        return [str(item) for item in profile]
    if isinstance(profile, dict) and isinstance(profile.get("services"), list):
        return [str(item) for item in profile["services"]]
    return []


def is_legacy_auto_run_bundle_name(name: str) -> bool:
    return (
        name in {"contents", "infra"}
        or name.startswith("proxy.")
        or name.startswith("fixity-")
    )


def auto_run_bundle_candidates(services: Dict[str, Any]) -> Dict[str, List[str]]:
    grouped: Dict[str, List[str]] = {}
    for service_name, service in services.items():
        if not isinstance(service, dict):
            continue
        for bundle_name in auto_run_bundle_names(service_name, service):
            grouped.setdefault(bundle_name, []).append(service_name)

    return {
        name: sorted(unique(names))
        for name, names in grouped.items()
        if len(unique(names)) >= 2
    }


def auto_run_bundle_names(service_name: str, service: Dict[str, Any]) -> List[str]:
    module = str(service.get("module") or "")
    parts = [part for part in module.split("/") if part] if module else service_name.split(".")
    names: List[str] = []

    if is_managed_infra_service_name(service_name):
        names.append("integration")

    # NB: this dotted-path check accepts both ``ccstack.infra.*`` (legacy
    # alias, Shim 5) and ``devstack.infra.*`` (canonical) when the module
    # name was supplied as the slash-style fallback. Service-name based
    # detection above already covers the dotted form.
    if (
        len(parts) >= 2
        and parts[0] in ("devstack", "ccstack")
        and parts[1] == "infra"
    ):
        names.append("integration")

    if service.get("type") == "compose":
        names.append("integration")

    if len(parts) >= 3 and parts[0] == "apps" and parts[1] == "proxy":
        names.append("proxy")

    if len(parts) >= 2 and parts[0] == "apps" and parts[1].startswith("fixity-"):
        names.append("fixity")

    return unique(names)


def apply_service_environment_overrides(services: Dict[str, Any], overrides: List[Dict[str, str]]) -> None:
    stale_h2_services = {
        service_name
        for service_name, service in services.items()
        if isinstance(service, dict)
        and isinstance(service.get("env"), dict)
        and service_env_contains_h2_datasource(service["env"])
    }
    managed_routing_ports = managed_routing_port_set(services)
    for item in overrides:
        service_name = item.get("service", "")
        service = services.get(service_name)
        if not isinstance(service, dict):
            continue
        env = service.setdefault("env", {})
        if isinstance(env, dict):
            name = item["name"]
            value = item["value"]
            if should_replace_environment_override(
                env,
                item,
                service_name in stale_h2_services,
                managed_routing_ports=managed_routing_ports,
            ):
                env[name] = value
            else:
                env.setdefault(name, value)


def should_replace_environment_override(
    env: Dict[str, Any],
    item: Dict[str, str],
    had_stale_h2_datasource: bool = False,
    managed_routing_ports: Optional[Set[int]] = None,
) -> bool:
    name = item.get("name", "")
    if name not in env:
        return True

    current = str(env.get(name, ""))
    if is_stale_h2_datasource_value(current):
        return True

    source = str(item.get("source", ""))
    if source.startswith("database-") and had_stale_h2_datasource:
        return True
    if source.startswith("database-") and name.endswith("DRIVER_CLASS_NAME") and is_legacy_mysql_driver_value(current):
        return True

    # Staleness-aware replacement of devstack-managed routing overrides.
    #
    # devstack generates localhost routing values (``http://localhost:{port}`` or
    # ``localhost:{port}``) for external-HTTP candidates and mock/registry
    # targets. When ports are reshuffled (e.g. ``ensure_unique_gradle_service_ports``
    # reassigns a service's port), a previously persisted value goes stale and the
    # default ``env.setdefault`` would keep it. We replace such stale values while
    # preserving genuinely user-set values that do not look devstack-generated.
    #
    # Managed-ness is decided data-first: an override whose ``source`` marks it as
    # a devstack routing override (``external-http*``) exists only because devstack
    # manages the key, so any persisted localhost value is fair game. For legacy
    # manifests that predate the source marker, we fall back to a value-shape check
    # gated on the managed-port set so a developer's own localhost stub on a
    # non-managed port is never clobbered.
    new_value = str(item.get("value", ""))
    if new_value and new_value != current:
        if is_devstack_routing_override_source(source):
            if parse_localhost_routing_endpoint(current) is not None:
                return True
        elif is_devstack_managed_localhost_value(current, managed_routing_ports):
            return True

    return False


def is_devstack_routing_override_source(source: str) -> bool:
    """True when an override's ``source`` marks it as a devstack routing override.

    External-HTTP candidate overrides carry ``source = "external-http-{index}"``
    (see ``environment_override_entries`` callers). That source only exists
    because devstack manages the routing key, so the override is authoritative:
    any persisted localhost value for the key is a prior devstack generation and
    may be replaced when it differs from the freshly computed value.
    """
    return str(source).startswith("external-http")


def parse_localhost_routing_endpoint(value: str) -> Optional[Tuple[str, Optional[int]]]:
    """Parse a value as a localhost routing endpoint, or return None.

    Recognizes devstack-generated value shapes:
      * full URLs whose host is ``localhost`` / ``127.0.0.1`` / ``0.0.0.0``
        (e.g. ``http://localhost:8087/path``), and
      * bare ``host:port`` forms with a localhost host (e.g. ``localhost:1080``).

    Returns ``(host, port)`` (port may be ``None`` for a hostless/bare host) when
    the value looks like a localhost endpoint, otherwise ``None``. Values with a
    non-localhost host (custom hostnames, real domains) return ``None`` so they
    are treated as user-owned and preserved.
    """
    text = str(value).strip()
    if not text:
        return None

    localhost_hosts = {"localhost", "127.0.0.1", "0.0.0.0"}

    parsed = urllib.parse.urlparse(text)
    if parsed.scheme and parsed.netloc:
        host = (parsed.hostname or "").lower()
        if host in localhost_hosts:
            return host, (int(parsed.port) if parsed.port else None)
        return None

    # Bare ``host:port`` (no scheme). Parse with a synthetic scheme so urllib
    # splits host/port consistently and rejects malformed inputs.
    bare = urllib.parse.urlparse(f"//{text}")
    host = (bare.hostname or "").lower()
    if host in localhost_hosts:
        try:
            port = int(bare.port) if bare.port else None
        except ValueError:
            port = None
        return host, port
    return None


def is_devstack_managed_localhost_value(value: str, managed_routing_ports: Optional[Set[int]]) -> bool:
    """Value-shape fallback for legacy manifests predating the source marker.

    A persisted value is treated as devstack-managed only when it parses as a
    localhost routing endpoint AND its port belongs to the managed routing port
    set (mockserver port(s) plus current runtime service ports). This keeps a
    developer's hand-set localhost stub on a non-managed port (e.g.
    ``http://localhost:9999``) from being clobbered, while still catching stale
    values whose port was reassigned among managed routing targets.
    """
    endpoint = parse_localhost_routing_endpoint(value)
    if endpoint is None:
        return False
    _, port = endpoint
    if port is None:
        return False
    ports = managed_routing_ports or set()
    return port in ports


def managed_routing_port_set(services: Dict[str, Any]) -> Set[int]:
    """All ports devstack may have generated for localhost routing targets.

    Union of:
      * the managed mockserver port(s) declared by infra services (falling back
        to the canonical default ``1080`` so legacy manifests without an explicit
        mock service are still covered), and
      * every runtime service port in the manifest (sibling routing targets).

    A persisted localhost value whose port is in this set is a prior devstack
    routing generation: either it still points at a managed target or its target
    was reassigned and the value is now stale.
    """
    ports: Set[int] = {1080}
    for name, service in services.items():
        if not isinstance(service, dict):
            continue
        port = service.get("port")
        try:
            port_int = int(port) if port else 0
        except (TypeError, ValueError):
            continue
        if port_int > 0:
            ports.add(port_int)
        container_port = service.get("container_port")
        try:
            container_int = int(container_port) if container_port else 0
        except (TypeError, ValueError):
            container_int = 0
        if container_int > 0 and is_managed_infra_service_name(str(name)):
            ports.add(container_int)
    return ports


def is_stale_h2_datasource_value(value: str) -> bool:
    lowered = value.lower()
    return lowered.startswith("jdbc:h2:") or value == "org.h2.Driver"


def is_legacy_mysql_driver_value(value: str) -> bool:
    return value == "com.mysql.jdbc.Driver"


def service_env_contains_h2_datasource(env: Dict[str, Any]) -> bool:
    return any(
        ("DATASOURCE" in str(key).upper() or str(key).upper().startswith("DB_"))
        and is_stale_h2_datasource_value(str(value))
        for key, value in env.items()
    )


def apply_service_argument_overrides(services: Dict[str, Any], overrides: List[Dict[str, str]]) -> None:
    for item in overrides:
        service = services.get(item.get("service", ""))
        if not isinstance(service, dict):
            continue
        args = service.setdefault("args", [])
        if not isinstance(args, list):
            args = [str(args)]
            service["args"] = args
        value = str(item.get("value", ""))
        if value and value not in args:
            args.append(value)


def apply_runtime_dependencies(services: Dict[str, Any], dependencies: List[str]) -> None:
    if not dependencies:
        return
    for name, service in services.items():
        if name in dependencies or not isinstance(service, dict):
            continue
        if service.get("type") not in {"gradle", "command"}:
            continue
        depends_on = service.setdefault("depends_on", [])
        if not isinstance(depends_on, list):
            depends_on = [str(depends_on)]
            service["depends_on"] = depends_on
        for dependency in dependencies:
            if dependency not in depends_on:
                depends_on.append(dependency)


def gradle_service_paths_requiring_spring_boot_plugin(services: Dict[str, Any]) -> List[str]:
    modules: List[str] = []
    for service in services.values():
        if not isinstance(service, dict) or service.get("type") != "gradle":
            continue
        if not service.get("apply_spring_boot_plugin"):
            continue
        task = str(service.get("task") or "")
        path = gradle_project_path_from_task(task)
        if path:
            modules.append(path)
    return sorted(unique(modules))


def gradle_project_path_from_task(task: str) -> str:
    if not task.startswith(":"):
        return ""
    parts = [part for part in task.split(":") if part]
    if parts and parts[-1] in {"bootRun", "run"}:
        parts = parts[:-1]
    return ":" + ":".join(parts) if parts else ""


def write_local_schema_files(name: str, persistence: Dict[str, Any]) -> Dict[str, Path]:
    tables = persistence.get("tables", []) if isinstance(persistence, dict) else []
    if not tables:
        return {}
    tables = merge_duplicate_schema_tables(tables)

    schema_paths = {
        "h2": managed_schema_path(name, "h2"),
        "mysql": managed_schema_path(name, "mysql"),
        "mssql": managed_schema_path(name, "mssql"),
        "postgresql": managed_schema_path(name, "postgresql"),
    }
    for engine, path in schema_paths.items():
        text = render_local_schema_sql(tables, engine)
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(text, encoding="utf-8")
        if engine == "h2":
            versioned_path = versioned_sql_path(path, text)
            versioned_path.write_text(text, encoding="utf-8")
            schema_paths[engine] = versioned_path
    return schema_paths


def write_local_dml_files(
    name: str,
    persistence: Dict[str, Any],
    overrides: Optional[Dict[str, Any]] = None,
) -> Dict[str, Path]:
    tables = persistence.get("tables", []) if isinstance(persistence, dict) else []
    if not tables:
        return {}
    tables = merge_duplicate_schema_tables(tables)

    dml_paths = {
        "h2": managed_dml_path(name, "h2"),
        "mysql": managed_dml_path(name, "mysql"),
        "mssql": managed_dml_path(name, "mssql"),
        "postgresql": managed_dml_path(name, "postgresql"),
    }
    written: Dict[str, Path] = {}
    for engine, path in dml_paths.items():
        text = render_local_dml_sql(tables, engine, overrides=overrides)
        if not text:
            continue
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(text, encoding="utf-8")
        if engine == "h2":
            path = versioned_sql_path(path, text)
            path.write_text(text, encoding="utf-8")
        written[engine] = path
    return written


def merge_duplicate_schema_tables(tables: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    merged: Dict[str, Dict[str, Any]] = {}
    order: List[str] = []
    for table in tables:
        if not isinstance(table, dict):
            continue
        table_name = str(table.get("name", "")).strip()
        if not table_name:
            continue
        key = table_name.lower()
        if key not in merged:
            merged[key] = dict(table)
            merged[key]["columns"] = []
            order.append(key)
        target = merged[key]
        if table_name != target.get("name") and has_mixed_case_identifier(table_name):
            target["name"] = table_name
        merge_table_columns(target, table.get("columns", []))
    return [merged[key] for key in order]


def has_mixed_case_identifier(value: str) -> bool:
    return any(char.islower() for char in value) and any(char.isupper() for char in value)


def attach_schema_files_to_generated_databases(
    generated: List[Dict[str, Any]],
    schema_files: Dict[str, Path],
    dml_files: Optional[Dict[str, Path]] = None,
) -> None:
    dml_files = dml_files or {}
    for requirement in generated:
        engine = str(requirement.get("technology", ""))
        script_path = schema_files.get(engine)
        volumes = requirement.setdefault("volumes", [])
        if script_path:
            target = (
                "/devstack-init/010-devstack-local-schema.sql"
                if engine == "mssql"
                else "/docker-entrypoint-initdb.d/010-devstack-local-schema.sql"
            )
            # Set init_schema for all database types so existing_managed_infra_requirement
            # can reconstruct the bind-mount on re-apply (GitHub issue #2).
            # MySQL/PostgreSQL: named volumes and initdb.d are mutually exclusive at first
            # start — if a named data volume already exists the init script is silently
            # skipped by the container runtime; this field still must be populated so the
            # bind-mount entry survives across repeated `devstack apply` calls.
            requirement["init_schema"] = target
            bind = f"{script_path}:{target}:ro"
            if bind not in volumes:
                volumes.append(bind)
        dml_path = dml_files.get(engine)
        if dml_path:
            target = (
                "/devstack-init/020-devstack-local-dml.sql"
                if engine == "mssql"
                else "/docker-entrypoint-initdb.d/020-devstack-local-dml.sql"
            )
            # Set init_dml for all database types (same reasoning as init_schema above).
            requirement["init_dml"] = target
            bind = f"{dml_path}:{target}:ro"
            if bind not in volumes:
                volumes.append(bind)


def attach_mockserver_expectations(generated: List[Dict[str, Any]], expectation_path: Path) -> None:
    for requirement in generated:
        if requirement.get("technology") != "mockserver":
            continue

        environment = requirement.setdefault("environment", {})
        environment["MOCKSERVER_INITIALIZATION_JSON_PATH"] = "/config/mockserver-expectations.json"

        volumes = requirement.setdefault("volumes", [])
        bind = f"{expectation_path}:/config/mockserver-expectations.json:ro"
        if bind not in volumes:
            volumes.append(bind)


def write_mockserver_expectations(
    path: Path,
    candidates: List[Dict[str, str]],
    overrides: Optional[Dict[str, Any]] = None,
) -> Path:
    """Materialize the mockserver expectations JSON for a workspace.

    Domain-agnostic engine: value-path expectations come from each candidate's
    URL path. Optional ``overrides["mockserver"]`` enables a workspace to
    inject keyword-triggered route lists (``key_route_triggers``) and named
    response envelopes (``responses`` + ``route_responses``). The trailing
    entry is always ``mockserver_catchall_expectation()`` so an unmatched
    request returns a generic 200 envelope instead of mockserver's default
    404. Mockserver evaluates expectations in registration order; the
    trailing entry only matches when every prior expectation missed.

    Every emitted expectation (specific AND catch-all) carries the
    ``X-Devstack-Mock: true`` and ``X-Devstack-Routed-From: <host>`` response
    headers so callers and tests can assert post-hoc whether a call hit the
    managed mock rather than a real sibling service. The routed-from value
    is the original endpoint's hostname for specific expectations and the
    sentinel ``unmatched`` for the catch-all. Status-counter tooling can
    grep for the literal header pair as a machine-readable marker.
    """
    path.parent.mkdir(parents=True, exist_ok=True)
    overrides = overrides or {}
    expectations = [
        mockserver_json_expectation(
            route,
            mockserver_dummy_response_for_route(route, overrides),
            routed_from=host,
        )
        for route, host in mockserver_dummy_routes_with_hosts(candidates, overrides)
    ]
    expectations.append(mockserver_catchall_expectation())
    path.write_text(json.dumps(expectations, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
    return path


def mockserver_catchall_expectation() -> Dict[str, Any]:
    """Domain-agnostic 200 fallback used when no specific expectation matches.

    Replaces the previous samplegoods-only hardcoded behavior: any GET/POST/PUT/
    DELETE that fell through to mockserver without a registered route used to
    return 404, which surfaced as opaque integration failures in workspaces
    without keyword overrides.

    Carries ``X-Devstack-Mock: true`` and ``X-Devstack-Routed-From: unmatched``
    so a caller or test can distinguish a genuine sibling-service 200 from a
    mockserver catch-all 200 by inspecting response headers alone. The
    ``unmatched`` sentinel is deliberately distinct from ``unknown`` so the
    follow-up status-counter task can separate "no specific rule matched"
    from "host attribution unavailable at injection time".
    """
    body = {
        "status": 200,
        "message": "devstack local dummy",
        "data": {"items": [], "totalElements": 0, "content": []},
    }
    return {
        "httpRequest": {
            "path": "/.*",
        },
        "httpResponse": {
            "statusCode": 200,
            "headers": [
                {"name": "Content-Type", "values": ["application/json"]},
                {"name": "X-Devstack-Mock", "values": ["true"]},
                {"name": "X-Devstack-Routed-From", "values": ["unmatched"]},
            ],
            "body": json.dumps(body, ensure_ascii=False),
        },
        "priority": -100,
    }


def mockserver_dummy_routes(
    candidates: List[Dict[str, str]],
    overrides: Optional[Dict[str, Any]] = None,
) -> List[str]:
    """Build the route list for mockserver expectations.

    Generic mechanism: every candidate URL's path becomes a route. The
    optional ``overrides["mockserver"]["key_route_triggers"]`` is a map of
    keyword-substring -> list of extra routes; if either the candidate's
    ``key`` or its source ``path`` (lowercased, concatenated) contains the
    keyword as a substring, the listed routes are appended. Falls back to
    ``["/devstack-dummy"]`` only when the result is otherwise empty.

    Back-compat wrapper: discards the host attribution that
    ``mockserver_dummy_routes_with_hosts`` returns. New callers that need
    host wiring (for ``X-Devstack-Routed-From`` stamping) should use
    ``mockserver_dummy_routes_with_hosts`` directly.
    """
    return [route for route, _host in mockserver_dummy_routes_with_hosts(candidates, overrides)]


def mockserver_dummy_routes_with_hosts(
    candidates: List[Dict[str, str]],
    overrides: Optional[Dict[str, Any]] = None,
) -> List[Tuple[str, str]]:
    """Build the (route, originating-host) tuple list for mockserver expectations.

    Same dedupe semantics as ``mockserver_dummy_routes`` (first occurrence
    wins, ordering preserved), but each route is paired with the hostname
    of the candidate that produced it so the expectation builder can stamp
    ``X-Devstack-Routed-From: <host>``.

    Host attribution rules:
      * value-path route -> hostname of that candidate's ``value`` URL.
      * key_route_triggers route -> hostname of the candidate whose key/path
        matched the trigger keyword.
      * empty/missing/unparseable host -> the sentinel ``"unknown"`` so
        downstream stamping always has a non-empty value.

    The legacy ``/devstack-dummy`` fallback (used when every candidate yields
    no usable route) attributes to ``"unknown"`` because by construction it
    has no upstream.
    """
    overrides = overrides or {}
    triggers_raw = (overrides.get("mockserver") or {}).get("key_route_triggers") or {}
    triggers: Dict[str, List[str]] = {}
    if isinstance(triggers_raw, dict):
        for keyword, route_list in triggers_raw.items():
            if not isinstance(keyword, str) or not isinstance(route_list, list):
                continue
            cleaned = [str(r) for r in route_list if isinstance(r, str) and r]
            if cleaned:
                triggers[keyword.lower()] = cleaned

    pairs: List[Tuple[str, str]] = []
    for candidate in candidates:
        raw_value = str(candidate.get("value") or "")
        parsed = urllib.parse.urlparse(raw_value)
        host = parsed.hostname or "unknown"
        value_path = parsed.path.rstrip("/")
        if value_path:
            pairs.append((value_path, host))

        if triggers:
            key = str(candidate.get("key") or "").lower()
            source = str(candidate.get("path") or "").lower()
            haystack = f"{key} {source}"
            for keyword, extra_routes in triggers.items():
                if keyword in haystack:
                    for extra in extra_routes:
                        pairs.append((extra, host))

    if not pairs:
        pairs.append(("/devstack-dummy", "unknown"))

    seen: Dict[str, str] = {}
    deduped: List[Tuple[str, str]] = []
    for route, host in pairs:
        if route in seen:
            continue
        seen[route] = host
        deduped.append((route, host))
    return deduped


def mockserver_json_expectation(
    route: str,
    body: Dict[str, Any],
    routed_from: str = "unknown",
) -> Dict[str, Any]:
    """Build a single mockserver expectation that responds 200 with ``body``.

    Always stamps the self-identifying response headers
    ``X-Devstack-Mock: true`` and ``X-Devstack-Routed-From: <routed_from>``
    next to ``Content-Type: application/json`` so a caller or test can
    detect mock-fallback usage post-hoc by inspecting response headers.

    ``routed_from`` should be the hostname of the original endpoint the
    expectation is shadowing. When the call site has no host context
    (e.g. runtime-injected expectations in
    ``ensure_mockserver_expectation_routes`` which only receives bare
    route strings), the default ``"unknown"`` is emitted so the header
    contract is still honored.
    """
    return {
        "httpRequest": {
            "method": "GET",
            "path": route,
        },
        "httpResponse": {
            "statusCode": 200,
            "headers": [
                {"name": "Content-Type", "values": ["application/json"]},
                {"name": "X-Devstack-Mock", "values": ["true"]},
                {"name": "X-Devstack-Routed-From", "values": [routed_from or "unknown"]},
            ],
            "body": json.dumps(body, ensure_ascii=False),
        },
    }


def mockserver_dummy_response_for_route(
    route: str,
    overrides: Optional[Dict[str, Any]] = None,
) -> Dict[str, Any]:
    """Return the JSON body for a specific mockserver route.

    Generic default: ``mockserver_read_response({...generic list...})`` —
    a status/message/data envelope with a single dummy item. A workspace
    can install a custom response by listing route substrings in
    ``overrides["mockserver"]["route_responses"]`` (maps substring ->
    response name) and the body dict in
    ``overrides["mockserver"]["responses"]``. The first matching substring
    wins; when no override matches, the generic envelope is returned.
    """
    overrides = overrides or {}
    mockserver_overrides = overrides.get("mockserver") or {}
    route_responses = mockserver_overrides.get("route_responses") or {}
    responses = mockserver_overrides.get("responses") or {}
    if isinstance(route_responses, dict) and isinstance(responses, dict):
        for substring, response_name in route_responses.items():
            if not isinstance(substring, str) or not isinstance(response_name, str):
                continue
            if substring in route:
                body = responses.get(response_name)
                if isinstance(body, dict):
                    return body
    return mockserver_read_response({"items": [{"id": 1, "name": "devstack local dummy"}], "totalElements": 1})


def mockserver_read_response(data: Any) -> Dict[str, Any]:
    return {
        "status": 200,
        "message": "devstack local dummy",
        "data": data,
    }


def apply_h2_schema_init(
    env_overrides: List[Dict[str, str]],
    h2_script: Optional[Path],
    h2_dml_script: Optional[Path] = None,
) -> None:
    scripts = [script for script in (h2_script, h2_dml_script) if script]
    if not scripts:
        return
    for item in env_overrides:
        value = str(item.get("value", ""))
        if value.startswith("jdbc:h2:"):
            item["value"] = h2_url_with_init(value, scripts)


def h2_url_with_init(url: str, scripts: Any) -> str:
    if ";INIT=" in url.upper():
        return url
    script_list = scripts if isinstance(scripts, list) else [scripts]
    commands = []
    for script in script_list:
        escaped = str(script).replace("\\", "\\\\").replace("'", "''")
        commands.append(f"RUNSCRIPT FROM '{escaped}'")
    return f"{url};INIT=" + "\\;".join(commands)


def render_local_schema_sql(tables: List[Dict[str, Any]], engine: str) -> str:
    tables = merge_duplicate_schema_tables(tables)
    statements = [
        "-- Generated by devstack. Re-run workspace Analyze/Apply to refresh.",
        "-- Local-only schema inferred from persistence code. It is intentionally permissive.",
        "",
    ]
    if engine == "h2":
        for schema in local_h2_schema_names(tables):
            statements.append(f"CREATE SCHEMA IF NOT EXISTS {sql_table_identifier(schema, engine)};")
        if len(statements) > 3:
            statements.append("")
    if engine == "mssql":
        for schema in local_h2_schema_names(tables):
            escaped_schema = schema.replace("'", "''")
            statements.append(f"IF SCHEMA_ID(N'{escaped_schema}') IS NULL EXEC(N'CREATE SCHEMA {mssql_identifier(schema)}');")
        if len(statements) > 3:
            statements.append("")
    for table in tables:
        statement = render_create_table_statement(table, engine)
        if statement:
            statements.append(statement)
            statements.append("")
    return "\n".join(statements)


def render_local_dml_sql(
    tables: List[Dict[str, Any]],
    engine: str,
    overrides: Optional[Dict[str, Any]] = None,
) -> str:
    tables = merge_duplicate_schema_tables(tables)
    seed_statements = local_seed_statements(tables, engine, overrides=overrides)
    if not seed_statements:
        return ""
    statements = [
        "-- Generated by devstack. Re-run workspace Analyze/Apply to refresh.",
        "-- Local-only seed DML inferred from persistence code and known local bootstrap data.",
        "",
    ]
    if seed_statements:
        statements.extend(seed_statements)
        statements.append("")
    return "\n".join(statements)


def render_create_table_statement(table: Dict[str, Any], engine: str) -> str:
    table_name = str(table.get("name", "")).strip()
    if not table_name:
        return ""

    columns = normalize_schema_columns(table.get("columns", []))
    if not columns:
        columns = [{"name": "id", "type": "long", "id": True}]

    if engine == "mssql":
        lines = [f"IF OBJECT_ID(N'{table_name.replace(chr(39), chr(39) + chr(39))}', N'U') IS NULL"]
        lines.append(f"CREATE TABLE {sql_table_identifier(table_name, engine)} (")
    else:
        lines = [f"CREATE TABLE IF NOT EXISTS {sql_table_identifier(table_name, engine)} ("]
    column_lines = []
    primary_columns = []
    for column in columns:
        column_name = str(column.get("name", "")).strip()
        if not column_name:
            continue
        if engine == "h2" and column_name.lower() in H2_SYNTHETIC_OR_RESERVED_COLUMNS:
            continue
        if column.get("id"):
            primary_columns.append(column_name)
        column_type = local_sql_type(column, engine)
        column_lines.append(
            f"  {sql_identifier(column_name, engine)} {column_type}"
        )
    if not column_lines:
        return ""
    lines.append(",\n".join(column_lines))
    if primary_columns:
        primary = ", ".join(sql_identifier(name, engine) for name in primary_columns)
        lines[-1] += f",\n  PRIMARY KEY ({primary})"
    lines.append(");")
    if engine == "mssql":
        escaped_table = table_name.replace("'", "''")
        for column in columns:
            column_name = str(column.get("name", "")).strip()
            if not column_name:
                continue
            escaped_column = column_name.replace("'", "''")
            lines.append(f"IF COL_LENGTH(N'{escaped_table}', N'{escaped_column}') IS NULL")
            lines.append(
                f"ALTER TABLE {sql_table_identifier(table_name, engine)} "
                f"ADD {sql_identifier(column_name, engine)} {local_sql_type(column, engine)};"
            )
    return "\n".join(lines)


def normalize_schema_columns(columns: Any) -> List[Dict[str, Any]]:
    normalized: Dict[str, Dict[str, Any]] = {}
    if not isinstance(columns, list):
        return []
    for column in columns:
        if not isinstance(column, dict):
            continue
        name = str(column.get("name", "")).strip()
        if not name:
            continue
        key = name.lower()
        current = normalized.setdefault(key, {"name": name})
        current.update({k: v for k, v in column.items() if v not in ("", None)})
        current["name"] = name
        current["id"] = bool(current.get("id"))
    return list(normalized.values())


def sql_identifier(name: str, engine: str) -> str:
    if engine == "mysql":
        return "`" + name.replace("`", "``") + "`"
    if engine == "h2":
        if "." in name:
            return ".".join(sql_identifier(part, engine) for part in name.split("."))
        if not h2_identifier_requires_quotes(name):
            return name
        return '"' + name.replace('"', '""') + '"'
    if engine == "postgresql":
        if "." in name:
            return ".".join('"' + part.replace('"', '""') + '"' for part in name.split("."))
        return '"' + name.replace('"', '""') + '"'
    return name


def h2_identifier_requires_quotes(name: str) -> bool:
    if not name:
        return True
    if has_mixed_case_identifier(name):
        return True
    return not re.match(r"^[A-Za-z_][A-Za-z0-9_]*$", name)


def sql_table_identifier(name: str, engine: str) -> str:
    if engine == "h2":
        return name
    return sql_identifier(name, engine)


def local_h2_schema_names(tables: List[Dict[str, Any]]) -> List[str]:
    schemas: Set[str] = set()
    for table in tables:
        table_name = str(table.get("name", "")).strip()
        if "." not in table_name:
            continue
        schema = table_name.rsplit(".", 1)[0]
        if valid_sql_table_candidate(schema):
            schemas.add(schema)
    return sorted(schemas)


def mssql_identifier(name: str) -> str:
    return "[" + name.replace("]", "]]") + "]"


def local_sql_type(column: Dict[str, Any], engine: str) -> str:
    kind = str(column.get("type") or "").lower()
    name = str(column.get("name") or "").lower()
    length = column.get("length")
    if kind in {"byte", "ubyte"}:
        return "TINYINT" if engine == "mysql" else "SMALLINT"
    if kind in {"short", "ushort"}:
        return "SMALLINT"
    if kind in {"integer", "int"}:
        return "INT"
    if kind in {"long", "bigint"}:
        return "BIGINT"
    if kind in {"bool", "boolean"}:
        if engine == "mssql":
            return "BIT"
        return "BOOLEAN" if engine != "mysql" else "TINYINT"
    if kind in {"decimal", "bigdecimal"}:
        return "DECIMAL(19, 4)"
    if kind in {"double", "float"}:
        return "DOUBLE"
    if kind in {"date"}:
        return "DATE"
    if kind in {"time"}:
        return "TIME"
    if kind in {"datetime", "timestamp"}:
        if engine == "mssql":
            return "DATETIME2"
        return "TIMESTAMP"
    if kind in {"text"}:
        return "TEXT"
    if kind in {"blob", "binary"}:
        return "BLOB"
    if name.startswith(("n", "cnt", "count")) and not kind:
        return "BIGINT"
    if name.startswith(("dt", "created_at", "updated_at")) and not kind:
        if engine == "mssql":
            return "DATETIME2"
        return "TIMESTAMP"
    try:
        width = int(length)
    except (TypeError, ValueError):
        width = 255
    if engine == "h2":
        width = max(width, 255)
    width = max(1, min(width, 4000))
    return f"VARCHAR({width})"


def local_seed_statements(
    tables: List[Dict[str, Any]],
    engine: str,
    overrides: Optional[Dict[str, Any]] = None,
) -> List[str]:
    """Emit local INSERT/MERGE statements for every detected persistence table.

    Domain-agnostic engine: for each table, the resolver runs in this order:
      1. Optional ``overrides["seeds"]["tables"][<lower-name>]`` — workspace
         declares the columns + rows (or preferred_columns + values_map) for
         the table.
      2. ``generic_local_seed_statement(table, engine)`` — deterministic
         multi-row INSERT derived from the table schema.

    A workspace with no overrides file gets purely generic seeds; a workspace
    with shipped shopping overrides ships the historical notes_box / notesys /
    tslander / tsample* fixed-column rows through the overrides path.
    """
    overrides = overrides or {}
    seed_tables_overrides = (overrides.get("seeds") or {}).get("tables") or {}
    if not isinstance(seed_tables_overrides, dict):
        seed_tables_overrides = {}

    table_by_name = {str(table.get("name", "")).lower(): table for table in tables}
    statements: List[str] = []
    seeded: Set[str] = set()

    for lower_name, table in table_by_name.items():
        spec = seed_tables_overrides.get(lower_name)
        if not isinstance(spec, dict):
            continue
        engines = spec.get("engines")
        if isinstance(engines, list) and engines and engine not in engines:
            continue
        original_name = str(table.get("name", ""))
        statement = build_override_seed_statement(original_name, table, spec, engine)
        if statement:
            seeded.add(lower_name)
            statements.append(statement)

    for key, table in table_by_name.items():
        if key in seeded:
            continue
        statement = generic_local_seed_statement(table, engine, overrides=overrides)
        if statement:
            statements.append(statement)
    return [statement for statement in statements if statement]


def build_override_seed_statement(
    original_name: str,
    table: Dict[str, Any],
    spec: Dict[str, Any],
    engine: str,
) -> str:
    """Build a single seed INSERT/MERGE from an overrides entry.

    Two forms are supported:

      * **Fixed-column form** — ``{ "columns": [...], "rows": [[...], ...] }``.
        Used for tables whose seed rows are independent of the inferred schema
        (e.g. mssql notes_box / notesys_report_info). The original_name is used
        verbatim (case-sensitive) so the emitted SQL targets the existing
        table identifier.

      * **Preferred-column form** — ``{ "preferred_columns": [...],
        "values_map": {<col-lower>: <value>}, "default_value": <any> }``.
        The columns are filtered to those present in the table schema (via
        ``resolve_seed_columns``), and each value is looked up by lowercase
        column name in ``values_map`` (or ``default_value`` when absent).
    """
    if "columns" in spec and "rows" in spec:
        columns = [str(c) for c in spec["columns"]] if isinstance(spec["columns"], list) else []
        rows = spec["rows"] if isinstance(spec["rows"], list) else []
        if not columns or not rows:
            return ""
        return local_insert_ignore(original_name, columns, rows, engine)

    preferred = spec.get("preferred_columns")
    values_map_raw = spec.get("values_map") or {}
    default_value = spec.get("default_value", "devstack")
    if not isinstance(preferred, list) or not isinstance(values_map_raw, dict):
        return ""
    columns = resolve_seed_columns(table, [str(c) for c in preferred])
    if not columns:
        return ""
    values_map_lower = {str(k).lower(): v for k, v in values_map_raw.items()}
    row = [values_map_lower.get(col.lower(), default_value) for col in columns]
    return local_insert_ignore(original_name, columns, [row], engine)


def resolve_seed_columns(table: Dict[str, Any], preferred: List[str]) -> List[str]:
    columns = {
        str(column.get("name", "")).lower(): str(column.get("name", ""))
        for column in normalize_schema_columns(table.get("columns", []))
    }
    return [columns.get(name.lower(), name) for name in preferred if name.lower() in columns]


def generic_local_seed_statement(
    table: Dict[str, Any],
    engine: str,
    row_count: int = GENERIC_LOCAL_SEED_ROW_COUNT,
    overrides: Optional[Dict[str, Any]] = None,
) -> str:
    """Emit a multi-row INSERT for any detected persistence table.

    Previously this helper refused to seed wide tables (>8 columns) or tables
    without a status/deleted/hidden-style column. Both guards are now relaxed
    so that newly-introduced services with arbitrary schemas still receive
    deterministic local seed data. `row_count` rows are emitted (default 3,
    clamped to the contract range 3-5). The key column is offset by row index
    so primary keys do not collide; textual columns receive a `-N` suffix.

    Overrides-driven seeds (workspace ``.devstack-overrides.json``) win for
    any table their ``seeds.tables[<lower-name>]`` entry covers; the generic
    loop only runs for tables not already seeded by overrides.
    """
    table_name = str(table.get("name", "")).strip()
    columns = normalize_schema_columns(table.get("columns", []))
    if not table_name or not columns:
        return ""

    key_column = choose_seed_key_column(columns)
    display_column = choose_seed_display_column(columns)
    if not key_column:
        return ""

    seed_columns = [column for column in columns if seedable_column(column)]
    if key_column not in seed_columns:
        seed_columns.insert(0, key_column)
    if display_column and display_column not in seed_columns:
        seed_columns.append(display_column)
    seed_columns = seed_columns[:24]
    # Skip tables that have only the key column (or no non-key seedable columns).
    # Such tables are typically pure id registries / lookup-by-id stubs where a
    # synthetic seed row carries no smoke-test value and risks colliding with
    # joins from upstream tables.
    key_name_lower = str(key_column.get("name", "")).lower()
    non_key_seed_columns = [
        column for column in seed_columns
        if str(column.get("name", "")).lower() != key_name_lower
    ]
    if not non_key_seed_columns:
        return ""

    # Clamp row_count to the documented seed-pipeline contract (3-5 rows).
    row_count = max(3, min(int(row_count or 1), 5))
    rows = generic_local_seed_rows(seed_columns, table_name, key_column, row_count, overrides)
    column_names = [str(column["name"]) for column in seed_columns]
    return local_insert_ignore(table_name, column_names, rows, engine)


def generic_local_seed_rows(
    seed_columns: List[Dict[str, Any]],
    table_name: str,
    key_column: Dict[str, Any],
    row_count: int,
    overrides: Optional[Dict[str, Any]] = None,
) -> List[List[Any]]:
    """Build `row_count` deterministic row vectors.

    Row 1 reuses the original `seed_value_for_column` output. Subsequent rows
    offset the integer key column by the row index (so primary keys do not
    collide) and append the row index to textual columns. Non-key, non-text
    columns reuse the row-1 value verbatim so semantics (status flags,
    display flags, timestamps) remain stable across rows.
    """
    base = [seed_value_for_column(column, table_name, overrides) for column in seed_columns]
    if row_count <= 1:
        return [base]
    rows: List[List[Any]] = []
    key_name = str(key_column.get("name", "")).lower()
    for row_index in range(row_count):
        if row_index == 0:
            rows.append(list(base))
            continue
        row: List[Any] = []
        for column, base_value in zip(seed_columns, base):
            column_name = str(column.get("name", "")).lower()
            if column_name == key_name:
                # Offset numeric primary keys; fall back to a suffixed string
                # for non-numeric ids so duplicates are still avoided.
                if isinstance(base_value, int):
                    row.append(base_value + row_index)
                elif isinstance(base_value, float):
                    row.append(base_value + row_index)
                else:
                    row.append(f"{base_value}-{row_index + 1}")
            elif isinstance(base_value, str) and base_value.startswith("devstack"):
                row.append(f"{base_value} {row_index + 1}")
            elif isinstance(base_value, str) and "Local " in base_value:
                row.append(f"{base_value} ({row_index + 1})")
            else:
                row.append(base_value)
        rows.append(row)
    return rows


def has_seed_state_column(columns: List[Dict[str, Any]]) -> bool:
    tokens = ("deleted", "hidden", "display", "status", "active", "enabled", "use_yn")
    for column in columns:
        name = str(column.get("name", "")).lower()
        if any(token in name for token in tokens):
            return True
    return False


def choose_seed_key_column(columns: List[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
    for column in columns:
        if column.get("id"):
            return column
    preferred = {"id", "seq", "no"}
    for column in columns:
        name = str(column.get("name", "")).lower()
        if name in preferred or name.endswith("_id") or name.endswith("_seq") or name.endswith("_no"):
            return column
    return columns[0] if columns else None


def choose_seed_display_column(columns: List[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
    tokens = ("title", "subject", "name", "content", "body", "description")
    for column in columns:
        name = str(column.get("name", "")).lower()
        if any(token in name for token in tokens) and seed_column_is_textual(column):
            return column
    return None


def seed_column_is_textual(column: Dict[str, Any]) -> bool:
    sql_type = local_sql_type(column, "postgresql").lower()
    return any(token in sql_type for token in ("char", "text", "clob"))


def seedable_column(column: Dict[str, Any]) -> bool:
    name = str(column.get("name", "")).strip()
    if not name:
        return False
    return name.lower() not in {"rownum", "total_count"}


def seed_value_for_column(
    column: Dict[str, Any],
    table_name: str,
    overrides: Optional[Dict[str, Any]] = None,
) -> Any:
    """Return a deterministic seed value for ``column`` in ``table_name``.

    Domain-agnostic engine: generic name/type heuristics produce ``1`` for
    id/seq/no/integer columns, date/time/timestamp constants for time
    columns, boolean defaults, and a labeled string fallback for textual
    columns. The optional ``overrides["seeds"]["column_enum_literals"]``
    map lets a workspace inject column-name -> enum-literal overrides for
    domain-specific status enums (e.g. shopping's ``external_provide_status``
    => ``"ENABLED"``). Without overrides the function uses only the generic
    rules — no domain literals appear.
    """
    overrides = overrides or {}
    name = str(column.get("name", "")).lower()
    sql_type = local_sql_type(column, "postgresql").lower()
    label = table_name.replace("_", " ").strip().lower() or "row"
    numeric_type = any(token in sql_type for token in ("int", "decimal", "double", "float"))

    column_enum_literals = (overrides.get("seeds") or {}).get("column_enum_literals")
    if isinstance(column_enum_literals, dict):
        literal = column_enum_literals.get(name)
        if literal is not None:
            return literal

    if name in {"id", "seq", "no"} or name.endswith(("_id", "_seq", "_no")):
        return 1
    if sql_type == "date":
        return "2026-01-01"
    if sql_type == "time":
        return "10:00:00"
    if "timestamp" in sql_type:
        return "2026-01-01 10:00:00"
    if "deleted" in name or "hidden" in name or name.endswith("_del_flag"):
        if "boolean" in sql_type:
            return False
        return 0 if numeric_type else "0"
    if "display" in name or name.endswith("_yn") or name.endswith("_flag"):
        if "boolean" in sql_type:
            return True
        return 1 if numeric_type else "Y"
    if numeric_type:
        return 1
    if "title" in name or "subject" in name:
        return f"devstack local {label}"
    if "content" in name or "body" in name or "description" in name:
        return f"Local {label} seeded by devstack for smoke verification."
    if "name" in name or "nick" in name:
        return "devstack local"
    if "user" in name or "author" in name:
        return "devstack"
    if "date" in name or "time" in name or "created" in name or "updated" in name:
        return "2026-01-01 10:00:00"
    if "count" in name or name.endswith("_cnt"):
        return 1
    if "boolean" in sql_type:
        return False
    return "devstack"


def local_insert_ignore(table: str, columns: List[str], rows: List[List[Any]], engine: str) -> str:
    if engine == "h2":
        key = sql_identifier(columns[0], engine) if columns else ""
        column_text = ", ".join(sql_identifier(column, engine) for column in columns)
        values = []
        for row in rows:
            values.append("(" + ", ".join(sql_literal(value) for value in row) + ")")
        return (
            f"MERGE INTO {sql_table_identifier(table, engine)} ({column_text}) "
            f"KEY({key}) VALUES\n  " + ",\n  ".join(values) + ";"
        )
    if engine == "mssql":
        key_column = sql_identifier(columns[0], engine) if columns else ""
        column_text = ", ".join(sql_identifier(column, engine) for column in columns)
        statements = []
        for row in rows:
            if not row:
                continue
            value_text = "(" + ", ".join(sql_literal(value) for value in row) + ")"
            statements.append(
                f"IF NOT EXISTS (SELECT 1 FROM {sql_identifier(table, engine)} WHERE {key_column} = {sql_literal(row[0])})\n"
                f"INSERT INTO {sql_identifier(table, engine)} ({column_text}) VALUES {value_text};"
            )
        return "\n".join(statements)
    verb = "INSERT IGNORE INTO" if engine == "mysql" else "INSERT INTO"
    column_text = ", ".join(sql_identifier(column, engine) for column in columns)
    values = []
    for row in rows:
        values.append("(" + ", ".join(sql_literal(value) for value in row) + ")")
    if not values:
        return ""
    statement = f"{verb} {sql_table_identifier(table, engine)} ({column_text}) VALUES\n  " + ",\n  ".join(values)
    if engine in {"h2", "postgresql"}:
        statement += "\nON CONFLICT DO NOTHING" if engine == "postgresql" else ""
    return statement + ";"


def sql_literal(value: Any) -> str:
    if value is None:
        return "NULL"
    if isinstance(value, bool):
        return "TRUE" if value else "FALSE"
    if isinstance(value, (int, float)):
        return str(value)
    return "'" + str(value).replace("'", "''") + "'"


def write_managed_compose(
    path: Path,
    requirements: List[Dict[str, Any]],
    workspace_name: str,
) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    network_name = managed_compose_network_name(workspace_name)
    lines = [
        "# Generated by devstack. Re-run workspace Analyze/Apply to refresh.",
        "services:",
    ]
    volumes: List[str] = []
    for requirement in requirements:
        compose_service = str(requirement["compose_service"])
        lines.append(f"  {compose_service}:")
        lines.append(f"    image: {yaml_scalar(requirement['image'])}")
        port = requirement.get("port")
        container_port = requirement.get("container_port")
        if port and container_port:
            lines.extend(["    ports:", f"      - {yaml_scalar(f'{port}:{container_port}')}"])
        environment = requirement.get("environment", {})
        if environment:
            lines.append("    environment:")
            for key, value in sorted(environment.items()):
                lines.append(f"      {key}: {yaml_scalar(value)}")
        command = str(requirement.get("command") or "")
        if command:
            lines.append(f"    command: {yaml_scalar(command)}")
        service_volumes = requirement.get("volumes", [])
        if service_volumes:
            lines.append("    volumes:")
            for volume in service_volumes:
                lines.append(f"      - {yaml_scalar(volume)}")
                volume_name = compose_named_volume_source(str(volume))
                if volume_name and volume_name not in volumes:
                    volumes.append(volume_name)
        lines.extend(["    networks:", f"      - {network_name}"])
    if volumes:
        lines.append("volumes:")
        for volume in volumes:
            lines.append(f"  {volume}: {{}}")
    lines.extend([
        "networks:",
        f"  {network_name}:",
        f"    name: {network_name}",
    ])
    path.write_text("\n".join(lines) + "\n")


def compose_named_volume_source(volume: str) -> str:
    source = volume.split(":", 1)[0]
    if not source or source.startswith(("/", ".", "~")):
        return ""
    return source


def write_managed_env(path: Path, overrides: List[Dict[str, str]]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    lines = ["# Generated by devstack. Values are also applied to managed service env blocks."]
    for item in overrides:
        lines.append(f"# service: {item['service']} source: {item['source']}")
        lines.append(f"{item['name']}={shell_env_value(item['value'])}")
    path.write_text("\n".join(lines) + "\n")


def write_managed_local_yml(path: Path) -> None:
    """Materialize the placeholder ``devstack-local.yml`` classpath resource.

    The file lands under ``managed_infra_dir(workspace)`` and is wired onto
    every Spring Boot module's runtime classpath by
    ``write_managed_gradle_init`` (see the ``managed_infra_dir`` kwarg).
    Body is a comment header plus an empty YAML map — valid YAML that
    Spring's ``YamlPropertySourceLoader`` accepts as an empty property
    source, and extensible later to carry real datasource properties
    without changing the wiring on either end.

    Without this file the mandatory ``classpath:devstack-local.yml`` import
    (LOCAL_CONFIG_IMPORT) fails Spring Boot startup with
    ``ConfigDataResourceNotFoundException`` — exactly the silent-degradation
    circuit commit 1ea4928 was meant to close. Writing the placeholder
    preserves the fail-fast invariant (no ``optional:`` prefix) while
    restoring the boot happy path.

    Shim 7 — ``write_managed_local_yml_dual`` invokes this writer twice
    (once for ``devstack-local.yml``, once for ``devstack-local.yml``) so
    previously-built user app jars whose Spring config references
    ``classpath:devstack-local.yml`` continue to import their overlay file.
    """
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(
        "# managed by devstack — do not edit. Regenerated on every Analyze/Apply.\n"
        "{}\n"
    )


def write_managed_gradle_init(
    path: Path,
    include_config_server_patch: bool = False,
    spring_boot_plugin_modules: Optional[List[str]] = None,
    graphql_dummy_modules: Optional[Dict[str, str]] = None,
    mybatis_mapper_scan_modules: Optional[Dict[str, str]] = None,
    runtime_dependencies: Optional[Dict[str, List[str]]] = None,
    boot_run_environment: Optional[Dict[str, Dict[str, str]]] = None,
    managed_infra_dir: Optional[Path] = None,
) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    spring_boot_plugin_modules = spring_boot_plugin_modules or []
    graphql_dummy_modules = graphql_dummy_modules or {}
    mybatis_mapper_scan_modules = mybatis_mapper_scan_modules or {}
    runtime_dependencies = runtime_dependencies or {}
    boot_run_environment = boot_run_environment or {}
    boot_projects = ", ".join(json.dumps(module) for module in spring_boot_plugin_modules)
    graphql_entries = ", ".join(
        f"{json.dumps(key)}: {json.dumps(value)}"
        for key, value in sorted(graphql_dummy_modules.items())
    )
    mybatis_entries = ", ".join(
        f"{json.dumps(key)}: {json.dumps(value)}"
        for key, value in sorted(mybatis_mapper_scan_modules.items())
    )
    graphql_sources = f"[{graphql_entries}]" if graphql_entries else "[:]"
    mybatis_sources = f"[{mybatis_entries}]" if mybatis_entries else "[:]"
    runtime_dependency_entries = ", ".join(
        f"{json.dumps(key)}: [{', '.join(json.dumps(item) for item in values)}]"
        for key, values in sorted(runtime_dependencies.items())
    )
    runtime_dependency_map = f"[{runtime_dependency_entries}]" if runtime_dependency_entries else "[:]"
    boot_run_environment_entries: List[str] = []
    for task_path, env_map in sorted(boot_run_environment.items()):
        if not env_map:
            continue
        inner_entries = ", ".join(
            f"{json.dumps(str(env_key))}: {json.dumps(str(env_value))}"
            for env_key, env_value in sorted(env_map.items())
        )
        if not inner_entries:
            continue
        boot_run_environment_entries.append(
            f"{json.dumps(str(task_path))}: [{inner_entries}]"
        )
    boot_run_environment_map = (
        f"[{', '.join(boot_run_environment_entries)}]"
        if boot_run_environment_entries
        else "[:]"
    )
    lines = [
        "// Generated by devstack. Re-run workspace Analyze/Apply to refresh.",
        "// Adds local/public repository fallbacks and patches local-only runtime needs without editing project files.",
        f"def devstackSpringBootProjects = [{boot_projects}] as Set",
        f"def devstackGraphqlDummySources = {graphql_sources}",
        f"def devstackMybatisMapperScanSources = {mybatis_sources}",
        f"def devstackRuntimeDependencies = {runtime_dependency_map}",
        "def devstackPreferLocalRepositories = { repositories ->",
        "    repositories.mavenLocal()",
        "    repositories.mavenCentral()",
        "    repositories.google()",
        "    repositories.maven { url = uri('https://jitpack.io') }",
        "    repositories.maven { url = uri('https://packages.confluent.io/maven/') }",
        "}",
        "def devstackRoutePublicRuntimeRepositories = { repositories ->",
        "    repositories.exclusiveContent {",
        "        forRepository { repositories.mavenCentral() }",
        "        filter { includeGroup('com.microsoft.sqlserver') }",
        "    }",
        "}",
        "def devstackPatchDgsCodegenSchemaPaths = { project ->",
        "    project.tasks.configureEach { task ->",
        "        if (task.hasProperty('schemaPaths')) {",
        "            task.doFirst {",
        "                def devstackSchemaDir = new File(project.buildDir, \"devstack/graphql-schema/${task.name}\")",
        "                devstackSchemaDir.deleteDir()",
        "                devstackSchemaDir.mkdirs()",
        "                def devstackSchemaPaths = []",
        "                def devstackSchemaPathIndex = 0",
        "                task.schemaPaths.each { pathValue ->",
        "                    def source = project.file(pathValue)",
        "                    if (source.isDirectory()) {",
        "                        def devstackSourceDir = new File(devstackSchemaDir, \"source-${devstackSchemaPathIndex++}\")",
        "                        project.copy {",
        "                            from(source) { include '**/*.graphql'; include '**/*.graphqls' }",
        "                            into(devstackSourceDir)",
        "                        }",
        "                        devstackSchemaPaths.add(devstackSourceDir.absolutePath)",
        "                    } else if (source.name ==~ /.*\\.graphqls?$/) {",
        "                        def devstackSourceDir = new File(devstackSchemaDir, \"source-${devstackSchemaPathIndex++}\")",
        "                        devstackSourceDir.mkdirs()",
        "                        project.copy { from(source); into(devstackSourceDir) }",
        "                        devstackSchemaPaths.add(devstackSourceDir.absolutePath)",
        "                    }",
        "                }",
        "                if (!devstackSchemaPaths.isEmpty()) {",
        "                    task.schemaPaths = devstackSchemaPaths",
        "                }",
        "            }",
        "        }",
        "    }",
        "}",
        "def devstackApplyRuntimeDependencies = { project ->",
        "    if (!devstackRuntimeDependencies.containsKey(project.path)) {",
        "        return",
        "    }",
        "    project.plugins.withId('java') {",
        "        if (project.ext.has('devstackRuntimeDependenciesApplied')) {",
        "            return",
        "        }",
        "        project.ext.devstackRuntimeDependenciesApplied = true",
        "        devstackRuntimeDependencies[project.path].each { dependency ->",
        "            project.dependencies.add('runtimeOnly', dependency)",
        "        }",
        "    }",
        "}",
    ]
    if include_config_server_patch:
        # When the workspace-managed infra dir is supplied, inject an extra
        # processResources `from(...)` source that copies the real
        # `devstack-local.yml` file (materialized by
        # materialize_managed_environment) into `build/resources/main/`. This
        # satisfies the mandatory `classpath:devstack-local.yml` import for
        # both bootRun and packaged builds without reverting the fail-fast
        # invariant. When `managed_infra_dir` is None (legacy callers, unit
        # tests not passing the kwarg) the wire is omitted so the existing
        # init-script shape stays byte-identical.
        infra_dir_extra_source = ""
        if managed_infra_dir is not None:
            infra_dir_literal = json.dumps(str(managed_infra_dir))
            infra_dir_extra_source = (
                f"        task.from({infra_dir_literal}) "
                "{ include 'devstack-local.yml' }"
            )
        config_server_lines = [
            "def devstackConfigServerOverrideProperties = [",
            "    'spring.cloud.config.enabled': 'false',",
            "    'spring.cloud.config.import-check.enabled': 'false',",
            f"    'spring.config.import': '{LOCAL_CONFIG_IMPORT}',",
            "]",
            f"def devstackBootRunEnvironment = {boot_run_environment_map}",
            "def devstackPatchConfigServerImports = { project ->",
            "    project.tasks.matching { task -> task.name == 'processResources' }.configureEach { task ->",
            "        task.outputs.upToDateWhen { false }",
        ]
        if infra_dir_extra_source:
            config_server_lines.append(infra_dir_extra_source)
        config_server_lines.extend(
            [
                "        task.filesMatching(['**/*.yml', '**/*.yaml', '**/*.properties']) {",
                "            filter { line ->",
                "                line",
                f"                    .replaceAll(/optional:configserver:https?:\\/\\/[^\"'\\s]+/, '{LOCAL_CONFIG_IMPORT}')",
                f"                    .replaceAll(/configserver:https?:\\/\\/[^\"'\\s]+/, '{LOCAL_CONFIG_IMPORT}')",
                "                    .replaceAll(/(?i)SET\\s+statement_timeout\\s*=\\s*'[^']+'/, 'SET LOCK_TIMEOUT 30000')",
                "            }",
                "        }",
                "    }",
                "}",
            ]
        )
        lines.extend(config_server_lines)
        lines.extend(
            [
                "def devstackPatchConfigServerBootTasks = { project ->",
                "    project.tasks.matching { task -> task.name == 'bootRun' }.configureEach { task ->",
                "        devstackConfigServerOverrideProperties.each { key, value ->",
                "            task.systemProperty(key, value)",
                "        }",
                "        def envForTask = devstackBootRunEnvironment[task.path] ?: [:]",
                "        envForTask.each { k, v -> task.environment(k, v) }",
                "    }",
                "}",
            ]
        )
    lines.extend(
        [
        "settingsEvaluated { settings ->",
        "    devstackPreferLocalRepositories(settings.pluginManagement.repositories)",
        "    if (settings.metaClass.hasProperty(settings, 'dependencyResolutionManagement')) {",
        "        devstackPreferLocalRepositories(settings.dependencyResolutionManagement.repositories)",
        "    }",
        "}",
        "gradle.beforeProject { project ->",
        "    if (devstackSpringBootProjects.contains(project.path)) {",
        "        project.pluginManager.apply('org.springframework.boot')",
        "    }",
        "    if (devstackGraphqlDummySources.containsKey(project.path)) {",
        "        project.plugins.withId('java') {",
        "            project.sourceSets.main.java.srcDir(devstackGraphqlDummySources[project.path])",
        "        }",
        "        project.plugins.withId('org.jetbrains.kotlin.jvm') {",
        "            project.sourceSets.main.java.srcDir(devstackGraphqlDummySources[project.path])",
        "        }",
        "    }",
        "    if (devstackMybatisMapperScanSources.containsKey(project.path)) {",
        "        project.plugins.withId('java') {",
        "            project.sourceSets.main.java.srcDir(devstackMybatisMapperScanSources[project.path])",
        "        }",
        "        project.plugins.withId('org.jetbrains.kotlin.jvm') {",
        "            project.sourceSets.main.java.srcDir(devstackMybatisMapperScanSources[project.path])",
        "        }",
        "    }",
        "    devstackPreferLocalRepositories(project.buildscript.repositories)",
        "    devstackPreferLocalRepositories(project.repositories)",
        "    devstackRoutePublicRuntimeRepositories(project.repositories)",
        "    devstackApplyRuntimeDependencies(project)",
        "    devstackPatchDgsCodegenSchemaPaths(project)",
        ]
    )
    if include_config_server_patch:
        lines.append("    devstackPatchConfigServerImports(project)")
        lines.append("    devstackPatchConfigServerBootTasks(project)")
    lines.append("}")
    path.write_text("\n".join(lines) + "\n")


# --- Concrete remote-config patch strategies ------------------------------
#
# Defined here (rather than next to the Protocol declaration near
# LOCAL_CONFIG_IMPORT) because they call ``write_managed_local_yml`` and
# ``write_managed_gradle_init``, which are defined above. The Protocol +
# RemoteConfigPatchContext class live near the constant where the rest of the
# config-import contract is documented.
#
# ``select_remote_config_strategies(ctx)`` is the registry helper: it returns
# every strategy whose ``applies_to(ctx)`` is True. The order is stable
# (gradle-spring before dotenv) so reviewers see deterministic artifacts.


# Spring-style env keys mirrored from the config_server runtime_signal_requirement.
# Kept as a module-level constant so the DotenvStrategy and any future strategy
# can reuse the same key set without duplicating the literals (and so tests
# can introspect it).
_REMOTE_CONFIG_DISABLE_ENV: Dict[str, str] = {
    "SPRING_CLOUD_CONFIG_ENABLED": "false",
    "SPRING_CLOUD_CONFIG_IMPORT_CHECK_ENABLED": "false",
    "SPRING_CONFIG_IMPORT": LOCAL_CONFIG_IMPORT,
}


class GradleSpringStrategy:
    """The legacy Gradle/Spring path, wrapped behind the strategy seam.

    BYTE-IDENTICAL contract: ``materialize`` delegates to the existing
    ``write_managed_local_yml`` and ``write_managed_gradle_init`` functions
    with the same arguments the legacy ``materialize_managed_environment``
    used at the original call site (devstack ~2046-2065). No new artifact
    bytes are produced.
    """

    name = "gradle-spring"

    def applies_to(self, ctx: "RemoteConfigPatchContext") -> bool:
        if not ctx.requires_config_resource_patch:
            return False
        return any(
            isinstance(service, dict) and service.get("type") == "gradle"
            for service in ctx.services.values()
        )

    def materialize(self, ctx: "RemoteConfigPatchContext") -> Dict[str, Any]:
        # 1. Placeholder local-yml — Shim 7 emits BOTH ``devstack-local.yml``
        #    (canonical) and ``devstack-local.yml`` (legacy alias) under
        #    managed_infra_dir, byte-identical to write_managed_local_yml's
        #    output for the same target path. The legacy ``local_yml``
        #    artifact key remains the devstack-local.yml path so existing
        #    consumers of the returned ``artifacts`` map (test goldens,
        #    audit reporting) continue to find the same file; the
        #    ``local_yml_canonical`` key carries the new path.
        write_managed_local_yml_dual(ctx.managed_infra_dir)
        legacy_local_yml_path = ctx.managed_infra_dir / DUAL_LOCAL_YML_LEGACY
        canonical_local_yml_path = ctx.managed_infra_dir / DUAL_LOCAL_YML_NEW

        # 2. Gradle init-script — delegates to write_managed_gradle_init with
        #    include_config_server_patch=True. All other kwargs come from
        #    ctx.gradle_init_kwargs verbatim, preserving the existing call shape.
        init_path = ctx.gradle_init_path
        write_managed_gradle_init(
            init_path,
            include_config_server_patch=True,
            managed_infra_dir=ctx.managed_infra_dir_for_patch,
            **ctx.gradle_init_kwargs,
        )

        return {
            "strategy": self.name,
            "artifacts": {
                "local_yml": str(legacy_local_yml_path),
                "local_yml_canonical": str(canonical_local_yml_path),
                "gradle_init": str(init_path),
            },
            "env_injection": {},
        }


class DotenvStrategy:
    """Materializes a .env-style local overlay for ``type=command`` services.

    Writes ``managed_infra_dir/devstack-local.env`` containing the same env keys
    the legacy ``config_server`` requirement payload set on gradle services
    (``SPRING_CLOUD_CONFIG_ENABLED``, ``SPRING_CLOUD_CONFIG_IMPORT_CHECK_ENABLED``,
    ``SPRING_CONFIG_IMPORT``). Command services already receive these values
    through the generic ``environment_override_entries`` pipeline; this
    strategy adds the file artifact so non-JVM stacks can also source the
    overlay directly via ``set -a; source devstack-local.env`` or
    ``docker --env-file``.

    The strategy returns an ``env_injection`` map describing the per-service
    env contract so downstream callers can apply it programmatically if
    needed.
    """

    name = "dotenv"

    _ENV_FILE_NAME = "devstack-local.env"

    def applies_to(self, ctx: "RemoteConfigPatchContext") -> bool:
        if not ctx.requires_config_resource_patch:
            return False
        return any(
            isinstance(service, dict) and service.get("type") == "command"
            for service in ctx.services.values()
        )

    def materialize(self, ctx: "RemoteConfigPatchContext") -> Dict[str, Any]:
        env_path = ctx.managed_infra_dir / self._ENV_FILE_NAME
        env_path.parent.mkdir(parents=True, exist_ok=True)

        body_lines = [
            "# managed by devstack — do not edit. "
            "Regenerated on every Analyze/Apply.",
            "# Source this file (e.g. `set -a; source devstack-local.env`) or pass",
            "# it to docker via `--env-file devstack-local.env` for type=command",
            "# services. Mirrors the SPRING_* values the Gradle path injects via",
            "# init-script systemProperty + per-task environment.",
        ]
        for key in sorted(_REMOTE_CONFIG_DISABLE_ENV):
            value = _REMOTE_CONFIG_DISABLE_ENV[key]
            body_lines.append(f"{key}={shell_env_value(value)}")
        env_path.write_text("\n".join(body_lines) + "\n")

        # Per-service env injection map: only command services receive the
        # overlay. Compose / gradle services are intentionally excluded so a
        # mixed workspace's gradle services keep their existing init-script
        # injection path.
        env_injection: Dict[str, Dict[str, str]] = {}
        for service_name, service in ctx.services.items():
            if not isinstance(service, dict):
                continue
            if service.get("type") != "command":
                continue
            env_injection[service_name] = dict(_REMOTE_CONFIG_DISABLE_ENV)

        return {
            "strategy": self.name,
            "artifacts": {
                "env_file": str(env_path),
            },
            "env_injection": env_injection,
        }


# Registry of all built-in strategies, in stable order. New strategies appear
# at the tail so the iteration order remains deterministic for tests + logs.
_REMOTE_CONFIG_STRATEGY_REGISTRY: Tuple[RemoteConfigPatchStrategy, ...] = (
    GradleSpringStrategy(),
    DotenvStrategy(),
)


def select_remote_config_strategies(
    ctx: RemoteConfigPatchContext,
) -> List[RemoteConfigPatchStrategy]:
    """Return the list of strategies whose ``applies_to(ctx)`` is True.

    A mixed workspace (both ``gradle`` and ``command`` services) returns both
    strategies, each materializing its own artifact set. A workspace that
    does not need the config-server patch at all returns an empty list.
    """
    return [s for s in _REMOTE_CONFIG_STRATEGY_REGISTRY if s.applies_to(ctx)]
# --- End concrete remote-config patch strategies --------------------------


def yaml_scalar(value: Any) -> str:
    return json.dumps(str(value))


def shell_env_value(value: Any) -> str:
    text = str(value)
    if re.match(r"^[A-Za-z0-9_./:@-]+$", text):
        return text
    return "'" + text.replace("'", "'\"'\"'") + "'"


class WorkspaceScanCache:
    def __init__(self, root: Path):
        self.root = root
        self._runtime_files: Optional[List[Path]] = None
        self._persistence_files: Optional[List[Path]] = None
        self._small_text: Dict[Tuple[Path, int], str] = {}

    def runtime_files(self) -> List[Path]:
        if self._runtime_files is None:
            self._runtime_files = collect_runtime_scan_files(self.root)
        return self._runtime_files

    def persistence_files(self) -> List[Path]:
        if self._persistence_files is None:
            self._persistence_files = [
                path
                for path in self.runtime_files()
                if path.suffix.lower() in {".java", ".kt"}
            ]
        return self._persistence_files

    def read_small_text(self, path: Path, limit: int = 300000) -> str:
        key = (path, limit)
        if key not in self._small_text:
            self._small_text[key] = read_small_text(path, limit)
        return self._small_text[key]


def analyze_workspace_config(
    root: Path,
    config: Dict[str, Any],
    progress: Optional[Callable[[str], None]] = None,
    reserved_ports: Optional[Set[int]] = None,
) -> Dict[str, Any]:
    services = config.get("services", {})
    scan_cache = WorkspaceScanCache(root)
    if progress:
        progress("Inspecting infrastructure definitions")
    compose_files = sorted(
        {
            str(service.get("compose"))
            for service in services.values()
            if isinstance(service, dict) and service.get("compose")
        }
    )
    if progress:
        progress(f"Found {len(compose_files)} infrastructure file(s)")
        progress("Inspecting persistence models and data access")
    persistence = inspect_persistence(root, scan_cache=scan_cache)
    if progress:
        table_count = len(persistence.get("tables", []))
        repository_count = len(persistence.get("repositories", []))
        mapper_count = len(persistence.get("mappers", []))
        exposed_count = len(persistence.get("exposed", {}).get("queries", []))
        progress(
            f"Found {table_count} table candidate(s), "
            f"{repository_count} repository item(s), "
            f"{mapper_count} mapper item(s), "
            f"{exposed_count} Exposed query item(s)"
        )
        progress("Inspecting SQL files as secondary evidence")
    sql_evidence = inspect_sql_files(root)
    if progress:
        progress(f"Found {len(sql_evidence)} SQL evidence file(s)")
        progress("Inspecting local execution environment requirements")
    environment = build_local_environment_plan(
        root,
        str(config.get("workspace") or root.name),
        config,
        persistence,
        progress=progress,
        scan_cache=scan_cache,
        reserved_ports=reserved_ports,
    )
    if progress:
        generated_count = len(environment.get("generated", []))
        manual_count = len(environment.get("manual", []))
        env_count = len(environment.get("env", []))
        progress(
            f"Planned {generated_count} managed infrastructure item(s), "
            f"{env_count} environment override(s), "
            f"{manual_count} manual review item(s)"
        )
    destructive_sql = [item for item in sql_evidence if item["destructive"]]
    warnings = []
    if destructive_sql:
        warnings.append("destructive SQL evidence detected; do not auto-apply without review")
    if not services:
        warnings.append("no runnable services detected")
    if sql_evidence and not persistence["tables"]:
        warnings.append("SQL files detected only as secondary evidence; no persistence model was found")
    if persistence["tables"] and not database_service_candidates(services):
        warnings.append("persistence model detected but no obvious database service was found")
    if environment["manual"]:
        warnings.append("some infrastructure or external dependencies require manual review before local generation")

    confidence = "high" if services and persistence["tables"] else "medium" if services or persistence["tables"] else "low"
    return {
        "confidence": confidence,
        "infrastructure": [{"type": "docker compose", "path": path} for path in compose_files],
        "services": summarize_services(services),
        "databases": database_service_candidates(services),
        "persistence": persistence,
        "environment": environment,
        "sql_evidence": sql_evidence,
        "destructive_sql": destructive_sql,
        "warnings": warnings,
    }


def summarize_services(services: Dict[str, Any]) -> List[Dict[str, Any]]:
    summary = []
    for name, service in sorted(services.items()):
        if not isinstance(service, dict):
            continue
        summary.append(
            {
                "name": name,
                "type": service.get("type", "unknown"),
                "compose": service.get("compose", ""),
                "service": service.get("service", ""),
                "port": service.get("port", ""),
            }
        )
    return summary


def database_service_candidates(services: Dict[str, Any]) -> List[Dict[str, Any]]:
    terms = ("db", "database", "postgres", "postgresql", "mysql", "mariadb", "oracle", "mongo", "redis", "mssql")
    candidates = []
    for name, service in sorted(services.items()):
        service_name = str(service.get("service", "")) if isinstance(service, dict) else ""
        haystack = f"{name} {service_name}".lower()
        if any(term in haystack for term in terms):
            candidates.append({"name": name, "service": service_name})
    return candidates


def build_local_environment_plan(
    root: Path,
    name: str,
    config: Dict[str, Any],
    persistence: Dict[str, Any],
    progress: Optional[Callable[[str], None]] = None,
    scan_cache: Optional[WorkspaceScanCache] = None,
    reserved_ports: Optional[Set[int]] = None,
) -> Dict[str, Any]:
    def emit(message: str) -> None:
        if progress:
            progress(message)

    scan_cache = scan_cache or WorkspaceScanCache(root)
    services = config.get("services", {})
    used_ports = set(reserved_ports or set())
    used_ports.update(used_configured_ports(services))
    requirements: List[Dict[str, Any]] = []
    env_overrides: List[Dict[str, str]] = []
    generated_database_engines: Set[str] = set()
    generated_database_connections: Dict[str, Dict[str, str]] = {}
    arg_overrides: List[Dict[str, str]] = []

    for datasource in persistence.get("datasources", []):
        requirement = database_environment_requirement(name, datasource, services, used_ports)
        engine = str(requirement.get("technology") or "")
        if requirement.get("status") == "generate" and engine:
            if engine in generated_database_connections:
                connection = generated_database_connections[engine]
                requirement = duplicate_database_environment_requirement(datasource, engine, connection)
            else:
                generated_database_engines.add(engine)
                generated_database_connections[engine] = dict(requirement.get("connection", {}))
        requirements.append(requirement)
        if requirement.get("status") in {"generate", "configure"}:
            env_overrides.extend(
                environment_override_entries(
                    config,
                    datasource.get("path", ""),
                    requirement.get("application_env", {}),
                    str(requirement["id"]),
                )
            )
            arg_overrides.extend(
                application_argument_entries(
                    config,
                    datasource.get("path", ""),
                    requirement.get("application_args", []),
                    str(requirement["id"]),
                )
            )

    if persistence.get("tables") and not generated_database_engines and not database_service_candidates(services):
        requirements.append(
            {
                "id": "database-manual-review",
                "kind": "database",
                "technology": "unknown",
                "status": "manual_review",
                "confidence": "low",
                "source": "persistence model",
                "reason": "Persistence tables were detected, but no datasource URL or database service identifies the engine.",
            }
        )

    persistence_tables = persistence.get("tables", [])
    table_names = {str(table.get("name", "")) for table in persistence_tables}
    ddl_plan = {
        "source": "persistence code",
        "tables": len([name for name in table_names if name]),
        "engines": ["h2", "mysql", "postgresql"] if table_names else [],
    }
    dml_plan = {
        "source": "local bootstrap seed rules",
        "statements": len(local_seed_statements(persistence_tables, "h2")) if table_names else 0,
        "engines": ["h2", "mysql", "postgresql"] if table_names else [],
    }

    emit("Scanning runtime dependency signals")
    signals = inspect_runtime_environment_signals(root, scan_cache=scan_cache)
    # Union non-JVM (Node/Python/Go/Rust) infra dependency signals into the
    # same dict so the existing runtime_signal_requirement dispatcher applies
    # uniformly. Only the four infra kinds with a dispatcher entry are
    # carried (redis/kafka/mongo/search); the 20-per-kind cap from the JVM
    # scanner is preserved here.
    try:
        command_signals = inspect_command_service_runtime_signals(root, scan_cache=scan_cache)
    except Exception:
        command_signals = {}
    for kind, extras in command_signals.items():
        if kind not in signals:
            continue
        existing_paths = {entry.get("path") for entry in signals[kind]}
        for entry in extras:
            if len(signals[kind]) >= 20:
                break
            if entry.get("path") in existing_paths:
                continue
            signals[kind].append(entry)
            existing_paths.add(entry.get("path"))

    for kind in ("redis", "kafka", "mongo", "search", "object_storage", "config_server"):
        requirement = runtime_signal_requirement(name, kind, signals.get(kind, []), services, used_ports)
        if not requirement:
            continue
        requirements.append(requirement)
        if requirement.get("status") in {"generate", "configure"}:
            env_overrides.extend(
                environment_override_entries(
                    config,
                    "",
                    requirement.get("application_env", {}),
                    str(requirement["id"]),
                )
            )
            arg_overrides.extend(
                application_argument_entries(config, "", requirement.get("application_args", []), str(requirement["id"]))
            )

    emit("Inspecting Spring local profiles")
    profiles = inspect_spring_profiles(root, scan_cache=scan_cache)
    profile_requirement = spring_local_profile_requirement(root, profiles=profiles)
    if profile_requirement:
        requirements.append(profile_requirement)
        env_overrides.extend(
            environment_override_entries(
                config,
                "",
                profile_requirement.get("application_env", {}),
                str(profile_requirement["id"]),
            )
        )
        arg_overrides.extend(
            application_argument_entries(config, "", profile_requirement.get("application_args", []), str(profile_requirement["id"]))
        )

    emit("Inspecting Spring Batch local requirements")
    for batch_requirement in inspect_spring_batch_requirements(root, scan_cache=scan_cache):
        requirements.append(batch_requirement)
        env_overrides.extend(
            environment_override_entries(
                config,
                batch_requirement["source"],
                batch_requirement.get("application_env", {}),
                str(batch_requirement["id"]),
            )
        )
        arg_overrides.extend(
            application_argument_entries(
                config,
                batch_requirement["source"],
                batch_requirement.get("application_args", []),
                str(batch_requirement["id"]),
            )
        )

    emit("Inspecting conditional Spring properties")
    for conditional_requirement in inspect_conditional_property_requirements(root, scan_cache=scan_cache):
        requirements.append(conditional_requirement)
        env_overrides.extend(
            environment_override_entries(
                config,
                conditional_requirement["source"],
                conditional_requirement.get("application_env", {}),
                str(conditional_requirement["id"]),
            )
        )

    emit("Inspecting external HTTP dependency candidates")
    external = inspect_external_http_candidates(root, scan_cache=scan_cache)
    if external:
        mock_requirement = external_http_mock_requirement(name, external, services, used_ports)
        if mock_requirement:
            requirements.append(mock_requirement)
            used_ports.add(int(mock_requirement["port"]))
        mock_port = int(mock_requirement["port"]) if mock_requirement and mock_requirement.get("port") else 1080
        for index, candidate in enumerate(external, start=1):
            application_env = external_http_candidate_env(candidate, mock_port, services)
            status = "configure" if application_env else "manual_review"
            sibling_port = sibling_gradle_service_port(candidate, services) if application_env else None
            if not application_env:
                reason = "HTTP client code was detected, but the target property could not be identified for override."
            elif sibling_port is not None:
                reason = (
                    "External HTTP URL routed to sibling app at "
                    f"localhost:{sibling_port} (workspace-managed gradle service)."
                )
            else:
                reason = "External HTTP URL will be pointed at the local devstack mock endpoint."
            requirement = {
                "id": f"external-http-{index}",
                "kind": "external_http",
                "technology": "http",
                "status": status,
                "confidence": candidate["confidence"],
                "source": candidate["path"],
                "reason": reason,
                "target": candidate.get("value") or candidate.get("marker", ""),
                "application_env": application_env,
            }
            requirements.append(requirement)
            if status == "configure":
                env_overrides.extend(
                    environment_override_entries(config, candidate["path"], application_env, str(requirement["id"]))
                )
                arg_overrides.extend(
                    application_argument_entries(
                        config,
                        candidate["path"],
                        requirement.get("application_args", []),
                        str(requirement["id"]),
                    )
                )

    emit("Inspecting private Gradle repository requirements")
    requirements.extend(inspect_gradle_private_repository_requirements(root))

    emit("Inspecting environment variables and run profiles")
    variables = inspect_environment_variables(root, scan_cache=scan_cache)
    run_scripts = inspect_run_scripts(root)

    return {
        "requirements": requirements,
        "generated": [item for item in requirements if item.get("status") == "generate"],
        "provided": [item for item in requirements if item.get("status") == "provided"],
        "manual": [item for item in requirements if item.get("status") == "manual_review"],
        "env": env_overrides,
        "args": arg_overrides,
        "ddl": ddl_plan,
        "dml": dml_plan,
        "variables": variables,
        "profiles": profiles,
        "run_scripts": run_scripts,
        "external": external,
        "compose_path": str(managed_infra_compose_path(name)),
        "env_path": str(managed_env_path(name)),
    }


def inspect_gradle_private_repository_requirements(root: Path) -> List[Dict[str, Any]]:
    required_env: Set[str] = set()
    required_properties: Set[str] = set()
    sources: Set[str] = set()
    for path in [root / "settings.gradle", root / "settings.gradle.kts", root / "build.gradle", root / "build.gradle.kts"]:
        if not path.exists():
            continue
        text = path.read_text(errors="ignore")
        lowered = text.lower()
        configured_hosts = private_gradle_repository_hosts()
        if (
            "artifactory" not in lowered
            and "credentials" not in lowered
            and not any(host in lowered for host in configured_hosts)
        ):
            continue
        sources.add(relative_to_root(root, path))
        required_env.update(re.findall(r"environmentVariable\(\s*[\"']([A-Za-z_][A-Za-z0-9_]*)[\"']\s*\)", text))
        required_properties.update(re.findall(r"gradleProperty\(\s*[\"']([A-Za-z_][A-Za-z0-9_]*)[\"']\s*\)", text))

    if not sources:
        return []

    return [
        {
            "id": "gradle-private-repository-credentials",
            "kind": "build_dependency",
            "technology": "gradle-private-repository",
            "status": "configure",
            "confidence": "high",
            "source": ", ".join(sorted(sources)),
            "reason": (
                "Gradle private repository usage was detected; devstack will remove known private "
                "remote repositories and prefer local/public dependency resolution in the generated run config."
            ),
            "required_env": sorted(required_env),
            "required_properties": sorted(required_properties),
        }
    ]


def database_environment_requirement(
    name: str,
    datasource: Dict[str, str],
    services: Dict[str, Any],
    used_ports: Set[int],
) -> Dict[str, Any]:
    parsed = parse_jdbc_url(datasource.get("url", ""))
    engine = normalize_database_engine(parsed.get("engine", ""))
    source = datasource.get("path", "")
    if not engine:
        return {
            "id": f"database-unknown-{requirement_id_suffix(source, datasource.get('key', ''))}",
            "kind": "database",
            "technology": "unknown",
            "status": "manual_review",
            "confidence": "low",
            "source": source,
            "reason": f"Datasource URL could not be classified: {datasource.get('url', '')}",
            "url": datasource.get("url", ""),
        }

    if engine == "h2":
        return {
            "id": "database-h2",
            "kind": "database",
            "technology": engine,
            "status": "manual_review",
            "confidence": "high",
            "source": source,
            "reason": "Embedded H2 datasource detected; devstack does not replace Docker-backed database runtime with H2.",
            "url": datasource.get("url", ""),
        }

    if engine not in MANAGED_DATABASES:
        return {
            "id": f"database-{engine}-manual-{requirement_id_suffix(source, datasource.get('key', ''))}",
            "kind": "database",
            "technology": engine,
            "status": "manual_review",
            "confidence": "medium",
            "source": source,
            "reason": f"{engine} datasource detected, but devstack has no Docker-managed template for this database engine.",
            "url": datasource.get("url", ""),
        }

    provided = existing_database_services(services, engine)
    if provided:
        managed_connection = managed_database_service_connection(name, services, provided[0], engine, parsed)
        if managed_connection:
            application_env = datasource_application_env(
                datasource,
                managed_connection["url"],
                managed_connection["username"],
                managed_connection["password"],
                managed_connection["driver"],
                managed_connection["host"],
                managed_connection["database"],
                managed_connection["port"],
            )
            return {
                "id": f"database-{engine}-configure-{requirement_id_suffix(source, datasource.get('key', ''))}",
                "kind": "database",
                "technology": engine,
                "status": "configure",
                "confidence": "high",
                "source": source,
                "reason": "Existing devstack-managed database will be used with service-specific property overrides.",
                "provided_by": provided,
                "url": datasource.get("url", ""),
                "application_env": application_env,
                "application_args": datasource_application_args(datasource),
            }
        return {
            "id": f"database-{engine}",
            "kind": "database",
            "technology": engine,
            "status": "provided",
            "confidence": "high",
            "source": source,
            "reason": "Existing compose service appears to provide this database.",
            "provided_by": provided,
            "url": datasource.get("url", ""),
        }

    host = parsed.get("host", "")
    if host and is_symbolic_host(host):
        reason = f"Datasource host {host!r} is symbolic; devstack will generate a Docker-backed {engine} database."
    elif host and not is_local_or_symbolic_host(host):
        reason = f"Datasource host {host!r} is remote; devstack will generate a Docker-backed {engine} database."
    else:
        reason = "Local datasource URL detected and no existing database compose service was found."

    defaults = MANAGED_DATABASES[engine]
    label = defaults["label"]
    database = safe_database_name(parsed.get("database") or name)
    port = allocate_port(int(parsed.get("port") or defaults["port"]), used_ports)
    used_ports.add(port)
    username = defaults["username"]
    password = defaults["password"]
    application_url = jdbc_url(engine, port, database)
    compose_env = database_compose_environment(engine, database, username, password)
    application_env = datasource_application_env(
        datasource,
        application_url,
        username,
        password,
        database_driver_class(engine),
        "localhost",
        database,
        str(port),
    )

    return {
        "id": f"database-{label}",
        "kind": "database",
        "technology": engine,
        "status": "generate",
        "confidence": "high",
        "source": source,
        "reason": reason,
        "url": datasource.get("url", ""),
        "service_name": f"{MANAGED_INFRA_PREFIX}.{label}",
        "compose_service": label,
        "image": defaults["image"],
        "port": port,
        "container_port": int(defaults["container_port"]),
        "environment": compose_env,
        "volumes": database_data_volumes(engine, label),
        "application_env": application_env,
        "application_args": datasource_application_args(datasource),
        "connection": {
            "url": application_url,
            "username": username,
            "password": password,
            "driver": database_driver_class(engine),
            "host": "localhost",
            "database": database,
            "port": str(port),
        },
    }


def managed_database_service_connection(
    name: str,
    services: Dict[str, Any],
    service_name: str,
    engine: str,
    parsed: Dict[str, Any],
) -> Dict[str, str]:
    service = services.get(service_name)
    if not isinstance(service, dict) or not is_managed_infra_service_name(service_name):
        return {}

