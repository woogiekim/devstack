def graphql_query_fields(module_dir: Path) -> Set[str]:
    fields: Set[str] = set()
    graphql_dir = module_dir / "src" / "main" / "resources" / "graphql"
    if not graphql_dir.exists():
        return fields
    for path in sorted(graphql_dir.rglob("*.graphql*")):
        text = read_small_text(path)
        for body in re.findall(r"type\s+Query\s*\{(.*?)\}", text, flags=re.DOTALL):
            for match in re.finditer(r"^\s*([A-Za-z_][A-Za-z0-9_]*)\s*(?:\(|:)", body, flags=re.MULTILINE):
                fields.add(match.group(1))
    return fields


def module_contains_dgs_query(module_dir: Path) -> bool:
    source_dir = module_dir / "src" / "main"
    if not source_dir.exists():
        return False
    for suffix in ("*.java", "*.kt"):
        for path in source_dir.rglob(suffix):
            if ignored_generated_source_path(path):
                continue
            text = read_small_text(path)
            if "@DgsQuery" in text:
                return True
    return False


def ignored_generated_source_path(path: Path) -> bool:
    return any(part in {"build", "generated"} for part in path.parts)


def spring_boot_application_package(module_dir: Path) -> str:
    source_dir = module_dir / "src" / "main"
    if not source_dir.exists():
        return ""
    for suffix in ("*.kt", "*.java"):
        for path in sorted(source_dir.rglob(suffix)):
            text = read_small_text(path)
            if "@SpringBootApplication" not in text:
                continue
            match = re.search(r"^\s*package\s+([A-Za-z_][A-Za-z0-9_.]*)", text, re.MULTILINE)
            if match:
                return f"{match.group(1)}.devstack.local"
    return ""


