      }});
      if (doctorServiceTargets) {{
        doctorServiceTargets.hidden = !isFailedScope;
      }}
      if (doctorTargetTools) {{
        doctorTargetTools.hidden = !isFailedScope || failedCount === 0;
      }}
      if (doctorNoFailedServices) {{
        doctorNoFailedServices.hidden = failedCount > 0;
      }}
      const selectedCount = doctorSelectedServices().length;
      if (doctorTargetSummary) {{
        doctorTargetSummary.textContent = isFailedScope
          ? (failedCount ? selectedCount + " of " + failedCount + " failed service target(s) selected." : "No failed services detected.")
          : "Doctor will inspect all services.";
      }}
      if (startDoctorWorkflowButton) {{
        startDoctorWorkflowButton.disabled = Boolean(doctorStatusTimer) || !workspaceReady || (isFailedScope && selectedCount === 0);
      }}
      updateDoctorGuidance();
