def datasource_application_env(
    datasource: Dict[str, str],
    url: str,
    username: str,
    password: str,
    driver_class: str,
    host: str,
    database: str,
    port: str,
) -> Dict[str, str]:
    env = {
        "SPRING_DATASOURCE_URL": url,
        "SPRING_DATASOURCE_DRIVER_CLASS_NAME": driver_class,
        "SPRING_DATASOURCE_USERNAME": username,
        "SPRING_DATASOURCE_PASSWORD": password,
    }
    if port:
        env["SPRING_DATASOURCE_PORT"] = str(port)

    key = datasource.get("key", "").strip()
    if key:
        env[property_key_to_env_name(key)] = url
        base_key = datasource_base_property_key(key)
        if base_key:
            env[property_key_to_env_name(f"{base_key}.driver-class-name")] = driver_class
            env[property_key_to_env_name(f"{base_key}.username")] = username
            env[property_key_to_env_name(f"{base_key}.password")] = password
            if port:
                env[property_key_to_env_name(f"{base_key}.port")] = str(port)

    env.update(datasource_placeholder_env(datasource.get("url", ""), host, database, username, password, port))
    return env


def datasource_application_args(datasource: Dict[str, str]) -> List[str]:
    return []


def datasource_placeholder_env(
    url: str,
    host: str,
    database: str,
    username: str,
    password: str,
    port: str,
) -> Dict[str, str]:
    env: Dict[str, str] = {}
    database_prefixes: Set[str] = set()
    port_value = str(port or parse_jdbc_url(url).get("port") or "")
    for placeholder in re.findall(r"\$\{([^}:]+)(?::[^}]*)?\}", str(url)):
        lowered = placeholder.lower()
        value = ""
        if lowered.endswith(".host"):
            value = host
            database_prefixes.add(placeholder[: -len(".host")])
        elif lowered.endswith(".port"):
            value = port_value
            database_prefixes.add(placeholder[: -len(".port")])
        elif lowered.endswith((".db", ".database", ".name")):
            value = database
            suffix = placeholder.rsplit(".", 1)[-1]
            database_prefixes.add(placeholder[: -(len(suffix) + 1)])
        elif lowered.endswith((".username", ".user")):
            value = username
        elif lowered.endswith((".password", ".pass")):
            value = password
        if value:
            env[property_key_to_env_name(placeholder)] = value
    for prefix in database_prefixes:
        if port_value:
            env.setdefault(property_key_to_env_name(f"{prefix}.port"), port_value)
        env.setdefault(property_key_to_env_name(f"{prefix}.username"), username)
        env.setdefault(property_key_to_env_name(f"{prefix}.password"), password)
    return env


def datasource_base_property_key(key: str) -> str:
    lowered = key.lower()
    for suffix in (".jdbc-url", ".jdbcurl", ".url"):
        if lowered.endswith(suffix):
            return key[: -len(suffix)]
    return ""


def property_key_to_env_name(key: str) -> str:
    return re.sub(r"_+", "_", re.sub(r"[^A-Za-z0-9]+", "_", key)).strip("_").upper()


def requirement_id_suffix(*values: str) -> str:
    digest = hashlib.sha1("|".join(values).encode("utf-8")).hexdigest()
    return digest[:8]


