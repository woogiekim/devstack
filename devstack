# ---------------------------------------------------------------------------
# Compat shim 1 — env_read(name, default=None)
# ---------------------------------------------------------------------------
# Reads DEVSTACK_<name> if present; else falls back to CCSTACK_<name> with a
# one-time stderr deprecation warning per variable. Apply at every
# environment read site that used to look at CCSTACK_*. Centralising the
# fallback here keeps the read sites short and the warning policy uniform.

_ENV_READ_WARNED: Set[str] = set()


def env_read(name: str, default: Optional[str] = None) -> Optional[str]:
    """Read the named environment variable, preferring DEVSTACK_<name>.

    Falls back to CCSTACK_<name> when only the legacy variable is set, and
    emits a deprecation warning to stderr at most once per ``name`` per
    process. Returns ``default`` when neither variable is set.
    """
    new_key = f"DEVSTACK_{name}"
    legacy_key = f"CCSTACK_{name}"
    new_value = os.environ.get(new_key)
    if new_value is not None:
        return new_value
    legacy_value = os.environ.get(legacy_key)
    if legacy_value is not None:
        if legacy_key not in _ENV_READ_WARNED:
            _ENV_READ_WARNED.add(legacy_key)
            sys.stderr.write(
                f"devstack: warning: {legacy_key} is deprecated; "
                f"set {new_key} instead. Using legacy value for this run.\n"
            )
        return legacy_value
    return default


def _reset_env_read_warned_for_tests() -> None:
    """Clear the per-process warned-set. Tests only."""
    _ENV_READ_WARNED.clear()


# ---------------------------------------------------------------------------
# Compat shim 2 — State home resolution
# ---------------------------------------------------------------------------
# Prefer ``~/.devstack``; fall back to existing ``~/.devstack`` only when
# ``~/.devstack`` does not exist AND ``~/.devstack`` does. Never auto-moves
# data — operators upgrade on their own schedule. When neither exists, the
# new canonical path is returned (callers create directories on demand).


def resolve_state_home(home_dir: Optional[Path] = None) -> Path:
    home = Path(home_dir) if home_dir is not None else Path.home()
    new_path = home / ".devstack"
    legacy_path = home / ".ccstack"
    if new_path.exists():
        return new_path
    if legacy_path.exists():
        return legacy_path
    return new_path


