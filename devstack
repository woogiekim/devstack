      }}
      .logs-toolbar {{
        grid-template-columns: 1fr;
        align-items: stretch;
      }}
      .logs-tools {{
        justify-content: stretch;
      }}
      .logs-tools button {{
        flex: 1 1 auto;
      }}
      .logs-shell-status {{
        justify-content: flex-start;
      }}
      .logs-dock.is-minimized .logs-panel,
      .logs-panel.is-minimized {{
        right: 10px;
        bottom: 64px;
        width: calc(100vw - 20px);
      }}
      .logs-toggle {{
        right: 10px;
        bottom: 64px;
      }}
      .drawer-header {{ grid-template-columns: minmax(0, 1fr) auto; }}
      .buttons {{ grid-template-columns: 1fr; }}
      .service-cards {{ grid-template-columns: 1fr; }}
      .service-workspace {{ grid-template-columns: 1fr; }}
      .state-overview {{ gap: 8px 12px; }}
      .workspace-toolbar {{ grid-template-columns: 1fr; }}
      .workspace-toolbar-actions {{
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        justify-content: stretch;
      }}
      .workspace-toolbar-actions button {{
        min-width: 0;
        width: 100%;
      }}
      .workspace-summary {{ grid-template-columns: 1fr; }}
      .ai-doctor-head,
      .doctor-workflow,
      .doctor-actions {{
        grid-template-columns: 1fr;
      }}
      .doctor-scope {{
        grid-template-columns: 1fr;
      }}
      .doctor-status {{
        justify-self: start;
      }}
      .action-panel-title {{ align-items: flex-start; flex-direction: column; }}
      .action-panel-title span {{ text-align: left; }}
      .advanced-entry {{ grid-template-columns: 1fr; align-items: stretch; }}
      .advanced-entry button {{ width: 100%; }}
      .path-row {{ grid-template-columns: 1fr; }}
      .wizard {{ grid-template-columns: 1fr; gap: 4px; }}
      .wizard-step {{
        grid-template-columns: 26px minmax(0, 1fr);
        min-height: 34px;
        padding-right: 0;
      }}
      .wizard-step::after {{
        top: 28px;
        left: 13px;
        right: auto;
        width: 2px;
        height: 14px;
      }}
      .wizard-marker {{
        width: 26px;
        height: 26px;
      }}
      .activity {{
        height: 72px;
        min-height: 72px;
        max-height: 72px;
        padding-right: 10px;
      }}
      .statusline {{ grid-template-columns: 1fr; }}
      .status-actions {{ justify-content: space-between; flex-wrap: wrap; }}
      .doctor-output-bar {{ grid-template-columns: 1fr; }}
      #streamState {{ text-align: left; }}
      .brand {{ align-items: flex-start; flex-direction: column; }}
      .top-metrics {{ justify-content: flex-start; }}
      .doctor-output {{ display: grid; }}
      pre {{
        height: auto;
        min-height: 0;
        max-height: none;
      }}
    }}
  </style>
</head>
<body>
  <div class="global-activity" id="globalActivity" aria-live="polite" aria-busy="false">
    <span class="spinner" aria-hidden="true"></span>
    <span class="global-activity-text">
      <strong id="globalActivityTitle">Working</strong>
      <span id="globalActivityDetail">Preparing request</span>
    </span>
  </div>
  <header>
    <div class="brand">
      <div>
        <div class="eyebrow">Local service operations</div>
        <h1>devstack</h1>
        <div class="sub">{workspace_name} · {root}</div>
      </div>
      <div class="top-metrics">
        <span class="metric"><strong>{service_count}</strong> services</span>
        <span class="metric"><strong>{server_count}</strong> apps</span>
        <span class="metric"><strong>{infra_count}</strong> infra</span>
      </div>
    </div>
  </header>
  <main>
    <section class="control-panel" id="controlPanel">
      <div class="control-viewport">
        <div class="control-pages" id="controlPages">
          <div class="control-page control-page-main" id="mainControlPage" data-control-page="main" aria-hidden="false">
            <div class="section-title">
              <h2>Workspace Control</h2>
              <span class="pill" id="workspaceStatusPill">{workspace_status_text}</span>
            </div>
            <label for="workspace">Workspace</label>
            <select id="workspace">{workspace_options}</select>
            <label for="workspaceRoot">Local path</label>
            <div class="path-row">
              <input id="workspaceRoot" type="text" value="{workspace_root_value}" placeholder="{workspace_root_placeholder}">
              <button class="soft" id="browseWorkspace" type="button">Browse</button>
            </div>
            <div class="workspace-summary" aria-label="Workspace summary">
              <div class="summary-item">
                <span>Registration</span>
                <strong id="workspaceLifecycleState">{workspace_status_label}</strong>
              </div>
              <div class="summary-item">
                <span>Root</span>
                <strong>{workspace_root_summary}</strong>
              </div>
              <div class="summary-item">
                <span>Draft</span>
                <strong id="draftStatus">{draft_status_label}</strong>
              </div>
            </div>
            <input id="draftId" type="hidden" value="">
            <ol class="wizard" aria-label="Workspace setup progress">
              <li class="wizard-step is-active" data-step="bind" aria-current="step">
                <span class="wizard-marker" aria-hidden="true">1</span>
                <span class="wizard-label">Setup</span>
              </li>
              <li class="wizard-step" data-step="analyze">
                <span class="wizard-marker" aria-hidden="true">2</span>
                <span class="wizard-label">Analyze</span>
              </li>
              <li class="wizard-step" data-step="review">
                <span class="wizard-marker" aria-hidden="true">3</span>
                <span class="wizard-label">Review</span>
              </li>
              <li class="wizard-step" data-step="apply">
                <span class="wizard-marker" aria-hidden="true">4</span>
                <span class="wizard-label">Apply</span>
              </li>
            </ol>
            <div class="workspace-progress" id="workspaceProgress" aria-live="polite" aria-busy="false">
              <div class="workspace-progress-head">
                <strong>Analysis progress</strong>
                <span class="workspace-progress-status">
                  <span class="workspace-progress-spinner" id="workspaceProgressSpinner" aria-hidden="true"></span>
                  <span id="workspaceProgressState">Idle</span>
                </span>
              </div>
              <pre class="workspace-progress-log" id="workspaceProgressLog">No analysis yet.</pre>
            </div>
            <div class="action-panel">
              <div class="action-panel-title">
                <strong>Workspace Setup</strong>
                <span>Setup · Analyze · Register</span>
              </div>
              <div class="buttons setup-buttons">
                <button class="soft" id="bindWorkspace" type="button">Set up path</button>
                <button class="soft" data-action="workspace_analyze" data-requires-path="1">Analyze</button>
                <button class="primary" data-action="workspace_apply" data-requires-draft="1" disabled>Apply</button>
              </div>
            </div>
            <div class="action-panel">
              <div class="advanced-entry">
                <span>Service actions are on the service board. Advanced keeps options and workspace maintenance.</span>
                <button class="soft" id="openAdvanced" type="button" aria-controls="advancedControlPage" aria-expanded="false">Advanced</button>
              </div>
            </div>
          </div>
          <div class="control-page control-page-advanced" id="advancedControlPage" data-control-page="advanced" aria-hidden="true">
            <div class="detail-header">
              <button class="soft" id="backAdvanced" type="button">Back</button>
              <div class="detail-title">
                <h2>Advanced Settings</h2>
                <span>Execution options and destructive workspace actions</span>
              </div>
            </div>
            <div class="control-group">
              <div class="control-title">Execution Options</div>
              <div class="row">
                <div>
                  <label for="mode">Start mode</label>
                  <select id="mode">
                    <option value="full">full</option>
                    <option value="light">light</option>
                  </select>
                </div>
              </div>
              <div class="checks">
                <label><input id="noDeps" type="checkbox"> no deps</label>
              </div>
            </div>
            <div class="control-group">
              <div class="control-title">Workspace Maintenance</div>
              <div class="buttons danger-buttons">
                <button class="danger" data-action="workspace_delete" data-requires-workspace="1"{stack_disabled_attr}>Delete</button>
                <button class="danger" data-action="workspace_delete" data-purge="1" data-requires-workspace="1"{stack_disabled_attr}>Purge</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <section class="service-board-panel" aria-label="Service board panel">
      <div class="section-title">
        <h2>Service Board</h2>
        <span class="pill" id="serviceBoardStatus">live</span>
      </div>
      <div class="service-board" aria-label="Service board">
        <div class="state-overview" aria-label="Service state summary">
          <div class="state-item">
            <span class="state-dot" aria-hidden="true"></span>
            <span>Running</span>
            <strong id="servicesRunningCount">0</strong>
          </div>
          <div class="state-item attention">
            <span class="state-dot" aria-hidden="true"></span>
            <span>Attention</span>
            <strong id="servicesAttentionCount">0</strong>
          </div>
          <div class="state-item stopped">
            <span class="state-dot" aria-hidden="true"></span>
            <span>Stopped</span>
            <strong id="servicesStoppedCount">0</strong>
          </div>
        </div>
        <div class="workspace-toolbar">
          <label for="target">
            <span>Target</span>
            <select id="target">{target_options}</select>
          </label>
          <div class="workspace-toolbar-actions">
            {refresh_button}
            <button data-action="up" data-requires-workspace="1"{stack_disabled_attr}>Start target</button>
            <button class="danger" data-action="down" data-requires-workspace="1"{stack_disabled_attr}>Stop target</button>
          </div>
        </div>
        <div class="service-board-title">
          <strong>Services</strong>
          <span>state, health, logs, and focused actions</span>
        </div>
        <div class="service-workspace">
          <div class="service-roster">
            <label class="service-search" for="serviceSearch">
              <span>Search services</span>
              <input id="serviceSearch" type="search" placeholder="service name, role, type, port">
            </label>
            <div class="service-cards">{service_cards}</div>
          </div>
          <div class="service-detail" aria-label="Selected service detail">
            <div class="detail-service-head">
              <span>Selected service</span>
              <strong id="selectedServiceName">{selected_service_label}</strong>
            </div>
            <div class="detail-health-strip">
              <div class="detail-chip">
                <span>State</span>
                <strong id="selectedServiceState">checking</strong>
              </div>
              <div class="detail-chip">
                <span>Next</span>
                <strong id="selectedServiceNext">Start</strong>
              </div>
              <div class="detail-chip">
                <span>Role</span>
                <strong id="selectedServiceRole">-</strong>
              </div>
              <div class="detail-chip">
                <span>Endpoint</span>
                <strong id="selectedServiceEndpoint">-</strong>
              </div>
            </div>
            <div class="service-board-actions" aria-label="Selected service actions">
              <select id="service" hidden{service_select_disabled_attr}>{service_options}</select>
              <div class="buttons service-board-buttons detail-actions">
                <button data-action="up" data-use-mode="1" data-service-only="1" data-requires-workspace="1" data-requires-service="1"{service_action_disabled_attr}>Start</button>
                <button class="danger" data-action="down" data-service-only="1" data-requires-workspace="1" data-requires-service="1"{service_action_disabled_attr}>Stop</button>
                <button data-action="restart" data-requires-workspace="1" data-requires-service="1"{service_action_disabled_attr}>Restart</button>
                <button class="soft" data-action="logs" data-requires-workspace="1" data-requires-service="1"{service_action_disabled_attr}>Logs</button>
                <button class="soft" data-action="recover" data-recover-scope="selected-service" data-requires-workspace="1" data-requires-service="1"{service_action_disabled_attr}>Recover</button>
              </div>
            </div>
            <div class="detail-next">
              <strong id="selectedServiceHint">Waiting for status</strong>
              <span id="selectedServiceMeta">Select a service to inspect its role, endpoint, health, and operational actions.</span>
            </div>
          </div>
        </div>
      </div>
    </section>
    <aside class="ai-doctor-aside" aria-label="AI Doctor panel">
      <div class="ai-doctor-panel" id="aiDoctorPanel" aria-label="AI Doctor guided workflow">
        <div class="ai-doctor-head">
          <div class="ai-doctor-title">
            <strong>AI Doctor</strong>
            <span>Diagnose service issues with a guided host workflow. Technical output stays in details.</span>
          </div>
          <span class="pill doctor-status" id="doctorStatusPill">ready</span>
          <span class="doctor-heartbeat" id="doctorHeartbeat" aria-live="polite" hidden></span>
        </div>
        <div class="doctor-workflow">
          <div class="doctor-controls">
            <div class="ai-agent-picker" id="aiAgentPicker" aria-label="AI assistant">
              <button class="ai-agent is-active" type="button" data-ai-agent="claude" aria-pressed="true">
                <span class="ai-agent-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" role="img" aria-label="Claude">
                    <path fill="#D97757" d="m4.7144 15.9555 4.7174-2.6471.079-.2307-.079-.1275h-.2307l-.7893-.0486-2.6956-.0729-2.3375-.0971-2.2646-.1214-.5707-.1215-.5343-.7042.0546-.3522.4797-.3218.686.0608 1.5179.1032 2.2767.1578 1.6514.0972 2.4468.255h.3886l.0546-.1579-.1336-.0971-.1032-.0972L6.973 9.8356l-2.55-1.6879-1.3356-.9714-.7225-.4918-.3643-.4614-.1578-1.0078.6557-.7225.8803.0607.2246.0607.8925.686 1.9064 1.4754 2.4893 1.8336.3643.3035.1457-.1032.0182-.0728-.164-.2733-1.3539-2.4467-1.445-2.4893-.6435-1.032-.17-.6194c-.0607-.255-.1032-.4674-.1032-.7285L6.287.1335 6.6997 0l.9957.1336.419.3642.6192 1.4147 1.0018 2.2282 1.5543 3.0296.4553.8985.2429.8318.091.255h.1579v-.1457l.1275-1.706.2368-2.0947.2307-2.6957.0789-.7589.3764-.9107.7468-.4918.5828.2793.4797.686-.0668.4433-.2853 1.8517-.5586 2.9021-.3643 1.9429h.2125l.2429-.2429.9835-1.3053 1.6514-2.0643.7286-.8196.85-.9046.5464-.4311h1.0321l.759 1.1293-.34 1.1657-1.0625 1.3478-.8804 1.1414-1.2628 1.7-.7893 1.36.0729.1093.1882-.0183 2.8535-.607 1.5421-.2794 1.8396-.3157.8318.3886.091.3946-.3278.8075-1.967.4857-2.3072.4614-3.4364.8136-.0425.0304.0486.0607 1.5482.1457.6618.0364h1.621l3.0175.2247.7892.522.4736.6376-.079.4857-1.2142.6193-1.6393-.3886-3.825-.9107-1.3113-.3279h-.1822v.1093l1.0929 1.0686 2.0035 1.8092 2.5075 2.3314.1275.5768-.3218.4554-.34-.0486-2.2039-1.6575-.85-.7468-1.9246-1.621h-.1275v.17l.4432.6496 2.3436 3.5214.1214 1.0807-.17.3521-.6071.2125-.6679-.1214-1.3721-1.9246L14.38 17.959l-1.1414-1.9428-.1397.079-.674 7.2552-.3156.3703-.7286.2793-.6071-.4614-.3218-.7468.3218-1.4753.3886-1.9246.3157-1.53.2853-1.9004.17-.6314-.0121-.0425-.1397.0182-1.4328 1.9672-2.1796 2.9446-1.7243 1.8456-.4128.164-.7164-.3704.0667-.6618.4008-.5889 2.386-3.0357 1.4389-1.882.929-1.0868-.0062-.1579h-.0546l-6.3385 4.1164-1.1293.1457-.4857-.4554.0608-.7467.2307-.2429 1.9064-1.3114Z"/>
                  </svg>
                </span> Claude
              </button>
              <button class="ai-agent" type="button" data-ai-agent="codex" aria-pressed="false">
                <span class="ai-agent-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" role="img" aria-label="Codex">
                    <path fill="#74AA9C" d="M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729z"/>
                  </svg>
                </span> Codex
              </button>
              <button class="ai-agent" type="button" data-ai-agent="gemini" aria-pressed="false">
                <span class="ai-agent-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" role="img" aria-label="Gemini">
                    <path fill="#8E75B2" d="M11.04 19.32Q12 21.51 12 24q0-2.49.93-4.68.96-2.19 2.58-3.81t3.81-2.55Q21.51 12 24 12q-2.49 0-4.68-.93a12.3 12.3 0 0 1-3.81-2.58 12.3 12.3 0 0 1-2.58-3.81Q12 2.49 12 0q0 2.49-.96 4.68-.93 2.19-2.55 3.81a12.3 12.3 0 0 1-3.81 2.58Q2.49 12 0 12q2.49 0 4.68.96 2.19.93 3.81 2.55t2.55 3.81"/>
                  </svg>
                </span> Gemini
              </button>
            </div>
            <div class="doctor-scope" role="radiogroup" aria-label="Doctor service scope">
              <label><input type="radio" name="doctorScope" value="all" checked> All services</label>
              <label><input type="radio" name="doctorScope" value="failed"> Failed services</label>
            </div>
            <div class="doctor-service-targets" id="doctorServiceTargets" hidden>
              {doctor_service_targets}
            </div>
            <div class="doctor-target-tools" id="doctorTargetTools" hidden>
              <button class="soft" id="doctorSelectAllFailed" type="button">Select all failed</button>
              <button class="soft" id="doctorClearFailed" type="button">Clear failed</button>
            </div>
            <div class="doctor-actions">
              <span class="hint" id="doctorTargetSummary">Doctor will inspect all services.</span>
              <button class="primary" id="startDoctorWorkflow" type="button" data-requires-workspace="1"{stack_disabled_attr}>Start diagnosis</button>
              <button class="soft" id="doctorCancelButton" type="button" hidden disabled>Cancel diagnosis</button>
              <button class="soft" id="doctorDetailsButton" type="button" hidden disabled>Details</button>
            </div>
          </div>
          <div class="doctor-run-status" aria-live="polite">
            <strong id="doctorOutcome">Ready to diagnose</strong>
            <span id="doctorRecommendation">Choose a host and scope, then start diagnosis.</span>
            <div class="doctor-technical-details" id="doctorTechnicalDetails">
              <span class="doctor-technical-title">Technical details</span>
              <pre id="doctorTechnicalOutput">No doctor run yet.</pre>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </main>
  <div class="drawer-backdrop" id="drawerBackdrop" aria-hidden="true"></div>
  <div class="logs-backdrop" id="logsBackdrop" aria-hidden="true"></div>
  <div class="logs-dock" id="logsDock">
    <aside class="logs-panel" id="logsPanel" role="dialog" aria-labelledby="logsTitle" aria-hidden="true">
      <div class="drawer-header">
        <div class="drawer-title">
          <span class="drawer-eyebrow">Logs</span>
          <h2 id="logsTitle">Service logs</h2>
          <span class="drawer-meta" id="logsMeta">Select a service from the board</span>
        </div>
        <button class="soft drawer-close" id="closeLogsPanel" type="button" aria-label="Minimize logs layer">&minus;</button>
      </div>
      <div class="activity" id="logsActivity" aria-live="polite" aria-busy="false">
        <span class="spinner" aria-hidden="true"></span>
        <div class="activity-copy">
          <strong id="logsActivityTitle">Loading logs</strong>
          <span id="logsActivityDetail">Reading recent service output</span>
        </div>
      </div>
      <div class="statusline">
        <span id="logsCommand">devstack logs</span>
        <div class="status-actions">
          <strong id="logsResult">idle</strong>
        </div>
      </div>
      <div class="logs-toolbar" aria-label="Logs tools">
        <label class="logs-field" for="logsLines">
          <span>Tail</span>
          <input id="logsLines" type="number" min="20" max="2000" value="120" step="10">
        </label>
        <div></div>
        <div class="logs-tools">
          <button class="soft" id="followLogs" type="button">Follow</button>
          <button class="soft" id="stopLogsFollow" type="button" disabled>Stop follow</button>
          <button class="soft" id="copyLogs" type="button">Copy</button>
          <button class="soft" id="clearLogs" type="button">Clear log</button>
        </div>
      </div>
      <div class="logs-shell">
        <div class="logs-shell-bar">
          <span id="logsServiceName">devstack://logs</span>
          <div class="logs-shell-status">
            <button class="soft logs-jump" id="jumpToLatestLogs" type="button" hidden>Jump to latest</button>
            <span id="logsStreamState">idle</span>
          </div>
        </div>
        <div class="logs-output-body">
          <pre class="logs-output" id="logsOutput">Select a service and open logs.</pre>
        </div>
      </div>
    </aside>
    <button class="logs-toggle" id="logsToggle" type="button" aria-label="Restore logs layer" aria-controls="logsPanel" aria-expanded="false" title="Restore logs layer">
      <span class="console-glyph" aria-hidden="true">log</span>
    </button>
  </div>
  <div class="console-dock" id="consoleDock">
    <aside class="output-panel" id="outputPanel" role="dialog" aria-labelledby="drawerTitle" aria-hidden="true" data-console-mode="doctor">
      <div class="drawer-header">
        <div class="drawer-title">
          <span class="drawer-eyebrow">Details</span>
          <h2 id="drawerTitle">AI Doctor details</h2>
          <span class="drawer-meta" id="drawerMeta">Technical status, prompt, and log details</span>
        </div>
        <button class="soft drawer-close" id="closeOutputPanel" type="button" aria-label="Minimize doctor panel">&minus;</button>
      </div>
      <div class="statusline">
        <span id="command">devstack doctor</span>
        <div class="status-actions">
          <strong id="result">idle</strong>
        </div>
      </div>
      <div class="console-toolbar" aria-label="Console tools">
        <span>AI Doctor technical details</span>
        <div class="console-tools">
          <button class="soft" id="copyOutput" type="button">Copy</button>
          <button class="soft" id="clearOutput" type="button">Clear</button>
        </div>
      </div>
      <div class="doctor-output">
        <div class="doctor-output-bar">
          <span>devstack://doctor</span>
          <span id="streamState">idle</span>
        </div>
        <div class="doctor-output-body">
          <pre id="output">Ready.</pre>
        </div>
      </div>
    </aside>
    <button class="console-toggle" id="consoleToggle" type="button" aria-label="Show AI Doctor details" aria-controls="outputPanel" aria-expanded="false" title="Show AI Doctor details">
      <span class="console-glyph" aria-hidden="true">tech</span>
      <span class="console-dot" aria-hidden="true"></span>
    </button>
  </div>
  <script>
    const outputPanel = document.querySelector("#outputPanel");
    const aiDoctorPanel = document.querySelector("#aiDoctorPanel");
    const logsPanel = document.querySelector("#logsPanel");
