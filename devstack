      logsActivity.classList.toggle("active", isLoading);
      logsActivity.setAttribute("aria-busy", isLoading ? "true" : "false");
      if (isLoading) {{
        logsActivityTitle.textContent = title;
        logsActivityDetail.textContent = detail;
      }}
    }}

    function logsLineValue() {{
      const min = Number(logsLinesInput?.min || 20);
      const max = Number(logsLinesInput?.max || 2000);
      const value = Number(logsLinesInput?.value || min);
      if (!Number.isFinite(value)) {{
        return min;
      }}
      return Math.min(max, Math.max(min, Math.trunc(value)));
    }}

    function setLogsLineValue(nextValue) {{
      const min = Number(logsLinesInput?.min || 20);
      const max = Number(logsLinesInput?.max || 2000);
      const next = Math.min(max, Math.max(min, Math.trunc(Number(nextValue) || min)));
      if (logsLinesInput) {{
        logsLinesInput.value = String(next);
      }}
    }}

