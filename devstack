def inspect_conditional_property_requirements(
    root: Path,
    scan_cache: Optional[WorkspaceScanCache] = None,
) -> List[Dict[str, Any]]:
    requirements: List[Dict[str, Any]] = []
    seen: Set[Tuple[str, str, str]] = set()
    for path in persistence_source_files(root, scan_cache=scan_cache):
        text = read_small_text(path, scan_cache=scan_cache)
        if "@ConditionalOnProperty" not in text:
            continue
        for body in conditional_on_property_bodies(text):
            property_name = conditional_property_name(body)
            property_value = conditional_property_having_value(body)
            if not property_name or not property_value:
                continue
            source = relative_to_root(root, path)
            key = (source, property_name, property_value)
            if key in seen:
                continue
            seen.add(key)
            requirements.append(
                {
                    "id": f"conditional-property-{requirement_id_suffix(*key)}",
                    "kind": "runtime_property",
                    "technology": "spring-conditional-property",
                    "status": "configure",
                    "confidence": "medium",
                    "source": source,
                    "reason": (
                        f"Spring ConditionalOnProperty requires {property_name}={property_value} "
                        "for local service beans."
                    ),
                    "application_env": {
                        property_key_to_env_name(property_name): property_value,
                    },
                }
            )
    return requirements[:30]


def conditional_on_property_bodies(text: str) -> List[str]:
    return re.findall(r"@ConditionalOnProperty\s*\((.*?)\)", text, re.DOTALL)


def conditional_property_name(body: str) -> str:
    match = re.search(r"\b(?:name|value)\s*=\s*(?:\[\s*)?[\"']([^\"']+)[\"']", body)
    return match.group(1) if match else ""


def conditional_property_having_value(body: str) -> str:
    match = re.search(r"\bhavingValue\s*=\s*[\"']([^\"']+)[\"']", body)
    return match.group(1) if match else ""


def used_configured_ports(services: Dict[str, Any]) -> Set[int]:
    ports: Set[int] = set()
    for service in services.values():
        if not isinstance(service, dict) or not service.get("port"):
            continue
        try:
            ports.add(int(service["port"]))
        except (TypeError, ValueError):
            continue
    return ports


def registered_workspace_reserved_ports(
    current_name: str,
    current_root: Path,
    registry: Optional["WorkspaceRegistry"] = None,
) -> Set[int]:
    registry = registry or WorkspaceRegistry.load()
    current_root = current_root.expanduser().resolve()
    reserved: Set[int] = set()
    for entry in registry.entries():
        entry_name = str(entry["name"])
        entry_root = Path(entry["root"]).expanduser().resolve()
        if entry_name == current_name or entry_root == current_root:
            continue
        if not entry_root.is_dir():
            continue

        config_path = registry.config_path(entry_name, entry_root)
        if not config_path:
            continue
        try:
            config = load_json(config_path)
        except Exception:
            continue

        services = config.get("services", {})
        if isinstance(services, dict):
            reserved.update(used_configured_ports(services))
    return reserved


def allocate_port(preferred: int, used_ports: Set[int]) -> int:
    port = preferred
    while port in used_ports:
        port += 1
    return port


def parse_jdbc_url(url: str) -> Dict[str, Any]:
    url = str(url).strip()
    _placeholder = re.match(r'^\$\{[^}]*:(jdbc:[^}]+)\}$', url)
    if _placeholder:
        url = _placeholder.group(1)
    match = re.match(r"jdbc:([^:]+):(.*)", url)
    if not match:
        return {}
    engine, remainder = match.groups()
    if engine.lower() == "p6spy" and re.match(r"^[A-Za-z0-9_+-]+://", remainder):
        nested = parse_jdbc_url(f"jdbc:{remainder}")
        if nested:
            nested["raw"] = url
            nested["wrapper"] = "p6spy"
            return nested

    parsed: Dict[str, Any] = {"engine": engine.lower(), "raw": url}
    if not remainder.startswith("//"):
        return parsed

    authority_and_path = remainder[2:]
    authority, _, path_and_query = authority_and_path.partition("/")
    authority_host_port, _, authority_options = authority.partition(";")
    host, port = split_host_port(authority_host_port)
    parsed["host"] = host
    if port:
        parsed["port"] = port
    database = path_and_query.split("?", 1)[0].split(";", 1)[0].strip("/")
    if database:
        parsed["database"] = database
    if parsed["engine"].lower() in {"sqlserver", "jtds"}:
        options = ";".join(part for part in (authority_options, path_and_query) if part)
        match = re.search(r"(?:^|;)databaseName=([^;]+)", options, re.IGNORECASE)
        if match:
            parsed["database"] = match.group(1)
    return parsed


def split_host_port(authority: str) -> Tuple[str, Optional[int]]:
    if not authority:
        return "", None
    if authority.startswith("["):
        host, _, rest = authority[1:].partition("]")
        port_text = rest[1:] if rest.startswith(":") else ""
        return host, int(port_text) if port_text.isdigit() else None
    host, _, port_text = authority.partition(":")
    return host, int(port_text) if port_text.isdigit() else None


def normalize_database_engine(engine: str) -> str:
    value = engine.lower().strip()
    aliases = {
        "postgres": "postgresql",
        "pgsql": "postgresql",
        "maria": "mariadb",
        "sqlserver": "mssql",
        "jtds": "mssql",
    }
    return aliases.get(value, value)


def is_local_or_symbolic_host(host: str) -> bool:
    value = host.lower().strip()
    if not value or is_symbolic_host(value):
        return True
    return value in {"localhost", "127.0.0.1", "0.0.0.0", "::1", "db", "database", "postgres", "postgresql", "mysql", "mariadb"}


def is_symbolic_host(host: str) -> bool:
    value = host.lower().strip()
    return value.startswith("${") or "$" in value


def safe_database_name(value: str) -> str:
    cleaned = re.sub(r"[^A-Za-z0-9_]+", "_", value.strip().strip("/"))
    return cleaned.strip("_") or "app"


def jdbc_url(engine: str, port: int, database: str) -> str:
    if engine == "mssql":
        return (
            f"jdbc:sqlserver://localhost:{port};databaseName={database};"
            "encrypt=false;trustServerCertificate=true"
        )
    jdbc_engine = "postgresql" if engine == "postgresql" else engine
    return f"jdbc:{jdbc_engine}://localhost:{port}/{database}"


def database_compose_environment(engine: str, database: str, username: str, password: str) -> Dict[str, str]:
    if engine == "postgresql":
        return {
            "POSTGRES_DB": database,
            "POSTGRES_USER": username,
            "POSTGRES_PASSWORD": password,
        }
    if engine in {"mysql", "mariadb"}:
        return {
            "MYSQL_DATABASE": database,
            "MYSQL_USER": username,
            "MYSQL_PASSWORD": password,
            "MYSQL_ROOT_PASSWORD": password,
        }
    if engine == "mssql":
        return {
            "ACCEPT_EULA": "Y",
            "MSSQL_SA_PASSWORD": password,
            "MSSQL_PID": "Developer",
        }
    return {}


def database_data_volumes(engine: str, label: str) -> List[str]:
