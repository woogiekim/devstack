def dispatch_workspace(args: argparse.Namespace) -> int:
    registry = WorkspaceRegistry.load()

    if args.workspace_command == "list":
        entries = registry.entries()
        if args.json:
            print(json.dumps(registry.as_json(), ensure_ascii=False, indent=2))
            return 0
        if not entries:
            print("No registered workspaces.")
            print(workspace_guidance())
            return 0
        for entry in entries:
            marker = "*" if entry["default"] else " "
            status = "ok" if registry.config_path(entry["name"], entry["root"]) else f"missing {CONFIG_NAME}"
            print(f"{marker} {entry['name']:24} {entry['root']} ({status})")
        return 0

    if args.workspace_command == "default":
        if not args.name:
            default = registry.default
            if not default:
                raise DevstackError(f"default workspace is not set. {workspace_guidance()}")
            root = registry.resolve(default)
            print(f"{default}: {root}")
            return 0
        registry.set_default(args.name)
        registry.save()
        print(f"default workspace: {args.name}")
        return 0

    if args.workspace_command == "register":
        root = workspace_setup_root(args.root)
        name, manifest_path, config_source = prepare_workspace_config(
            root,
            name=args.name,
            write_manifest=False,
        )
        registry.register(name, root, manifest_path if config_source == "generated" else None)
        if args.default or not registry.default:
            registry.default = name
        registry.save()
        write_workspace_state(name, root, manifest_path, config_source)
        print(f"registered workspace: {name} -> {root}")
        print(f"config: {manifest_path}")
        if registry.default == name:
            print(f"default workspace: {name}")
        return 0

    if args.workspace_command == "setup":
        root = workspace_setup_root(args.root)
        name, manifest_path, config_source = prepare_workspace_config(
            root,
            name=args.name,
            write_manifest=args.write_manifest,
        )
        registry.register(name, root, manifest_path if config_source == "generated" else None)
        if args.default or not registry.default:
            registry.default = name
        registry.save()
        write_workspace_state(name, root, manifest_path, config_source)
        print(f"workspace: {name}")
        print(f"root: {root}")
        print(f"config: {manifest_path}")
        print(f"registered: yes")
        if registry.default == name:
            print(f"default workspace: {name}")
        return 0

    if args.workspace_command in {"remove", "delete", "purge"}:
        purge = bool(getattr(args, "purge", False) or args.workspace_command == "purge")
        removed = delete_registered_workspace(args.name, purge=purge)
        verb = "purged" if purge else "removed"
        print(f"{verb} workspace: {removed['name']}")
        print(f"root preserved: {removed['root']}")
        if removed.get("config"):
            print(f"config preserved: {removed['config']}")
        for path in removed.get("purged", []):
            print(f"purged state: {path}")
        if removed.get("default"):
            print("default workspace cleared")
        return 0

    raise DevstackError(f"unsupported workspace command: {args.workspace_command}")


def dispatch_uninstall(args: argparse.Namespace) -> int:
    targets = uninstall_targets(purge_state=args.purge_state)
    print_uninstall_targets(targets, dry_run=args.dry_run)

    if args.dry_run:
        return 0

    if not args.yes:
        if not sys.stdin.isatty():
            raise DevstackError("uninstall requires --yes when running non-interactively")
        answer = input("Proceed with uninstall? [y/N]: ").strip().lower()
        if answer not in {"y", "yes"}:
            print("uninstall cancelled")
            return 0

    results = apply_uninstall_targets(targets)
    print_uninstall_results(results)
    return 0


def run_ui(workspace: "Workspace", host: str, port: int, open_browser: bool) -> int:
    server = DevstackUiServer((host, port), DevstackUiHandler)
    server.workspace = workspace
    server.registry = WorkspaceRegistry.load()
    server.auto_run = bool(
        not workspace.config.get("workspace_setup")
        and (server.registry.default == workspace.name or len(server.registry.entries()) <= 1)
    )
    url = f"http://{host}:{port}"
    print(f"devstack UI: {url}")
    print(f"workspace: {workspace.name} ({workspace.root})")
    print("Press Ctrl+C to stop.")
    if open_browser:
        webbrowser.open(url)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print()
        return 0
    finally:
        server.server_close()
    return 0


class DevstackUiServer(http.server.ThreadingHTTPServer):
    workspace: "Workspace"
    registry: "WorkspaceRegistry"
    auto_run: bool


class DevstackUiHandler(http.server.BaseHTTPRequestHandler):
    server: DevstackUiServer

    def do_GET(self) -> None:
        parsed = urllib.parse.urlparse(self.path)
        self.server.registry = WorkspaceRegistry.load()
        if parsed.path == "/":
            params = urllib.parse.parse_qs(parsed.query)
            try:
                workspace = resolve_ui_workspace(self.server.workspace, self.server.registry, params)
            except DevstackError:
                workspace = self.server.workspace
            self.send_html(ui_page(workspace, self.server.registry, self.server.auto_run))
            return
        if parsed.path == "/api/meta":
            params = urllib.parse.parse_qs(parsed.query)
            workspace = resolve_ui_workspace(self.server.workspace, self.server.registry, params)
            self.send_json(workspace_meta(workspace, self.server.registry))
            return
        if parsed.path == "/api/logs/follow":
            params = urllib.parse.parse_qs(parsed.query)
            try:
                workspace = resolve_ui_workspace(self.server.workspace, self.server.registry, params)
                self.stream_follow_logs(workspace, params)
            except DevstackError as error:
                self.send_error(400, str(error))
            return
        if parsed.path == "/api/workspace/analyze/stream":
            params = urllib.parse.parse_qs(parsed.query)
            self.stream_workspace_analyze(params)
            return
        if parsed.path == "/api/run":
            self.send_error(405, "Use POST for devstack actions")
            return
        self.send_error(404)

    def do_POST(self) -> None:
        parsed = urllib.parse.urlparse(self.path)
        self.server.registry = WorkspaceRegistry.load()
        if parsed.path not in {
            "/api/run",
            "/api/pick-directory",
        }:
            self.send_error(404)
            return

        if ui_source_is_stale():
            self.send_json(ui_error(stale_ui_message()))
            return

        length = int(self.headers.get("Content-Length", "0"))
        body = self.rfile.read(length).decode("utf-8")
        params = urllib.parse.parse_qs(body)
        if parsed.path == "/api/pick-directory":
            result = execute_pick_directory(params)
            self.send_json(result)
            return

        try:
            workspace = resolve_ui_workspace(self.server.workspace, self.server.registry, params)
            result = execute_ui_action(workspace, params)
        except DevstackError as error:
            result = ui_error(str(error))
        self.send_json(result)

    def log_message(self, fmt: str, *args: Any) -> None:
        print("devstack-ui:", fmt % args)

    def send_html(self, body: str) -> None:
        data = body.encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def send_json(self, payload: Dict[str, Any]) -> None:
        data = json.dumps(payload, ensure_ascii=False).encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def stream_follow_logs(self, workspace: "Workspace", params: Dict[str, List[str]]) -> None:
        service = first_param(params, "service", "")
        lines = first_param(params, "lines", "120")
        cmd = ui_log_follow_command(workspace, service, lines)

        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream; charset=utf-8")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("X-Accel-Buffering", "no")
        self.end_headers()

        process = subprocess.Popen(
            cmd,
            cwd=workspace.root,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            start_new_session=True,
        )
        try:
            self.write_sse("status", {"message": "following"})
            if process.stdout is None:
                raise DevstackError("log stream did not open")
            self.pipe_process_to_sse(process)
        except (BrokenPipeError, ConnectionResetError):
            pass
        finally:
            if process.poll() is None:
                terminate_pid_or_group(process.pid, signal.SIGTERM, "log follow")
                try:
                    process.wait(timeout=2)
                except subprocess.TimeoutExpired:
                    terminate_pid_or_group(process.pid, signal.SIGKILL, "log follow")

    def stream_workspace_analyze(self, params: Dict[str, List[str]]) -> None:
        root_value = first_param(params, "workspace_root", "")

        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream; charset=utf-8")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("X-Accel-Buffering", "no")
        self.end_headers()

        try:
            if ui_source_is_stale():
                self.write_sse("done", ui_error(stale_ui_message()))
                return

            draft = analyze_workspace_draft(
                root_value,
                progress=lambda message: self.write_sse("log", {"chunk": message}),
            )
            self.write_sse(
                "done",
                {
                    "ok": True,
                    "returncode": 0,
                    "output": format_workspace_draft(draft),
                    "elapsed": 0,
                    "command": f"devstack workspace analyze {draft['root']}",
                    "draft": draft,
                    "draft_id": draft["draft_id"],
                    "status": "review",
                },
            )
        except DevstackError as error:
            self.write_sse("done", ui_error(str(error)))
        except (BrokenPipeError, ConnectionResetError):
            pass

    def pipe_process_to_sse(self, process: subprocess.Popen[bytes]) -> None:
        assert process.stdout is not None
        fd = process.stdout.fileno()
        next_ping = time.time() + 2

        while True:
            if process.poll() is not None:
                remainder = os.read(fd, 4096)
                if remainder:
                    self.write_sse("log", {"chunk": remainder.decode("utf-8", errors="replace")})
                break

            readable, _, _ = select.select([fd], [], [], 0.5)
            if readable:
                chunk = os.read(fd, 4096)
                if not chunk:
                    break
                self.write_sse("log", {"chunk": chunk.decode("utf-8", errors="replace")})

            if time.time() >= next_ping:
                self.wfile.write(b": keepalive\n\n")
                self.wfile.flush()
                next_ping = time.time() + 2

        returncode = process.wait()
        self.write_sse("done", {"returncode": returncode})

    def write_sse(self, event: str, payload: Dict[str, Any]) -> None:
        data = json.dumps(payload, ensure_ascii=False)
        message = f"event: {event}\ndata: {data}\n\n".encode("utf-8")
        self.wfile.write(message)
        self.wfile.flush()


def resolve_ui_workspace(
    fallback: "Workspace",
    registry: "WorkspaceRegistry",
    params: Dict[str, List[str]],
) -> "Workspace":
    name = first_param(params, "workspace", "")
    if not name:
        return fallback
    if name == NEW_WORKSPACE_ID:
        return Workspace(Path.cwd().resolve(), setup_workspace_config(Path.cwd().resolve()))

    root = registry.resolve(name)
    config = dict(load_workspace_config(root, registry, name))
    config["workspace_setup"] = False
    return Workspace(root, config)


def ui_source_is_stale(source_path: Optional[Path] = None, loaded_mtime: Optional[float] = None) -> bool:
    path = source_path or Path(__file__).resolve()
    loaded = UI_SOURCE_MTIME if loaded_mtime is None else loaded_mtime
    try:
        current = path.stat().st_mtime
    except OSError:
        return False
    return current > loaded + 0.001


def stale_ui_message() -> str:
    return (
        "devstack UI is running with an older in-memory version. "
        "Restart the UI process and retry the action."
    )


def setup_workspace_config(root: Path, name: str = NEW_WORKSPACE_ID, label: str = "Add workspace") -> Dict[str, Any]:
    return {
        "workspace": name,
        "workspace_label": label,
        "workspace_setup": True,
        "profiles": {"default": {"services": []}},
        "services": {},
    }


def registered_workspace_catalog(registry: Optional["WorkspaceRegistry"] = None) -> List[Dict[str, Any]]:
    registry = registry or WorkspaceRegistry.load()
    catalog: List[Dict[str, Any]] = []
    for entry in registry.entries():
        config_path = registry.config_path(entry["name"], entry["root"])
        catalog.append(
            {
                "id": entry["name"],
                "label": entry["name"],
                "registered": bool(config_path),
                "root": str(entry["root"]),
                "default": entry["default"],
            }
        )
    return catalog


def analyze_workspace_draft(root_value: str, progress: Optional[Callable[[str], None]] = None) -> Dict[str, Any]:
    def emit(message: str) -> None:
        if progress:
            progress(f"{datetime.datetime.now().strftime('%H:%M:%S')}  {message}\n")

    emit("Validating workspace path")
    if not root_value.strip():
        raise DevstackError("workspace root is required")

    root = Path(root_value).expanduser().resolve()
    if not root.exists() or not root.is_dir():
        raise DevstackError(f"workspace root is not a directory: {root}")

    emit(f"Workspace root: {root}")
    # Shim 3 — accept ``.devstack.json`` or legacy ``.ccstack.json``.
    repo_config = resolve_manifest_path(root) or (root / CONFIG_NAME)
    registry = WorkspaceRegistry.load()
    if repo_config.exists():
        emit(f"Reading existing {repo_config.name}")
        config = load_json(repo_config)
        requested_name = str(config.get("workspace") or root.name)
        name = unique_workspace_name_for_root(requested_name, root, registry)
        if name != requested_name:
            emit(f"Workspace name {requested_name!r} is already registered for another root; using {name!r}")
        config["workspace"] = name
        reserved_ports = registered_workspace_reserved_ports(name, root)
        config, augment = augment_workspace_config(root, config, reserved_ports=reserved_ports)
        if augment.get("added_services"):
            emit(f"Detected {len(augment['added_services'])} additional Gradle server service(s)")
        if augment.get("port_reassignments"):
            emit(f"Resolved {len(augment['port_reassignments'])} service port conflict(s)")
        config_source = "repo"
        manifest_path = repo_config
    else:
        emit("No project manifest found; generating devstack config")
        requested_name = root.name
        name = unique_workspace_name_for_root(requested_name, root, registry)
        if name != requested_name:
            emit(f"Workspace name {requested_name!r} is already registered for another root; using {name!r}")
        reserved_ports = registered_workspace_reserved_ports(name, root)
        emit("Inspecting Docker Compose and Gradle/Spring services")
        config = inspect_workspace(root, name, reserved_ports=reserved_ports)
        emit(f"Detected {len(config.get('services', {}))} service(s)")
        config_source = "generated"
        manifest_path = workspace_draft_manifest_path(workspace_draft_id(root, name))
        write_json(manifest_path, config)

    draft_id = workspace_draft_id(root, name)
    if config_source == "generated":
        manifest_path = workspace_draft_manifest_path(draft_id)
        write_json(manifest_path, config)

    draft = {
        "draft_id": draft_id,
        "workspace": name,
        "root": str(root),
        "config": str(manifest_path),
        "config_source": config_source,
        "status": "draft",
        "analysis": analyze_workspace_config(root, config, progress=emit, reserved_ports=reserved_ports),
        "updated_at": datetime.datetime.now(datetime.timezone.utc).isoformat(),
    }
    emit("Writing workspace draft")
    write_json(workspace_draft_path(draft_id), draft)
    emit("Analysis complete. Review the result, then Apply")
    return draft


def apply_workspace_draft(draft_id: str, recreate_volumes: bool = False) -> Dict[str, Any]:
    """Apply a previously analyzed workspace draft.

    When `recreate_volumes` is True the caller has explicitly opted in to
    destroying docker named volumes managed by devstack (compose `down` +
    `docker volume rm`) so a fresh `docker compose up` picks up the new
    DDL/DML seed scripts. Default `recreate_volumes=False` preserves the
    historical warn-only behavior: a `seed_changed` flag is surfaced on
    the result object but no destructive docker call is made.
    """
    if not draft_id.strip():
        raise DevstackError("workspace draft is required. Run Analyze before Apply.")

    draft = load_workspace_draft(draft_id)
    root = Path(draft["root"]).expanduser().resolve()
    name = str(draft["workspace"])
    registry = WorkspaceRegistry.load()
    resolved_name = unique_workspace_name_for_root(name, root, registry)
    if resolved_name != name:
        name = resolved_name
        draft["workspace"] = name
    config_source = str(draft["config_source"])
    draft_manifest = Path(draft["config"]).expanduser().resolve()
    if not root.exists() or not root.is_dir():
        raise DevstackError(f"workspace root no longer exists: {root}. Set up the path and Analyze again.")

    if config_source == "repo":
        # Shim 3 — re-discovery preserves the legacy filename if present.
        manifest_path = resolve_manifest_path(root) or (root / CONFIG_NAME)
        if not manifest_path.exists():
            raise DevstackError(f"{CONFIG_NAME} no longer exists under {root}. Analyze again.")
        config = load_json(manifest_path)
        repo_workspace_name = str(config.get("workspace") or root.name)
        force_generated_manifest = repo_workspace_name != name
        if force_generated_manifest:
            config["workspace"] = name
        reserved_ports = registered_workspace_reserved_ports(name, root)
        config, augment = augment_workspace_config(root, config, reserved_ports=reserved_ports)
        config, managed_environment = materialize_managed_environment(name, root, config, draft.get("analysis", {}))
        if augment.get("changed") or managed_environment or force_generated_manifest:
            manifest_path = generated_manifest_path(name)
            write_json(manifest_path, config)
            registry_manifest = manifest_path
            effective_config_source = "managed"
        else:
            registry_manifest = None
            effective_config_source = config_source
    else:
        if not draft_manifest.exists():
            raise DevstackError(f"workspace draft config is missing: {draft_manifest}. Analyze again.")
        config = load_json(draft_manifest)
        config["workspace"] = name
        reserved_ports = registered_workspace_reserved_ports(name, root)
        config, augment = augment_workspace_config(root, config, reserved_ports=reserved_ports)
        config, managed_environment = materialize_managed_environment(name, root, config, draft.get("analysis", {}))
        manifest_path = generated_manifest_path(name)
        write_json(manifest_path, config)
        registry_manifest = manifest_path
        effective_config_source = "managed" if augment.get("changed") or managed_environment else config_source

    registry.register(name, root, registry_manifest)
    registry.default = name
    registry.save()
    write_workspace_state(name, root, manifest_path, effective_config_source)

    draft["status"] = "applied"
    draft["applied_at"] = datetime.datetime.now(datetime.timezone.utc).isoformat()
    draft["config"] = str(manifest_path)
    draft["applied_config_source"] = effective_config_source
    write_json(workspace_draft_path(draft_id), draft)

    seed_changed = bool(managed_environment.get("seed_changed")) if managed_environment else False
    named_volumes = list(managed_environment.get("named_volumes", []) or []) if managed_environment else []
    volume_recreation: Dict[str, Any] = {
        "requested": bool(recreate_volumes),
        "performed": False,
        "removed": [],
        "errors": [],
        "available_volumes": named_volumes,
    }
    if recreate_volumes and named_volumes:
        # Opt-in path only — caller has explicitly authorized data destruction.
        summary = recreate_managed_named_volumes(name, config)
        volume_recreation["performed"] = True
        volume_recreation["removed"] = summary.get("removed", [])
        volume_recreation["errors"] = summary.get("errors", [])

    # Seed-drift readiness state — see SEED_DRIFT_FILENAME comment for the
    # full rationale. The persisted record drives the DEGRADED render in
    # `print_status` / `workspace_meta` until drift is cleared.
    #
    # Decision rules:
    #   - persist when drift is present AND named-volume recreation was NOT
    #     opted into (or recreation was opted into but produced errors AND no
    #     volumes were actually removed — we conservatively keep DEGRADED in
    #     that case so the user is not lulled into thinking the drift cleared)
    #   - clear when fingerprint matches restored (seed_changed=False) OR when
    #     recreate was opted into and at least one volume was removed without
    #     errors
    fingerprint_current = ""
    fingerprint_previous = ""
    if managed_environment:
        fingerprint_current = str(managed_environment.get("seed_fingerprint", "") or "")
        fingerprint_previous = str(managed_environment.get("seed_fingerprint_previous", "") or "")

    recreate_resolved_drift = bool(
        recreate_volumes
        and volume_recreation["performed"]
        and volume_recreation["removed"]
        and not volume_recreation["errors"]
    )

    warnings: List[Dict[str, Any]] = []
    if seed_changed and not recreate_resolved_drift:
        affected_services = seed_drift_affected_services(managed_environment or {}, config)
        drift_state = {
            "workspace": name,
            "recorded_at": datetime.datetime.now(datetime.timezone.utc).isoformat(),
            "fingerprint_previous": fingerprint_previous,
            "fingerprint_current":  fingerprint_current,
            "named_volumes": named_volumes,
            "affected_services": affected_services,
            "remediation": format_seed_drift_remediation(name),
        }
        write_seed_drift_state(name, drift_state)
        warnings.append(seed_drift_warning_entry(drift_state))
    else:
        # Either fingerprint match restored, or destructive recreate cleared
        # the drift. Idempotent — safe to call when no record exists.
        clear_seed_drift_state(name)

    return {
        "name": name,
        "root": str(root),
        "config": str(manifest_path),
        "config_source": effective_config_source,
        "managed_environment": managed_environment,
        "analysis": draft.get("analysis", {}),
        "seed_changed": seed_changed,
        "named_volumes": named_volumes,
        "volume_recreation": volume_recreation,
        "warnings": warnings,
    }


def delete_registered_workspace(name: str, purge: bool = False) -> Dict[str, Any]:
    if not name.strip() or name == NEW_WORKSPACE_ID:
        raise DevstackError("registered workspace name is required")

    registry = WorkspaceRegistry.load()
    removed = registry.unregister(name)
    registry.save()
    removed["purged"] = purge_workspace_state(name) if purge else []
    return removed


def purge_workspace_state(name: str) -> List[str]:
    state_dir = STATE_HOME / safe_name(name)
    if not path_under(state_dir, STATE_HOME):
        raise DevstackError(f"refusing to purge state outside {STATE_HOME}: {state_dir}")
    if not state_dir.exists():
        return []

    shutil.rmtree(state_dir)
    return [str(state_dir)]


def path_under(path: Path, parent: Path) -> bool:
    try:
        path.resolve().relative_to(parent.resolve())
        return True
    except ValueError:
        return False


def load_workspace_draft(draft_id: str) -> Dict[str, Any]:
    path = workspace_draft_path(draft_id)
    if not path.exists():
        raise DevstackError(f"workspace draft not found: {draft_id}")
    return load_json(path)


def workspace_draft_id(root: Path, name: str) -> str:
    return f"{safe_name(name)}-{workspace_root_digest(root)}"


def workspace_root_digest(root: Path) -> str:
    return hashlib.sha1(str(root.expanduser().resolve()).encode("utf-8")).hexdigest()[:10]


def unique_workspace_name_for_root(
    requested_name: str,
    root: Path,
    registry: Optional["WorkspaceRegistry"] = None,
    explicit: bool = False,
) -> str:
    name = str(requested_name or root.name).strip() or root.name
    registry = registry or WorkspaceRegistry.load()
    root = root.expanduser().resolve()
    existing_root = registry.workspaces.get(name)
    if not existing_root or same_workspace_root(existing_root, root):
        return name

    if explicit:
        raise DevstackError(
            f"workspace name {name!r} is already registered for {Path(existing_root).expanduser().resolve()}. "
            "Use a unique --name or remove the old workspace registration first."
        )

    base = f"{name}-{workspace_root_digest(root)}"
    candidate = base
    suffix = 2
    while True:
        existing_candidate_root = registry.workspaces.get(candidate)
        if not existing_candidate_root or same_workspace_root(existing_candidate_root, root):
            return candidate
        candidate = f"{base}-{suffix}"
        suffix += 1


def same_workspace_root(left: Any, right: Any) -> bool:
    return Path(left).expanduser().resolve() == Path(right).expanduser().resolve()


def workspace_draft_path(draft_id: str) -> Path:
    return STATE_HOME / "_drafts" / safe_name(draft_id) / "draft.json"


def workspace_draft_manifest_path(draft_id: str) -> Path:
    return STATE_HOME / "_drafts" / safe_name(draft_id) / "devstack.generated.json"


def managed_infra_dir(name: str) -> Path:
    return STATE_HOME / safe_name(name) / "infra"


def managed_infra_compose_path(name: str) -> Path:
    return managed_infra_dir(name) / "docker-compose.devstack.yml"


def managed_compose_project_name(name: str) -> str:
    normalized = re.sub(r"[^a-z0-9_-]+", "_", safe_name(name).lower()).strip("_-")
    return f"devstack_{normalized or 'workspace'}"


def managed_compose_network_name(name: str) -> str:
    normalized = re.sub(r"[^a-z0-9_-]+", "_", safe_name(name).lower()).strip("_-")
    return f"devstack_{normalized or 'workspace'}_net"


def managed_env_path(name: str) -> Path:
    return managed_infra_dir(name) / "devstack.env"


def managed_gradle_init_path(name: str) -> Path:
    return managed_infra_dir(name) / MANAGED_GRADLE_INIT_NAME


def managed_schema_dir(name: str) -> Path:
    return managed_infra_dir(name) / "schema"


def managed_schema_path(name: str, engine: str) -> Path:
    return managed_schema_dir(name) / f"devstack-local-schema-{engine}.sql"


def managed_dml_path(name: str, engine: str) -> Path:
    return managed_schema_dir(name) / f"devstack-local-dml-{engine}.sql"


def versioned_sql_path(path: Path, text: str) -> Path:
    digest = hashlib.sha256(text.encode("utf-8")).hexdigest()[:12]
    return path.with_name(f"{path.stem}-{digest}{path.suffix}")


# ---------------------------------------------------------------------------
# Domain overrides (declarative per-workspace customization)
# ---------------------------------------------------------------------------
# The devstack engine is domain-agnostic. Per-workspace business-domain data
# (mockserver trigger keywords + response envelopes, seed table rows, column
# enum literals, verification probes, GraphQL field gates) lives in an
# external JSON file that the engine consumes declaratively. The shipped
# shopping-domain overrides live at examples/overrides/sample-shop/.devstack-
# overrides.json and reproduce the historical hardcoded behavior when copied
# into a workspace root. A workspace with no overrides file gets purely
# derived/generic engine behavior.

# Module-level cache so repeated lookups during a single materialize pass
# do not re-parse the JSON. Keyed by (str(root), workspace_name).
_DOMAIN_OVERRIDES_CACHE: Dict[Tuple[str, str], Dict[str, Any]] = {}


def domain_overrides_repo_path(root: Path) -> Path:
    """Return the canonical repo-level overrides file path (devstack name).

    Callers that need to honor the legacy ``.devstack-overrides.json`` filename
    should go through ``load_domain_overrides`` which checks both. The
    canonical path is exposed here so writers and "where to create the file"
    paths refer to the new name.
    """
    return Path(root) / DOMAIN_OVERRIDES_REPO_FILENAME


def legacy_domain_overrides_repo_path(root: Path) -> Path:
    """Return the legacy repo-level overrides file path (Shim 4)."""
    return Path(root) / LEGACY_DOMAIN_OVERRIDES_REPO_FILENAME


def domain_overrides_infra_path(workspace_name: str) -> Path:
    return managed_infra_dir(workspace_name) / DOMAIN_OVERRIDES_INFRA_FILENAME


def load_domain_overrides(root: Path, workspace_name: str) -> Dict[str, Any]:
    """Load the per-workspace domain overrides JSON.

    Lookup precedence (first match wins):
      1. ``<root>/.devstack-overrides.json`` (repo-level canonical).
      2. ``<root>/.devstack-overrides.json`` (repo-level legacy, Shim 4).
      3. ``managed_infra_dir(workspace_name) / "devstack-domain-overrides.json"``
         (workspace-private — lives under the host state dir, not committed).

    Returns an empty dict when no file exists OR every candidate fails to
    parse. A malformed file never crashes the engine; instead the engine
    falls back to its built-in generic mechanism for every section.

    Cached per (root, workspace_name) so concurrent engine calls within a
    single materialize pass do not re-read the file. Call
    ``reset_domain_overrides_cache()`` from tests that need to swap overrides
    mid-run.
    """
    key = (str(root), str(workspace_name))
    cached = _DOMAIN_OVERRIDES_CACHE.get(key)
    if cached is not None:
        return cached

    overrides: Dict[str, Any] = {}
    candidates = (
        domain_overrides_repo_path(root),
        legacy_domain_overrides_repo_path(root),
        domain_overrides_infra_path(workspace_name),
    )
    for path in candidates:
        try:
            if path.exists():
                with path.open("r", encoding="utf-8") as f:
                    parsed = json.load(f)
                if isinstance(parsed, dict):
                    overrides = parsed
                    break
        except (OSError, json.JSONDecodeError):
            # Malformed overrides file: fall through to the next candidate.
            # The engine never crashes on a bad overrides file — generic
            # behavior remains the safe default.
            continue

    _DOMAIN_OVERRIDES_CACHE[key] = overrides
    return overrides


def reset_domain_overrides_cache() -> None:
    """Clear the overrides cache. Tests use this to swap overrides between
    test cases that share the same tmp workspace key."""
    _DOMAIN_OVERRIDES_CACHE.clear()


def seed_fingerprint_path(name: str) -> Path:
    """Return the workspace-level DDL+DML fingerprint file path."""
    return managed_infra_dir(name) / SEED_FINGERPRINT_FILENAME


def compute_seed_fingerprint(
    schema_files: Dict[str, Path],
    dml_files: Dict[str, Path],
) -> str:
    """Compute a stable workspace-level DDL+DML fingerprint.

    The fingerprint is the first 16 hex chars of `sha256(json(<engine-sorted
    mapping of schema_text + dml_text>))`. Used by `apply_workspace_draft` to
    detect when the local seed pipeline has produced different DDL/DML
    output since the last apply, which in turn drives the warn-only
    `seed_changed` flag and the docker named-volume recreation opt-in.
    """
    parts: Dict[str, Dict[str, str]] = {}
    for engine, file_path in sorted(schema_files.items()):
        try:
            parts.setdefault(engine, {})["schema"] = Path(file_path).read_text(encoding="utf-8")
        except OSError:
            continue
    for engine, file_path in sorted(dml_files.items()):
        try:
            parts.setdefault(engine, {})["dml"] = Path(file_path).read_text(encoding="utf-8")
        except OSError:
            continue
    payload = json.dumps(parts, sort_keys=True, ensure_ascii=False)
    return hashlib.sha256(payload.encode("utf-8")).hexdigest()[:16]


def read_seed_fingerprint(name: str) -> str:
    """Return the previously persisted seed fingerprint, or empty string."""
    path = seed_fingerprint_path(name)
    try:
        return path.read_text(encoding="utf-8").strip()
    except OSError:
        return ""


def write_seed_fingerprint(name: str, fingerprint: str) -> Path:
    """Persist the current workspace DDL+DML fingerprint to disk."""
    path = seed_fingerprint_path(name)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(fingerprint + "\n", encoding="utf-8")
    return path


# -- Seed drift state -------------------------------------------------------
#
# When `apply_workspace_draft` detects a fingerprint change (`seed_changed`)
# AND the operator declined the destructive named-volume recreation, the drift
# is persisted to disk so later, independent processes (status / UI meta /
# status-counter aggregators) can render the workspace as DEGRADED instead of
# rendering as fully green. The record lives at
# `STATE_HOME/{name}/seed-drift.json` so it shares lifecycle with
# `workspace.json` (write_workspace_state) and is removed automatically by
# `purge_workspace_state`'s rmtree — no extra code needed at teardown.
#
# Boot is never blocked by drift; the file is a pure observability signal.


def seed_drift_state_path(name: str) -> Path:
    """Return the workspace-level persisted drift record path."""
    return STATE_HOME / safe_name(name) / SEED_DRIFT_FILENAME


def read_seed_drift_state(name: str) -> Dict[str, Any]:
    """Return the persisted drift record, or {} when absent / unreadable.

    Malformed JSON is treated as absent — the engine never crashes on a bad
    drift file. A status command that cannot read drift simply renders the
    workspace without the DEGRADED annotation; the next apply will re-derive
    the file.
    """
    path = seed_drift_state_path(name)
    if not path.exists():
        return {}
    try:
        data = load_json(path)
    except Exception:
        return {}
    return data if isinstance(data, dict) else {}


def write_seed_drift_state(name: str, payload: Dict[str, Any]) -> Path:
    """Persist the drift record. Parents are created on demand."""
    path = seed_drift_state_path(name)
    path.parent.mkdir(parents=True, exist_ok=True)
    write_json(path, payload)
    return path


def clear_seed_drift_state(name: str) -> bool:
    """Remove the persisted drift record. Idempotent; returns True iff a
    record was removed."""
    path = seed_drift_state_path(name)
    if path.exists():
        try:
            path.unlink()
            return True
        except OSError:
            return False
    return False


def seed_drift_affected_services(
    managed_environment: Dict[str, Any],
    config: Dict[str, Any],
) -> List[str]:
    """Compute the list of services flagged as DEGRADED by seed drift.

    A service is "affected" when:
      - it appears in `managed_environment['services']` (the managed compose
        infra services prepared by the current apply), AND
      - its name matches the `database_service_candidates` name heuristic
        (db / database / postgres / mysql / mariadb / oracle / mongo / redis /
        mssql), since seed drift specifically describes DDL/DML divergence
        affecting the database backends.

    Computed once at apply time and frozen into the persisted drift record so
    later status reads do not need to re-scan the live config.
    """
    managed_services = list(managed_environment.get("services", []) or [])
    if not managed_services:
        return []
    services = config.get("services") or {}
    if not isinstance(services, dict):
        return []
    candidate_names = {
        item["name"]
        for item in database_service_candidates({
            key: value
            for key, value in services.items()
            if key in managed_services
        })
    }
    return [name for name in managed_services if name in candidate_names]


def format_seed_drift_remediation(workspace_name: str) -> str:
    """The exact CLI form that clears the drift. Stable string — the
    follow-up status-counter task and the UI may both compare or display it
    verbatim."""
    return f"devstack workspace apply {workspace_name} --recreate-volumes"


def seed_drift_warning_entry(state: Dict[str, Any]) -> Dict[str, Any]:
    """Build the machine-readable warning entry consumed by workspace_meta
    and the apply result's `warnings` array. Stable schema so a follow-up
    status-counter task can aggregate by `code` / `level` without parsing
    free-text."""
    return {
        "code": "seed-drift",
        "level": "degraded",
        "workspace": state.get("workspace", ""),
        "affected_services": list(state.get("affected_services", []) or []),
        "named_volumes": list(state.get("named_volumes", []) or []),
        "remediation": state.get("remediation", ""),
        "fingerprint_previous": state.get("fingerprint_previous", ""),
        "fingerprint_current":  state.get("fingerprint_current", ""),
    }


# ---------------------------------------------------------------------------
# Grey-zone status counters
#
# Aggregates the machine-readable signals emitted by the four reliability
# features into four explicit counters that the `devstack status` CLI and the
# `workspace_meta` JSON surface render — so a workspace with grey-zone state
# never silently looks fully green. Aggregation is read-only: probe signals
# are read via the non-destructive `peek_managed_datasource_probe_signals`
# helper (calling `consume_*` here would damage the other readiness
# consumers); `devstack_status_notes` is read directly off the live service
# dicts; seed-drift comes from the persisted state file; and mock-fallback
# routes come from the additive `mock_fallback_routes` field persisted into
# `devstack_managed_environment` at materialize time.
#
# Counter keys are stable contract — do not rename:
#   degraded            workspace-level seed-drift state (and any future
#                       degraded reasons added under the same prefix).
#   low_confidence      probe signals with confidence ∈ {"low","degraded"}.
#                       Pre-existing manifest requirements carrying
#                       confidence in {"low","medium"} are NOT counted here:
#                       they describe an analysis-time inference, not a
#                       boot-time readiness gap.
#   mock_fallback       external-HTTP candidates routed to the mockserver
#                       fallback rather than a sibling gradle service.
#   unverified_binding  devstack_status_notes entries with
#                       key == "app_binding_unverified" (value truthy).
# ---------------------------------------------------------------------------

_GREY_ZONE_COUNTER_KEYS = (
    "degraded",
    "low_confidence",
    "mock_fallback",
    "unverified_binding",
    # unmanaged_dependency — analysis-time classification of datasource
    # engines outside MANAGED_DATABASES (Altibase, Oracle, DB2, Tibero,
    # CUBRID, ...). Counted from the persisted
    # ``devstack_managed_environment.manual_review`` array so a workspace
    # whose apps depend on an engine devstack cannot provision is reported
    # honestly at status time instead of failing namelessly at boot.
    # See ``count_unmanaged_datasource_dependencies`` for the boundary
    # rule (kind=database AND status=manual_review AND technology is
    # non-empty AND not in MANAGED_DATABASES AND not in {"h2","unknown"}).
    "unmanaged_dependency",
)

# Substring identifying the mockserver-fallback reason emitted in
# build_local_environment_plan for an external_http candidate that lacks a
# sibling gradle service. The sibling-routing reason starts with
# "External HTTP URL routed to sibling app at ..."; the fallback reason
# starts with "External HTTP URL will be pointed at the local devstack mock
# endpoint." Use the unique fallback substring so future reason changes
# stay isolated to one literal.
_MOCK_FALLBACK_REASON_PREFIX = "External HTTP URL will be pointed at the local devstack mock endpoint"
# Legacy reason prefix preserved for manifests written before the rename so
# the workspace-grey-zone counter does not silently drop pre-rename entries.
_MOCK_FALLBACK_REASON_PREFIX_LEGACY = (
    "External HTTP URL will be pointed at the local ccstack mock endpoint"
)


def count_external_http_mock_fallback_requirements(
    requirements: Iterable[Dict[str, Any]],
) -> int:
    """Count external_http requirements routed to the mockserver fallback.

    Sibling-routed candidates carry a distinct reason string that names the
    sibling port explicitly; only candidates whose reason starts with
    ``_MOCK_FALLBACK_REASON_PREFIX`` (or the legacy ccstack-named variant —
    Shim 1 reason-string compatibility) are mock-fallback. The single
    workspace-wide ``external-http-mock`` generator requirement is NOT a
    fallback by itself — it is only generated when at least one candidate
    needs the fallback, and counting it would double-count. The mock
    generator requirement is filtered by ``id == "external-http-mock"``.
    """
    total = 0
    if not requirements:
        return 0
    for requirement in requirements:
        if not isinstance(requirement, dict):
            continue
        if requirement.get("kind") != "external_http":
            continue
        if requirement.get("id") == "external-http-mock":
            # Workspace-wide mock generator entry — not a per-candidate route.
            continue
        reason = str(requirement.get("reason") or "")
        if (
            reason.startswith(_MOCK_FALLBACK_REASON_PREFIX)
            or reason.startswith(_MOCK_FALLBACK_REASON_PREFIX_LEGACY)
        ):
            total += 1
    return total


def count_unmanaged_datasource_dependencies(
    manual_review_entries: Iterable[Dict[str, Any]],
) -> int:
    """Count distinct datasource dependencies whose engine is outside
    ``MANAGED_DATABASES`` (the unmanaged-engine grey zone — Altibase,
    Oracle, DB2, Tibero, CUBRID, future additions).

    The contract is intentionally narrow so the counter has one job and
    one job only: surface analysis-time classifications that devstack
    cannot provision a Docker-backed runtime for. An entry counts iff
    every clause below holds:

    - ``kind == "database"`` — non-database manual_review entries are
      filtered out so private-Gradle-repo or external_http manual_review
      items never bleed into this count.
    - ``status == "manual_review"`` — only the analysis-time grey-zone
      bucket. ``generate`` / ``configure`` / ``provided`` entries are
      managed and contribute 0.
    - ``technology`` is a non-empty string AND not in ``MANAGED_DATABASES``
      AND not in ``{"h2", "unknown"}``. The ``h2`` exclusion preserves
      the existing first-class embedded-H2 manual_review reason as a
      separate concern (it is an embedded driver, not an external
      dependency devstack should report as "unmanaged"). The ``unknown``
      exclusion preserves the existing "URL could not be classified"
      operator-action semantics — those are missing-information items,
      not unmanaged engines.

    Distinct counting: deduplicate by ``(technology, source)`` pair so a
    workspace with three Altibase datasource files counts three distinct
    entries (matching the multi-datasource real-world failure pattern),
    while two identical entries (same engine + same source path) count
    as one. The ``source`` field is the requirement's source path
    (datasource file or persistence model) and is empty-string-tolerant.

    Best-effort: any malformed entry (non-dict, missing keys) is silently
    skipped — consistent with the rest of the grey-zone aggregator's
    "never crash a status render" stance.
    """
    if not manual_review_entries:
        return 0
    seen = set()
    for entry in manual_review_entries:
        if not isinstance(entry, dict):
            continue
        if entry.get("kind") != "database":
            continue
        if entry.get("status") != "manual_review":
            continue
        technology = entry.get("technology")
        if not isinstance(technology, str) or not technology:
            continue
        if technology in MANAGED_DATABASES:
            continue
        if technology in {"h2", "unknown"}:
            continue
        source = entry.get("source")
        source_key = source if isinstance(source, str) else ""
        seen.add((technology, source_key))
    return len(seen)


def empty_grey_zone_counters() -> Dict[str, int]:
    """Return a fresh counters dict with every contract key initialized to 0.

    Used by ``count_workspace_grey_zone`` and by tooling that wants to
    enumerate the stable counter set without depending on a specific
    workspace.
    """
    return {key: 0 for key in _GREY_ZONE_COUNTER_KEYS}


def count_workspace_grey_zone(workspace: "Workspace") -> Dict[str, int]:
    """Aggregate grey-zone signals into the four named counters.

    Always returns the full contract dict
    ``{"degraded": int, "low_confidence": int, "mock_fallback": int,
    "unverified_binding": int}`` — missing signal sources contribute 0,
    they do not omit keys. Best-effort: any exception while reading a
    signal source is swallowed so a defective signal pipeline cannot
    break ``devstack status`` rendering.

    The probe signals list is read non-destructively via
    ``peek_managed_datasource_probe_signals`` so other consumers of
    ``consume_managed_datasource_probe_signals`` are unaffected. The
    aggregator is workspace-scoped and idempotent; calling it twice in a
    row yields identical results unless an underlying signal changed.
    """
    counters = empty_grey_zone_counters()

    # degraded — persisted seed-drift state. Only bound workspaces have a
    # persisted drift record; an unbound workspace (`workspace_setup`) is
    # in setup mode and has no readiness story to grade yet.
    try:
        if workspace and not workspace.config.get("workspace_setup"):
            drift = read_seed_drift_state(workspace.name)
            if drift:
                counters["degraded"] += 1
    except Exception:  # noqa: BLE001 — never raise from the aggregator
        pass

    # low_confidence — drainable probe signal list (read-only). Both
    # "low" and "degraded" confidence levels count: the contract from the
    # probe layer is that "high" == proven and anything else is a
    # grey-zone signal worth surfacing.
    try:
        for signal in peek_managed_datasource_probe_signals():
            if not isinstance(signal, dict):
                continue
            if str(signal.get("confidence") or "") in {"low", "degraded"}:
                counters["low_confidence"] += 1
    except Exception:  # noqa: BLE001
        pass

    # mock_fallback — persisted count from devstack_managed_environment (or
    # the legacy ccstack_managed_environment key via Shim 6 dual-read).
    # Older manifests (pre-counter persistence) lack the field; treat as
    # 0 — the apply flow re-derives this on every materialize_managed_environment
    # invocation, so the first apply after upgrade fills it in.
    try:
        managed = read_managed_environment(workspace.config) if workspace else None
        if isinstance(managed, dict):
            value = managed.get("mock_fallback_routes")
            if isinstance(value, int) and value > 0:
                counters["mock_fallback"] += int(value)
    except Exception:  # noqa: BLE001
        pass

    # unverified_binding — live per-service notes attached by the command
    # / gradle datasource handshake (verify_command_service_datasources,
    # verify_managed_datasource soft-pass branches).
    try:
        services = workspace.services if workspace else {}
        for service in services.values():
            if not isinstance(service, dict):
                continue
            notes = read_status_notes(service)
            if not isinstance(notes, list):
                continue
            for note in notes:
                if not isinstance(note, dict):
                    continue
                if note.get("key") == "app_binding_unverified" and note.get("value"):
                    counters["unverified_binding"] += 1
                    break  # one note per service is enough
    except Exception:  # noqa: BLE001
        pass

    # unmanaged_dependency — analysis-time classifications persisted into
    # devstack_managed_environment.manual_review. The classification is
    # produced by `database_environment_requirement` whenever the parsed
    # JDBC engine is outside MANAGED_DATABASES (and is neither "h2" nor
    # "unknown" — both of those have separate manual_review semantics).
    # Status reads it back here so a workspace whose apps will boot-fail
    # against an unmanaged engine driver (Altibase, Oracle, DB2, ...) is
    # reported honestly instead of looking fully green. Older manifests
    # without the field default to 0 — the aggregator coerces missing
    # keys, matching the four arms above.
    try:
        managed = read_managed_environment(workspace.config) if workspace else None
        if isinstance(managed, dict):
            manual_review_entries = managed.get("manual_review")
            if isinstance(manual_review_entries, list):
                counters["unmanaged_dependency"] += (
                    count_unmanaged_datasource_dependencies(manual_review_entries)
                )
    except Exception:  # noqa: BLE001
        pass

    return counters


def format_grey_zone_counters_line(counters: Dict[str, int]) -> str:
    """Render the always-printable parseable counters line.

    Format::

        CCSTACK STATUS COUNTERS: degraded=N low_confidence=N \\
            mock_fallback=N unverified_binding=N

    Stable field order matches ``_GREY_ZONE_COUNTER_KEYS`` so tooling can
    pattern-match on a fixed layout. Missing keys default to 0.
    """
    parts = [f"{key}={int(counters.get(key, 0) or 0)}" for key in _GREY_ZONE_COUNTER_KEYS]
    return "CCSTACK STATUS COUNTERS: " + " ".join(parts)


def format_grey_zone_summary_line(counters: Dict[str, int]) -> str:
    """Render the human-readable workspace state line for non-zero counters.

    Returns an empty string when every counter is 0 (the status output
    must stay quiet in the all-zero case). When at least one counter is
    non-zero, returns a single line of the form::

        WORKSPACE STATE: grey-zone - <key>=<n>[, <key>=<n>...]

    listing the non-zero counters in stable contract order.
    """
    non_zero = [
        (key, int(counters.get(key, 0) or 0))
        for key in _GREY_ZONE_COUNTER_KEYS
        if int(counters.get(key, 0) or 0) > 0
    ]
    if not non_zero:
        return ""
    body = ", ".join(f"{key}={value}" for key, value in non_zero)
    return f"WORKSPACE STATE: grey-zone - {body}"


def collect_managed_named_volumes(managed_config: Dict[str, Any]) -> List[str]:
    """Enumerate docker named-volume sources across managed compose services.

    Walks the managed config's service entries, looking at each compose
    service's `volumes` list, and returns the deduplicated list of
    `compose_named_volume_source` outputs (excluding bind mounts). Used by
    `recreate_managed_named_volumes` to decide which `docker volume rm`
    invocations to issue under the opt-in flag.
    """
    seen: Set[str] = set()
    names: List[str] = []
    services = managed_config.get("services") or {}
    if not isinstance(services, dict):
        return names
    for service in services.values():
        if not isinstance(service, dict) or service.get("type") != "compose":
            continue
        for entry in service.get("volumes", []) or []:
            volume_name = compose_named_volume_source(str(entry))
            if volume_name and volume_name not in seen:
                seen.add(volume_name)
                names.append(volume_name)
    return names


def recreate_managed_named_volumes(
    name: str,
    managed_config: Dict[str, Any],
) -> Dict[str, Any]:
    """Tear down compose and remove every managed named docker volume.

    Strict opt-in path — must only be reached after explicit user approval
    (CLI `--recreate-volumes` flag or UI `workspace_recreate_volumes`
    action). Brings the managed compose stack down first so the volumes are
    not in use, then issues `docker volume rm` per name. Returns a summary
    dict with the list of removed names and any docker errors collected.
    """
    summary: Dict[str, Any] = {
        "workspace": name,
        "removed": [],
        "errors": [],
    }
    compose_file = managed_infra_compose_path(name)
    volumes = collect_managed_named_volumes(managed_config)
    if not volumes:
        return summary
    if compose_file.exists():
        try:
            run(
                [*compose_command(compose_file.parent), "-f", str(compose_file), "down", "--remove-orphans"],
                cwd=compose_file.parent,
            )
        except DevstackError as error:
            summary["errors"].append(f"compose down failed: {error}")
    for volume_name in volumes:
        try:
            run(["docker", "volume", "rm", "-f", volume_name], cwd=compose_file.parent if compose_file.exists() else Path.cwd())
            summary["removed"].append(volume_name)
        except DevstackError as error:
            summary["errors"].append(f"volume {volume_name}: {error}")
    return summary


def managed_mockserver_expectations_path(name: str) -> Path:
    return managed_infra_dir(name) / "mockserver-expectations.json"


def augment_workspace_config(
    root: Path,
    config: Dict[str, Any],
    reserved_ports: Optional[Set[int]] = None,
) -> Tuple[Dict[str, Any], Dict[str, Any]]:
    managed_config = json.loads(json.dumps(config))
    workspace_name = str(managed_config.get("workspace") or root.name)
    services = managed_config.setdefault("services", {})
    if not isinstance(services, dict):
        services = {}
        managed_config["services"] = services

    profiles = managed_config.setdefault("profiles", {})
    if not isinstance(profiles, dict):
        profiles = {}
        managed_config["profiles"] = profiles

    default_services = default_profile_services(profiles)
    existing_signatures = service_identity_signatures(services)
    detected_services = inspect_gradle_services(root, [])
    added_services: List[str] = []
    updated_services: List[str] = []
    for detected_name, detected_service in detected_services.items():
        if detected_name in services:
            before = json.dumps(services[detected_name], sort_keys=True)
            reconcile_detected_gradle_service(services[detected_name], detected_service)
            if json.dumps(services[detected_name], sort_keys=True) != before:
                updated_services.append(detected_name)
            continue
        if gradle_service_identity(detected_service) in existing_signatures:
            continue

        service_name = unique_service_name(detected_name, services)
        services[service_name] = json.loads(json.dumps(detected_service))
        existing_signatures.add(gradle_service_identity(detected_service))
        if service_name not in default_services:
            default_services.append(service_name)
        added_services.append(service_name)

    port_reassignments = ensure_unique_gradle_service_ports(
        services,
        reserved_ports=reserved_ports,
        workspace_name=workspace_name,
    )
    added_bundles = apply_auto_run_bundles(profiles, services)
    changed = bool(added_services or updated_services or port_reassignments or added_bundles)
    return managed_config, {
        "changed": changed,
        "added_services": added_services,
        "updated_services": updated_services,
        "port_reassignments": port_reassignments,
        "added_bundles": added_bundles,
    }


def reconcile_detected_gradle_service(service: Any, detected_service: Dict[str, Any]) -> None:
    if not isinstance(service, dict) or service.get("type") != "gradle":
        return
    if detected_service.get("apply_spring_boot_plugin"):
        service["apply_spring_boot_plugin"] = True

    detected_port = detected_service.get("port")
    current_health = str(service.get("health") or "")
    if detected_port and current_health == f"http://localhost:{detected_port}/actuator/health" and not detected_service.get("health"):
        service.pop("health", None)


def service_identity_signatures(services: Dict[str, Any]) -> Set[Tuple[str, str]]:
    signatures: Set[Tuple[str, str]] = set()
    for service in services.values():
        if not isinstance(service, dict) or service.get("type") != "gradle":
            continue
        signatures.add(gradle_service_identity(service))
    return signatures


def gradle_service_identity(service: Dict[str, Any]) -> Tuple[str, str]:
    task = str(service.get("task") or "")
    module = str(service.get("module") or "")
    return task, module


def unique_service_name(preferred: str, services: Dict[str, Any]) -> str:
    if preferred not in services:
        return preferred
    index = 2
    while f"{preferred}-{index}" in services:
        index += 1
    return f"{preferred}-{index}"


def ensure_unique_gradle_service_ports(
    services: Dict[str, Any],
    reserved_ports: Optional[Set[int]] = None,
    workspace_name: str = "",
) -> List[Dict[str, Any]]:
    used_ports: Set[int] = set(reserved_ports or set())
    reassignments: List[Dict[str, Any]] = []
    for name, service in services.items():
        if not isinstance(service, dict):
            continue

        port = service.get("port")
        if not port:
            continue
        try:
            preferred = int(port)
        except (TypeError, ValueError):
            continue

        if service.get("type") != "gradle" and not is_reassignable_managed_infra_service(
            name,
            service,
            workspace_name,
        ):
            used_ports.add(preferred)
            continue

        assigned = allocate_port(preferred, used_ports)
        used_ports.add(assigned)
        if assigned == preferred:
            continue

        if service.get("type") == "gradle":
            apply_gradle_service_port_override(service, preferred, assigned)
        else:
            apply_managed_infra_service_port_override(service, preferred, assigned)
        reassignments.append({"service": name, "from": preferred, "to": assigned})
    return reassignments


def is_reassignable_managed_infra_service(name: str, service: Dict[str, Any], workspace_name: str) -> bool:
    if not workspace_name or not is_managed_infra_service_name(name):
        return False
    if service.get("type") != "compose":
        return False
    return str(service.get("compose") or "") == str(managed_infra_compose_path(workspace_name))


def apply_managed_infra_service_port_override(service: Dict[str, Any], previous_port: int, port: int) -> None:
    service["port"] = port
    health = str(service.get("health") or "")
    if health:
        service["health"] = replace_url_port(health, previous_port, port)


def apply_gradle_service_port_override(service: Dict[str, Any], previous_port: int, port: int) -> None:
    service["port"] = port
    health = str(service.get("health") or "")
    if health:
        service["health"] = replace_url_port(health, previous_port, port)

    env = service.setdefault("env", {})
    if isinstance(env, dict):
        env["SERVER_PORT"] = str(port)
        env["MANAGEMENT_SERVER_PORT"] = str(port)

    args = [arg for arg in string_list(service.get("args")) if not arg.startswith("--server.port=")]
    args.append(f"--server.port={port}")
    service["args"] = unique(args)


def replace_url_port(value: str, previous_port: int, port: int) -> str:
    replaced = re.sub(rf"(?<=:){previous_port}(?=/|$)", str(port), value, count=1)
    if replaced != value:
        return replaced
    return re.sub(r":\d+(?=/|$)", f":{port}", value, count=1)


def materialize_managed_environment(
    name: str,
    root: Path,
    config: Dict[str, Any],
    analysis: Dict[str, Any],
) -> Tuple[Dict[str, Any], Dict[str, Any]]:
    # Domain overrides are loaded once per materialize call and threaded into
    # every engine helper that depends on them. Absent file = empty dict =
    # pure generic engine behavior.
    domain_overrides = load_domain_overrides(root, name)

    environment = analysis.get("environment", {})
    generated = [
        item
        for item in environment.get("generated", [])
        if item.get("service_name") and item.get("compose_service") and item.get("image")
    ]
    env_overrides = environment.get("env", [])
    arg_overrides = environment.get("args", [])
    requirements = environment.get("requirements", [])
    persistence = analysis.get("persistence", {})
    source_services = config.get("services", {})
    spring_boot_plugin_modules = gradle_service_paths_requiring_spring_boot_plugin(source_services)
    graphql_dummy_modules = materialize_graphql_dummy_resolvers(name, root, source_services, overrides=domain_overrides)
    mybatis_mapper_scan_modules = materialize_mybatis_mapper_scan_configs(name, root, source_services)
    gradle_runtime_dependencies = gradle_runtime_dependencies_for_environment(source_services, env_overrides, requirements)
    # Idempotency / defensive seed: previously persisted gradle_runtime_dependencies
    # survive regenerations whose freshly-built analysis lacks the mysql requirement
    # (e.g. recovery paths). Without this, an empty fresh map silently overwrites the
    # init script and fixity-* bootRun loses mysql-connector-j from its runtime
    # classpath. Freshly-computed entries take precedence on key collision; previously
    # persisted entries for project paths not in the fresh map are preserved as-is.
    gradle_runtime_dependencies = merge_persisted_runtime_dependencies(
        config, gradle_runtime_dependencies
    )
    requires_gradle_resource_args = has_gradle_services(source_services)
    requires_gradle_local_only = any(
        item.get("technology") == "gradle-private-repository"
        for item in requirements
    )
    requires_config_resource_patch = any(item.get("id") == "config-server-local-overrides" for item in requirements)
    requires_gradle_init = (
        requires_gradle_local_only
        or requires_config_resource_patch
        or bool(spring_boot_plugin_modules)
        or bool(graphql_dummy_modules)
        or bool(mybatis_mapper_scan_modules)
        or bool(gradle_runtime_dependencies)
    )
    if (
        not generated
        and not env_overrides
        and not arg_overrides
        and not requires_gradle_init
        and not requires_gradle_resource_args
    ):
        return config, {}

    managed_config = json.loads(json.dumps(config))
    services = managed_config.setdefault("services", {})
    profiles = managed_config.setdefault("profiles", {})
    spring_boot_plugin_modules = gradle_service_paths_requiring_spring_boot_plugin(services)
    graphql_dummy_modules = materialize_graphql_dummy_resolvers(name, root, services, overrides=domain_overrides)
    mybatis_mapper_scan_modules = materialize_mybatis_mapper_scan_configs(name, root, services)
    gradle_runtime_dependencies = gradle_runtime_dependencies_for_environment(services, env_overrides, requirements)
    # Same defensive seed as above (see comment near the first recompute). This
    # call site is what actually feeds write_managed_gradle_init below, so the
    # merge must happen here too. Using `config` (the unmodified input) instead of
    # `managed_config` keeps the persisted block as the canonical source for the
    # seed even when managed_config has already been mutated above.
    gradle_runtime_dependencies = merge_persisted_runtime_dependencies(
        config, gradle_runtime_dependencies
    )
    default_services = default_profile_services(profiles)
    managed_services: List[str] = []
    schema_files = write_local_schema_files(name, persistence)
    dml_files = write_local_dml_files(name, persistence, overrides=domain_overrides)
    generated = preserve_existing_managed_infra_requirements(name, generated, services)
    mockserver_expectations = ""
    if any(item.get("technology") == "mockserver" for item in generated):
        expectation_path = write_mockserver_expectations(
            managed_mockserver_expectations_path(name),
            environment.get("external", []),
            overrides=domain_overrides,
        )
        mockserver_expectations = str(expectation_path)
        attach_mockserver_expectations(generated, expectation_path)

    if schema_files or dml_files:
        attach_schema_files_to_generated_databases(generated, schema_files, dml_files)
        apply_h2_schema_init(env_overrides, schema_files.get("h2"), dml_files.get("h2"))

    if generated:
        compose_path = managed_infra_compose_path(name)
        write_managed_compose(compose_path, generated, name)
        for requirement in generated:
            service_name = str(requirement["service_name"])
            services[service_name] = {
                "type": "compose",
                "compose": str(compose_path),
                "project": managed_compose_project_name(name),
                "service": str(requirement["compose_service"]),
                "port": requirement.get("port"),
                "engine": requirement.get("technology"),
                "image": requirement.get("image"),
                "container_port": requirement.get("container_port"),
                "environment": requirement.get("environment", {}),
                "command": requirement.get("command"),
                "volumes": requirement.get("volumes", []),
                "database": requirement.get("connection", {}).get("database"),
                "username": requirement.get("connection", {}).get("username"),
                "password": requirement.get("connection", {}).get("password"),
                "init_schema": requirement.get("init_schema"),
                "init_dml": requirement.get("init_dml"),
            }
            managed_services.append(service_name)
            if service_name not in default_services:
                default_services.insert(0, service_name)

    apply_service_environment_overrides(services, env_overrides)
    apply_service_argument_overrides(services, arg_overrides)
    if generated:
        apply_runtime_dependencies(services, managed_services)

    env_path = managed_env_path(name)
    if env_overrides:
        write_managed_env(env_path, env_overrides)

    gradle_init_path = managed_gradle_init_path(name)
    gradle_default_args = list(MANAGED_GRADLE_RESOURCE_ARGS) if requires_gradle_resource_args else []
    boot_run_environment: Dict[str, Dict[str, str]] = {}
    for service in services.values():
        if not isinstance(service, dict) or service.get("type") != "gradle":
            continue
        task_path = str(service.get("task") or "")
        if not (task_path.endswith(":bootRun") or task_path == "bootRun"):
            continue
        service_env = service.get("env") or {}
        if not isinstance(service_env, dict) or not service_env:
            continue
        boot_run_environment[task_path] = {
            str(env_key): str(env_value) for env_key, env_value in service_env.items()
        }
    # Materialize the devstack-local.yml classpath resource referenced by
    # the mandatory LOCAL_CONFIG_IMPORT (`classpath:devstack-local.yml`).
    # Without this file Spring Boot startup fails fast with
    # ConfigDataResourceNotFoundException — exactly the silent-degradation
    # circuit commit 1ea4928 was meant to close. The body is a placeholder
    # (comment header + empty map) so it is structurally valid YAML and
    # extensible later (e.g. to serialized datasource properties).
    managed_infra_dir_path = managed_infra_dir(name)
    if requires_config_resource_patch:
        # Shim 7 — emit BOTH devstack-local.yml (canonical) AND
        # devstack-local.yml (legacy alias) with identical content under
        # managed_infra_dir so previously-built user app jars referencing
        # classpath:devstack-local.yml keep importing their overlay for one
        # release. The new init-script processResources wiring picks the
        # devstack name (see write_managed_gradle_init below).
        write_managed_local_yml_dual(managed_infra_dir_path)
    if requires_gradle_init:
        write_managed_gradle_init(
            gradle_init_path,
            include_config_server_patch=requires_config_resource_patch,
            spring_boot_plugin_modules=spring_boot_plugin_modules,
            graphql_dummy_modules=graphql_dummy_modules,
            mybatis_mapper_scan_modules=mybatis_mapper_scan_modules,
            runtime_dependencies=gradle_runtime_dependencies,
            boot_run_environment=boot_run_environment,
            managed_infra_dir=managed_infra_dir_path if requires_config_resource_patch else None,
        )
        gradle_default_args.extend(["--init-script", str(gradle_init_path)])

    # Strategy-seam extension point: when the workspace requires the
    # config-server patch AND contains type=command services, materialize the
    # DotenvStrategy artifacts as well. This is purely additive — gradle-only
    # workspaces see no new artifacts (the dotenv strategy's applies_to is
    # False) so the existing byte-identical Gradle output is preserved.
    #
    # GradleSpringStrategy is intentionally NOT invoked here: the legacy call
    # above is what tests pin as byte-identical, and calling the strategy
    # would just delegate back to the same write_managed_gradle_init with
    # equivalent kwargs. The Protocol/class exists primarily so callers can
    # add new strategies (DotenvStrategy is the first) without touching this
    # call site again.
    if requires_config_resource_patch:
        strategy_ctx = RemoteConfigPatchContext(
            workspace_name=name,
            managed_infra_dir=managed_infra_dir_path,
            services=services,
            requires_config_resource_patch=True,
            gradle_init_path=gradle_init_path,
            gradle_init_kwargs={},
        )
        for strategy in select_remote_config_strategies(strategy_ctx):
            if strategy.name == "gradle-spring":
                # Skip — the legacy direct call above is the byte-identical
                # source of truth for the Gradle path. The strategy class
                # exists for tests and future use; runtime delegation here
                # would be a no-op that risks drifting the byte-identity
                # contract.
                continue
            strategy.materialize(strategy_ctx)

    if gradle_default_args:
        existing_args = string_list(managed_config.get("gradle_args", []))
        managed_config["gradle_args"] = merge_managed_gradle_args(
            existing_args,
            gradle_default_args,
        )

    # DDL/DML fingerprint — captures whether the local seed pipeline produced
    # different output than the previous apply. The previous fingerprint (if
    # any) is read BEFORE we overwrite the file so callers can detect drift.
    # Volume recreation is offered only via the explicit opt-in path; the
    # fingerprint itself is a non-destructive signal.
    previous_fingerprint = read_seed_fingerprint(name)
    current_fingerprint = ""
    fingerprint_path = ""
    if schema_files or dml_files:
        current_fingerprint = compute_seed_fingerprint(schema_files, dml_files)
        if current_fingerprint:
            written = write_seed_fingerprint(name, current_fingerprint)
            fingerprint_path = str(written)
    seed_changed = bool(
        current_fingerprint
        and previous_fingerprint
        and current_fingerprint != previous_fingerprint
    )
    managed_named_volumes = collect_managed_named_volumes(managed_config)

    managed = {
        "compose": str(managed_infra_compose_path(name)) if generated else "",
        "env": str(env_path) if env_overrides else "",
        "gradle_init": str(gradle_init_path) if requires_gradle_init else "",
        "gradle_private_repositories_removed": requires_gradle_local_only,
        "gradle_h2_runtime": False,
        "gradle_config_server_patch": requires_config_resource_patch,
        "gradle_resource_args": list(MANAGED_GRADLE_RESOURCE_ARGS) if requires_gradle_resource_args else [],
        "gradle_boot_plugin_modules": spring_boot_plugin_modules,
        "gradle_graphql_dummy_modules": graphql_dummy_modules,
        "gradle_mybatis_mapper_scan_modules": mybatis_mapper_scan_modules,
        "gradle_runtime_dependencies": gradle_runtime_dependencies,
        "schema": {engine: str(path) for engine, path in schema_files.items()},
        "dml": {engine: str(path) for engine, path in dml_files.items()},
        "mockserver_expectations": mockserver_expectations,
        "services": managed_services,
        "env_overrides": len(env_overrides),
        "arg_overrides": len(arg_overrides),
        "manual_review": environment.get("manual", []),
        # Grey-zone counter persistence: count of external_http requirements
        # routed to the mockserver fallback (vs a sibling gradle service).
        # The per-candidate reason strings are built deterministically in
        # build_local_environment_plan — match the mockserver-fallback reason
        # literally so the counter stays exact. Status renderers read this
        # field via count_workspace_grey_zone; older manifests without the
        # key default to 0 (the aggregator coerces missing keys).
        "mock_fallback_routes": count_external_http_mock_fallback_requirements(
            requirements
        ),
        "seed_fingerprint": current_fingerprint,
        "seed_fingerprint_path": fingerprint_path,
        "seed_fingerprint_previous": previous_fingerprint,
        "seed_changed": seed_changed,
        "named_volumes": managed_named_volumes,
    }
    apply_auto_run_bundles(profiles, services)
    managed_config["devstack_managed_environment"] = managed
    return managed_config, managed


def merge_managed_gradle_args(existing_args: List[str], default_args: List[str]) -> List[str]:
    merged = list(existing_args)
    for arg in default_args:
        prefix = managed_gradle_resource_arg_prefix(arg)
        if prefix and any(existing == prefix or existing.startswith(prefix + "=") for existing in merged):
            continue
        if arg not in merged:
            merged.append(arg)
    return merged


def has_gradle_services(services: Dict[str, Any]) -> bool:
    return any(isinstance(service, dict) and service.get("type") == "gradle" for service in services.values())


def merge_persisted_runtime_dependencies(
    config: Dict[str, Any],
    fresh_dependencies: Dict[str, List[str]],
) -> Dict[str, List[str]]:
    """Defensive seed for gradle_runtime_dependencies.

    Some materialize_managed_environment call sites (notably
    reanalyze_local_runtime_for_recovery) build a fresh analysis whose
    requirements / env_overrides may not include the mysql database
    requirement that originally drove the runtime-dep map. The freshly-
    computed `gradle_runtime_dependencies_for_environment(...)` result is
    then empty (or missing entries) and silently overwrites the previously
    persisted block in `config["devstack_managed_environment"]["gradle_runtime_dependencies"]`,
    which produces an init script with `def devstackRuntimeDependencies = [:]`
    and breaks every fixity-* / proxy:acme:* bootRun classpath that
    relied on mysql-connector-j.

    This helper unions the persisted map (read from `config`) with the
    freshly computed map. Freshly-computed entries take precedence on key
    collision (so a real re-analysis can update / remove specific
    dependencies). Previously persisted entries for project paths that the
    fresh map does NOT mention are preserved as-is. The result is sorted
    by key with sorted, de-duplicated value lists — matching the shape
    `gradle_runtime_dependencies_for_environment` already returns.

    Idempotent: when `fresh_dependencies` already contains every persisted
    entry, the return value equals `fresh_dependencies` byte-for-byte.
    """
    if not isinstance(config, dict):
        return dict(fresh_dependencies or {})
    managed = read_managed_environment(config)
    persisted = (
        managed.get("gradle_runtime_dependencies")
        if isinstance(managed, dict)
        else None
    )
    if not isinstance(persisted, dict) or not persisted:
        return dict(fresh_dependencies or {})

    merged: Dict[str, List[str]] = {}
    for key, values in persisted.items():
        if not isinstance(key, str) or not isinstance(values, list):
            continue
        merged[key] = [str(item) for item in values if isinstance(item, str)]
    for key, values in (fresh_dependencies or {}).items():
        if not isinstance(key, str) or not isinstance(values, list):
            continue
        merged[key] = [str(item) for item in values if isinstance(item, str)]

    return {
        key: sorted(set(values))
        for key, values in sorted(merged.items())
    }


def gradle_runtime_dependencies_for_environment(
    services: Dict[str, Any],
    env_overrides: List[Dict[str, str]],
    requirements: List[Dict[str, Any]],
) -> Dict[str, List[str]]:
    mysql_requirement_ids = {
        str(item.get("id"))
        for item in requirements
        if item.get("kind") == "database" and item.get("technology") == "mysql"
    }
    if not mysql_requirement_ids:
        return {}

    dependencies: Dict[str, List[str]] = {}
    for override in env_overrides:
        if str(override.get("source")) not in mysql_requirement_ids:
            continue

        service = services.get(str(override.get("service") or ""))
        if not isinstance(service, dict) or service.get("type") != "gradle":
            continue

        project_path = gradle_project_path_from_task(str(service.get("task") or ""))
        if project_path:
            dependencies.setdefault(project_path, [])
            if MYSQL_RUNTIME_DEPENDENCY not in dependencies[project_path]:
                dependencies[project_path].append(MYSQL_RUNTIME_DEPENDENCY)

    return {key: sorted(value) for key, value in sorted(dependencies.items())}


def managed_gradle_resource_arg_prefix(arg: str) -> str:
    for prefix in MANAGED_GRADLE_RESOURCE_ARG_PREFIXES:
        if arg == prefix or arg.startswith(prefix + "="):
            return prefix
    return ""


def preserve_existing_managed_infra_requirements(
    name: str,
    generated: List[Dict[str, Any]],
    services: Dict[str, Any],
) -> List[Dict[str, Any]]:
    by_name = {str(item.get("service_name")): item for item in generated if item.get("service_name")}
    compose_path = str(managed_infra_compose_path(name))
    for service_name, service in sorted(services.items()):
        if service_name in by_name:
            continue
        if not is_managed_infra_service_name(service_name) or not isinstance(service, dict):
            continue
        if str(service.get("compose") or "") != compose_path:
            continue
        requirement = existing_managed_infra_requirement(name, service_name, service)
        if requirement:
            by_name[service_name] = requirement
    return list(by_name.values())


def existing_managed_infra_requirement(name: str, service_name: str, service: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    compose_service = str(service.get("service") or service_name.rsplit(".", 1)[-1])
    engine = str(service.get("engine") or service.get("database") or compose_service).lower()
    port = service.get("port")
    environment = service.get("environment") if isinstance(service.get("environment"), dict) else {}
    volumes = string_list(service.get("volumes"))
    base = {
        "id": f"preserve-{safe_name(service_name)}",
        "kind": "managed_infra",
        "status": "generate",
        "confidence": "high",
        "source": "existing generated devstack config",
        "reason": "Preserve existing devstack-managed infrastructure while recovering another dependency.",
        "service_name": service_name,
        "compose_service": compose_service,
        "port": port,
        "volumes": volumes,
    }
    if "redis" in engine or compose_service == "redis":
        return {
            **base,
            "technology": "redis",
            "image": service.get("image") or "redis:7-alpine",
            "container_port": int(service.get("container_port") or 6379),
            "command": str(service.get("command") or ""),
            "environment": environment,
        }
    if "kafka" in engine or compose_service == "kafka":
        return {
            **base,
            "technology": "kafka",
            "image": service.get("image") or "apache/kafka:3.7.0",
            "container_port": int(service.get("container_port") or 9092),
            "environment": environment or {
                "KAFKA_ADVERTISED_LISTENERS": f"PLAINTEXT://localhost:{port or 9092}",
                "KAFKA_AUTO_CREATE_TOPICS_ENABLE": "true",
                "KAFKA_CONTROLLER_LISTENER_NAMES": "CONTROLLER",
                "KAFKA_CONTROLLER_QUORUM_VOTERS": "1@kafka:9093",
                "KAFKA_LISTENERS": "PLAINTEXT://:9092,CONTROLLER://:9093",
                "KAFKA_LISTENER_SECURITY_PROTOCOL_MAP": "CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT",
                "KAFKA_NODE_ID": "1",
                "KAFKA_PROCESS_ROLES": "controller,broker",
            },
        }
    if "mongo" in engine or "mongodb" in engine or compose_service == "mongo":
        return {
            **base,
            "technology": "mongodb",
            "image": service.get("image") or "mongo:6.0",
            "container_port": int(service.get("container_port") or 27017),
            # DB credential literal stays ``ccstack`` (volume compat). The
            # mongo data volume name uses the new ``devstack-`` prefix —
            # bind that to your existing mongo volume if you need to reuse
            # previously persisted data.
            "environment": environment or {
                "MONGO_INITDB_ROOT_PASSWORD": "ccstack",
                "MONGO_INITDB_ROOT_USERNAME": "ccstack",
            },
            "volumes": volumes or ["devstack-mongo-data:/data/db"],
        }
    if "opensearch" in engine or "elastic" in engine or compose_service == "opensearch":
        return {
            **base,
            "technology": "opensearch/elasticsearch",
            "image": service.get("image") or "opensearchproject/opensearch:2.15.0",
            "container_port": int(service.get("container_port") or 9200),
            "environment": environment or {
                "discovery.type": "single-node",
                "plugins.security.disabled": "true",
                "OPENSEARCH_JAVA_OPTS": "-Xms512m -Xmx512m",
                "OPENSEARCH_INITIAL_ADMIN_PASSWORD": "N0nProd-Search!927",
            },
            "volumes": volumes or ["devstack-opensearch-data:/usr/share/opensearch/data"],
        }
    if "mock" in engine or compose_service == "mock-http":
        return {
            **base,
            "technology": "mockserver",
            "image": service.get("image") or "mockserver/mockserver:5.15.0",
            "container_port": int(service.get("container_port") or 1080),
            "environment": environment or {"MOCKSERVER_SERVER_PORT": "1080"},
        }
    database_engine = engine if engine in MANAGED_DATABASES else ""
    if not database_engine:
        database_engine = next(
            (
                key
                for key, defaults in MANAGED_DATABASES.items()
                if compose_service == defaults["label"]
            ),
            "",
        )
    if database_engine:
        defaults = MANAGED_DATABASES[database_engine]
        database = str(service.get("database") or name)
        username = str(service.get("username") or defaults["username"])
        password = str(service.get("password") or defaults["password"])
        volumes = database_data_volumes(database_engine, str(defaults["label"]))
        init_schema = str(service.get("init_schema") or "")
        init_dml = str(service.get("init_dml") or "")
        schema_path = managed_schema_path(name, database_engine)
        dml_path = managed_dml_path(name, database_engine)
        if init_schema and schema_path.exists():
            volumes.append(f"{schema_path}:{init_schema}:ro")
        if init_dml and dml_path.exists():
            volumes.append(f"{dml_path}:{init_dml}:ro")
        return {
            **base,
            "technology": database_engine,
            "image": service.get("image") or defaults["image"],
            "container_port": int(service.get("container_port") or defaults["container_port"]),
            "environment": environment or database_compose_environment(database_engine, database, username, password),
            "volumes": volumes or database_data_volumes(database_engine, str(defaults["label"])),
            "connection": {
                "url": jdbc_url(database_engine, int(port or defaults["port"]), database),
                "username": username,
                "password": password,
                "driver": database_driver_class(database_engine),
                "host": "localhost",
                "database": database,
            },
            "init_schema": init_schema or None,
            "init_dml": init_dml or None,
        }
    return None


def default_profile_services(profiles: Dict[str, Any]) -> List[str]:
    profile = profiles.setdefault("default", {"services": []})
    if isinstance(profile, list):
        profiles["default"] = {"services": profile}
        return profile
    if isinstance(profile, dict):
        services = profile.setdefault("services", [])
        if isinstance(services, list):
            return services
    profiles["default"] = {"services": []}
    return profiles["default"]["services"]


def materialize_graphql_dummy_resolvers(
    name: str,
    root: Path,
    services: Dict[str, Any],
    overrides: Optional[Dict[str, Any]] = None,
) -> Dict[str, str]:
    # The set of GraphQL Query schema fields that must be present in a module
    # before devstack generates a dummy resolver for it. The default of
    # {"shows", "actors"} matches the schema the Java dummy resolver template
    # below already implements; a workspace can opt in additional gates by
    # listing them under graphql_dummy.schema_field_triggers in its overrides.
    if overrides is None:
        overrides = load_domain_overrides(root, name)
    triggers_raw = (overrides.get("graphql_dummy") or {}).get("schema_field_triggers")
    if isinstance(triggers_raw, list) and triggers_raw:
        triggers = {str(t).strip() for t in triggers_raw if str(t).strip()}
    else:
        triggers = {"shows", "actors"}
    modules: Dict[str, str] = {}
    for service_name, service in sorted(services.items()):
        if not isinstance(service, dict) or service.get("type") != "gradle":
            continue
        module = str(service.get("module") or module_from_gradle_task(str(service.get("task", "")))).strip("/")
        if not module:
            continue
        module_dir = root / module
        fields = graphql_query_fields(module_dir)
        if not triggers.issubset(fields):
            continue
        if module_contains_dgs_query(module_dir):
            continue
        project_path = gradle_project_path_from_task(str(service.get("task", ""))) or ":" + module.replace("/", ":")
        package_name = spring_boot_application_package(module_dir) or "devstack.local"
        source_dir = managed_graphql_dummy_source_dir(name, service_name)
        write_graphql_dummy_resolver(source_dir, package_name)
        modules[project_path] = str(source_dir)
    return modules


def managed_graphql_dummy_source_dir(workspace_name: str, service_name: str) -> Path:
    return managed_infra_dir(workspace_name) / "generated" / "graphql" / safe_name(service_name) / "java"


def materialize_mybatis_mapper_scan_configs(name: str, root: Path, services: Dict[str, Any]) -> Dict[str, str]:
    modules: Dict[str, str] = {}
    for service_name, service in sorted(services.items()):
        if not isinstance(service, dict) or service.get("type") != "gradle":
            continue
        module = str(service.get("module") or module_from_gradle_task(str(service.get("task", "")))).strip("/")
        if not module:
            continue
        module_dir = root / module
        mapper_packages = mybatis_mapper_packages(module_dir)
        if not mapper_packages:
            continue
        project_path = gradle_project_path_from_task(str(service.get("task", ""))) or ":" + module.replace("/", ":")
        package_name = spring_boot_application_package(module_dir) or "devstack.local"
        # Complement-only contract (C1, C2): decide at materialization time
        # whether the app already owns a @Bean DataSource. When it does,
        # devstack must NOT emit a competing bean — runtime
        # @ConditionalOnMissingBean back-off is registration-order dependent
        # on a plain @Configuration and cannot be relied upon. See
        # module_provides_datasource_bean for the static-inspection rule.
        app_provides_datasource = module_provides_datasource_bean(module_dir)
        source_dir = managed_mybatis_mapper_scan_source_dir(name, service_name)
        write_mybatis_mapper_scan_config(
            source_dir, package_name, mapper_packages, app_provides_datasource
        )
        modules[project_path] = str(source_dir)
    return modules


def managed_mybatis_mapper_scan_source_dir(workspace_name: str, service_name: str) -> Path:
    return managed_infra_dir(workspace_name) / "generated" / "mybatis" / safe_name(service_name) / "java"


def mybatis_mapper_packages(module_dir: Path) -> List[str]:
    packages: Set[str] = set()
    source_dir = module_dir / "src" / "main"
    if not source_dir.exists():
        return []
    for suffix in ("*.java", "*.kt"):
        for path in sorted(source_dir.rglob(suffix)):
            if ignored_generated_source_path(path):
                continue
            text = read_small_text(path)
            if "@Mapper" not in text or "org.apache.ibatis.annotations.Mapper" not in text:
                continue
            match = re.search(r"^\s*package\s+([A-Za-z_][A-Za-z0-9_.]*)", text, re.MULTILINE)
            if match:
                packages.add(match.group(1))
    return sorted(packages)


# Generic detector for "does the application's own source declare a @Bean
# producing a bean of the given Spring type?". Used by the complement-only
# contract enforced in materialize_mybatis_mapper_scan_configs and reusable
# for any future devstack-generated bean type (just change the call-site
# target).
#
# Match contract:
#   - the file imports the type (e.g. "javax.sql.DataSource"), AND
#   - the file declares a @Bean method/function whose declared return type
#     token is the type's simple name (e.g. "DataSource"). Other annotations
#     (e.g. @Primary, @Qualifier(...)) may appear between @Bean and the
#     signature; up to 5 intervening lines are tolerated.
#
# Two function-declaration shapes are recognised:
#   - Java:   public <return-type> name(...)
#   - Kotlin: fun name(...): <return-type>
#
# Fail-closed: any exception while reading a file aborts that file's check
# but does not crash the helper; an empty/missing src/main returns False
# and the materializer falls back to emitting the bean (matching the
# original behaviour for vanilla modules).
_JAVA_RETURN_TYPE_RE = re.compile(
    r"^\s*(?:public|protected|private|static|final|abstract|synchronized|@\w+(?:\([^)]*\))?\s+)*"
    r"([A-Za-z_][A-Za-z0-9_.<>?, \[\]]*?)\s+[A-Za-z_]\w*\s*\("
)
_KOTLIN_RETURN_TYPE_RE = re.compile(
    r"^\s*(?:public|protected|private|internal|open|final|override|@\w+(?:\([^)]*\))?\s+)*"
    r"fun\s+[A-Za-z_]\w*\s*\([^)]*\)\s*:\s*([A-Za-z_][A-Za-z0-9_.<>?, \[\]]*)"
)


def module_declares_spring_bean_of_type(module_dir: Path, fq_type: str) -> bool:
    source_dir = module_dir / "src" / "main"
    if not source_dir.exists():
        return False
    simple_name = fq_type.rsplit(".", 1)[-1]
    for suffix in ("*.java", "*.kt", "*.kts"):
        for path in sorted(source_dir.rglob(suffix)):
            if ignored_generated_source_path(path):
                continue
            try:
                text = read_small_text(path)
            except Exception:
                continue
            if fq_type not in text:
                continue
            # Find every `@Bean` (line-level token, not in a comment-only
            # context) and look ahead up to 5 non-blank lines for a method
            # or function declaration whose return-type token is
            # simple_name. The intervening lines may carry other Spring
            # annotations such as @Primary, @Qualifier(...), @Profile, etc.
            lines = text.splitlines()
            return_re = (
                _JAVA_RETURN_TYPE_RE if path.suffix == ".java" else _KOTLIN_RETURN_TYPE_RE
            )
            for idx, line in enumerate(lines):
                # Anchor: `@Bean` appears as a token (not `@BeanFactory`,
                # not in `// @Bean ...` comment-only line — bare guard).
                stripped = line.lstrip()
                if stripped.startswith("//") or stripped.startswith("*"):
                    continue
                if not re.search(r"@Bean\b", line):
                    continue
                # Scan forward to find the declaration. Skip pure-annotation
                # lines (@Primary, @Qualifier, …) until we hit a declaration
                # or run out of look-ahead budget.
                for fwd_offset in range(0, 6):
                    fwd_idx = idx + fwd_offset
                    if fwd_idx >= len(lines):
                        break
                    candidate = lines[fwd_idx]
                    if not candidate.strip():
                        continue
                    m = return_re.match(candidate)
                    if not m:
                        # Allow further annotation-only lines between
                        # @Bean and the signature.
                        cs = candidate.lstrip()
                        if cs.startswith("@") or cs.startswith("//") or cs.startswith("*"):
                            continue
                        # Anything else (e.g. a class declaration or an
                        # unrelated line) ends this @Bean's look-ahead.
                        break
                    # We have a method/function declaration; compare its
                    # return-type token against simple_name (last
                    # whitespace-separated chunk of the captured type so
                    # `final DataSource` still maps to `DataSource`, and
                    # generics like `Map<String, DataSource>` are NOT a
                    # match because the rightmost token there is the inner
                    # type — which is the intended behaviour: only direct
                    # producers of the target type count).
                    return_token = m.group(1).strip().split()[-1]
                    # Strip a trailing nullable mark from Kotlin types
                    # (e.g. `DataSource?`).
                    return_token = return_token.rstrip("?")
                    if return_token == simple_name:
                        return True
                    break
    return False


def module_provides_datasource_bean(module_dir: Path) -> bool:
    """Return True iff the module's src/main declares at least one @Bean method
    whose return type is javax.sql.DataSource. Used by
    materialize_mybatis_mapper_scan_configs to satisfy the complement-only
    contract (C1, C4) — the decision is made statically at materialization
    time so the generated config can never compete with an app-owned bean.
    """
    return module_declares_spring_bean_of_type(module_dir, "javax.sql.DataSource")


def write_mybatis_mapper_scan_config(
    source_dir: Path,
    package_name: str,
    mapper_packages: List[str],
    app_provides_datasource: bool = False,
) -> None:
    package_dir = source_dir.joinpath(*package_name.split("."))
    package_dir.mkdir(parents=True, exist_ok=True)
    base_packages = ", ".join(json.dumps(package) for package in mapper_packages)
    # Complement-only generator (contract C1, C2, C3): the boolean is decided
    # offline by materialize_mybatis_mapper_scan_configs based on a static
    # scan of the app's src/main. Choose one of two emission shapes:
    #
    #   app_provides_datasource is True  -> the app already owns the
    #     DataSource bean(s). Emit MyBatis wiring only and let Spring's
    #     normal autowiring resolve the DataSource (the app's @Primary
    #     applies, or the app's own @MapperScan / @Qualifier resolves
    #     ambiguity). Importantly, NEITHER DataSourceBuilder NOR the
    #     devstackLocalDataSource bean appear in the generated source — so
    #     no NoUniqueBeanDefinitionException can occur.
    #
    #   app_provides_datasource is False -> the app has no @Bean DataSource.
    #     Emit devstack's own DataSource bean wired from spring.datasource.*
    #     properties, plus the MyBatis wiring. The runtime
    #     @ConditionalOnMissingBean guard is omitted because the static
    #     check has already proven devstack is the sole owner — the guard
    #     is misleading and registration-order dependent.
    if app_provides_datasource:
        java_source = """
package __PACKAGE_NAME__;

import java.io.IOException;
import java.util.ArrayList;
import java.util.Arrays;
import java.util.List;
import javax.sql.DataSource;
import org.apache.ibatis.session.SqlSessionFactory;
import org.mybatis.spring.SqlSessionFactoryBean;
import org.mybatis.spring.annotation.MapperScan;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.context.ApplicationContext;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.core.io.Resource;

@Configuration
@MapperScan(basePackages = {__BASE_PACKAGES__}, sqlSessionFactoryRef = "devstackLocalSqlSessionFactory")
public class DevstackLocalMybatisMapperScanConfig {
    @Bean(name = "devstackLocalSqlSessionFactory")
    public SqlSessionFactory devstackLocalSqlSessionFactory(
            DataSource dataSource,
            ApplicationContext context,
            @Value("${mybatis.mapper-locations:classpath*:mapper/**/*.xml,classpath*:mybatis/**/*.xml}") String mapperLocations)
            throws Exception {
        SqlSessionFactoryBean bean = new SqlSessionFactoryBean();
        bean.setDataSource(dataSource);
        bean.setMapperLocations(resolveMapperLocations(context, mapperLocations));
        return bean.getObject();
    }

    private Resource[] resolveMapperLocations(ApplicationContext context, String mapperLocations) throws IOException {
        List<Resource> resources = new ArrayList<>();
        for (String location : mapperLocations.split(",")) {
            String trimmed = location.trim();
            if (!trimmed.isEmpty()) {
                resources.addAll(Arrays.asList(context.getResources(trimmed)));
            }
        }
        return resources.toArray(new Resource[0]);
    }
}
""".strip()
    else:
        java_source = """
