    function updateLogsJumpAffordance() {{
      if (logsAutoFollow || !liveLogs) {{
        jumpToLatestLogsButton.hidden = true;
        return;
      }}
      jumpToLatestLogsButton.hidden = false;
      jumpToLatestLogsButton.textContent = unseenLiveLogChunks > 0 ? "New logs" : "Jump to latest";
    }}

    function jumpToLatestLogs() {{
      setLogsAutoFollow(true);
      scrollLogsOutput();
      updateLogsJumpAffordance();
    }}

    function resetLogsOutput(value = "") {{
      pendingLogChunks = [];
      if (pendingLogFlush) {{
        window.cancelAnimationFrame(pendingLogFlush);
        pendingLogFlush = 0;
      }}
      logsOutput.textContent = value;
      setLogsAutoFollow(true);
      scrollLogsOutput();
      updateLogsJumpAffordance();
    }}

    function flushPendingLogChunks() {{
      pendingLogFlush = 0;
      if (pendingLogChunks.length === 0) {{
        return;
      }}
      const shouldFollow = logsAutoFollow && isLogsOutputAtBottom();
      const chunk = pendingLogChunks.join("");
      pendingLogChunks = [];
      logsOutput.append(document.createTextNode(chunk));
      if (shouldFollow) {{
        scrollLogsOutput();
      }} else {{
        setLogsAutoFollow(false);
        unseenLiveLogChunks += 1;
      }}
      updateLogsJumpAffordance();
    }}

    function appendLiveLogChunk(chunk) {{
      if (!chunk) {{
        return;
      }}
      pendingLogChunks.push(chunk);
      if (!pendingLogFlush) {{
        pendingLogFlush = window.requestAnimationFrame(flushPendingLogChunks);
      }}
    }}

    function handleLogsOutputScroll() {{
      setLogsAutoFollow(isLogsOutputAtBottom());
      updateLogsJumpAffordance();
    }}

