# --- Remote-config patch strategy seam ------------------------------------
#
# The Gradle/Spring config-server disable + devstack-local.yml overlay flow is
# implemented by `write_managed_local_yml` and
# `write_managed_gradle_init(include_config_server_patch=True, ...)` and
# orchestrated by `materialize_managed_environment`. To support non-JVM
# (`type=command`) services that need the same local-override values, the
# orchestration is dispatched through a Protocol-based strategy seam:
# `select_remote_config_strategies(ctx)` returns a list of strategies that
# apply to the workspace; each strategy materializes its own artifacts.
#
# Implementations:
#   - GradleSpringStrategy — wraps the existing public writers. BYTE-IDENTICAL.
#   - DotenvStrategy — emits `devstack-local.env` for command services.
#
# The concrete classes are defined AFTER the writer functions (see below the
# write_managed_gradle_init definition) so they can call those writers
# directly. Only the Protocol + Context are declared here.
class RemoteConfigPatchContext:
    """Inputs the remote-config patch strategies need to materialize artifacts.

    Lightweight stdlib-only carrier (no dataclasses dependency at import time
    needed beyond what devstack already imports). All fields are read-only by
    convention; strategies must not mutate the context.

    Fields:
      workspace_name: devstack workspace id (used by managed_infra_dir).
      managed_infra_dir: Path under which all per-strategy artifacts land
        (devstack-local.yml, devstack-local-only.gradle, devstack-local.env).
      services: services dict from the workspace config (mapping name -> svc).
      requires_config_resource_patch: True when the workspace requires the
        config-server-local-overrides patch (see requires_config_resource_patch
        derivation in materialize_managed_environment).
      gradle_init_path: Path the GradleSpringStrategy must write the
        init-script to. Optional; defaults to
        ``managed_infra_dir / MANAGED_GRADLE_INIT_NAME``.
      gradle_init_kwargs: kwargs forwarded into ``write_managed_gradle_init``
        (other than ``include_config_server_patch`` and ``managed_infra_dir``).
        Examples: ``spring_boot_plugin_modules``, ``graphql_dummy_modules``,
        ``mybatis_mapper_scan_modules``, ``runtime_dependencies``,
        ``boot_run_environment``.
      managed_infra_dir_for_patch: explicit override for the
        ``managed_infra_dir`` kwarg passed into ``write_managed_gradle_init``.
        When unset, the strategy uses ``ctx.managed_infra_dir`` if the
        ``requires_config_resource_patch`` flag is True (matching the existing
        call site). Allows tests to opt out of the processResources extra
        ``from(...)`` source (``None`` keeps the legacy minimal init-script).
    """

    __slots__ = (
        "workspace_name",
        "managed_infra_dir",
        "services",
        "requires_config_resource_patch",
        "gradle_init_path",
        "gradle_init_kwargs",
        "_managed_infra_dir_for_patch",
        "_managed_infra_dir_for_patch_set",
    )

    def __init__(
        self,
        workspace_name: str,
        managed_infra_dir: "Path",
        services: Dict[str, Any],
        requires_config_resource_patch: bool = True,
        gradle_init_path: Optional["Path"] = None,
        gradle_init_kwargs: Optional[Dict[str, Any]] = None,
        managed_infra_dir_for_patch: Any = "__unset__",
    ) -> None:
        self.workspace_name = workspace_name
        self.managed_infra_dir = managed_infra_dir
        self.services = services or {}
        self.requires_config_resource_patch = bool(requires_config_resource_patch)
        self.gradle_init_path = (
            gradle_init_path
            if gradle_init_path is not None
            else (managed_infra_dir / MANAGED_GRADLE_INIT_NAME)
        )
        self.gradle_init_kwargs = dict(gradle_init_kwargs or {})
        # Sentinel-based tracking: ``None`` is a legitimate explicit value the
        # caller may pass to disable the processResources extra ``from(...)``
        # source. The sentinel ``"__unset__"`` means "use the default rule:
        # mirror ctx.managed_infra_dir when requires_config_resource_patch".
        if managed_infra_dir_for_patch == "__unset__":
            self._managed_infra_dir_for_patch_set = False
            self._managed_infra_dir_for_patch = None
        else:
            self._managed_infra_dir_for_patch_set = True
            self._managed_infra_dir_for_patch = managed_infra_dir_for_patch

    @property
    def managed_infra_dir_for_patch(self) -> Any:
        if self._managed_infra_dir_for_patch_set:
            return self._managed_infra_dir_for_patch
        return self.managed_infra_dir if self.requires_config_resource_patch else None


@runtime_checkable
class RemoteConfigPatchStrategy(Protocol):
    """Generates local-overlay artifacts + env/arg injections that disable
    remote-config dependencies for one workspace service class.

    Implementations declare a stable ``name`` attribute (used by tests and
    diagnostics) and provide ``applies_to`` + ``materialize`` methods. The
    strategy is responsible for its own artifact set; selection by
    ``select_remote_config_strategies(ctx)`` allows multiple strategies to
    co-exist in a mixed workspace.
    """

    name: str

    def applies_to(self, ctx: RemoteConfigPatchContext) -> bool: ...

    def materialize(self, ctx: RemoteConfigPatchContext) -> Dict[str, Any]: ...
# --- End remote-config patch strategy seam --------------------------------


