def option(value: str, label: Optional[str] = None, selected: bool = False) -> str:
    escaped = html.escape(value)
    text = html.escape(label if label is not None else value)
    selected_attr = " selected" if selected else ""
    return f'<option value="{escaped}"{selected_attr}>{text}</option>'


class Workspace:
    def __init__(self, root: Path, config: Dict[str, Any]):
        self.root = root
        self.config = config
        self.name = config.get("workspace") or root.name
        self.state_dir = STATE_HOME / safe_name(str(self.name))
        self.pid_dir = self.state_dir / "pids"
        self.failure_dir = self.state_dir / "failures"
        self.log_dir = self.state_dir / "logs"
        self.pid_dir.mkdir(parents=True, exist_ok=True)
        self.failure_dir.mkdir(parents=True, exist_ok=True)
        self.log_dir.mkdir(parents=True, exist_ok=True)

    @property
    def domain_overrides(self) -> Dict[str, Any]:
        """Return the lazy-loaded per-workspace domain overrides dict.

        See ``load_domain_overrides`` for the file-lookup contract. The
        property always returns a dict — empty when no overrides file
        exists or the file fails to parse.
        """
        return load_domain_overrides(self.root, str(self.name))

    @classmethod
    def load(cls, args: argparse.Namespace) -> "Workspace":
        registry = WorkspaceRegistry.load()
        root = resolve_workspace_root(args)
        name = args.workspace if getattr(args, "workspace", None) else None
        return cls(root, load_workspace_config(root, registry, name))

    @classmethod
    def load_for_ui(cls, args: argparse.Namespace) -> "Workspace":
        registry = WorkspaceRegistry.load()
        if args.workspace:
            if args.workspace == NEW_WORKSPACE_ID:
                root = Path.cwd().resolve()
                return cls(root, setup_workspace_config(root))
            return cls.load(args)

        if args.root:
            return cls.load(args)

        if registry.default:
            try:
                return cls.load(argparse.Namespace(root=None, workspace=registry.default))
            except DevstackError:
                pass

        for entry in registry.entries():
            if registry.config_path(entry["name"], entry["root"]):
                return cls(entry["root"], load_workspace_config(entry["root"], registry, entry["name"]))

        root = Path.cwd().resolve()
        return cls(root, setup_workspace_config(root))

    @property
    def services(self) -> Dict[str, Dict[str, Any]]:
        return self.config.get("services", {})

    @property
    def profiles(self) -> Dict[str, List[str]]:
        profiles = self.config.get("profiles", {})
        normalized: Dict[str, List[str]] = {}
        for key, value in profiles.items():
            if isinstance(value, dict):
                services = value.get("services", [])
            else:
                services = value
            normalized[key] = services if isinstance(services, list) else []
        return normalized

    @property
    def groups(self) -> Dict[str, List[str]]:
        return self.config.get("groups", {})

    def resolve_target(self, target: str, only: Optional[str] = None) -> List[str]:
        if only:
            return split_csv(only)
        if target == "all":
            return list(self.services.keys())
        if target in self.services:
            return [target]
        if target in self.profiles:
            return list(self.profiles[target])
        if target in self.groups:
            services: List[str] = []
            for profile in self.groups[target]:
                services.extend(self.resolve_target(profile))
            return unique(services)
        raise DevstackError(f"unknown target: {target}")

    def start_many(
        self,
        services: Iterable[str],
        include_deps: bool = True,
        skip_recoverable: bool = False,
    ) -> None:
        failures: List[str] = []
        for service in self.expand_dependencies(services) if include_deps else services:
            if skip_recoverable and self.is_recoverable_nonserver(service):
                print(f"devstack: skipped recoverable non-server service: {service}", file=sys.stderr)
                continue
            try:
                self.start_service(service, include_deps=False)
            except DevstackError as error:
                failures.append(f"{service}: {error}")
                print(f"devstack: failed to start {service}: {error}", file=sys.stderr)

        if failures:
            raise DevstackError("some services failed to start:\n" + "\n".join(f"- {item}" for item in failures))

    def stop_many(self, services: Iterable[str]) -> None:
        failures: List[str] = []
        for service in reversed(self.expand_dependencies(services)):
            try:
                self.stop_service(service)
            except DevstackError as error:
                failures.append(f"{service}: {error}")
                print(f"devstack: failed to stop {service}: {error}", file=sys.stderr)

        if failures:
            raise DevstackError("some services failed to stop:\n" + "\n".join(f"- {item}" for item in failures))

    def start_service(self, service_name: str, include_deps: bool = True) -> None:
        service = self.service(service_name)
        try:
            self.clear_service_failure(service_name)
            if include_deps:
                for dep in self.expand_dependencies(service.get("depends_on", [])):
                    self.start_service(dep, include_deps=False)

            service_type = service.get("type")
            if service_type == "gradle":
                self.start_gradle(service_name, service)
            elif service_type == "compose":
                container = service.get("container")
                if container:
                    existing = docker_container_inspect(container)
                    if existing and docker_container_running_from_inspect(existing):
                        return
                    if existing:
                        compose_service = docker_compose_service_from_inspect(existing)
                        if compose_service == service["service"]:
                            run(["docker", "start", container], cwd=self.root)
                        else:
                            owner = compose_service or "unknown"
                            raise DevstackError(
                                f"{service_name}: container {container!r} already exists "
                                f"for compose service {owner!r}"
                            )
                    else:
                        self.run_compose(service, ["up", "-d", service["service"]])
                else:
                    self.run_compose(service, ["up", "-d", service["service"]])
            elif service_type == "command":
                self.start_command(service_name, service)
            else:
                raise DevstackError(f"{service_name}: unsupported service type {service_type!r}")

            self.wait_for_ready(service_name, service)
            self.initialize_managed_infra(service)
        except DevstackError as error:
            self.cleanup_failed_start(service_name, service)
            self.mark_service_failed(service_name, str(error))
            raise
        else:
            self.clear_service_failure(service_name)

    def stop_service(self, service_name: str, allow_port_owner: bool = False) -> None:
        service = self.service(service_name)
        service_type = service.get("type")
        self.clear_service_failure(service_name)
        if service_type == "compose":
            container = service.get("container")
            if container and docker_container_running(container):
                run(["docker", "stop", container], cwd=self.root)
                self.ensure_service_port_released(service_name, service)
                return
            self.run_compose(service, ["stop", service["service"]])
            self.ensure_service_port_released(service_name, service)
            return

        pid = self.read_pid(service_name)
        if pid is None:
            if (allow_port_owner or service.get("stop_by_port")) and service.get("port"):
                self.stop_port_process(service_name, int(service["port"]))
                self.ensure_service_port_released(service_name, service)
                return
            self.ensure_service_port_released(service_name, service)
            return
        self.terminate_service_pid(service_name, pid)
        self.stop_lingering_service_port(service_name, service, pid)
        if process_running(pid):
            reason = f"{service_name}: process {pid} did not stop"
            self.mark_service_failed(service_name, reason)
            raise DevstackError(reason)
        self.pid_path(service_name).unlink(missing_ok=True)
        self.ensure_service_port_released(service_name, service)

    def terminate_service_pid(self, service_name: str, pid: int) -> None:
        terminate_pid_or_group(pid, signal.SIGTERM, service_name)
        self.wait_pid_exit(pid, timeout=10)
        if not process_running(pid):
            return

        terminate_pid_or_group(pid, signal.SIGKILL, service_name)
        self.wait_pid_exit(pid, timeout=5)

    def cleanup_failed_start(self, service_name: str, service: Dict[str, Any]) -> None:
        pid = self.read_pid(service_name)
        if pid is None:
            return

        try:
            self.terminate_service_pid(service_name, pid)
            self.stop_lingering_service_port(service_name, service, pid)
        except DevstackError:
            return

        if not process_running(pid):
            self.pid_path(service_name).unlink(missing_ok=True)

    def stop_port_process(self, service_name: str, port: int) -> None:
        container = docker_container_for_host_port(port)
        if container:
            run(["docker", "stop", docker_container_id(container)], cwd=self.root)
            return

        pid = pid_for_listening_port(port)
        if pid is None:
            return
        self.terminate_service_pid(service_name, pid)

    def ensure_service_port_released(self, service_name: str, service: Dict[str, Any]) -> None:
        port = service.get("port")
        if not port or not port_open("127.0.0.1", int(port)):
            return

        owner = listening_port_owner_summary(int(port))
        reason = f"{service_name}: stop did not release port {port}; owner: {owner}"
        self.mark_service_failed(service_name, reason)
        raise DevstackError(reason)

    def stop_lingering_service_port(self, service_name: str, service: Dict[str, Any], started_pid: int) -> None:
        port = service.get("port")
        if not port:
            return

        owner_pid = pid_for_listening_port(int(port))
        if owner_pid is None:
            return

        owner_group = process_group_id(owner_pid)
        if owner_pid != started_pid and owner_group != started_pid:
            if self.service_owns_process_command(service, process_command(owner_pid)):
                self.terminate_service_pid(service_name, owner_pid)
                return
            return

        terminate_process_group(started_pid, signal.SIGTERM, service_name)
        self.wait_pid_exit(owner_pid, timeout=5)

        owner_pid = pid_for_listening_port(int(port))
        if owner_pid is None:
            return

        owner_group = process_group_id(owner_pid)
        if owner_pid == started_pid or owner_group == started_pid:
            terminate_process_group(started_pid, signal.SIGKILL, service_name)
            self.wait_pid_exit(owner_pid, timeout=5)

    def service_owns_process_command(self, service: Dict[str, Any], command: str) -> bool:
        if not command or command == "unknown command":
            return False
        root = str(self.root)
        if root and root not in command:
            return False
        port = service.get("port")
        if port and f"--server.port={port}" in command:
            return True
        task = str(service.get("task") or "")
        if task and task in command:
            return True
        module = gradle_task_module_path(task)
        if module:
            module_path = module.strip(":").replace(":", "/")
            if module_path and f"/{module_path}/" in command:
                return True
        return False

    def start_gradle(self, service_name: str, service: Dict[str, Any]) -> None:
        existing = self.read_pid(service_name)
        if existing and process_running(existing):
            return
        port = service.get("port")
        if port and port_open("127.0.0.1", int(port)):
            health = service.get("health")
            if health and http_ok(health):
                return
            raise DevstackError(f"{service_name}: port {port} is already in use")

        env = self.process_env(service)
        gradle_args = [
            expand_value(str(arg), self.root, env)
            for arg in [*string_list(self.config.get("gradle_args", [])), *string_list(service.get("gradle_args", []))]
        ]
        cmd = [self.gradlew(), *gradle_args, service["task"]]
        args = service.get("args", [])
        if args:
            expanded_args = [expand_value(str(arg), self.root, env) for arg in args]
            cmd.append("--args=" + " ".join(expanded_args))

        self.spawn(service_name, cmd, env)

    def start_command(self, service_name: str, service: Dict[str, Any]) -> None:
        existing = self.read_pid(service_name)
        if existing and process_running(existing):
            return
        cmd = service.get("command")
        if not cmd:
            raise DevstackError(f"{service_name}: command is required")
        self.spawn(service_name, cmd, self.process_env(service), shell=isinstance(cmd, str))

    def spawn(self, service_name: str, cmd: Any, env: Dict[str, str], shell: bool = False) -> None:
        log_path = self.service_log_path(service_name)
        log_path.parent.mkdir(parents=True, exist_ok=True)
        log_file = log_path.open("ab")
        process = subprocess.Popen(
            cmd,
            cwd=self.root,
            env=env,
            stdout=log_file,
            stderr=subprocess.STDOUT,
            start_new_session=True,
            shell=shell,
        )
        self.pid_path(service_name).write_text(str(process.pid))

    def run_compose(self, service: Dict[str, Any], args: List[str]) -> None:
        compose_file = self.compose_file_path(service)
        self.refresh_managed_infra_compose(compose_file)
        if not compose_file.exists():
            raise DevstackError(f"compose file not found: {compose_file}")
        cmd = [*compose_command(self.root), *compose_project_args(service), "-f", str(compose_file), *args]
        run(cmd, cwd=self.root)

    def refresh_managed_infra_compose(self, compose_file: Path) -> None:
        if compose_file != managed_infra_compose_path(self.name):
            return

        requirements: List[Dict[str, Any]] = []
        for service_name, service in sorted(self.services.items()):
            if not is_managed_infra_service_name(service_name):
                continue
            if not isinstance(service, dict) or service.get("type") != "compose":
                continue
            if self.compose_file_path(service) != compose_file:
                continue
            requirement = existing_managed_infra_requirement(self.name, service_name, service)
            if requirement:
                requirements.append(requirement)

        if requirements:
            write_managed_compose(compose_file, requirements, self.name)

    def initialize_managed_infra(self, service: Dict[str, Any]) -> None:
        if service.get("type") != "compose":
            return
        engine = str(service.get("engine") or "").lower()
        if engine == "mssql":
            self._initialize_mssql(service)
            return
        if engine in {"mysql", "mariadb"}:
            self._initialize_mysql_family(service, engine)
            return
        if engine == "postgresql":
            self._initialize_postgresql(service)
            return
        # Any other compose service (redis, kafka, mongo, ...) carries no
        # devstack-managed DDL and is left untouched.

    def _initialize_mssql(self, service: Dict[str, Any]) -> None:
        database = str(service.get("database") or "").strip()
        if not database:
            return

        self.run_mssql_sqlcmd_with_retry(
            service,
            ["-Q", f"IF DB_ID(N'{database.replace(chr(39), chr(39) + chr(39))}') IS NULL CREATE DATABASE {mssql_identifier(database)};"],
        )
        for key in ("init_schema", "init_dml"):
            script = str(service.get(key) or "").strip()
            if script:
                self.run_mssql_sqlcmd_with_retry(service, ["-d", database, "-i", script])

    def _initialize_mysql_family(self, service: Dict[str, Any], engine: str) -> None:
        """Apply DDL/DML for MySQL or MariaDB.

        Unlike MSSQL we cannot rely on a sqlcmd-style CLI driver, but unlike
        the pure-compose path we also cannot rely on
        ``/docker-entrypoint-initdb.d/`` because the official image silently
        skips that directory whenever the named data volume already contains
        an initialized database. The fix is to actively run the seeded SQL
        files (resolved via ``managed_schema_path`` / ``managed_dml_path``)
        through ``docker compose exec`` on every start.
        """
        database = str(service.get("database") or "").strip()
        if not database:
            return

        defaults = MANAGED_DATABASES[engine]
        label = str(defaults["label"])
        self._warn_if_managed_data_volume_stale(service, engine, label)

        for key in ("init_schema", "init_dml"):
            host_path = self._resolved_managed_sql_host_path(service, engine, key)
            if host_path is None:
                continue
            self.run_mysql_apply_sql_with_retry(service, str(host_path))

    def _initialize_postgresql(self, service: Dict[str, Any]) -> None:
        """Apply DDL/DML for PostgreSQL — same rationale as MySQL above."""
        database = str(service.get("database") or "").strip()
        if not database:
            return

        defaults = MANAGED_DATABASES["postgresql"]
        label = str(defaults["label"])
        self._warn_if_managed_data_volume_stale(service, "postgresql", label)

        for key in ("init_schema", "init_dml"):
            host_path = self._resolved_managed_sql_host_path(service, "postgresql", key)
            if host_path is None:
                continue
            self.run_postgres_apply_sql_with_retry(service, str(host_path))

    def _resolved_managed_sql_host_path(
        self, service: Dict[str, Any], engine: str, key: str
    ) -> Optional[Path]:
        """Resolve the host-side path of the seeded init_schema / init_dml file.

        Returns None when the field is not set on the service or when the
        materialized file is missing on disk — the caller treats both as
        "no SQL to apply" and silently skips it.
        """
        script = str(service.get(key) or "").strip()
        if not script:
            return None
        if key == "init_schema":
            path = managed_schema_path(self.name, engine)
        else:
            path = managed_dml_path(self.name, engine)
        if not path.exists():
            return None
        return path

    def _warn_if_managed_data_volume_stale(
        self, service: Dict[str, Any], engine: str, label: str
    ) -> None:
        """When the named data volume for `(engine, label)` already exists,
        write a one-line warning explaining that the image's first-run
        ``/docker-entrypoint-initdb.d/`` is being silently skipped and that
        the seeded SQL is being applied via ``docker compose exec`` instead.

        The warning also points the user at the existing ``--recreate-volumes``
        remediation path so they can rebuild from scratch when needed."""
        # Skip the warning entirely when neither init_schema nor init_dml is
        # configured — there is no DDL to apply, so no bypass is happening.
        if not service.get("init_schema") and not service.get("init_dml"):
            return
        if not managed_data_volume_exists(engine, label):
            return
        volume_name = f"devstack-{label}-data"
        service_name = str(service.get("service") or label)
        sys.stderr.write(
            f"devstack: warning: named data volume {volume_name!r} already exists; "
            f"the {service_name} container will silently skip "
            f"/docker-entrypoint-initdb.d/ on this start. "
            f"devstack is re-applying the seeded schema via 'docker compose exec' "
            f"so the DDL is still loaded, but if you need a clean re-init run:\n"
            f"    devstack workspace apply <workspace> --recreate-volumes\n"
        )

    def run_mysql_apply_sql_with_retry(self, service: Dict[str, Any], script_path: str) -> None:
        deadline = time.time() + self.service_start_timeout(service)
        while True:
            try:
                self.run_mysql_apply_sql(service, script_path)
                return
            except DevstackError as error:
                if time.time() >= deadline:
                    raise error
                time.sleep(2)

    def run_mysql_apply_sql(self, service: Dict[str, Any], script_path: str) -> None:
        compose_file = self.compose_file_path(service)
        engine = str(service.get("engine") or "mysql").lower()
        defaults = MANAGED_DATABASES.get(engine, MANAGED_DATABASES["mysql"])
        username = str(service.get("username") or defaults["username"])
        password = str(service.get("password") or defaults["password"])
        database = str(service.get("database") or "").strip()
        if not database:
            raise DevstackError(
                f"{service.get('service', 'mysql')}: cannot apply SQL — no database configured"
            )
        # `sh -c "mysql ... < /script"` is the most portable form across mysql
        # and mariadb images: it avoids assumptions about argparse handling
        # of `-e` quoting and reuses stdin redirection which every official
        # image supports.
        inner = (
            f"mysql -u{shlex.quote(username)} -p{shlex.quote(password)} "
            f"{shlex.quote(database)} < {shlex.quote(script_path)}"
        )
        command = [
            *compose_command(self.root),
            *compose_project_args(service),
            "-f",
            str(compose_file),
            "exec",
            "-T",
            str(service["service"]),
            "sh",
            "-c",
            inner,
        ]
        run(command, cwd=self.root)

    def run_postgres_apply_sql_with_retry(self, service: Dict[str, Any], script_path: str) -> None:
        deadline = time.time() + self.service_start_timeout(service)
        while True:
            try:
                self.run_postgres_apply_sql(service, script_path)
                return
            except DevstackError as error:
                if time.time() >= deadline:
                    raise error
                time.sleep(2)

    def run_postgres_apply_sql(self, service: Dict[str, Any], script_path: str) -> None:
        compose_file = self.compose_file_path(service)
        defaults = MANAGED_DATABASES["postgresql"]
        username = str(service.get("username") or defaults["username"])
        password = str(service.get("password") or defaults["password"])
        database = str(service.get("database") or "").strip()
        if not database:
            raise DevstackError(
                f"{service.get('service', 'postgres')}: cannot apply SQL — no database configured"
            )
        # `sh -c "PGPASSWORD=... psql -U <user> -d <db> -f <path>"` is the
        # canonical psql invocation. PGPASSWORD avoids interactive prompts
        # without exposing the password on the argv list outside the container.
        inner = (
            f"PGPASSWORD={shlex.quote(password)} "
            f"psql -v ON_ERROR_STOP=1 -U {shlex.quote(username)} "
            f"-d {shlex.quote(database)} -f {shlex.quote(script_path)}"
        )
        command = [
            *compose_command(self.root),
            *compose_project_args(service),
            "-f",
            str(compose_file),
            "exec",
            "-T",
            str(service["service"]),
            "sh",
            "-c",
            inner,
        ]
        run(command, cwd=self.root)

    def run_mssql_sqlcmd_with_retry(self, service: Dict[str, Any], args: List[str]) -> None:
        deadline = time.time() + self.service_start_timeout(service)
        while True:
            try:
                self.run_mssql_sqlcmd(service, args)
                return
            except DevstackError as error:
                if time.time() >= deadline:
                    raise error
                time.sleep(2)

    def run_mssql_sqlcmd(self, service: Dict[str, Any], args: List[str]) -> None:
        compose_file = self.compose_file_path(service)
        username = str(service.get("username") or "sa")
        password = str(service.get("password") or MANAGED_DATABASES["mssql"]["password"])
        command = [
            *compose_command(self.root),
            *compose_project_args(service),
            "-f",
            str(compose_file),
            "exec",
            "-T",
            str(service["service"]),
            "/opt/mssql-tools18/bin/sqlcmd",
            "-S",
            "localhost",
            "-U",
            username,
            "-P",
            password,
            "-C",
            *args,
        ]
        run(command, cwd=self.root)

    def compose_file_path(self, service: Dict[str, Any]) -> Path:
        env = os.environ.copy()
        # Export both new and legacy names so service compose files that
        # interpolate either ``${DEVSTACK_ROOT}`` or the legacy
        # ``${CCSTACK_ROOT}`` placeholder continue to resolve.
        env["DEVSTACK_ROOT"] = str(self.root)
        env["CCSTACK_ROOT"] = str(self.root)
        compose_value = expand_value(str(service["compose"]), self.root, env)
        compose_file = Path(compose_value)
        if not compose_file.is_absolute():
            compose_file = self.root / compose_file
        return compose_file

    def wait_for_ready(self, service_name: str, service: Dict[str, Any]) -> None:
        timeout = self.service_start_timeout(service)
        health = service.get("health")
        port = service.get("port")
        deadline = time.time() + timeout

        # Non-JVM (type=command) services may carry datasource-shaped env
        # keys (DATABASE_URL=..., *_DB_URL=..., jdbc:...) without exposing
        # health/port. The Spring Boot actuator path used by
        # `verify_managed_datasource` cannot prove the binding here, so we
        # run the minimal handshake: TCP-open of the promised host:port,
        # plus the managed-DB container liveness when the endpoint resolves
        # to a devstack-managed compose service. The app-side binding stays
        # unverified — that fact is recorded via `add_service_status_note`
        # instead of staying silent.
        datasource_entries: List[Tuple[str, str]] = []
        if service.get("type") == "command":
            datasource_entries = command_service_datasource_env(service)

        if not health and not port and not datasource_entries:
            return

        while time.time() < deadline:
            if health and http_ok(health):
                # Startup datasource invariant: process listens AND health
                # endpoint is green — now prove the app bound the managed
                # JDBC URL. Raises DevstackError on mismatch; soft-passes
                # when actuator env is unreachable.
                verify_managed_datasource(service_name, service)
                if datasource_entries and not verify_command_service_datasources(
                    service_name, service, datasource_entries, self.services
                ):
                    time.sleep(1)
                    continue
                return
            if not health and port and port_open("127.0.0.1", int(port)):
                verify_managed_datasource(service_name, service)
                if datasource_entries and not verify_command_service_datasources(
                    service_name, service, datasource_entries, self.services
                ):
                    time.sleep(1)
                    continue
                return
            if not health and not port and datasource_entries:
                # Pure datasource-gated command service (no HTTP, no
                # process-listening port to wait on). The handshake is
                # the only proof we have.
                if verify_command_service_datasources(
                    service_name, service, datasource_entries, self.services
                ):
                    return
            pid = self.read_pid(service_name)
            if pid and not process_running(pid):
                raise DevstackError(f"{service_name}: process exited; see {self.service_log_path(service_name)}")
            time.sleep(1)
        pid = self.read_pid(service_name)
        if pid and not process_running(pid):
            raise DevstackError(f"{service_name}: process exited; see {self.service_log_path(service_name)}")
        if health:
            raise DevstackError(
                f"{service_name}: health check did not become ready in {timeout}s; "
                f"see {self.service_log_path(service_name)}"
            )
        if port:
            raise DevstackError(
                f"{service_name}: port {port} did not open in {timeout}s; "
                f"see {self.service_log_path(service_name)}"
            )
        if datasource_entries:
            raise DevstackError(
                f"{service_name}: datasource handshake did not complete in {timeout}s; "
                f"see {self.service_log_path(service_name)} and service notes for "
                f"datasource_tcp_unreachable / managed_database_not_alive entries"
            )
        raise DevstackError(f"{service_name}: did not become ready in {timeout}s")

    def service_start_timeout(self, service: Dict[str, Any]) -> int:
        if service.get("timeout") is not None:
            return int(service["timeout"])
        if self.config.get("default_timeout") is not None:
            return int(self.config["default_timeout"])
        if service.get("type") == "gradle":
            return DEFAULT_GRADLE_SERVICE_TIMEOUT
        return DEFAULT_SERVICE_TIMEOUT

    def print_status(self, services: Iterable[str]) -> None:
        print(f"workspace: {self.name}")
        printed_names: List[str] = []
        for name in unique(services):
            service = self.service(name)
            state = self.service_state(name, service)
            port = service.get("port", "-")
            health = "ok" if service.get("health") and http_ok(service["health"]) else "-"
            print(f"{name:28} {state:10} port={port} health={health} log={self.service_log_path(name)}")
            printed_names.append(name)

        # Seed-drift readiness — when a drift record exists, append a
        # `DEGRADED: seed drift` annotation for every printed service that is
        # in `affected_services`, then append a single workspace-level state
        # line carrying the exact remediation command. Boot is not blocked,
        # but the user must see the workspace is not fully green until drift
        # is resolved. See SEED_DRIFT_FILENAME for the schema and lifecycle.
        seed_drift_state_emitted = False
        drift_state = read_seed_drift_state(self.name)
        if drift_state:
            affected = set(drift_state.get("affected_services", []) or [])
            remediation = str(drift_state.get("remediation", "") or format_seed_drift_remediation(self.name))
            for name in printed_names:
                if name in affected:
                    print(f"{name:28} {'DEGRADED':10} reason=seed-drift remediation=\"{remediation}\"")
            print(f"WORKSPACE STATE: degraded - seed drift; run: {remediation}")
            seed_drift_state_emitted = True

        # Grey-zone counters — aggregate the four reliability-feature signal
        # surfaces (seed-drift, probe signals, mock-fallback routes,
        # devstack_status_notes) into the four named counters. Render rules:
        #
        # 1. Per-service `GREY-ZONE: app_binding_unverified` annotation rows
        #    for every printed service that carries the matching status note,
        #    so the operator can tie a workspace-level count back to specific
        #    services without re-running the probe.
        # 2. A single, always-printable parseable counters line so external
        #    tooling can grep for a fixed prefix and parse `key=value` pairs.
        # 3. A human-readable `WORKSPACE STATE: grey-zone - ...` summary line
        #    ONLY when at least one counter is non-zero AND the seed-drift
        #    block above did not already emit its own WORKSPACE STATE line.
        #    This keeps an all-green workspace fully quiet (no extra lines
        #    beyond the parseable counters line) and avoids duplicating the
        #    `degraded` signal when seed-drift was the only source.
        counters = count_workspace_grey_zone(self)
        for name in printed_names:
            service = self.services.get(name) or {}
            notes = read_status_notes(service) if isinstance(service, dict) else None
            if not isinstance(notes, list):
                continue
            for note in notes:
                if not isinstance(note, dict):
                    continue
                if note.get("key") == "app_binding_unverified" and note.get("value"):
                    detail = str(note.get("detail") or "").strip()
                    suffix = f" detail=\"{detail}\"" if detail else ""
                    print(
                        f"{name:28} {'GREY-ZONE':10} reason=app_binding_unverified{suffix}"
                    )
                    break
        # Per-service unmanaged_dependency annotation. The manifest's
        # `devstack_managed_environment.manual_review` array holds the
        # analysis-time classification with the engine (`technology`)
        # and source path. We attach a GREY-ZONE row to every printed
        # service whose name matches the basename of an unmanaged
        # entry's source path, or whose path field appears in the
        # entry's source. Matching is best-effort and tolerant — when
        # no service can be matched the workspace-level counter still
        # fires; the per-service annotation is purely additional UX.
        try:
            managed_for_status = (
                read_managed_environment(self.config)
                if isinstance(self.config, dict) else None
            )
            unmanaged_entries: List[Dict[str, Any]] = []
            if isinstance(managed_for_status, dict):
                raw = managed_for_status.get("manual_review")
                if isinstance(raw, list):
                    for entry in raw:
                        if not isinstance(entry, dict):
                            continue
                        if entry.get("kind") != "database":
                            continue
                        if entry.get("status") != "manual_review":
                            continue
                        engine = entry.get("technology")
                        if not isinstance(engine, str) or not engine:
                            continue
                        if engine in MANAGED_DATABASES:
                            continue
                        if engine in {"h2", "unknown"}:
                            continue
                        unmanaged_entries.append(entry)
            for name in printed_names:
                if not unmanaged_entries:
                    break
                service = self.services.get(name) or {}
                service_path = ""
                if isinstance(service, dict):
                    service_path = str(service.get("path") or "")
                for entry in unmanaged_entries:
                    source = str(entry.get("source") or "")
                    engine = str(entry.get("technology") or "")
                    if not engine:
                        continue
                    # Match if: the service name appears as a path
                    # segment of the entry's source; or the service's
                    # configured path is a prefix of the source; or the
                    # source's last path component contains the service
                    # name. Any of these signals "this manual_review
                    # entry describes this service".
                    matched = False
                    if name and source:
                        if name in source.split("/"):
                            matched = True
                        elif name in source:
                            matched = True
                    if not matched and service_path and source:
                        if source.startswith(service_path):
                            matched = True
                    if matched:
                        print(
                            f"{name:28} {'GREY-ZONE':10} "
                            f"reason=unmanaged_dependency engine={engine}"
                        )
                        break
        except Exception:  # noqa: BLE001 — never break status rendering
            pass
        print(format_grey_zone_counters_line(counters))
        if not seed_drift_state_emitted:
            summary = format_grey_zone_summary_line(counters)
            if summary:
                print(summary)

    def service_state(self, name: str, service: Dict[str, Any]) -> str:
        if service.get("type") == "compose":
            return self.compose_service_state(service)
        pid = self.read_pid(name)
        if pid and process_running(pid):
            health = service.get("health")
            port = service.get("port")
            if health:
                if http_ok(health):
                    self.clear_service_failure(name)
                    return "ready"
                if port and port_open("127.0.0.1", int(port)):
                    return "unhealthy"
                return "starting"
            if port:
                if port_open("127.0.0.1", int(port)):
                    self.clear_service_failure(name)
                    return "ready"
                self.clear_service_failure(name)
                return "starting"
            self.clear_service_failure(name)
            return f"pid:{pid}"
        if pid:
            health = service.get("health")
            if health and http_ok(health):
                self.clear_service_failure(name)
                self.pid_path(name).unlink(missing_ok=True)
                return "external"
            port = service.get("port")
            if port and port_open("127.0.0.1", int(port)):
                self.clear_service_failure(name)
                self.pid_path(name).unlink(missing_ok=True)
                return "external"
            return "failed"
        health = service.get("health")
        if health and http_ok(health):
            self.clear_service_failure(name)
            return "external"
        port = service.get("port")
        if port and port_open("127.0.0.1", int(port)):
            self.clear_service_failure(name)
            return "external"
        if self.service_failed(name):
            return "failed"
        return "stopped"

    def compose_service_state(self, service: Dict[str, Any]) -> str:
        container = service.get("container")
        if container:
            status = docker_container_status(container)
            if status == "running":
                return "docker:up"
            if status in {"created", "exited"}:
                return "docker:down"
            if status:
                return f"docker:{status}"
            return "docker:down"

        status = docker_compose_service_status(
            self.compose_file_path(service),
            self.root,
            str(service["service"]),
            compose_project_name(service),
        )
        if status == "running":
            return "docker:up"
        if status in {"created", "exited", "stopped"}:
            return "docker:down"
        if status:
            return f"docker:{status}"
        return "docker:down"

    def show_logs(self, service_name: str, follow: bool, lines: int) -> None:
        service = self.service(service_name)
        if service.get("type") == "compose":
            args = ["logs", "--tail", str(lines)]
            if follow:
                args.append("-f")
            args.append(service["service"])
            self.run_compose(service, args)
            return
        log_path = self.service_log_path(service_name)
        if not log_path.exists():
            raise DevstackError(f"log not found: {log_path}")
        cmd = ["tail", "-n", str(lines)]
        if follow:
            cmd.append("-f")
        cmd.append(str(log_path))
        run(cmd, cwd=self.root)

    def clear_logs(self, service_name: str) -> Path:
        service = self.service(service_name)
        if service.get("type") == "compose":
            raise DevstackError(f"{service_name}: Docker-managed logs cannot be cleared safely from devstack UI")

        log_path = self.service_log_path(service_name)
        log_path.parent.mkdir(parents=True, exist_ok=True)
        log_path.write_text("")
        return log_path

    def recover_service(
        self,
        service_name: str,
        mode: str = "auto",
        target: str = "default",
        confirm: bool = False,
    ) -> str:
        self.service(service_name)
        if mode == "auto":
            return self.recover_failed_service(service_name)
        if mode == "skip-if-nonserver":
            return self.recover_skip_nonserver(service_name, target)
        if mode == "stop-port-and-restart":
            return self.recover_stop_port_and_restart(service_name, confirm=confirm)
        if mode == "local-config-and-restart":
            return self.recover_local_config_and_restart(service_name)
        raise DevstackError(f"unsupported recovery mode: {mode}")

    def recover_failed_service(self, service_name: str) -> str:
        service = self.service(service_name)
        state = self.service_state(service_name, service)
        if state != "failed":
            verified, verification = self.verify_service_api_dummy_data(service_name)
            if verified:
                return self.recovery_not_needed_output(service_name, state, verification)
            state = f"{state} (api verification failed: {verification})"

        diagnostics = self.recovery_diagnostics(service_name, service, state)
        applied: List[str] = []
        applied.extend(self.reanalyze_local_runtime_for_recovery(service_name))
        service = self.service(service_name)
        if self.apply_local_config_recovery(service):
            applied.append("devstack-managed local config overrides")
        api_mock_fixes = self.apply_api_mock_recovery(service_name, service)
        applied.extend(api_mock_fixes)
        self.persist_current_config()
        if applied:
            applied.append("persisted devstack-managed local runtime config")

        self.stop_service(service_name, allow_port_owner=True)
        self.start_service(service_name)

        final_state = self.service_state(service_name, service)
        verified, verification = self.verify_service_api_dummy_data(service_name)
        status = "passed" if verified else "not verified"
        return "\n".join(
            [
                f"recovery target: {service_name}",
                "diagnosis:",
                *[f"- {line}" for line in diagnostics],
                "applied fixes:",
                *(f"- {item}" for item in (applied or ["none"])),
                f"restarted only: {service_name}",
                f"final state: {final_state}",
                f"api verification: {status} - {verification}",
            ]
        )

    def reanalyze_local_runtime_for_recovery(self, service_name: str) -> List[str]:
        config = json.loads(json.dumps(self.config))
        reserved_ports = registered_workspace_reserved_ports(self.name, self.root)
        config, augment = augment_workspace_config(self.root, config, reserved_ports=reserved_ports)
        analysis = analyze_workspace_config(self.root, config, reserved_ports=reserved_ports)
        managed_config, managed_environment = materialize_managed_environment(self.name, self.root, config, analysis)
        self.config = managed_config

        applied = ["reanalyzed workspace local environment"]
        added_services = augment.get("added_services", [])
        updated_services = augment.get("updated_services", [])
        port_reassignments = augment.get("port_reassignments", [])
        if added_services:
            applied.append(f"detected {len(added_services)} additional service(s)")
        if updated_services:
            applied.append(f"updated {len(updated_services)} detected service definition(s)")
        if port_reassignments:
            applied.append(f"resolved {len(port_reassignments)} service port conflict(s)")
        if managed_environment.get("services"):
            applied.append(f"prepared {len(managed_environment['services'])} managed infrastructure service(s)")
        if managed_environment.get("env_overrides"):
            applied.append(f"applied {managed_environment['env_overrides']} local environment override(s)")
        if managed_environment.get("arg_overrides"):
            applied.append(f"applied {managed_environment['arg_overrides']} local argument override(s)")
        if service_name not in self.services:
            raise DevstackError(f"{service_name}: service disappeared after recovery analysis")
        return applied

    def persist_current_config(self) -> Path:
        manifest_path = generated_manifest_path(self.name)
        write_json(manifest_path, self.config)
        registry = WorkspaceRegistry.load()
        registry.register(self.name, self.root, manifest_path)
        registry.save()
        write_workspace_state(self.name, self.root, manifest_path, "managed")
        return manifest_path

    def recovery_not_needed_output(self, service_name: str, state: str, verification: str) -> str:
        return "\n".join(
            [
                f"recovery target: {service_name}",
                "diagnosis:",
                f"- state: {state}",
                "- API dummy-data verification already passes",
                "applied fixes:",
                "- none",
                "restarted only: none",
                f"final state: {state}",
                f"api verification: passed - {verification}",
            ]
        )

    def recovery_diagnostics(self, service_name: str, service: Dict[str, Any], state: str) -> List[str]:
        diagnostics = [f"state: {state}", f"type: {service.get('type', 'unknown')}"]
        port = service.get("port")
        if port:
            diagnostics.append(f"port: {port}")
        health = service.get("health")
        if health:
            diagnostics.append(f"health: {health}")

        failure = self.service_failure_reason(service_name)
        if failure:
            diagnostics.append(f"failure: {failure}")

        tail = self.service_log_tail(service_name, lines=8)
        if tail:
            diagnostics.append("recent log:")
            diagnostics.extend(f"  {line}" for line in tail.splitlines()[-8:])
        return diagnostics

    def service_failure_reason(self, service_name: str) -> str:
        path = self.failure_path(service_name)
        if not path.exists():
            return ""
        try:
            data = json.loads(path.read_text())
        except (OSError, json.JSONDecodeError):
            return ""
        return str(data.get("reason") or "")

    def service_log_tail(self, service_name: str, lines: int = 20) -> str:
        path = self.service_log_path(service_name)
        if not path.exists():
            return ""
        text = path.read_text(errors="replace")
        return "\n".join(text.splitlines()[-lines:])

    def apply_local_config_recovery(self, service: Dict[str, Any]) -> bool:
        if service.get("type") != "gradle":
            return False

        env = service.setdefault("env", {})
        before_env = dict(env)
        env.setdefault("SPRING_CLOUD_CONFIG_ENABLED", "false")
        env.setdefault("SPRING_CLOUD_CONFIG_IMPORT_CHECK_ENABLED", "false")
        env.setdefault("SPRING_CONFIG_IMPORT", LOCAL_CONFIG_IMPORT)

        args = service.setdefault("args", [])
        before_args = list(args)
        for value in (
            "--spring.cloud.config.enabled=false",
            "--spring.cloud.config.import-check.enabled=false",
            f"--spring.config.import={LOCAL_CONFIG_IMPORT}",
        ):
            if value not in args:
                args.append(value)

        return before_env != env or before_args != args

    def apply_api_mock_recovery(self, service_name: str, service: Dict[str, Any]) -> List[str]:
        """Apply workspace-declared backend-to-mockserver recovery rules.

        Domain-agnostic engine: rules live in
        ``overrides["api_mock_recovery"]["service_name_keyword_rules"]`` as a
        map of keyword-substring -> rule. Each rule may declare:
          * ``env_overrides``: dict of env-var -> value to set on the service
            when missing or stale.
          * ``fix_message``: a single human-readable fix message to append
            when at least one env override was applied.
          * ``expectation_routes``: list of mockserver routes to ensure exist
            (always invoked when the keyword matches, even if env was already
            up to date — keeps mockserver expectations in lockstep).

        Without overrides the function is a no-op (returns ``[]``). With the
        shipped shopping overrides loaded, the samplegoods recovery rule routes
        ``SAMPLEGOODS_SERVICE_URL`` to ``http://localhost:1080`` and re-asserts
        the /sample-goods family of mockserver expectations.
        """
        fixes: List[str] = []
        rules = (self.domain_overrides.get("api_mock_recovery") or {}).get(
            "service_name_keyword_rules"
        ) or {}
        if not isinstance(rules, dict):
            return fixes
        lowered = service_name.lower()
        for keyword, rule in rules.items():
            if not isinstance(keyword, str) or not isinstance(rule, dict):
                continue
            if keyword.lower() not in lowered:
                continue
            env_overrides = rule.get("env_overrides") or {}
            fix_message = rule.get("fix_message")
            expectation_routes = rule.get("expectation_routes") or []
            if isinstance(env_overrides, dict) and env_overrides:
                env = service.setdefault("env", {})
                env_changed = False
                for key, value in env_overrides.items():
                    target = str(value)
                    if env.get(key) != target:
                        env[key] = target
                        env_changed = True
                if env_changed and isinstance(fix_message, str) and fix_message:
                    fixes.append(fix_message)
            if isinstance(expectation_routes, list) and expectation_routes:
                routes = [str(r) for r in expectation_routes if isinstance(r, str) and r]
                if routes:
                    self.ensure_mockserver_expectation_routes(routes)
        return fixes

    def ensure_mockserver_expectation_routes(self, routes: List[str]) -> None:
        path = managed_mockserver_expectations_path(self.name)
        existing: List[Dict[str, Any]] = []
        if path.exists():
            try:
                loaded = json.loads(path.read_text())
                if isinstance(loaded, list):
                    existing = loaded
            except (OSError, json.JSONDecodeError):
                existing = []

        by_route = {
            str(item.get("httpRequest", {}).get("path") or ""): item
            for item in existing
            if isinstance(item, dict)
        }
        overrides = self.domain_overrides
        for route in routes:
            by_route[route] = mockserver_json_expectation(
                route, mockserver_dummy_response_for_route(route, overrides)
            )

        path.parent.mkdir(parents=True, exist_ok=True)
        existing = list(by_route.values())
        path.write_text(json.dumps(existing, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
        self.put_mockserver_expectations(existing)

    def put_mockserver_expectations(self, expectations: List[Dict[str, Any]]) -> None:
        for expectation in expectations:
            if not isinstance(expectation, dict):
                continue
            route = str(expectation.get("httpRequest", {}).get("path") or "")
            if route:
                self.clear_mockserver_expectation(route)
            self.put_mockserver_expectation(expectation)

    def clear_mockserver_expectation(self, route: str) -> None:
        request = urllib.request.Request(
            "http://localhost:1080/mockserver/clear",
            data=json.dumps({"path": route}).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="PUT",
        )
        try:
            with urllib.request.urlopen(request, timeout=3):
                return
        except (OSError, urllib.error.URLError):
            return

    def put_mockserver_expectation(self, expectation: Dict[str, Any]) -> None:
        request = urllib.request.Request(
            "http://localhost:1080/mockserver/expectation",
            data=json.dumps(expectation).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="PUT",
        )
        try:
            with urllib.request.urlopen(request, timeout=3):
                return
        except (OSError, urllib.error.URLError):
            return

    def verify_service_api_dummy_data(self, service_name: str) -> Tuple[bool, str]:
        service = self.service(service_name)
        port = service.get("port")
        if not port:
            return False, "no port configured for API verification"

        overrides = self.domain_overrides
        rest_checks: List[Tuple[str, str]] = []

        # Workspace-declared keyword-triggered REST probes. The engine never
        # hardcodes a service-name match; it consults
        # overrides["verification"]["service_name_keyword_probes"]: a map of
        # keyword-substring -> list of {label, path} entries. A service whose
        # lowercased name contains the keyword as a substring inherits the
        # listed probes, in registration order. Without overrides this loop
        # contributes nothing — derive_rest_probe_urls is the sole source of
        # REST checks below.
        keyword_probes = (overrides.get("verification") or {}).get("service_name_keyword_probes") or {}
        if isinstance(keyword_probes, dict):
            lowered_name = service_name.lower()
            for keyword, probes in keyword_probes.items():
                if not isinstance(keyword, str) or not isinstance(probes, list):
                    continue
                if keyword.lower() not in lowered_name:
                    continue
                for probe in probes:
                    if not isinstance(probe, dict):
                        continue
                    label = str(probe.get("label") or "")
                    path = str(probe.get("path") or "")
                    if not label or not path:
                        continue
                    sub_path = path if path.startswith("/") else "/" + path
                    rest_checks.append((label, f"http://localhost:{int(port)}{sub_path}"))

        # Auto-derived probes from the service's persisted controller_routes
        # (populated during workspace analysis by inspect_gradle_services).
        # Newly-introduced services get smoke coverage without hard-coding
        # their service name here.
        for derived_probe in derive_rest_probe_urls(service):
            if derived_probe not in rest_checks:
                rest_checks.append(derived_probe)
        if rest_checks:
            results = []
            for label, url in rest_checks:
                ok, detail = self.verify_rest_dummy_response(url)
                results.append((label, ok, detail))
            failures = [f"{label}: {detail}" for label, ok, detail in results if not ok]
            if not failures:
                return True, "; ".join(f"{label}: {detail}" for label, _, detail in results)
            return False, "; ".join(failures)

        # No REST surface available. Fall back to GraphQL probes. The default
        # probes target the always-on dummy resolver schema (hello / shows /
        # actors) shipped by write_graphql_dummy_resolver. A workspace can
        # extend this list via overrides["verification"]["graphql_probes"].
        graphql_url = f"http://localhost:{int(port)}/graphql"
        checks: List[Tuple[str, Dict[str, Any], Dict[str, str]]] = [
            ("GraphQL hello", {"query": "{ hello }"}, {}),
            ("GraphQL shows", {"query": "{ shows { title actors { name } } actors { name } }"}, {}),
        ]
        for entry in (overrides.get("verification") or {}).get("graphql_probes") or []:
            if not isinstance(entry, dict):
                continue
            label = str(entry.get("label") or "")
            query = entry.get("query")
            headers = entry.get("headers") or {}
            if not label or not isinstance(query, str) or not query:
                continue
            payload: Dict[str, Any] = {"query": query}
            variables = entry.get("variables")
            if isinstance(variables, dict):
                payload["variables"] = variables
            if not isinstance(headers, dict):
                headers = {}
            checks.append((label, payload, {str(k): str(v) for k, v in headers.items()}))

        for label, payload, headers in checks:
            ok, detail = self.verify_graphql_dummy_response(graphql_url, payload, headers)
            if ok:
                return True, f"{label}: {detail}"
        if service.get("health") and http_ok(str(service["health"])):
            return False, "health endpoint is ready, but no dummy-data API probe matched"
        return False, "no 2xx GraphQL dummy-data response matched"

    def verify_rest_dummy_response(self, url: str) -> Tuple[bool, str]:
        try:
            with urllib.request.urlopen(url, timeout=5) as response:
                if response.status < 200 or response.status >= 300:
                    return False, f"HTTP {response.status}"
                body = json.loads(response.read().decode("utf-8"))
        except (OSError, urllib.error.URLError, json.JSONDecodeError):
            return False, "request failed"

        if json_contains_non_empty_collection(body):
            return True, "non-empty data returned"
        return False, "empty data"

    def verify_graphql_dummy_response(
        self,
        url: str,
        payload: Dict[str, Any],
        headers: Dict[str, str],
    ) -> Tuple[bool, str]:
        request = urllib.request.Request(
            url,
            data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json", **headers},
            method="POST",
        )
        try:
            with urllib.request.urlopen(request, timeout=5) as response:
                if response.status < 200 or response.status >= 300:
                    return False, f"HTTP {response.status}"
                body = json.loads(response.read().decode("utf-8"))
        except (OSError, urllib.error.URLError, json.JSONDecodeError):
            return False, "request failed"

        data = body.get("data") if isinstance(body, dict) else None
        if not data or body.get("errors"):
            return False, "empty data or GraphQL errors"
        return True, "non-empty data returned"

    def recover_skip_nonserver(self, service_name: str, target: str) -> str:
        if not self.is_recoverable_nonserver(service_name):
            raise DevstackError(
                f"{service_name}: not a safe non-server skip candidate. "
                "Inspect logs before changing the start flow."
            )

        services = [name for name in self.resolve_target(target or "default") if name != service_name]
        if not services:
            raise DevstackError(f"{service_name}: no services remain after skipping this entry")

        self.start_many(services, include_deps=True, skip_recoverable=True)
        return "\n".join([
            f"recovered by skipping non-server candidate: {service_name}",
            f"target: {target or 'default'}",
            "started remaining services:",
            *[f"- {name}" for name in services],
        ])

    def recover_stop_port_and_restart(self, service_name: str, confirm: bool = False) -> str:
        service = self.service(service_name)
        port = service.get("port")
        if not port:
            raise DevstackError(f"{service_name}: no port is configured")

        pid = pid_for_listening_port(int(port))
        if pid is None:
            raise DevstackError(f"{service_name}: no process is listening on port {port}")
        if not confirm:
            raise DevstackError(
                f"{service_name}: port {port} is held by pid {pid}. "
                "Re-run with confirmation to stop it and restart the service."
            )

        terminate_pid_or_group(pid, signal.SIGTERM, service_name)
        self.wait_pid_exit(pid, timeout=10)
        self.start_service(service_name)
        return f"recovered by stopping pid {pid} on port {port} and restarting {service_name}"

    def recover_local_config_and_restart(self, service_name: str) -> str:
        service = self.service(service_name)
        if service.get("type") != "gradle":
            raise DevstackError(f"{service_name}: local config recovery only supports Gradle services")

        self.apply_local_config_recovery(service)

        self.stop_service(service_name, allow_port_owner=True)
        self.start_service(service_name)
        return "\n".join([
            f"recovered by restarting {service_name} with local Spring config overrides",
            "applied process environment:",
            "- SPRING_CLOUD_CONFIG_ENABLED=false",
            "- SPRING_CLOUD_CONFIG_IMPORT_CHECK_ENABLED=false",
            f"- SPRING_CONFIG_IMPORT={LOCAL_CONFIG_IMPORT}",
            "applied application arguments:",
            "- --spring.cloud.config.enabled=false",
            "- --spring.cloud.config.import-check.enabled=false",
            f"- --spring.config.import={LOCAL_CONFIG_IMPORT}",
        ])

    def is_recoverable_nonserver(self, service_name: str) -> bool:
        service = self.service(service_name)
        if service.get("type") != "gradle":
            return False
        if service.get("port") or service.get("health"):
            return False
        task = str(service.get("task") or "")
        return task == "bootRun" or task.startswith(":lib:")

    def expand_dependencies(self, service_names: Iterable[str]) -> List[str]:
        resolved: List[str] = []
        visiting: Set[str] = set()

        def visit(name: str) -> None:
            if name in resolved:
                return
            if name in visiting:
                raise DevstackError(f"cyclic dependency at {name}")
            visiting.add(name)
            service = self.service(name)
            for dep in service.get("depends_on", []):
                visit(dep)
            visiting.remove(name)
            resolved.append(name)

        for service_name in service_names:
            visit(service_name)
        return resolved

    def service(self, name: str) -> Dict[str, Any]:
        if name in self.services:
            return self.services[name]
        # Shim 5 — accept the alternate managed-infra prefix spelling.
        # Lookups by ``devstack.infra.<x>`` should resolve to a service stored
        # as ``ccstack.infra.<x>``, and vice-versa, so workspaces whose
        # manifests still use the legacy prefix keep working under callers
        # that have already migrated their service-id literal.
        if isinstance(name, str):
            if name.startswith(f"{MANAGED_INFRA_PREFIX}."):
                alt = LEGACY_MANAGED_INFRA_PREFIX + name[len(MANAGED_INFRA_PREFIX):]
                if alt in self.services:
                    return self.services[alt]
            elif name.startswith(f"{LEGACY_MANAGED_INFRA_PREFIX}."):
                alt = MANAGED_INFRA_PREFIX + name[len(LEGACY_MANAGED_INFRA_PREFIX):]
                if alt in self.services:
                    return self.services[alt]
        raise DevstackError(f"unknown service: {name}")

    def gradlew(self) -> str:
        gradlew = self.root / self.config.get("gradlew", "./gradlew")
        if not gradlew.exists():
            raise DevstackError(f"gradle wrapper not found: {gradlew}")
        return str(gradlew)

    def process_env(self, service: Dict[str, Any]) -> Dict[str, str]:
        env = os.environ.copy()
        # Export both new and legacy ``*_ROOT`` and ``*_JAVA_HOME`` names so
        # services that read either spelling keep working through one release.
        env["DEVSTACK_ROOT"] = str(self.root)
        env["CCSTACK_ROOT"] = str(self.root)
        explicit_java_home = False
        devstack_java_home = env.get("DEVSTACK_JAVA_HOME") or env.get("CCSTACK_JAVA_HOME")
        if devstack_java_home:
            env["JAVA_HOME"] = devstack_java_home
            explicit_java_home = True
        java_home = self.config.get("java_home")
        if java_home:
            env["JAVA_HOME"] = expand_value(java_home, self.root, env)
            explicit_java_home = True
        for key, value in self.config.get("env", {}).items():
            env[key] = expand_value(str(value), self.root, env)
            if key == "JAVA_HOME":
                explicit_java_home = True
        for key, value in service.get("env", {}).items():
            env[key] = expand_value(str(value), self.root, env)
            if key == "JAVA_HOME":
                explicit_java_home = True
        if service.get("type") == "gradle" and not explicit_java_home:
            compatible_java_home = compatible_gradle_java_home(self.root, env)
            if compatible_java_home:
                env["JAVA_HOME"] = compatible_java_home
        return env

    def pid_path(self, service_name: str) -> Path:
        return self.pid_dir / f"{safe_name(service_name)}.pid"

    def failure_path(self, service_name: str) -> Path:
        return self.failure_dir / f"{safe_name(service_name)}.json"

    def mark_service_failed(self, service_name: str, reason: str) -> None:
        self.failure_dir.mkdir(parents=True, exist_ok=True)
        self.failure_path(service_name).write_text(
            json.dumps(
                {
                    "service": service_name,
                    "reason": reason,
                    "failed_at": datetime.datetime.now(datetime.timezone.utc).isoformat(),
                },
                ensure_ascii=False,
                indent=2,
            )
            + "\n"
        )

    def clear_service_failure(self, service_name: str) -> None:
        self.failure_path(service_name).unlink(missing_ok=True)

    def service_failed(self, service_name: str) -> bool:
        return self.failure_path(service_name).exists()

    def read_pid(self, service_name: str) -> Optional[int]:
        path = self.pid_path(service_name)
        if not path.exists():
            return None
        try:
            return int(path.read_text().strip())
        except ValueError:
            path.unlink(missing_ok=True)
            return None

    def service_log_path(self, service_name: str) -> Path:
        service = self.service(service_name)
        if "log" in service:
            return (self.root / service["log"]).resolve()
        return self.log_dir / f"{safe_name(service_name)}.log"

    @staticmethod
    def wait_pid_exit(pid: int, timeout: int) -> None:
        deadline = time.time() + timeout
        while time.time() < deadline:
            if not process_running(pid):
                return
            time.sleep(0.5)
        try:
            terminate_pid_or_group(pid, signal.SIGKILL, str(pid))
        except ProcessLookupError:
            pass


class WorkspaceRegistry:
    def __init__(
        self,
        workspaces: Optional[Dict[str, str]] = None,
        default: Optional[str] = None,
        manifests: Optional[Dict[str, str]] = None,
    ):
        self.workspaces = workspaces or {}
        self.default = default
        self.manifests = manifests or {}

    @classmethod
    def load(cls) -> "WorkspaceRegistry":
        if not REGISTRY_PATH.exists():
            return cls()
        data = load_json(REGISTRY_PATH)
        if "workspaces" in data:
            workspaces = {
                str(name): str(root)
                for name, root in data.get("workspaces", {}).items()
                if isinstance(root, str)
            }
            default = data.get("default")
            manifests = {
                str(name): str(path)
                for name, path in data.get("manifests", {}).items()
                if isinstance(path, str)
            }
            return cls(workspaces, str(default) if default else None, manifests)
        workspaces = {
            str(name): str(root)
            for name, root in data.items()
            if isinstance(root, str) and not str(name).startswith("__")
        }
        default = data.get("__default__")
        return cls(workspaces, str(default) if isinstance(default, str) else None)

    def as_json(self) -> Dict[str, Any]:
        payload: Dict[str, Any] = {"default": self.default, "workspaces": dict(sorted(self.workspaces.items()))}
        if self.manifests:
            payload["manifests"] = dict(sorted(self.manifests.items()))
        return payload

    def save(self) -> None:
        REGISTRY_PATH.parent.mkdir(parents=True, exist_ok=True)
        REGISTRY_PATH.write_text(json.dumps(self.as_json(), ensure_ascii=False, indent=2) + "\n")

    def entries(self) -> List[Dict[str, Any]]:
        return [
            {"name": name, "root": Path(root).expanduser().resolve(), "default": name == self.default}
            for name, root in sorted(self.workspaces.items())
        ]

    def register(self, name: str, root: Path, manifest_path: Optional[Path] = None) -> None:
        resolved_root = root.expanduser().resolve()
        if manifest_path:
            resolved_manifest = str(manifest_path.expanduser().resolve())
            for existing_name, existing_manifest in self.manifests.items():
                if existing_name == name:
                    continue
                if existing_manifest == resolved_manifest:
                    raise DevstackError(
                        f"manifest path {resolved_manifest} is already registered to workspace "
                        f"{existing_name!r}"
                    )
            self.workspaces[name] = str(resolved_root)
            self.manifests[name] = resolved_manifest
        else:
            self.workspaces[name] = str(resolved_root)
            self.manifests.pop(name, None)

    def unregister(self, name: str) -> Dict[str, Any]:
        root = self.workspaces.get(name)
        if not root:
            raise DevstackError(f"workspace {name!r} is not registered")

        manifest = self.manifests.pop(name, None)
        del self.workspaces[name]
        was_default = self.default == name
        if was_default:
            self.default = None

        return {
            "name": name,
            "root": root,
            "config": manifest,
            "default": was_default,
        }

    def resolve(self, name: str) -> Path:
        root = self.workspaces.get(name)
        if not root:
            raise DevstackError(f"workspace {name!r} is not registered. {workspace_guidance()}")
        path = Path(root).expanduser().resolve()
        if not self.config_path(name, path):
            raise DevstackError(f"workspace {name!r} points to {path}, but no devstack config was found")
        return path

    def set_default(self, name: str) -> None:
        self.resolve(name)
        self.default = name

    def default_root(self) -> Optional[Path]:
        if self.default:
            return self.resolve(self.default)
        valid = [entry for entry in self.entries() if self.config_path(entry["name"], entry["root"])]
        if len(valid) == 1:
            return valid[0]["root"]
        return None

    def config_path(self, name: str, root: Path) -> Optional[Path]:
        manifest = self.manifests.get(name)
        if manifest:
            path = Path(manifest).expanduser().resolve()
            if path.exists():
                return path
        # Shim 3 — accept either the canonical or the legacy filename.
        repo_config = resolve_manifest_path(root)
        if repo_config is not None:
            return repo_config
        return None


def resolve_workspace_root(args: argparse.Namespace) -> Path:
    if args.root:
        return Path(args.root).expanduser().resolve()

    registry = WorkspaceRegistry.load()
    if args.workspace:
        return registry.resolve(args.workspace)

    try:
        return find_workspace_root(Path.cwd())
    except DevstackError:
        root = registry.default_root()
        if root:
            return root
        raise DevstackError(
            f"{CONFIG_NAME} not found from {Path.cwd()}. {workspace_guidance()}"
        )


def load_workspace_config(root: Path, registry: Optional[WorkspaceRegistry] = None, name: Optional[str] = None) -> Dict[str, Any]:
    registry = registry or WorkspaceRegistry.load()
    if name:
        config_path = registry.config_path(name, root)
        if config_path:
            return load_json(config_path)

    for entry in registry.entries():
        if entry["root"] != root:
            continue
        config_path = registry.config_path(entry["name"], root)
        if config_path:
            return load_json(config_path)

    # Shim 3 — fallback also accepts legacy ``.ccstack.json`` filename.
    repo_config = resolve_manifest_path(root)
    if repo_config is not None:
        return load_json(repo_config)

    raise DevstackError(
        f"neither {CONFIG_NAME} nor {LEGACY_CONFIG_NAME} found under {root} "
        "and no generated config is registered"
    )


def workspace_setup_root(root: Optional[str]) -> Path:
    if root:
        return Path(root).expanduser().resolve()
    try:
        return find_workspace_root(Path.cwd())
    except DevstackError:
        return Path.cwd().resolve()


def prepare_workspace_config(root: Path, name: Optional[str], write_manifest: bool) -> tuple[str, Path, str]:
    if not root.exists() or not root.is_dir():
        raise DevstackError(f"workspace root is not a directory: {root}")

    registry = WorkspaceRegistry.load()
    # Shim 3 — accept either ``.devstack.json`` (canonical) or
    # ``.ccstack.json`` (legacy) as the in-repo manifest. The canonical
    # path is used when writing a fresh manifest.
    repo_config = resolve_manifest_path(root) or (root / CONFIG_NAME)
    if repo_config.exists():
        config = load_json(repo_config)
        original_workspace_name = str(config.get("workspace") or root.name)
        requested_name = str(name or original_workspace_name)
        workspace_name = unique_workspace_name_for_root(
            requested_name,
            root,
            registry,
            explicit=bool(name),
        )
        workspace_name_changed = original_workspace_name != workspace_name
        if workspace_name_changed:
            config["workspace"] = workspace_name
        reserved_ports = registered_workspace_reserved_ports(str(workspace_name), root)
        if workspace_name_changed and write_manifest:
            write_json(repo_config, config)
        if not write_manifest:
            base_config = active_managed_workspace_config(root, str(workspace_name)) or config
            base_config["workspace"] = workspace_name
            config, augment = augment_workspace_config(root, base_config, reserved_ports=reserved_ports)
            config, managed_environment = materialize_workspace_setup_config(
                str(workspace_name),
                root,
                config,
                reserved_ports=reserved_ports,
            )
            if augment.get("changed") or managed_environment or workspace_name_changed:
                manifest_path = generated_manifest_path(workspace_name)
                write_json(manifest_path, config)
                return workspace_name, manifest_path, "generated"
        return workspace_name, repo_config, "repo"

    workspace_name = unique_workspace_name_for_root(str(name or root.name), root, registry, explicit=bool(name))
    reserved_ports = registered_workspace_reserved_ports(str(workspace_name), root)
    config = inspect_workspace(root, str(workspace_name), reserved_ports=reserved_ports)
    if write_manifest:
        manifest_path = repo_config
        config_source = "repo"
    else:
        config, _ = materialize_workspace_setup_config(
            str(workspace_name),
            root,
            config,
            reserved_ports=reserved_ports,
        )
        manifest_path = generated_manifest_path(workspace_name)
        config_source = "generated"

    write_json(manifest_path, config)
    return workspace_name, manifest_path, config_source


def active_managed_workspace_config(root: Path, workspace_name: str) -> Optional[Dict[str, Any]]:
    registry = WorkspaceRegistry.load()
    manifest_path = registry.config_path(workspace_name, root)
    if not manifest_path or manifest_path == root / CONFIG_NAME or not manifest_path.exists():
        return None

    try:
        config = load_json(manifest_path)
    except Exception:
        return None

    if not isinstance(config, dict):
        return None
    if not isinstance(config.get("services"), dict):
        return None
    return config


def materialize_workspace_setup_config(
    name: str,
    root: Path,
    config: Dict[str, Any],
    reserved_ports: Optional[Set[int]] = None,
) -> tuple[Dict[str, Any], Dict[str, Any]]:
    analysis = analyze_workspace_config(root, config, reserved_ports=reserved_ports)
    return materialize_managed_environment(name, root, config, analysis)


def generated_manifest_path(name: str) -> Path:
    return STATE_HOME / safe_name(name) / "devstack.generated.json"


def write_workspace_state(name: str, root: Path, manifest_path: Path, config_source: str) -> None:
    state_path = STATE_HOME / safe_name(name) / "workspace.json"
    payload = {
        "workspace": name,
        "root": str(root),
        "config": str(manifest_path),
        "config_source": config_source,
        "updated_at": datetime.datetime.now(datetime.timezone.utc).isoformat(),
    }
    write_json(state_path, payload)


def inspect_workspace(root: Path, name: str, reserved_ports: Optional[Set[int]] = None) -> Dict[str, Any]:
    services: Dict[str, Dict[str, Any]] = {}
    for compose_path in find_compose_files(root):
        compose_services = inspect_compose_services(compose_path)
        stem = compose_service_prefix(root, compose_path)
        for service_name in compose_services:
            devstack_name = f"{stem}.{service_name}" if stem else service_name
            services[devstack_name] = {
                "type": "compose",
                "compose": relative_to_root(root, compose_path),
                "service": service_name,
            }

    services.update(inspect_gradle_services(root, sorted(services)))
    services.update(inspect_command_services(root, set(services)))
    ensure_unique_gradle_service_ports(services, reserved_ports=reserved_ports, workspace_name=name)

    service_names = sorted(services)
    profiles = {"default": {"services": service_names}}
    apply_auto_run_bundles(profiles, services)
    return {
        "workspace": name,
        "profiles": profiles,
        "services": {key: services[key] for key in service_names},
    }


def find_compose_files(root: Path) -> List[Path]:
    patterns = ("compose*.yml", "compose*.yaml", "docker-compose*.yml", "docker-compose*.yaml", "*.compose.yml", "*.compose.yaml")
    found: List[Path] = []
    for pattern in patterns:
        for path in root.rglob(pattern):
            if any(part in IGNORED_INSPECT_DIRS for part in path.relative_to(root).parts):
                continue
            if path.is_file() and path not in found:
                found.append(path)
    return sorted(found)


def inspect_compose_services(path: Path) -> List[str]:
    services: List[str] = []
    in_services = False
    service_indent: Optional[int] = None
    for raw_line in path.read_text(errors="ignore").splitlines():
        stripped = raw_line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        indent = len(raw_line) - len(raw_line.lstrip(" "))
        if stripped == "services:":
            in_services = True
            service_indent = None
            continue
        if not in_services:
            continue
        if indent == 0 and raw_line[0] not in {" ", "-"}:
            break
        match = re.match(r"^([A-Za-z0-9_.-]+):(?:\s|$)", stripped)
        if not match:
            continue
        if service_indent is None:
            service_indent = indent
        if indent == service_indent:
            name = match.group(1)
            if name not in services:
                services.append(name)
    return services


COMMAND_SERVICE_MANIFESTS: Tuple[str, ...] = (
    "package.json",
    "pyproject.toml",
    "requirements.txt",
    "go.mod",
    "Cargo.toml",
)


def inspect_command_services(root: Path, claimed_names: Set[str]) -> Dict[str, Dict[str, Any]]:
    """Detect non-JVM project manifests under root and surface each as a
    type=command service. Additive only — service names already claimed by
    compose/gradle paths are skipped (Gradle precedence preserved).
    """
    services: Dict[str, Dict[str, Any]] = {}
    seen_dirs: Set[Path] = set()

    candidate_dirs: List[Tuple[Path, str]] = []
    for manifest in COMMAND_SERVICE_MANIFESTS:
        for path in sorted(root.rglob(manifest)):
            if ignored_path(root, path) or not path.is_file():
                continue
            module_dir = path.parent
            try:
                resolved = module_dir.resolve()
            except OSError:
                continue
            candidate_dirs.append((module_dir, manifest))

    # Stable per-directory precedence: first match in COMMAND_SERVICE_MANIFESTS wins.
    candidate_dirs.sort(key=lambda item: (str(item[0]), COMMAND_SERVICE_MANIFESTS.index(item[1])))

    for module_dir, manifest in candidate_dirs:
        try:
            resolved = module_dir.resolve()
        except OSError:
            continue
        if resolved in seen_dirs:
            continue
        seen_dirs.add(resolved)

        service_name = command_service_name(root, module_dir)
        if not service_name or service_name in claimed_names or service_name in services:
            continue

        command = derive_command_service_command(module_dir, manifest)
        if not command:
            continue

        entry: Dict[str, Any] = {
            "type": "command",
            "command": command,
        }
        if module_dir != root:
            entry["module"] = relative_to_root(root, module_dir)

        # Non-Spring port + /health inference for the recognized frameworks.
        # Failures are silent — the command service still ships without port
        # when no recognizable literal/env declaration is found.
        port = infer_command_service_port(module_dir, manifest)
        if port:
            entry["port"] = port
            health = infer_command_service_health(module_dir, port)
            if health:
                entry["health"] = health

        services[service_name] = entry

    return services


def command_service_name(root: Path, module_dir: Path) -> str:
    if module_dir == root:
        base = root.name or "service"
    else:
        rel = relative_to_root(root, module_dir)
        base = rel.replace("/", ".") if rel else (root.name or "service")
    cleaned = re.sub(r"[^A-Za-z0-9_.-]+", "-", base).strip("-.")
    return cleaned


def derive_command_service_command(module_dir: Path, manifest: str) -> str:
    if manifest == "package.json":
        return derive_package_json_command(module_dir)
    if manifest == "pyproject.toml":
        return derive_pyproject_command(module_dir)
    if manifest == "requirements.txt":
        return derive_python_entrypoint_command(module_dir)
    if manifest == "go.mod":
        return "go run ."
    if manifest == "Cargo.toml":
        return "cargo run"
    return ""


def derive_package_json_command(module_dir: Path) -> str:
    path = module_dir / "package.json"
    try:
        data = json.loads(path.read_text(errors="ignore"))
    except Exception:
        return "npm start"
    scripts = data.get("scripts") if isinstance(data, dict) else None
    if isinstance(scripts, dict):
        if isinstance(scripts.get("start"), str) and scripts["start"].strip():
            return "npm start"
        if isinstance(scripts.get("dev"), str) and scripts["dev"].strip():
            return "npm run dev"
        if isinstance(scripts.get("serve"), str) and scripts["serve"].strip():
            return "npm run serve"
    return "npm start"


def derive_pyproject_command(module_dir: Path) -> str:
    path = module_dir / "pyproject.toml"
    try:
        text = path.read_text(errors="ignore")
    except Exception:
        text = ""

    script_match = re.search(
        r'\[(?:project|tool\.poetry)\.scripts\][^\[]*?^\s*([A-Za-z0-9_.\-]+)\s*=',
        text,
        re.MULTILINE,
    )
    if script_match:
        return script_match.group(1)

    entry = python_default_entrypoint(module_dir)
    if entry:
        return entry
    return f"python -m {module_dir.name}"


def derive_python_entrypoint_command(module_dir: Path) -> str:
    entry = python_default_entrypoint(module_dir)
    if entry:
        return entry
    return f"python -m {module_dir.name}"


def python_default_entrypoint(module_dir: Path) -> str:
    if (module_dir / "manage.py").is_file():
        return "python manage.py runserver"
    for filename in ("app.py", "main.py", "server.py", "wsgi.py", "asgi.py"):
        if (module_dir / filename).is_file():
            return f"python {filename}"
    return ""


# ---------------------------------------------------------------------------
# Non-JVM infra dependency signal scanner.
#
# Mirrors inspect_runtime_environment_signals's output shape so the existing
# runtime_signal_requirement dispatcher consumes the union of JVM + non-JVM
# signals without special-casing.
#
# Only the four infra kinds that already have a dispatcher entry are emitted
# (redis / kafka / mongo / search). Postgres/MySQL/AMQP detection from
# dependency manifests is deliberately out of scope here — those engines
# are surfaced today by inspect_datasource_configs (JDBC URLs in .env etc.)
# and inventing a new requirement kind would risk crashing the dispatcher.
# ---------------------------------------------------------------------------

# Each entry: (substring to look for in manifest text, signal kind to emit).
# The substrings are lowercased so the same lower(text) comparison the JVM
# scanner uses is reused here.

_COMMAND_SIGNAL_PATTERNS_PACKAGE_JSON: Tuple[Tuple[str, str], ...] = (
    ("ioredis", "redis"),
    ("\"redis\"", "redis"),
    ("'redis'", "redis"),
    ("kafkajs", "kafka"),
    ("@confluentinc/kafka-javascript", "kafka"),
    ("mongoose", "mongo"),
    ("mongodb", "mongo"),
    ("@opensearch-project/opensearch", "search"),
    ("@elastic/elasticsearch", "search"),
)

_COMMAND_SIGNAL_PATTERNS_PYTHON: Tuple[Tuple[str, str], ...] = (
    ("redis", "redis"),
    ("pymongo", "mongo"),
    ("motor", "mongo"),
    ("confluent-kafka", "kafka"),
    ("aiokafka", "kafka"),
    ("kafka-python", "kafka"),
    ("opensearch-py", "search"),
    ("elasticsearch", "search"),
)

_COMMAND_SIGNAL_PATTERNS_GO_MOD: Tuple[Tuple[str, str], ...] = (
    ("github.com/redis/go-redis", "redis"),
    ("github.com/go-redis/redis", "redis"),
    ("go.mongodb.org/mongo-driver", "mongo"),
    ("github.com/ibm/sarama", "kafka"),
    ("github.com/shopify/sarama", "kafka"),
    ("github.com/confluentinc/confluent-kafka-go", "kafka"),
    ("github.com/opensearch-project/opensearch-go", "search"),
    ("github.com/elastic/go-elasticsearch", "search"),
)

_COMMAND_SIGNAL_PATTERNS_CARGO_TOML: Tuple[Tuple[str, str], ...] = (
    ("redis", "redis"),
    ("mongodb", "mongo"),
    ("rdkafka", "kafka"),
    ("opensearch", "search"),
    ("elasticsearch", "search"),
)

_COMMAND_SIGNAL_KINDS: Tuple[str, ...] = ("redis", "kafka", "mongo", "search")


def inspect_command_service_runtime_signals(
    root: Path,
    scan_cache: Optional["WorkspaceScanCache"] = None,
) -> Dict[str, List[Dict[str, str]]]:
    """Walk non-JVM manifests under ``root`` and emit infra dependency
    signals in the same shape as inspect_runtime_environment_signals.

    Returns ``{kind: [{path, marker}, ...]}`` for each kind in
    ``_COMMAND_SIGNAL_KINDS``. Malformed manifests are skipped silently.
    The result mirrors the JVM scanner: at most 20 entries per kind so a
    pathological monorepo cannot blow up the requirement list.
    """
    signals: Dict[str, List[Dict[str, str]]] = {kind: [] for kind in _COMMAND_SIGNAL_KINDS}

    manifest_dispatch = (
        ("package.json", _command_signal_kinds_from_package_json),
        ("pyproject.toml", _command_signal_kinds_from_pyproject),
        ("requirements.txt", _command_signal_kinds_from_requirements_txt),
        ("go.mod", _command_signal_kinds_from_go_mod),
        ("Cargo.toml", _command_signal_kinds_from_cargo_toml),
    )

    for manifest_name, scanner in manifest_dispatch:
        for path in sorted(root.rglob(manifest_name)):
            if ignored_path(root, path) or not path.is_file():
                continue
            try:
                text = path.read_text(errors="ignore")
            except OSError:
                continue
            try:
                detected = scanner(text)
            except Exception:
                # Defensive: any unexpected parser error must not crash the
                # caller — fall through with an empty contribution.
                detected = []
            for kind, marker in detected:
                if kind not in signals:
                    continue
                if len(signals[kind]) >= 20:
                    continue
                signals[kind].append(
                    {"path": relative_to_root(root, path), "marker": marker}
                )
    return signals


def _command_signal_kinds_from_package_json(text: str) -> List[Tuple[str, str]]:
    """Inspect a package.json text for known infra-client dependencies.

    The JSON is parsed defensively. When parsing fails the function returns
    an empty list — the caller has already wrapped this in try/except for
    extra safety.
    """
    try:
        data = json.loads(text)
    except Exception:
        return []
    if not isinstance(data, dict):
        return []

    dep_keys = ("dependencies", "devDependencies", "peerDependencies", "optionalDependencies")
    flat: Dict[str, str] = {}
    for key in dep_keys:
        block = data.get(key)
        if isinstance(block, dict):
            for name, version in block.items():
                if isinstance(name, str):
                    flat[name.lower()] = str(version) if version is not None else ""

    detected: List[Tuple[str, str]] = []
    for name in flat:
        if name == "ioredis":
            detected.append(("redis", "ioredis"))
        elif name == "redis":
            detected.append(("redis", "redis"))
        elif name == "kafkajs":
            detected.append(("kafka", "kafkajs"))
        elif name == "@confluentinc/kafka-javascript":
            detected.append(("kafka", "@confluentinc/kafka-javascript"))
        elif name == "mongoose":
            detected.append(("mongo", "mongoose"))
        elif name == "mongodb":
            detected.append(("mongo", "mongodb"))
        elif name == "@opensearch-project/opensearch":
            detected.append(("search", "@opensearch-project/opensearch"))
        elif name == "@elastic/elasticsearch":
            detected.append(("search", "@elastic/elasticsearch"))
    return detected


def _command_signal_kinds_from_pyproject(text: str) -> List[Tuple[str, str]]:
    """Inspect a pyproject.toml text without requiring a real TOML parser.

    Looks at the [project.dependencies] PEP 621 list AND the
    [tool.poetry.dependencies] mapping. Each line's leading bare package
    name (before any version specifier or extras) is matched against the
    known infra package set.
    """
    return _detect_python_packages_in_text(text)


def _command_signal_kinds_from_requirements_txt(text: str) -> List[Tuple[str, str]]:
    """Inspect a requirements.txt text. Each non-empty, non-comment line's
    leading package name is matched against the known infra packages.
    """
    detected: List[Tuple[str, str]] = []
    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith("#") or line.startswith("-"):
            continue
        # Strip extras / version spec / environment markers / inline comments.
        name = re.split(r"[\[\]<>=!~;# ]", line, maxsplit=1)[0].strip().lower()
        if not name:
            continue
        match = _PYTHON_INFRA_PACKAGES.get(name)
        if match:
            detected.append(match)
    return detected


_PYTHON_INFRA_PACKAGES: Dict[str, Tuple[str, str]] = {
    "redis": ("redis", "redis"),
    "pymongo": ("mongo", "pymongo"),
    "motor": ("mongo", "motor"),
    "confluent-kafka": ("kafka", "confluent-kafka"),
    "aiokafka": ("kafka", "aiokafka"),
    "kafka-python": ("kafka", "kafka-python"),
    "opensearch-py": ("search", "opensearch-py"),
    "elasticsearch": ("search", "elasticsearch"),
}


def _detect_python_packages_in_text(text: str) -> List[Tuple[str, str]]:
    """Shared pyproject heuristic: pull dependency-style lines from either
    PEP 621 list form or Poetry mapping form. Lines outside the known
    sections are ignored to avoid e.g. tool config keys colliding.
    """
    detected: List[Tuple[str, str]] = []
    section: Optional[str] = None
    in_project_deps_array = False
    in_poetry_deps_table = False

    section_pat = re.compile(r"^\s*\[([^\]]+)\]\s*$")

    for raw in text.splitlines():
        line = raw.rstrip()
        section_match = section_pat.match(line)
        if section_match:
            section = section_match.group(1).strip()
            in_project_deps_array = False
            in_poetry_deps_table = section in {
                "tool.poetry.dependencies",
                "tool.poetry.dev-dependencies",
                "tool.poetry.group.dev.dependencies",
            }
            continue

        if section == "project":
            # Heuristic: detect the start of a dependencies = [ ... ] block.
            if re.match(r"^\s*dependencies\s*=\s*\[", line):
                in_project_deps_array = True
                # Same-line entry? "dependencies = [\"redis\"]" → grab it.
                inner = line.split("[", 1)[1]
                _collect_quoted_dep_names(inner, detected)
                if "]" in inner:
                    in_project_deps_array = False
                continue
            if in_project_deps_array:
                _collect_quoted_dep_names(line, detected)
                if "]" in line:
                    in_project_deps_array = False
                continue

        if in_poetry_deps_table:
            # Poetry maps `package = "version"`; ignore python = "..." baseline.
            key_match = re.match(r"^\s*([A-Za-z0-9_.\-]+)\s*=", line)
            if key_match:
                name = key_match.group(1).strip().lower()
                if name == "python":
                    continue
                match = _PYTHON_INFRA_PACKAGES.get(name)
                if match:
                    detected.append(match)
    return detected


def _collect_quoted_dep_names(text: str, detected: List[Tuple[str, str]]) -> None:
    for raw in re.findall(r'"([^"]+)"|\'([^\']+)\'', text):
        spec = (raw[0] or raw[1]).strip()
        if not spec:
            continue
        name = re.split(r"[\[\]<>=!~;# ]", spec, maxsplit=1)[0].strip().lower()
        match = _PYTHON_INFRA_PACKAGES.get(name)
        if match:
            detected.append(match)


def _command_signal_kinds_from_go_mod(text: str) -> List[Tuple[str, str]]:
    """Inspect a go.mod text for known infra-client modules. The match is
    a prefix match on each `require` import path so that versioned sub-paths
    (`/v9`, `/v2`) and major-version directories are still recognized.
    """
    detected: List[Tuple[str, str]] = []
    lower = text.lower()
    for prefix, kind in _COMMAND_SIGNAL_PATTERNS_GO_MOD:
        if prefix in lower:
            detected.append((kind, prefix))
    return detected


def _command_signal_kinds_from_cargo_toml(text: str) -> List[Tuple[str, str]]:
    """Inspect a Cargo.toml text. Recognized crates that appear as a
    dependency key (`crate = "x.y"` or `[dependencies.crate]`) in any
    dependency table are detected.
    """
    detected: List[Tuple[str, str]] = []
    section: Optional[str] = None
    in_deps_table = False
    section_pat = re.compile(r"^\s*\[([^\]]+)\]\s*$")
    dep_table_suffix = re.compile(r"^(dependencies|dev-dependencies|build-dependencies)(\..+)?$")

    for raw in text.splitlines():
        line = raw.rstrip()
        section_match = section_pat.match(line)
        if section_match:
            section = section_match.group(1).strip()
            in_deps_table = bool(dep_table_suffix.match(section))
            # [dependencies.foo] form — the section name itself names the crate.
            sub = re.match(r"^(dependencies|dev-dependencies|build-dependencies)\.([A-Za-z0-9_\-]+)$", section)
            if sub:
                name = sub.group(2).strip().lower()
                _maybe_emit_cargo(name, detected)
            continue
        if not in_deps_table:
            continue
        key_match = re.match(r"^\s*([A-Za-z0-9_\-]+)\s*=", line)
        if key_match:
            name = key_match.group(1).strip().lower()
            _maybe_emit_cargo(name, detected)
    return detected


_CARGO_INFRA_PACKAGES: Dict[str, Tuple[str, str]] = {
    "redis": ("redis", "redis"),
    "mongodb": ("mongo", "mongodb"),
    "rdkafka": ("kafka", "rdkafka"),
    "opensearch": ("search", "opensearch"),
    "elasticsearch": ("search", "elasticsearch"),
}


def _maybe_emit_cargo(name: str, detected: List[Tuple[str, str]]) -> None:
    match = _CARGO_INFRA_PACKAGES.get(name)
    if match:
        detected.append(match)


# ---------------------------------------------------------------------------
# Non-Spring port + health inference for command-type services.
#
# Each helper is best-effort and silent on failure: any parser exception
# or missing literal yields ``None`` (no port assigned). The supervisor
# rule "manifest parsing must be resilient" is honored — malformed files
# never crash analysis.
# ---------------------------------------------------------------------------

_NODE_LISTEN_PATTERNS: Tuple[re.Pattern, ...] = (
    re.compile(r"\.listen\s*\(\s*(\d{2,5})\s*[,)]"),
    re.compile(r"\.listen\s*\(\s*[\"'](\d{2,5})[\"']\s*[,)]"),
    re.compile(r"createServer\s*\([^)]*\)\.listen\s*\(\s*(\d{2,5})"),
)

_NEST_PORT_PATTERN = re.compile(r"app\.listen\s*\(\s*(\d{2,5})")

_PY_UVICORN_RUN_PATTERN = re.compile(
    r"uvicorn\.run\s*\([^)]*?port\s*=\s*(\d{2,5})", re.DOTALL,
)
_PY_PORT_ARG_PATTERN = re.compile(r"--port[= ]\s*(\d{2,5})")
_PY_DJANGO_RUNSERVER_PATTERN = re.compile(r"runserver[\"',\s]+(?:[\w.]+:)?(\d{2,5})")

_GO_LISTEN_AND_SERVE_PATTERN = re.compile(
    r"ListenAndServe[A-Za-z]*\s*\(\s*[\"']:?(\d{2,5})[\"']"
)
_GO_GIN_RUN_PATTERN = re.compile(r"\.Run\s*\(\s*[\"']:?(\d{2,5})[\"']")

_PORT_ENV_PATTERN = re.compile(
    r"^\s*PORT\s*=\s*[\"']?(\d{2,5})[\"']?\s*$", re.MULTILINE,
)


def infer_command_service_port(module_dir: Path, manifest: str) -> Optional[int]:
    """Infer a non-Spring HTTP port for the command service rooted at
    ``module_dir``. Returns ``None`` when no recognizable literal is found.

    Detection order per manifest:

    - package.json: app.listen(N) literal in *.js / *.ts / *.mjs / *.cjs,
      then PORT env in .env files.
    - pyproject.toml / requirements.txt: uvicorn.run(..., port=N) literal,
      --port N in scripts, Django runserver host:port literal.
    - go.mod: http.ListenAndServe(":N", ...) or gin .Run(":N") literal.
    - Cargo.toml: bind("0.0.0.0:N") / listen(":N") — limited best-effort.
    """
    try:
        if manifest == "package.json":
            return _infer_node_port(module_dir)
        if manifest in {"pyproject.toml", "requirements.txt"}:
            return _infer_python_port(module_dir)
        if manifest == "go.mod":
            return _infer_go_port(module_dir)
        if manifest == "Cargo.toml":
            return _infer_rust_port(module_dir)
    except Exception:
        return None
    return None


def _read_command_service_source_files(module_dir: Path, extensions: Tuple[str, ...]) -> List[Tuple[Path, str]]:
    """Return (path, text) for top-level + first-level subdir source files
    matching ``extensions``. Limits recursion depth so a huge monorepo
    does not slow analysis.
    """
    results: List[Tuple[Path, str]] = []
    candidates: List[Path] = []
    try:
        for entry in module_dir.iterdir():
            if entry.is_file() and entry.suffix.lower() in extensions:
                candidates.append(entry)
            elif entry.is_dir() and entry.name not in {
                "node_modules", "dist", "build", "target", ".git",
                "__pycache__", ".venv", "venv", ".tox",
            }:
                try:
                    for sub in entry.iterdir():
                        if sub.is_file() and sub.suffix.lower() in extensions:
                            candidates.append(sub)
                except OSError:
                    continue
    except OSError:
        return results

    for path in candidates[:50]:  # bound work; 50 source files is plenty
        try:
            text = path.read_text(errors="ignore")
        except OSError:
            continue
        results.append((path, text))
    return results


def _infer_node_port(module_dir: Path) -> Optional[int]:
    sources = _read_command_service_source_files(
        module_dir, (".js", ".mjs", ".cjs", ".ts", ".tsx")
    )
    for _, text in sources:
        for pattern in _NODE_LISTEN_PATTERNS:
            match = pattern.search(text)
            if match:
                try:
                    return int(match.group(1))
                except ValueError:
                    continue

    # Fall back to PORT env declaration.
    port = _read_port_from_env_files(module_dir)
    if port:
        return port
    return None


def _infer_python_port(module_dir: Path) -> Optional[int]:
    sources = _read_command_service_source_files(module_dir, (".py",))
    for _, text in sources:
        match = _PY_UVICORN_RUN_PATTERN.search(text)
        if match:
            try:
                return int(match.group(1))
            except ValueError:
                pass
        match = _PY_DJANGO_RUNSERVER_PATTERN.search(text)
        if match:
            try:
                return int(match.group(1))
            except ValueError:
                pass
        match = _PY_PORT_ARG_PATTERN.search(text)
        if match:
            try:
                return int(match.group(1))
            except ValueError:
                pass

    port = _read_port_from_env_files(module_dir)
    if port:
        return port
    return None


def _infer_go_port(module_dir: Path) -> Optional[int]:
    sources = _read_command_service_source_files(module_dir, (".go",))
    for _, text in sources:
        match = _GO_LISTEN_AND_SERVE_PATTERN.search(text)
        if match:
            try:
                return int(match.group(1))
            except ValueError:
                pass
        match = _GO_GIN_RUN_PATTERN.search(text)
        if match:
            try:
                return int(match.group(1))
            except ValueError:
                pass
    return None


def _infer_rust_port(module_dir: Path) -> Optional[int]:
    sources = _read_command_service_source_files(module_dir, (".rs",))
    for _, text in sources:
        # Best-effort: bind("0.0.0.0:N") / listen(":N") literals.
        match = re.search(r"bind\s*\(\s*[\"'][^\"']*?:(\d{2,5})[\"']", text)
        if match:
            try:
                return int(match.group(1))
            except ValueError:
                pass
        match = re.search(r"listen\s*\(\s*[\"']:(\d{2,5})[\"']", text)
        if match:
            try:
                return int(match.group(1))
            except ValueError:
                pass
    return None


def _read_port_from_env_files(module_dir: Path) -> Optional[int]:
    for candidate in (".env", ".env.local", ".env.development", ".env.production"):
        path = module_dir / candidate
        if not path.is_file():
            continue
        try:
            text = path.read_text(errors="ignore")
        except OSError:
            continue
        match = _PORT_ENV_PATTERN.search(text)
        if match:
            try:
                return int(match.group(1))
            except ValueError:
                continue
    return None


_HEALTH_ROUTE_PATTERNS: Tuple[re.Pattern, ...] = (
    re.compile(r"""[\"']/health[\"']"""),
    re.compile(r"""[\"']/healthz[\"']"""),
    re.compile(r"@(?:Get|GET)\s*\(\s*[\"']/?health[\"']"),
    re.compile(r"path\s*\(\s*[\"']health/?[\"']"),
)


def infer_command_service_health(module_dir: Path, port: int) -> Optional[str]:
    """Return ``http://localhost:{port}/health`` only when a /health (or
    /healthz) route literal is detected in source. Otherwise returns
    ``None`` so the supervisor does not record a phantom probe.
    """
    if not port:
        return None
    extensions = (".js", ".mjs", ".cjs", ".ts", ".tsx", ".py", ".go", ".rs")
    sources = _read_command_service_source_files(module_dir, extensions)
    for _, text in sources:
        for pattern in _HEALTH_ROUTE_PATTERNS:
            if pattern.search(text):
                return f"http://localhost:{port}/health"
    return None


def inspect_gradle_services(root: Path, infrastructure_services: List[str]) -> Dict[str, Dict[str, Any]]:
    services: Dict[str, Dict[str, Any]] = {}
    if not (root / "gradlew").exists():
        return services

    for gradle_path, module_dir in find_gradle_server_modules(root):
        service_name = gradle_service_name(root, module_dir, gradle_path)
        if not service_name or service_name in infrastructure_services or service_name in services:
            continue

        service: Dict[str, Any] = {
            "type": "gradle",
            "task": gradle_boot_run_task(gradle_path),
        }
        if module_dir != root:
            service["module"] = relative_to_root(root, module_dir)
        port = infer_server_port(module_dir)
        port_from_config = bool(port)
        if not port and gradle_module_is_web_application(module_dir):
            port = DEFAULT_SPRING_WEB_PORT
        if port:
            service["port"] = port
            if gradle_module_exposes_actuator_health(module_dir):
                service["health"] = f"http://localhost:{port}{infer_actuator_health_path(module_dir)}"
            if not port_from_config:
                apply_gradle_service_port_override(service, port, port)
        if infrastructure_services:
            service["depends_on"] = infrastructure_services
        if gradle_service_needs_spring_boot_plugin(module_dir):
            service["apply_spring_boot_plugin"] = True
        # Persist detected controller routes so verify_service_api_dummy_data
        # can derive REST probes automatically without hard-coding service
        # names. The discovery is bounded by `discover_controller_routes`'s
        # rglob walk — same source-tree pass `has_web_endpoint_evidence`
        # already performs — and returns [] when no annotations are found.
        controller_routes = discover_controller_routes(module_dir)
        if controller_routes:
            service["controller_routes"] = controller_routes

        services[service_name] = service
    return services


def find_gradle_server_modules(root: Path) -> List[Tuple[str, Path]]:
    modules: List[Tuple[str, Path]] = []
    seen: Set[Path] = set()

    if is_gradle_server_module(root, root, ""):
        modules.append(("", root))
        seen.add(root.resolve())

    for gradle_path in parse_gradle_settings(root):
        module_dir = root.joinpath(*[part for part in gradle_path.split(":") if part])
        if module_dir.resolve() in seen or not module_dir.is_dir():
            continue
        if is_gradle_server_module(root, module_dir, gradle_path):
            modules.append((gradle_path, module_dir))
            seen.add(module_dir.resolve())

    if modules:
        return modules

    for build_file in sorted(root.rglob("build.gradle*")):
        module_dir = build_file.parent
        if ignored_path(root, build_file) or module_dir.resolve() in seen:
            continue
        gradle_path = relative_to_root(root, module_dir).replace("/", ":")
        if is_gradle_server_module(root, module_dir, gradle_path):
            modules.append((gradle_path, module_dir))
            seen.add(module_dir.resolve())
    return modules


def parse_gradle_settings(root: Path) -> List[str]:
    settings_files = [root / "settings.gradle", root / "settings.gradle.kts"]
    includes: List[str] = []
    for settings_file in settings_files:
        if not settings_file.exists():
            continue
        text = "\n".join(line.split("//", 1)[0] for line in settings_file.read_text(errors="ignore").splitlines())
        for block in re.findall(r"\binclude\s*\((.*?)\)", text, re.DOTALL):
            for value in re.findall(r"['\"](:?[^'\"]+)['\"]", block):
                gradle_path = value.strip().strip(":")
                if gradle_path:
                    includes.append(gradle_path)

        for raw_line in text.splitlines():
            line = raw_line.split("//", 1)[0]
            if not re.search(r"\binclude\b", line) or re.search(r"\bincludeBuild\b", line):
                continue
            for value in re.findall(r"['\"](:?[^'\"]+)['\"]", line):
                gradle_path = value.strip().strip(":")
                if gradle_path:
                    includes.append(gradle_path)
    return unique(includes)


def is_gradle_server_module(root: Path, module_dir: Path, gradle_path: str) -> bool:
    if is_one_shot_gradle_application(module_dir):
        return False

    explicit_server = has_explicit_server_evidence(module_dir)
    if explicit_server:
        return True
    if module_dir == root and not gradle_path:
        return False

    if is_library_like_module(root, module_dir, gradle_path):
        return False

    build_text = "\n".join(path.read_text(errors="ignore") for path in gradle_build_files(module_dir))
    if gradle_build_applies_spring_boot(build_text) or "bootRun" in build_text or "io.ktor.plugin" in build_text:
        return True

    return False


def gradle_service_needs_spring_boot_plugin(module_dir: Path) -> bool:
    if not has_application_entrypoint(module_dir):
        return False
    build_text = "\n".join(path.read_text(errors="ignore") for path in gradle_build_files(module_dir))
    return not gradle_build_applies_spring_boot(build_text) and "bootRun" not in build_text


def gradle_module_exposes_actuator_health(module_dir: Path) -> bool:
    build_text = "\n".join(path.read_text(errors="ignore") for path in gradle_build_files(module_dir))
    return "spring-boot-starter-actuator" in build_text


def gradle_build_applies_spring_boot(build_text: str) -> bool:
    return bool(
        re.search(r"\bid\s*\(?\s*['\"]org\.springframework\.boot['\"]", build_text)
        or re.search(r"\bapply\s+plugin:\s*['\"]org\.springframework\.boot['\"]", build_text)
    )


def has_explicit_server_evidence(module_dir: Path) -> bool:
    if infer_server_port(module_dir):
        return True

    return has_application_entrypoint(module_dir)


def discover_controller_routes(module_dir: Path) -> List[Dict[str, str]]:
    """Extract Spring `@*Mapping` route templates from a module.

    Walks `src/main/**/*.{java,kt}` once and returns a list of
    `{method, path}` dicts. `method` is one of `GET`, `POST`, `PUT`,
    `DELETE`, `PATCH`, or `ANY` (for raw `@RequestMapping`). `path` is the
    raw template extracted from the annotation. Class-level
    `@RequestMapping(prefix)` is prepended to each handler-level route on
    the same class. Best-effort regex extraction — this is used to surface
    candidate REST probes for `verify_service_api_dummy_data`; failures to
    parse simply return an empty list. When a workspace also installs
    domain overrides with a ``verification.service_name_keyword_probes``
    section, those probes are appended ahead of the auto-derived ones.
    """
    source_root = module_dir / "src" / "main"
    if not source_root.exists():
        return []
    method_annotations = {
        "@GetMapping": "GET",
        "@PostMapping": "POST",
        "@PutMapping": "PUT",
        "@DeleteMapping": "DELETE",
        "@PatchMapping": "PATCH",
        "@RequestMapping": "ANY",
    }
    # Annotation value matchers — Spring allows several forms:
    #   @GetMapping             (no args — handler answers on the class-level path)
    #   @GetMapping()           (empty args — same as above)
    #   @GetMapping("/foo")
    #   @GetMapping(value = "/foo")
    #   @GetMapping(path = "/foo")
    annotation_pattern = re.compile(
        r"@(GetMapping|PostMapping|PutMapping|DeleteMapping|PatchMapping|RequestMapping)"
        r"(?:\s*\(\s*(?:value\s*=\s*|path\s*=\s*)?[\"']([^\"']*)[\"'][^)]*\)"
        r"|\s*\(\s*\)"
        r"|(?=\s*(?:fun|public|private|protected|@|\bdef\b)))"
    )
    # Class-level @RequestMapping prefix — annotations placed immediately
    # before the `class` declaration apply to every handler inside the class.
    # Allow newlines, comments, and other annotations (@RestController, etc.)
    # to appear between the @RequestMapping and the class keyword.
    class_request_mapping_pattern = re.compile(
        r"@RequestMapping\s*\(\s*(?:value\s*=\s*|path\s*=\s*)?[\"']([^\"']+)[\"']"
        r"[\s\S]{0,400}?\bclass\s+\w+"
    )
    routes: List[Dict[str, str]] = []
    seen: Set[Tuple[str, str]] = set()
    for suffix in ("*.java", "*.kt"):
        for path in source_root.rglob(suffix):
            if not path.is_file():
                continue
            try:
                text = path.read_text(errors="ignore")
            except OSError:
                continue
            if "@" not in text or "Mapping" not in text:
                continue
            class_prefix = ""
            class_match = class_request_mapping_pattern.search(text)
            if class_match:
                class_prefix = class_match.group(1).rstrip("/")
            for annotation_match in annotation_pattern.finditer(text):
                annotation = "@" + annotation_match.group(1)
                template = (annotation_match.group(2) or "").strip()
                method = method_annotations.get(annotation, "ANY")
                # Skip the class-level @RequestMapping itself — we already
                # captured it as the prefix.
                if annotation == "@RequestMapping" and template == class_prefix and class_prefix:
                    continue
                if template:
                    sub_path = template if template.startswith("/") else "/" + template
                else:
                    sub_path = ""
                if class_prefix:
                    full_path = class_prefix + sub_path
                else:
                    full_path = sub_path if sub_path else "/"
                key = (method, full_path)
                if key in seen:
                    continue
                seen.add(key)
                routes.append({"method": method, "path": full_path})
    return routes


def derive_rest_probe_urls(service: Dict[str, Any]) -> List[Tuple[str, str]]:
    """Build REST probe (label, url) tuples from persisted controller_routes.

    Filters down to GET / ANY methods on non-parametric path templates
    (no `{...}` placeholders) so the smoke probe can be issued without
    fabricating request parameters. Returns an empty list when the
    service has no `controller_routes` key or no GET-shaped routes match.
    """
    port = service.get("port")
    if not port:
        return []
    routes = service.get("controller_routes") or []
    probes: List[Tuple[str, str]] = []
    for entry in routes:
        if not isinstance(entry, dict):
            continue
        method = str(entry.get("method", "ANY")).upper()
        path = str(entry.get("path", ""))
        if method not in {"GET", "ANY"}:
            continue
        if not path or "{" in path or "}" in path:
            continue
        url = f"http://localhost:{int(port)}{path}"
        probes.append((f"REST derived {path}", url))
    return probes


def has_application_entrypoint(module_dir: Path) -> bool:
    source_root = module_dir / "src" / "main"
    if not source_root.exists():
        return False
    for suffix in ("*.java", "*.kt"):
        for path in source_root.rglob(suffix):
            if not path.is_file():
                continue
            text = path.read_text(errors="ignore")
            if any(
                marker in text
                for marker in (
                    "@SpringBootApplication",
                    "SpringApplication.run(",
                    "runApplication<",
                    "embeddedServer(",
                    "fun Application.",
                )
            ):
                return True
    return False


def gradle_module_is_web_application(module_dir: Path) -> bool:
    if has_spring_web_application_type_none(module_dir, include_batch_profiles=False):
        return False

    build_text = "\n".join(path.read_text(errors="ignore") for path in gradle_build_files(module_dir)).lower()
    if any(
        token in build_text
        for token in (
            "spring-boot-starter-web",
            "spring-boot-starter-webflux",
            "spring-boot-starter-graphql",
            "dgs-starter",
            "io.ktor:ktor-server",
        )
    ):
        return True

    return has_web_endpoint_evidence(module_dir)


def has_web_endpoint_evidence(module_dir: Path) -> bool:
    source_root = module_dir / "src" / "main"
    if not source_root.exists():
        return False

    endpoint_markers = (
        "@RestController",
        "@Controller",
        "@RequestMapping",
        "@GetMapping",
        "@PostMapping",
        "@PutMapping",
        "@DeleteMapping",
        "@PatchMapping",
        "@DgsComponent",
        "@DgsQuery",
        "@DgsMutation",
        "embeddedServer(",
        "fun Application.",
    )
    for suffix in ("*.java", "*.kt"):
        for path in source_root.rglob(suffix):
            if not path.is_file():
                continue
            text = path.read_text(errors="ignore")
            if any(marker in text for marker in endpoint_markers):
                return True
    return False


def is_one_shot_gradle_application(module_dir: Path) -> bool:
    web_none_files = spring_web_application_type_none_files(module_dir)
    if not web_none_files:
        return False
    if all(is_batch_profile_config(path) for path in web_none_files) and has_server_evidence_outside_batch_profiles(module_dir):
        return False

    source_root = module_dir / "src" / "main"
    if not source_root.exists():
        return False

    one_shot_markers = (
        "SpringApplication.exit(",
        "ExitCodeGenerator",
        "exitProcess(",
        "System.exit(",
    )
    for suffix in ("*.java", "*.kt"):
        for path in source_root.rglob(suffix):
            if not path.is_file():
                continue
            text = path.read_text(errors="ignore")
            if any(marker in text for marker in one_shot_markers):
                return True
    return False


def has_spring_web_application_type_none(module_dir: Path, include_batch_profiles: bool = True) -> bool:
    return bool(
        spring_web_application_type_none_files(
            module_dir,
            include_batch_profiles=include_batch_profiles,
        )
    )


def spring_web_application_type_none_files(module_dir: Path, include_batch_profiles: bool = True) -> List[Path]:
    resources = module_dir / "src" / "main" / "resources"
    if not resources.exists():
        return []

    files: List[Path] = []
    for path in sorted(resources.glob("application*.properties")):
        if not include_batch_profiles and is_batch_profile_config(path):
            continue
        text = path.read_text(errors="ignore")
        if re.search(r"(?m)^\s*spring\.main\.web-application-type\s*[:=]\s*none\s*$", text, re.IGNORECASE):
            files.append(path)

    for pattern in ("application*.yml", "application*.yaml"):
        for path in sorted(resources.glob(pattern)):
            if not include_batch_profiles and is_batch_profile_config(path):
                continue
            text = path.read_text(errors="ignore")
            if re.search(r"(?m)^\s*web-application-type\s*:\s*none\s*$", text, re.IGNORECASE):
                files.append(path)
    return files


def is_batch_profile_config(path: Path) -> bool:
    stem = path.stem.lower()
    if stem == "application":
        return False

    profile = stem.removeprefix("application").strip("-_.")
    profile_tokens = {token for token in re.split(r"[-_.]+", profile) if token}
    return "batch" in profile_tokens


def has_server_evidence_outside_batch_profiles(module_dir: Path) -> bool:
    if infer_server_port(module_dir, include_batch_profiles=False):
        return True

    build_text = "\n".join(path.read_text(errors="ignore") for path in gradle_build_files(module_dir)).lower()
    if any(
        token in build_text
        for token in (
            "spring-boot-starter-web",
            "spring-boot-starter-webflux",
            "spring-boot-starter-graphql",
            "dgs-starter",
            "io.ktor:ktor-server",
        )
    ):
        return True

    return has_web_endpoint_evidence(module_dir)


def is_library_like_module(root: Path, module_dir: Path, gradle_path: str) -> bool:
    identity = gradle_path or relative_to_root(root, module_dir)
    tokens = [
        token
        for token in re.split(r"[:/_.-]+", identity.lower())
        if token
    ]
    if not tokens:
        return False

    server_tokens = {
        "api",
        "app",
        "apps",
        "application",
        "applications",
        "backend",
        "bff",
        "gateway",
        "proxy",
        "server",
        "service",
        "services",
        "web",
    }
    if any(token in server_tokens for token in tokens):
        return False

    library_tokens = {
        "lib",
        "libs",
        "library",
        "libraries",
        "core",
        "common",
        "commons",
        "shared",
        "support",
        "domain",
        "model",
        "models",
        "client",
        "clients",
        "sdk",
        "util",
        "utils",
    }
    return any(token in library_tokens for token in tokens)


def gradle_build_files(module_dir: Path) -> List[Path]:
    return [path for path in (module_dir / "build.gradle", module_dir / "build.gradle.kts") if path.exists()]


def gradle_service_name(root: Path, module_dir: Path, gradle_path: str) -> str:
    if gradle_path:
        segments = [service_name_segment(part) for part in gradle_path.split(":") if part]
        return ".".join(segment for segment in segments if segment)
    return service_name_segment(root.name or module_dir.name)


def service_name_segment(value: str) -> str:
    cleaned = re.sub(r"[^A-Za-z0-9_-]+", "-", value.strip())
    return cleaned.strip("-_")


def gradle_boot_run_task(gradle_path: str) -> str:
    if not gradle_path:
        return "bootRun"
    return ":" + ":".join(part for part in gradle_path.split(":") if part) + ":bootRun"


def infer_server_port(module_dir: Path, include_batch_profiles: bool = True) -> Optional[int]:
    resources = module_dir / "src" / "main" / "resources"
    if not resources.exists():
        return None

    for path in sorted(resources.glob("application*.properties")):
        if not include_batch_profiles and is_batch_profile_config(path):
            continue
        port = parse_properties_server_port(path.read_text(errors="ignore"))
        if port:
            return port
    for pattern in ("application*.yml", "application*.yaml"):
        for path in sorted(resources.glob(pattern)):
            if not include_batch_profiles and is_batch_profile_config(path):
                continue
            port = parse_yaml_server_port(path.read_text(errors="ignore"))
            if port:
                return port
    return None


def parse_properties_server_port(text: str) -> Optional[int]:
    match = re.search(r"(?m)^\s*server\.port\s*[:=]\s*([0-9]+)\s*$", text)
    return int(match.group(1)) if match else None


def parse_yaml_server_port(text: str) -> Optional[int]:
    server_indent: Optional[int] = None
    for raw_line in text.splitlines():
        stripped = raw_line.strip()
        if not stripped or stripped.startswith("#"):
            continue

        indent = len(raw_line) - len(raw_line.lstrip(" "))
        if re.match(r"^server\s*:\s*$", stripped):
            server_indent = indent
            continue
        if server_indent is None:
            continue
        if indent <= server_indent:
            server_indent = None
            continue

        match = re.match(r"^port\s*:\s*([0-9]+)\s*$", stripped)
        if match:
            return int(match.group(1))
    return None


def infer_actuator_health_path(module_dir: Path) -> str:
    properties: Dict[str, str] = {}
    resources = module_dir / "src" / "main" / "resources"
    if resources.exists():
        patterns = ("application*.properties", "application*.yml", "application*.yaml")
        for pattern in patterns:
            for path in sorted(resources.glob(pattern), key=spring_config_file_sort_key):
                for key, value in config_property_entries(path, read_small_text(path)):
                    properties[key] = value

    context_path = normalize_url_path(properties.get("server.servlet.context-path", ""))
    actuator_path = normalize_url_path(properties.get("management.endpoints.web.base-path", "/actuator"))
    health_path = normalize_url_path(properties.get("management.endpoints.web.path-mapping.health", "health"))
    return join_url_paths(context_path, actuator_path, health_path)


def spring_config_file_sort_key(path: Path) -> Tuple[int, str]:
    stem = path.stem
    base = stem in {"application", "bootstrap"}
    return (0 if base else 1, path.name)


def normalize_url_path(value: str) -> str:
    path = str(value or "").strip().strip("\"'")
    if not path:
        return ""
    if path == "/":
        return ""
    return "/" + path.strip("/")


def join_url_paths(*parts: str) -> str:
    path = "/".join(part.strip("/") for part in parts if part and part != "/")
    return "/" + path if path else "/"


def compose_service_prefix(root: Path, compose_path: Path) -> str:
    relative = compose_path.relative_to(root)
    if len(relative.parts) > 1:
        return safe_name(relative.parent.as_posix())
    stem = compose_path.name
    for suffix in (".compose.yaml", ".compose.yml", ".yaml", ".yml"):
        if stem.endswith(suffix):
            stem = stem[: -len(suffix)]
            break
    return safe_name(stem.replace("docker-compose", "compose").strip(".-_"))


def relative_to_root(root: Path, path: Path) -> str:
    try:
        return str(path.relative_to(root))
    except ValueError:
        return str(path)


def workspace_guidance() -> str:
    return (
        "Run from a configured workspace, pass --root/--workspace, "
        "or run: devstack workspace setup [root] --default"
    )


def find_workspace_root(start: Path) -> Path:
    current = start.resolve()
    for candidate in [current, *current.parents]:
        # Shim 3 — either filename qualifies.
        if (candidate / CONFIG_NAME).exists() or (candidate / LEGACY_CONFIG_NAME).exists():
            return candidate
    raise DevstackError(
        f"neither {CONFIG_NAME} nor {LEGACY_CONFIG_NAME} found from {start}"
    )


def workspace_root_from_registry(workspace: str) -> Path:
    return WorkspaceRegistry.load().resolve(workspace)


def write_json(path: Path, payload: Dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n")


def load_json(path: Path) -> Dict[str, Any]:
    try:
        return json.loads(path.read_text())
    except json.JSONDecodeError as error:
        raise DevstackError(f"invalid JSON in {path}: {error}") from error


def run(cmd: List[str], cwd: Path) -> None:
    try:
        subprocess.run(cmd, cwd=cwd, check=True)
    except FileNotFoundError as error:
        raise DevstackError(f"command not found: {cmd[0]}") from error
    except subprocess.CalledProcessError as error:
        raise DevstackError(f"command failed ({error.returncode}): {' '.join(cmd)}") from error


def compose_command(cwd: Path) -> List[str]:
    global COMPOSE_COMMAND_CACHE

    if COMPOSE_COMMAND_CACHE is not None:
        return list(COMPOSE_COMMAND_CACHE)

    candidates: Tuple[Tuple[str, ...], ...] = (("docker", "compose"), ("docker-compose",))
    for command in candidates:
        try:
            result = subprocess.run(
                [*command, "version"],
                cwd=cwd,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                text=True,
                check=False,
            )
        except FileNotFoundError:
            continue
        if result.returncode == 0:
            COMPOSE_COMMAND_CACHE = command
            return list(command)

    COMPOSE_COMMAND_CACHE = ("docker", "compose")
    return ["docker", "compose"]


def compose_project_name(service: Dict[str, Any]) -> str:
    return str(service.get("project") or service.get("compose_project") or "").strip()


def compose_project_args(service: Dict[str, Any]) -> List[str]:
    project_name = compose_project_name(service)
    return ["-p", project_name] if project_name else []


def http_ok(url: str) -> bool:
    try:
        with urllib.request.urlopen(url, timeout=2) as response:
            return 200 <= response.status < 400
    except (urllib.error.URLError, TimeoutError, ConnectionError, OSError):
        return False


# ---------------------------------------------------------------------------
# Non-JVM command-service datasource handshake (minimal)
#
# Spring Boot apps prove their datasource binding via the actuator `/env`
# endpoint (see `verify_managed_datasource`). Non-JVM command services (Node,
# Python, Go, Rust, ...) carry datasource-shaped env keys but expose no
# actuator equivalent, so the in-process binding cannot be proven from here.
#
# This block provides the next-best handshake: detect the datasource env
# entries on a command service, prove the promised host:port is reachable
# (TCP-open), additionally probe the devstack-managed DB container's liveness
# when the endpoint maps to one, and explicitly mark the service with a
# machine-readable status note that records "app-side binding unverified"
# instead of staying silent. A follow-up task aggregates these notes into
# `devstack status` output.
# ---------------------------------------------------------------------------


# Default ports for non-JDBC URI schemes used in `parse_datasource_endpoint`.
# JDBC ports come from `parse_jdbc_url` + this same map (keyed by engine).
_NON_JDBC_DEFAULT_PORTS: Dict[str, int] = {
    "postgres": 5432,
    "postgresql": 5432,
    "mysql": 3306,
    "mariadb": 3306,
    "mongodb": 27017,
    "mongodb+srv": 27017,
    "redis": 6379,
    "rediss": 6379,
    "sqlserver": 1433,
    "oracle": 1521,
    "cockroachdb": 26257,
}


def command_service_datasource_env(service: Dict[str, Any]) -> List[Tuple[str, str]]:
    """Return the (key, value) pairs in ``service["env"]`` whose key+value
    combination identifies a datasource (per `dotenv_value_is_datasource`).

    Returns an empty list when the service has no env, or no env entry
    qualifies — in which case the datasource handshake stays disabled and
    the service retains its existing readiness semantics.
    """
    env = service.get("env") if isinstance(service, dict) else None
    if not isinstance(env, dict):
        return []
    result: List[Tuple[str, str]] = []
    for key, value in env.items():
        if not isinstance(key, str) or not isinstance(value, str):
            continue
        if dotenv_value_is_datasource(key, value):
            result.append((key, value))
    return result


def parse_datasource_endpoint(value: str) -> Optional[Tuple[str, int]]:
    """Best-effort extraction of ``(host, port)`` from a datasource URL.

    Supports two URL shapes:

    1. ``jdbc:<engine>://host[:port]/db`` (delegates to ``parse_jdbc_url`` and
       falls back to the engine's default port from ``_NON_JDBC_DEFAULT_PORTS``
       when the URL omits one — same map covers all four managed engines).
    2. ``<scheme>://[user[:pass]@]host[:port]/db`` for non-JDBC schemes such
       as ``postgres://``, ``postgresql://``, ``mysql://``, ``mariadb://``,
       ``mongodb[+srv]://``, ``redis[s]://``, parsed via stdlib
       ``urllib.parse.urlsplit``.

    Returns ``None`` when the host is missing or empty, when the port cannot
    be resolved (no explicit port AND no default for the scheme), or when the
    value is not a recognized datasource URL shape.

    Symbolic hosts (env-var placeholders like ``${DB_HOST}``) yield ``None``
    so the caller can record an explicit "unparsed endpoint" note rather
    than probing a literal ``${`` host.
    """
    if not isinstance(value, str):
        return None
    text = value.strip()
    if not text:
        return None
    lowered = text.lower()

    if lowered.startswith("jdbc:"):
        parsed = parse_jdbc_url(text)
        host = str(parsed.get("host") or "").strip()
        if not host or is_symbolic_host(host):
            return None
        port = parsed.get("port")
        if port is None:
            engine = normalize_database_engine(str(parsed.get("engine") or ""))
            port = _NON_JDBC_DEFAULT_PORTS.get(engine)
        try:
            port_int = int(port) if port is not None else 0
        except (TypeError, ValueError):
            return None
        if port_int <= 0:
            return None
        return host, port_int

    # Non-JDBC URI: scheme://...
    if "://" not in text:
        return None
    try:
        split = urllib.parse.urlsplit(text)
    except ValueError:
        return None
    scheme = (split.scheme or "").lower()
    if not scheme:
        return None
    host = split.hostname or ""
    if not host or is_symbolic_host(host):
        return None
    port = split.port
    if port is None:
        port = _NON_JDBC_DEFAULT_PORTS.get(scheme)
    try:
        port_int = int(port) if port is not None else 0
    except (TypeError, ValueError):
        return None
    if port_int <= 0:
        return None
    return host, port_int


def _host_aliases(host: str) -> Set[str]:
    """Return the set of equivalent loopback aliases for ``host``.

    devstack-managed DB compose services typically expose ``localhost`` on the
    host network, but app env strings may use ``127.0.0.1`` or ``localhost``
    interchangeably. Normalize to a single equivalence class so the
    host:port match in ``find_managed_database_service`` does not miss a
    legitimate pairing for that reason alone.
    """
    if not host:
        return set()
    lowered = host.strip().lower()
    loopback = {"localhost", "127.0.0.1", "0.0.0.0", "::1"}
    if lowered in loopback:
        return loopback
    return {lowered}


def find_managed_database_service(
    services: Dict[str, Dict[str, Any]],
    host: str,
    port: int,
) -> Optional[Tuple[str, Dict[str, Any]]]:
    """Locate the devstack-managed DB compose service whose host:port matches
    ``(host, port)``. Returns ``(service_name, service_dict)`` or ``None``.

    Matching policy:
    - host is compared inside its loopback equivalence class (see
      ``_host_aliases``).
    - port equality is strict against the compose service's ``port`` (host
      side; the value devstack assigns when generating local infra).
    - the candidate must declare an ``engine`` that lives in
      ``MANAGED_DATABASES`` (postgresql / mysql / mariadb / mssql). Compose
      services without ``engine`` are ignored — those are not devstack DB
      containers regardless of port.
    """
    if not isinstance(services, dict) or port <= 0:
        return None
    aliases = _host_aliases(host)
    if not aliases:
        return None
    for name, svc in services.items():
        if not isinstance(svc, dict):
            continue
        if svc.get("type") != "compose":
            continue
        engine = str(svc.get("engine") or "").strip().lower()
        if engine not in MANAGED_DATABASES:
            continue
        svc_port = svc.get("port")
        try:
            svc_port_int = int(svc_port) if svc_port is not None else 0
        except (TypeError, ValueError):
            continue
        if svc_port_int != port:
            continue
        # Managed compose services bind on localhost by convention. Treat any
        # entry in the loopback equivalence class as a match for the host.
        if "localhost" in aliases or "127.0.0.1" in aliases:
            return name, svc
    return None


def managed_database_alive(db_service: Dict[str, Any], host: str, port: int) -> bool:
    """Return True when the devstack-managed DB compose service appears alive.

    The handshake at this layer is intentionally minimal — running an
    engine-specific query (``pg_isready``, ``mysqladmin ping``, ...) would
    require either reaching into the container (docker exec) or shipping
    drivers, which violates the stdlib-only / single-file constraints. So
    "alive" is two cheap checks:

    1. The compose service's container, if present, reports ``running``
       (via ``docker_container_status``). Absent container handles skip
       this branch — TCP-open carries the weight.
    2. ``port_open(host, port)`` returns True.

    Returns True when both available checks pass. Returns False otherwise.
    """
    if not isinstance(db_service, dict):
        return False
    container = db_service.get("container")
    if container:
        try:
            status = docker_container_status(str(container))
        except Exception:
            status = None
        if status != "running":
            return False
    return port_open(host, int(port))


def add_service_status_note(
    service: Dict[str, Any],
    key: str,
    value: Any,
    detail: Optional[str] = None,
) -> None:
    """Append a machine-readable status note onto ``service`` (in-memory).

    Notes accumulate under ``service["devstack_status_notes"]`` as a list of
    ``{"key": str, "value": Any, "ts": iso8601, "detail"?: str}`` dicts. The
    follow-up status-counter task aggregates these into ``devstack status``
    output — keep the shape stable.

    A note with the same ``(key, value)`` pair is not appended twice; only
    the timestamp would change and that adds churn without information.
    """
    if not isinstance(service, dict):
        return
    notes = service.get("devstack_status_notes")
    if not isinstance(notes, list):
        notes = []
        service["devstack_status_notes"] = notes
    for existing in notes:
        if isinstance(existing, dict) and existing.get("key") == key and existing.get("value") == value:
            return
    entry: Dict[str, Any] = {
        "key": key,
        "value": value,
        "ts": datetime.datetime.now(datetime.timezone.utc).isoformat(),
    }
    if detail is not None:
        entry["detail"] = detail
    notes.append(entry)


def verify_command_service_datasources(
    service_name: str,
    service: Dict[str, Any],
    datasource_entries: List[Tuple[str, str]],
    services: Dict[str, Dict[str, Any]],
) -> bool:
    """Run a single-pass datasource handshake check for one command service.

    Returns True when every parseable datasource endpoint is TCP-reachable
    AND (when the endpoint maps to a devstack-managed DB compose service)
    that DB also passes ``managed_database_alive``. Returns False when any
    required probe currently fails — the caller decides whether to retry
    inside its own deadline loop.

    On the True return path, this function also appends a single
    ``app_binding_unverified=true`` note to ``service`` so the readiness
    transition records the unverifiable gap explicitly. On the False
    return path, no permanent note is added — only ephemeral per-endpoint
    failures are recorded as transient ``datasource_tcp_unreachable``
    notes so operators can see which endpoint is currently blocking
    readiness without us pretending the binding was checked.

    Unparseable values record a ``datasource_endpoint_unparsed`` note once
    (subsequent loop iterations are deduped by ``add_service_status_note``)
    and are excluded from the "must succeed" set — an env entry we cannot
    parse cannot block readiness; it is recorded as a low-confidence
    signal for the follow-up status-counter task.
    """
    all_ok = True
    any_required = False
    for key, value in datasource_entries:
        endpoint = parse_datasource_endpoint(value)
        if endpoint is None:
            add_service_status_note(
                service,
                "datasource_endpoint_unparsed",
                key,
                detail=value,
            )
            continue
        any_required = True
        host, port = endpoint
        if not port_open(host, int(port)):
            add_service_status_note(
                service,
                "datasource_tcp_unreachable",
                f"{host}:{port}",
                detail=key,
            )
            all_ok = False
            continue
        managed = find_managed_database_service(services, host, int(port))
        if managed is not None:
            db_name, db_service = managed
            if not managed_database_alive(db_service, host, int(port)):
                add_service_status_note(
                    service,
                    "managed_database_not_alive",
                    db_name,
                    detail=f"{host}:{port}",
                )
                all_ok = False
                continue

    if all_ok and any_required:
        add_service_status_note(service, "app_binding_unverified", True)
    return all_ok and any_required


def expected_managed_jdbc_urls(service: Dict[str, Any]) -> Dict[str, str]:
    """Extract the set of (spring property name → expected JDBC URL) pairs
    that the managed environment planted on this service.

    `datasource_placeholder_env` populates `service["env"]` with
    `SPRING_DATASOURCE_URL` plus per-app variants such as
    `SPRING_DATASOURCE_BLMASTERBOARD_URL`. Each such key maps back to a
    Spring property name (`spring.datasource.url`,
    `spring.datasource.blmasterboard.url`, ...) — the same name actuator
    reports in its `/env` endpoint. Reuse this map as the single source of
    truth for "what URL should the app have bound?".
    """
    expected: Dict[str, str] = {}
    env = service.get("env") if isinstance(service, dict) else None
    if not isinstance(env, dict):
        return expected
    for key, value in env.items():
        if not isinstance(key, str) or not isinstance(value, str):
            continue
        upper = key.upper()
        if not upper.startswith("SPRING_DATASOURCE_") or not upper.endswith("_URL"):
            continue
        if upper == "SPRING_DATASOURCE_URL":
            property_name = "spring.datasource.url"
        else:
            # SPRING_DATASOURCE_BLMASTERBOARD_URL  →  spring.datasource.blmasterboard.url
            middle = upper[len("SPRING_DATASOURCE_"):-len("_URL")]
            if not middle:
                continue
            property_name = "spring.datasource." + middle.lower() + ".url"
        expected[property_name] = value
    return expected


def fetch_actuator_env_property(base_url: str, property_name: str) -> Optional[str]:
    """GET `{base_url}/env/{property_name}` and return the property's value,
    or None on any error / unparseable response.

    Spring Boot Actuator's `/env/{name}` endpoint returns JSON shaped like
    `{"property": {"source": "...", "value": "..."}, ...}` (Boot 2.x and 3.x).
    Returns None when the endpoint is unreachable (URLError / timeout /
    OSError), when HTTP status is non-2xx, when the body is not parseable
    JSON, or when the expected `property.value` field is absent. The
    None return is treated as "soft-pass" by the caller — verification is
    skipped, not failed.
    """
    url = base_url.rstrip("/") + "/env/" + urllib.parse.quote(property_name, safe=".")
    try:
        with urllib.request.urlopen(url, timeout=3) as response:
            if response.status < 200 or response.status >= 300:
                return None
            payload = json.loads(response.read().decode("utf-8"))
    except (urllib.error.URLError, TimeoutError, ConnectionError, OSError,
            json.JSONDecodeError, ValueError, UnicodeDecodeError):
        return None
    if not isinstance(payload, dict):
        return None
    prop = payload.get("property")
    if not isinstance(prop, dict):
        return None
    value = prop.get("value")
    if isinstance(value, str):
        return value
    return None


# ---------------------------------------------------------------------------
# Managed-datasource startup invariant — DB liveness probe (soft-pass arm)
# ---------------------------------------------------------------------------
# When the app's actuator endpoint is unreachable, devstack cannot read the
# Spring property and verify "the bound URL equals the managed URL". The
# original soft-pass branch (commit history pre-2026-06-04) simply emitted a
# WARN and let readiness succeed — which silently passes the H2-fallback bug
# class this invariant was added to catch. The probe layer below is the
# narrowed soft-pass contract: devstack independently proves each expected
# managed JDBC URL points at a *live database* before letting readiness
# succeed. Probe failure denies readiness with a clear reason.
#
# Stdlib-only by design (the constraint that devstack itself ships as a single
# self-contained script). MySQL/MariaDB are validated via the protocol
# greeting packet read directly from a TCP socket — no `pymysql` /
# `mysql-connector` import needed. Unknown engines fall back to either a
# `docker exec <managed-container> mysql -e 'SELECT 1'` query against the
# port's owning container, or, when no docker fallback is feasible, a
# TCP-open-only probe tagged `confidence=low` so the follow-up status-counter
# task can surface "low-confidence" readiness counts.

# Module-level append-only signal list. The follow-up status-counter task
# consumes it via consume_managed_datasource_probe_signals(); this file does
# NOT aggregate or surface counts itself — it only emits.
MANAGED_DATASOURCE_PROBE_SIGNALS: List[Dict[str, Any]] = []


def consume_managed_datasource_probe_signals() -> List[Dict[str, Any]]:
    """Return and clear the in-memory list of managed-datasource probe
    signals.

    Each entry is a dict shaped like::

        {
            "service": "apps.shop",
            "property": "spring.datasource.url",
            "jdbc_url": "jdbc:mysql://localhost:3306/shop",
            "host": "localhost",
            "port": 3306,
            "engine": "mysql",
            "ok": True,
            "method": "tcp+greeting" | "docker_exec" | "tcp_only" | "none",
            "confidence": "high" | "low" | "degraded",
            "reason": "MySQL greeting validated (protocol_version=10, server=8.0.36)",
            "ts": 1717520400.123,
        }

    Designed as a hand-off to a follow-up status-counter task that
    aggregates `confidence=low`, `confidence=degraded`, and probe-method
    mixes into the `devstack status` output. The follow-up task should call
    this getter once per status render so signals do not pile up between
    successive readiness probes.
    """
    drained = list(MANAGED_DATASOURCE_PROBE_SIGNALS)
    MANAGED_DATASOURCE_PROBE_SIGNALS.clear()
    return drained


def peek_managed_datasource_probe_signals() -> List[Dict[str, Any]]:
    """Non-destructive read of ``MANAGED_DATASOURCE_PROBE_SIGNALS``.

    Returns a defensive shallow copy so callers can iterate without
    risk of concurrent mutation, but does NOT clear the underlying
    list. Used by the grey-zone status counter aggregator
    (``count_workspace_grey_zone``) — that aggregator must not drain
    signals other consumers (``consume_managed_datasource_probe_signals``)
    expect to see.
    """
    return list(MANAGED_DATASOURCE_PROBE_SIGNALS)


def _record_managed_datasource_probe_signal(
    service_name: str,
    property_name: str,
    jdbc_url: str,
    host: str,
    port: int,
    engine: str,
    result: Dict[str, Any],
) -> None:
    """Append one probe outcome to MANAGED_DATASOURCE_PROBE_SIGNALS.

    Best-effort: any unexpected exception (e.g. signal list mutated by a
    concurrent caller) is swallowed so a defective signal pipeline cannot
    block readiness verification itself.
    """
    try:
        MANAGED_DATASOURCE_PROBE_SIGNALS.append(
            {
                "service": service_name,
                "property": property_name,
                "jdbc_url": jdbc_url,
                "host": host,
                "port": int(port),
                "engine": engine,
                "ok": bool(result.get("ok")),
                "method": str(result.get("method") or "none"),
                "confidence": str(result.get("confidence") or "degraded"),
                "reason": str(result.get("reason") or ""),
                "ts": time.time(),
            }
        )
    except Exception:  # noqa: BLE001 — never raise from a signal append
        pass


def _mysql_greeting_alive(host: str, port: int, timeout: float = 1.0) -> Dict[str, Any]:
    """TCP-connect to (host, port) and validate the MySQL/MariaDB handshake.

    Returns ``{"ok": bool, "reason": str, "server_version": Optional[str]}``.

    The MySQL classic protocol handshake (V10) is little-endian and starts
    with::

        bytes[0:3]   = payload length (LE uint24)
        bytes[3]     = sequence id (0x00 for the server greeting)
        bytes[4]     = protocol version (0x0a / decimal 10)
        bytes[5:..]  = NUL-terminated server version string, e.g.
                       "8.0.36"           (Oracle MySQL)
                       "5.7.43"           (MySQL 5.7)
                       "10.11.6-MariaDB"  (MariaDB)
                       "5.5.5-10.x.x-MariaDB" (MariaDB ≥10.2 prefix
                       compatibility quirk; first byte after protocol
                       version is still the leading ASCII of "5.5.5-")

    The validator only verifies "the first ASCII string after the protocol
    byte looks like a server-version literal" — it does not crack the rest
    of the handshake (capabilities, salt, auth plugin). That is sufficient
    to distinguish a real DB process from a generic TCP listener (e.g.
    nginx, H2 console, ssh) without depending on a third-party driver.
    """
    sock = None
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(timeout)
        sock.connect((host, int(port)))
        sock.settimeout(timeout)
        # 64 bytes is comfortably more than the version-string prefix while
        # staying short enough that a slow / silent peer times out fast.
        data = sock.recv(64)
    except (OSError, socket.timeout) as error:
        return {"ok": False, "reason": f"TCP/recv error: {error}", "server_version": None}
    finally:
        if sock is not None:
            try:
                sock.close()
            except OSError:
                pass

    if not data or len(data) < 6:
        return {
            "ok": False,
            "reason": f"short greeting ({len(data) if data else 0} bytes)",
            "server_version": None,
        }
    payload_len = data[0] | (data[1] << 8) | (data[2] << 16)
    seq_id = data[3]
    protocol_version = data[4]
    if protocol_version != 10:
        return {
            "ok": False,
            "reason": (
                f"unexpected protocol byte {protocol_version!r} "
                f"(want 10 for MySQL/MariaDB)"
            ),
            "server_version": None,
        }
    # Pull the NUL-terminated server-version string.
    rest = data[5:]
    nul_index = rest.find(b"\x00")
    if nul_index <= 0:
        return {
            "ok": False,
            "reason": "no NUL-terminated server version in greeting",
            "server_version": None,
        }
    version_bytes = rest[:nul_index]
    try:
        version_str = version_bytes.decode("ascii")
    except UnicodeDecodeError:
        return {
            "ok": False,
            "reason": "server version is not ASCII",
            "server_version": None,
        }
    # A valid MySQL/MariaDB version literal begins with a digit and is at
    # least 3 characters long (`5.x`, `8.0`, `10.x`, ...).
    if len(version_str) < 3 or not version_str[0].isdigit():
        return {
            "ok": False,
            "reason": f"implausible server version string {version_str!r}",
            "server_version": None,
        }
    # payload_len/seq_id are not strictly validated — older proxies (HAProxy
    # mysql-mode, AWS RDS proxy) may rewrite the framing — but we record
    # them in the reason string for diagnostic value.
    return {
        "ok": True,
        "reason": (
            f"MySQL greeting validated (protocol_version=10, "
            f"server={version_str}, payload_len={payload_len}, seq={seq_id})"
        ),
        "server_version": version_str,
    }


def _docker_exec_db_probe(
    host: str,
    port: int,
    engine: str,
    timeout: float = 4.0,
) -> Optional[Dict[str, Any]]:
    """Attempt a docker-exec ``SELECT 1`` against the managed container that
    publishes ``host:port``.

    Steps:
      1. Run ``docker ps --filter publish=<port> --format '{{.Names}}'`` —
         this returns container names that publish the port to the host
         (devstack's managed compose stack maps every DB container's
         internal port to a unique host port).
      2. If exactly one container name is returned, pick a client binary
         appropriate for the engine — ``mysql`` for MySQL, ``mariadb``
         (with ``mysql`` fallback) for MariaDB, ``sqlcmd`` for SQL Server —
         and run ``docker exec <name> <client> -h 127.0.0.1 -u root
         -e 'SELECT 1'``.

    Returns one of:

    - ``{"ok": True,  "reason": "..."}`` — docker exec returned 0
    - ``{"ok": False, "reason": "..."}`` — docker exec returned non-zero
    - ``None`` — fallback unavailable (no docker binary, no candidate
      container, more than one candidate which is ambiguous, or an
      unsupported engine for which no client invocation is defined)

    The ``None`` sentinel lets the orchestrator distinguish "fallback could
    not run" from "fallback ran and proved the DB is down" — the former
    must NOT deny readiness, the latter must.
    """
    candidates: List[str] = []
    try:
        result = subprocess.run(
            [
                "docker",
                "ps",
                "--filter",
                f"publish={int(port)}",
                "--format",
                "{{.Names}}",
            ],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=timeout,
            check=False,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired, OSError):
        return None
    if result.returncode != 0:
        return None
    for line in result.stdout.splitlines():
        candidate = line.strip()
        if candidate:
            candidates.append(candidate)
    if not candidates:
        return None
    if len(candidates) > 1:
        # Ambiguous — multiple containers publish the same host port. Refuse
        # to guess; treat as "fallback unavailable" so the TCP-only confidence
        # path still applies.
        return None
    container = candidates[0]

    normalized_engine = normalize_database_engine(engine)
    # Pick the in-container client invocation. Each tuple is
    # (binary, [args...]); we try them in order until one succeeds.
    client_invocations: List[Tuple[str, List[str]]] = []
    if normalized_engine == "mysql":
        client_invocations.append(
            ("mysql", ["-h", "127.0.0.1", "-uroot", "-e", "SELECT 1"])
        )
    elif normalized_engine == "mariadb":
        client_invocations.append(
            ("mariadb", ["-h", "127.0.0.1", "-uroot", "-e", "SELECT 1"])
        )
        client_invocations.append(
            ("mysql", ["-h", "127.0.0.1", "-uroot", "-e", "SELECT 1"])
        )
    elif normalized_engine == "mssql":
        client_invocations.append(
            (
                "/opt/mssql-tools/bin/sqlcmd",
                ["-S", "127.0.0.1", "-U", "sa", "-Q", "SELECT 1"],
            )
        )
    else:
        # Unknown engine — no canonical in-container client to call.
        return None

    last_error = ""
    for binary, args in client_invocations:
        try:
            attempt = subprocess.run(
                ["docker", "exec", container, binary, *args],
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
                timeout=timeout,
                check=False,
            )
        except (FileNotFoundError, subprocess.TimeoutExpired, OSError) as error:
            last_error = f"docker exec invocation failed: {error}"
            continue
        if attempt.returncode == 0:
            return {
                "ok": True,
                "reason": (
                    f"docker exec {container} {binary} SELECT 1 returned 0"
                ),
            }
        last_error = (
            f"docker exec {container} {binary} SELECT 1 exit="
            f"{attempt.returncode} stderr={attempt.stderr.strip()!r}"
        )
    return {"ok": False, "reason": last_error or "docker exec failed"}


def probe_managed_jdbc_target(
    property_name: str,
    jdbc_url: str,
    greeting_probe: Optional[Callable[[str, int], Dict[str, Any]]] = None,
    docker_probe: Optional[Callable[[str, int, str], Optional[Dict[str, Any]]]] = None,
) -> Dict[str, Any]:
    """Liveness-probe one expected managed JDBC target.

    Returns a result dict with keys::

        ok          : bool   — True iff target may be considered "live enough"
        method      : str    — "tcp+greeting" | "docker_exec" | "tcp_only" | "none"
        confidence  : str    — "high" | "low" | "degraded"
        reason      : str    — diagnostic text safe to surface in a WARN line
                               or a DevstackError message.
        host        : str
        port        : int
        engine      : str

    ``greeting_probe`` / ``docker_probe`` are injected test seams — they
    default to the module-level helpers and are only overridden by the
    regression tests in test_devstack_ui.py.

    Probe sequence:
      1. parse_jdbc_url(jdbc_url) → engine, host, port. If port is missing
         or host is symbolic / unresolvable, return method="none",
         confidence="degraded", ok=False.
      2. If engine is mysql / mariadb: call greeting_probe(host, port).
         - On success → ok=True, method="tcp+greeting", confidence="high".
         - On failure → fall through to step 3 (docker_exec may still
           prove liveness via the managed container).
      3. Call docker_probe(host, port, engine).
         - {ok: True}  → ok=True,  method="docker_exec", confidence="high".
         - {ok: False} → ok=False, method="docker_exec", confidence="degraded".
         - None        → fall through to step 4.
      4. Final fallback: TCP-only port_open. If the port is open but no
         protocol-level evidence is available, return ok=True,
         method="tcp_only", confidence="low" — the soft-pass is preserved
         for engines we cannot speak natively, while the signal pipeline
         records the low confidence for the follow-up status counter to
         surface.
      5. If even TCP-open fails → ok=False, method="none",
         confidence="degraded".
    """
    if greeting_probe is None:
        greeting_probe = _mysql_greeting_alive
    if docker_probe is None:
        docker_probe = _docker_exec_db_probe

    parsed = parse_jdbc_url(jdbc_url)
    engine = normalize_database_engine(str(parsed.get("engine") or ""))
    host = str(parsed.get("host") or "").strip() or "localhost"
    port_raw = parsed.get("port")
    try:
        port = int(port_raw) if port_raw is not None else 0
    except (TypeError, ValueError):
        port = 0
    if port <= 0:
        return {
            "ok": False,
            "method": "none",
            "confidence": "degraded",
            "reason": f"could not parse host:port from JDBC URL {jdbc_url!r}",
            "host": host,
            "port": 0,
            "engine": engine,
        }
    if is_symbolic_host(host):
        return {
            "ok": False,
            "method": "none",
            "confidence": "degraded",
            "reason": f"symbolic / unresolvable host {host!r} in JDBC URL",
            "host": host,
            "port": port,
            "engine": engine,
        }
    # Probe-host shim: managed DB containers publish on the host network as
    # "localhost". Container-only hostnames (e.g. the compose service name
    # "mysql") are not reachable from the supervisor's network — translate
    # them to 127.0.0.1 so the probe targets the published host port.
    probe_host = "127.0.0.1" if host in {"localhost", "mysql", "mariadb"} else host

    last_reason = ""
    if engine in ("mysql", "mariadb"):
        greeting = greeting_probe(probe_host, port)
        if greeting.get("ok"):
            return {
                "ok": True,
                "method": "tcp+greeting",
                "confidence": "high",
                "reason": str(greeting.get("reason") or "greeting validated"),
                "host": host,
                "port": port,
                "engine": engine,
            }
        last_reason = str(greeting.get("reason") or "greeting probe failed")

    docker_result = docker_probe(probe_host, port, engine)
    if isinstance(docker_result, dict):
        if docker_result.get("ok"):
            return {
                "ok": True,
                "method": "docker_exec",
                "confidence": "high",
                "reason": str(docker_result.get("reason") or "docker exec SELECT 1 ok"),
                "host": host,
                "port": port,
                "engine": engine,
            }
        return {
            "ok": False,
            "method": "docker_exec",
            "confidence": "degraded",
            "reason": str(docker_result.get("reason") or "docker exec SELECT 1 failed")
            + (f" (greeting: {last_reason})" if last_reason else ""),
            "host": host,
            "port": port,
            "engine": engine,
        }

    # docker_result is None → fallback unavailable. Try TCP-only as the
    # last permissive level. Reuse the existing port_open helper so we
    # do not duplicate the connect-with-timeout pattern.
    if port_open(probe_host, port):
        return {
            "ok": True,
            "method": "tcp_only",
            "confidence": "low",
            "reason": (
                f"TCP {probe_host}:{port} open; no protocol-level proof "
                f"(engine={engine or 'unknown'}, docker fallback unavailable)"
            )
            + (f" (greeting: {last_reason})" if last_reason else ""),
            "host": host,
            "port": port,
            "engine": engine,
        }
    return {
        "ok": False,
        "method": "none",
        "confidence": "degraded",
        "reason": (
            f"no evidence of a live DB at {probe_host}:{port} "
            f"(engine={engine or 'unknown'})"
        )
        + (f" (greeting: {last_reason})" if last_reason else ""),
        "host": host,
        "port": port,
        "engine": engine,
    }


def verify_managed_datasource(service_name: str, service: Dict[str, Any]) -> None:
    """Startup invariant: after `bootRun` readiness, assert that the actually
    running Spring Boot app is bound to the devstack-managed JDBC URL.

    Compares every `SPRING_DATASOURCE_*_URL` value planted on
    `service["env"]` against the value reported by
    `/actuator/env/<spring.property.name>`. On mismatch raises
    `DevstackError` so the caller (`start_service`) marks the service
    FAILED — readiness is denied.

    When the actuator endpoint is unreachable / 4xx / unparseable for
    *every* probed property, the function falls through to a narrowed
    soft-pass: devstack independently probes each expected managed JDBC
    URL via TCP + MySQL/MariaDB protocol greeting (or a docker-exec
    ``SELECT 1`` against the managed container as fallback). Probe
    success is now **required** for readiness — DB liveness is proven,
    but the app-side binding remains unverified (the original purpose of
    the actuator check). Probe failure raises ``DevstackError`` so the
    caller marks the service FAILED.

    No-op when:
    - service has no `SPRING_DATASOURCE_*_URL` entries in `env`, or
    - service has no usable `port` (cannot probe actuator), or
    - the service is not a gradle-bootRun service.
    """
    if not isinstance(service, dict):
        return
    expected = expected_managed_jdbc_urls(service)
    if not expected:
        return
    port = service.get("port")
    try:
        port_int = int(port) if port is not None else 0
    except (TypeError, ValueError):
        port_int = 0
    if port_int <= 0:
        return
    base_url = "http://localhost:" + str(port_int) + "/actuator"

    mismatches: List[str] = []
    reachable_any = False
    for property_name, expected_url in expected.items():
        actual = fetch_actuator_env_property(base_url, property_name)
        if actual is None:
            continue
        reachable_any = True
        if actual != expected_url:
            mismatches.append(
                f"{property_name}: actual={actual!r} expected={expected_url!r}"
            )
    if mismatches:
        raise DevstackError(
            f"{service_name}: bound JDBC URL does not match managed URL "
            f"({'; '.join(mismatches)}); refusing to mark ready"
        )
    if reachable_any:
        # Actuator-reachable path proved a match for at least one probed
        # property and detected no mismatches. The strict-mode invariant
        # is satisfied; do NOT run the DB-side liveness probe (it would
        # be redundant and would add startup latency for the common case
        # where actuator is exposed).
        return

    # ---- Soft-pass arm — DB liveness probe is now MANDATORY. ---------
    # Actuator was unreachable for every probed property. Independently
    # prove each expected JDBC URL points at a live database; deny
    # readiness with a clear reason on any failure.
    probe_results: List[Tuple[str, str, Dict[str, Any]]] = []
    for property_name, expected_url in expected.items():
        result = probe_managed_jdbc_target(property_name, expected_url)
        parsed = parse_jdbc_url(expected_url)
        engine = normalize_database_engine(str(parsed.get("engine") or ""))
        host = str(parsed.get("host") or "").strip() or "localhost"
        port_value = parsed.get("port") or 0
        try:
            port_value = int(port_value)
        except (TypeError, ValueError):
            port_value = 0
        # Prefer the probe result's view of host/port/engine — it carries
        # the post-shim values (e.g. "localhost" -> "127.0.0.1" is NOT
        # applied to the signal, only to the probe; the signal records the
        # JDBC URL host as declared by the manifest for downstream
        # aggregation accuracy).
        engine = str(result.get("engine") or engine)
        host = str(result.get("host") or host)
        port_value = int(result.get("port") or port_value)
        _record_managed_datasource_probe_signal(
            service_name,
            property_name,
            expected_url,
            host,
            port_value,
            engine,
            result,
        )
        probe_results.append((property_name, expected_url, result))

    failures = [
        (prop, url, result)
        for prop, url, result in probe_results
        if not result.get("ok")
    ]
    if failures:
        details = "; ".join(
            f"{prop} → {url}: {result.get('reason') or 'probe failed'} "
            f"(method={result.get('method')!r}, "
            f"confidence={result.get('confidence')!r})"
            for prop, url, result in failures
        )
        raise DevstackError(
            f"{service_name}: actuator env unreachable AND DB liveness probe "
            f"failed; refusing to mark ready ({details})"
        )

    # All probes succeeded. Summarize methods for the new WARN line so
    # operators can see which proof we have and which we don't (e.g. a
    # `confidence=low, method=tcp_only` outcome means "port is open but
    # we did not crack the protocol — consider exposing actuator or
    # making the managed container visible to docker for a tighter
    # invariant").
    method_summary = ",".join(
        sorted({str(result.get("method") or "none") for _, _, result in probe_results})
    )
    confidence_summary = ",".join(
        sorted({str(result.get("confidence") or "degraded") for _, _, result in probe_results})
    )
    sys.stderr.write(
        f"WARN: {service_name}: actuator env unreachable, "
        f"DB liveness proven via {method_summary} "
        f"(confidence={confidence_summary}), app-side binding unverified\n"
    )


def json_contains_non_empty_collection(value: Any) -> bool:
    if isinstance(value, list):
        return len(value) > 0
    if isinstance(value, dict):
        if value.get("errors"):
            return False
        return any(json_contains_non_empty_collection(child) for child in value.values())
    return False


def port_open(host: str, port: int) -> bool:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.settimeout(0.25)
        return sock.connect_ex((host, port)) == 0


def process_running(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return not process_zombie(pid)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True


def process_zombie(pid: int) -> bool:
    try:
        result = subprocess.run(
            ["ps", "-p", str(pid), "-o", "stat="],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            check=False,
        )
    except FileNotFoundError:
        return False
    if result.returncode != 0:
        return False
    return result.stdout.strip().startswith("Z")


def process_exists(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True


def process_group_id(pid: int) -> Optional[int]:
    getpgid = getattr(os, "getpgid", None)
    if getpgid is None:
        return None
    try:
        return int(getpgid(pid))
    except ProcessLookupError:
        return None
    except PermissionError:
        return None


def terminate_process_group(pgid: int, sig: signal.Signals, label: str) -> bool:
    killpg = getattr(os, "killpg", None)
    if killpg is None:
        return False
    try:
        killpg(pgid, sig)
        return True
    except ProcessLookupError:
        return False
    except PermissionError as error:
        raise DevstackError(f"{label}: cannot signal process group {pgid}: {error}") from error


def terminate_pid_or_group(pid: int, sig: signal.Signals, label: str) -> None:
    if terminate_process_group(pid, sig, label):
        return

    try:
        os.kill(pid, sig)
    except ProcessLookupError:
        pass
    except PermissionError as error:
        raise DevstackError(f"{label}: cannot signal pid {pid}: {error}") from error


def docker_container_inspect(container: str) -> Optional[Dict[str, Any]]:
    try:
        result = subprocess.run(
            ["docker", "inspect", container],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            check=False,
        )
    except FileNotFoundError:
        return None
    if result.returncode != 0:
        return None
    try:
        inspected = json.loads(result.stdout)
    except json.JSONDecodeError:
        return None
    if not inspected:
        return None
    return inspected[0]


def docker_container_running_from_inspect(inspected: Dict[str, Any]) -> bool:
    return bool(inspected.get("State", {}).get("Running"))


def docker_container_status(container: str) -> Optional[str]:
    inspected = docker_container_inspect(container)
    if not inspected:
        return None
    status = inspected.get("State", {}).get("Status")
    return str(status) if status else None


def docker_compose_service_from_inspect(inspected: Dict[str, Any]) -> Optional[str]:
    labels = inspected.get("Config", {}).get("Labels") or {}
    service = labels.get("com.docker.compose.service")
    return str(service) if service else None


def docker_container_running(container: str) -> bool:
    inspected = docker_container_inspect(container)
    if not inspected:
        return False
    return docker_container_running_from_inspect(inspected)


def docker_compose_service_status(
    compose_file: Path,
    cwd: Path,
    service_name: str,
    project_name: str = "",
) -> Optional[str]:
    compose_cmd = compose_command(cwd)
    try:
        result = subprocess.run(
            [
                *compose_cmd,
                *(["-p", project_name] if project_name else []),
                "-f",
                str(compose_file),
                "ps",
                "--all",
                "--format",
                "json",
                service_name,
            ],
            cwd=cwd,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            check=False,
        )
    except FileNotFoundError:
        return None
    if result.returncode != 0:
        return None

    for record in docker_compose_ps_records(result.stdout):
        service = str(record.get("Service") or record.get("Name") or "")
        if service != service_name and not service.endswith(f"-{service_name}-1"):
            continue
        status = normalize_docker_status(record.get("State") or record.get("Status"))
        if status:
            return status
    return None


def docker_compose_ps_records(output: str) -> List[Dict[str, Any]]:
    text = output.strip()
    if not text:
        return []
    try:
        loaded = json.loads(text)
        if isinstance(loaded, dict):
            return [loaded]
        if isinstance(loaded, list):
            return [item for item in loaded if isinstance(item, dict)]
    except json.JSONDecodeError:
        pass

    records: List[Dict[str, Any]] = []
    for line in text.splitlines():
        try:
            loaded = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(loaded, dict):
            records.append(loaded)
    return records


def normalize_docker_status(value: Any) -> Optional[str]:
    text = str(value or "").strip().lower()
    if not text:
        return None
    for status in ("running", "exited", "created", "restarting", "paused", "dead"):
        if status in text:
            return status
    return text.split()[0]


def docker_container_id(inspected: Dict[str, Any]) -> str:
    return str(inspected.get("Id") or inspected.get("ID") or "").strip()


def docker_container_name(inspected: Dict[str, Any]) -> str:
    name = str(inspected.get("Name") or "").strip("/")
    return name or docker_container_id(inspected)[:12] or "unknown"


def docker_container_for_host_port(port: int) -> Optional[Dict[str, Any]]:
    try:
        result = subprocess.run(
            ["docker", "ps", "-q"],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            check=False,
        )
    except FileNotFoundError:
        return None
    if result.returncode != 0:
        return None

    for container_id in result.stdout.splitlines():
        inspected = docker_container_inspect(container_id.strip())
        if inspected and docker_container_publishes_host_port(inspected, port):
            return inspected
    return None


def docker_container_publishes_host_port(inspected: Dict[str, Any], port: int) -> bool:
    port_text = str(port)
    bindings = inspected.get("HostConfig", {}).get("PortBindings") or {}
    for published in bindings.values():
        if not isinstance(published, list):
            continue
        for binding in published:
            if isinstance(binding, dict) and str(binding.get("HostPort")) == port_text:
                return True

    network_ports = inspected.get("NetworkSettings", {}).get("Ports") or {}
    for published in network_ports.values():
        if not isinstance(published, list):
            continue
        for binding in published:
            if isinstance(binding, dict) and str(binding.get("HostPort")) == port_text:
                return True
    return False


def docker_container_summary(inspected: Dict[str, Any]) -> str:
    labels = inspected.get("Config", {}).get("Labels") or {}
    details = [f"docker container {docker_container_name(inspected)}"]
    compose_service = labels.get("com.docker.compose.service")
    compose_project = labels.get("com.docker.compose.project")
    if compose_project:
        details.append(f"project={compose_project}")
    if compose_service:
        details.append(f"service={compose_service}")
    if len(details) == 1:
        return details[0]
    return f"{details[0]} ({', '.join(details[1:])})"


def process_command(pid: int) -> str:
    try:
        result = subprocess.run(
            ["ps", "-p", str(pid), "-o", "command="],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            check=False,
        )
    except FileNotFoundError:
        return "unknown command"
    command = result.stdout.strip()
    return command or "unknown command"


def listening_port_owner_summary(port: int) -> str:
    container = docker_container_for_host_port(port)
    if container:
        return docker_container_summary(container)

    pid = pid_for_listening_port(port)
    if pid is None:
        return "unknown owner"
    return f"pid {pid} ({process_command(pid)})"


def pid_for_listening_port(port: int) -> Optional[int]:
    try:
        result = subprocess.run(
            ["lsof", "-tiTCP:%s" % port, "-sTCP:LISTEN"],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            check=False,
        )
    except FileNotFoundError:
        return None
    for line in result.stdout.splitlines():
        try:
            return int(line.strip())
        except ValueError:
            continue
    return None


def split_csv(value: str) -> List[str]:
    return [item.strip() for item in value.split(",") if item.strip()]


def unique(values: Iterable[str]) -> List[str]:
    result: List[str] = []
    seen: Set[str] = set()
    for value in values:
        if value not in seen:
            seen.add(value)
            result.append(value)
    return result


def string_list(value: Any) -> List[str]:
    if value is None:
        return []
    if isinstance(value, list):
        return [str(item) for item in value if str(item)]
    if isinstance(value, tuple):
        return [str(item) for item in value if str(item)]
    if isinstance(value, str):
        return [value] if value else []
    return [str(value)]


def safe_name(value: str) -> str:
    return value.replace("/", "_").replace(":", "_").replace(".", "_")


def expand_value(value: str, root: Path, env: Dict[str, str]) -> str:
    # Both ``${PROJECT_ROOT}`` and ``${CCSTACK_ROOT}`` (legacy) and
    # ``${DEVSTACK_ROOT}`` (canonical) are honored as workspace-root tokens.
    value = (
        value
        .replace("${PROJECT_ROOT}", str(root))
        .replace("${DEVSTACK_ROOT}", str(root))
        .replace("${CCSTACK_ROOT}", str(root))
    )

    def replace_default(match: re.Match[str]) -> str:
        name = match.group(1)
        default = match.group(2)
        return env.get(name) or default

    value = re.sub(r"\$\{([A-Za-z_][A-Za-z0-9_]*)[:-]-(.*?)\}", replace_default, value)
    return os.path.expandvars(os.path.expanduser(value))


