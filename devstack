    function markServiceCardsFailed(names, label = "failed") {{
      names.forEach(name => markServiceCardFailed(name, label));
      if (names.length && serviceBoardStatus) {{
        serviceBoardStatus.textContent = label;
      }}
    }}

    function updateServiceStateOverview() {{
      const counts = {{ running: 0, attention: 0, stopped: 0 }};
      serviceCards.forEach(card => {{
        if (card.hidden) {{
          return;
        }}
        const kind = card.dataset.stateKind || "idle";
        if (["failed", "unhealthy", "unavailable"].includes(kind)) {{
          counts.attention += 1;
        }} else if (["up", "running", "external"].includes(kind)) {{
          counts.running += 1;
        }} else {{
          counts.stopped += 1;
        }}
      }});
      if (servicesRunningCount) {{
        servicesRunningCount.textContent = String(counts.running);
      }}
      if (servicesAttentionCount) {{
        servicesAttentionCount.textContent = String(counts.attention);
      }}
      if (servicesStoppedCount) {{
        servicesStoppedCount.textContent = String(counts.stopped);
      }}
    }}

    function delay(ms) {{
      return new Promise(resolve => window.setTimeout(resolve, ms));
    }}

    function profileServiceNames(profile) {{
      if (Array.isArray(profile)) {{
        return profile;
      }}
      if (profile && Array.isArray(profile.services)) {{
        return profile.services;
      }}
      return [];
    }}

    function targetServiceNames() {{
      const selectedTarget = target.value || "all";
      const allNames = serviceCatalog.map(item => item.name);
      if (selectedTarget === "all") {{
        return allNames;
      }}
      if (allNames.includes(selectedTarget)) {{
        return [selectedTarget];
      }}
      const mode = document.querySelector("#mode") ? document.querySelector("#mode").value : "full";
      const profileName = mode === "light" && workspaceProfiles[selectedTarget + "-light"]
        ? selectedTarget + "-light"
        : selectedTarget;
      const profileServices = profileServiceNames(workspaceProfiles[profileName] || workspaceProfiles[selectedTarget]);
      const knownProfileServices = profileServices.filter(name => allNames.includes(name));
      return knownProfileServices.length ? knownProfileServices : allNames;
    }}

    function serviceSearchText(item) {{
      if (!item) {{
        return "";
      }}
      return [
        item.name,
        item.role,
        item.type,
        item.port,
        item.health
      ].filter(Boolean).join(" ").toLowerCase();
    }}

    function filteredServiceNames() {{
      const targetNames = targetServiceNames();
      const query = serviceSearch ? serviceSearch.value.trim().toLowerCase() : "";
      if (!query) {{
        return targetNames;
      }}
      return targetNames.filter(name => {{
        const item = serviceCatalog.find(entry => entry.name === name);
        return serviceSearchText(item).includes(query);
      }});
    }}

    function updateServiceBoardFilter() {{
      const visibleNames = filteredServiceNames();
      const serviceSelect = document.querySelector("#service");
      serviceCards.forEach(card => {{
        card.hidden = !visibleNames.includes(card.dataset.serviceName);
        card.setAttribute("aria-hidden", card.hidden ? "true" : "false");
      }});
      if (serviceSelect) {{
        Array.from(serviceSelect.options).forEach(option => {{
          option.hidden = option.value && !visibleNames.includes(option.value);
          option.disabled = option.hidden;
        }});
      }}
      const current = currentServiceName();
      selectService(visibleNames.includes(current) ? current : (visibleNames[0] || ""));
      updateServiceStateOverview();
      if (serviceBoardStatus && activeProgressServices.size === 0) {{
        serviceBoardStatus.textContent = visibleNames.length ? visibleNames.length + " services" : "empty";
      }}
    }}

    function actionServiceNames(action, button = null) {{
      if (["restart", "recover"].includes(action)) {{
        const selected = currentServiceName();
        return selected ? [selected] : [];
      }}
      if (["up", "down"].includes(action) && button && button.dataset.serviceOnly === "1") {{
        const selected = currentServiceName();
        return selected ? [selected] : [];
      }}
      if (action === "up" || action === "down") {{
        return targetServiceNames();
      }}
      return [];
    }}

    function actionProgressLabel(action) {{
      if (action === "up") {{
        return "starting";
      }}
      if (action === "down") {{
        return "stopping";
      }}
      if (action === "restart") {{
        return "restarting";
      }}
      if (action === "logs") {{
        return "following logs";
      }}
      if (action === "recover") {{
        return "recovering selected service";
      }}
      return "working";
    }}

    function setActionServiceProgress(action, button = null) {{
      const names = actionServiceNames(action, button);
      const label = actionProgressLabel(action);
      const clearOnStatus = isLifecycleAction(action);
      const targetKind = serviceProgressTarget(action);
      names.forEach(name => setServiceCardProgress(name, label, clearOnStatus, targetKind));
      if (names.length && serviceBoardStatus) {{
        serviceBoardStatus.textContent = label;
      }}
      return names;
    }}

    function updateServiceBoardFromStatusOutput(text, options = {{}}) {{
      const resolveProgress = options.resolveProgress ?? true;
      const names = serviceCatalog.map(item => item.name).sort((left, right) => right.length - left.length);
      let matched = 0;
      text.split("\\n").forEach(line => {{
        const name = names.find(candidate => line.startsWith(candidate + " "));
        if (!name) {{
          return;
        }}
        matched += 1;
        const remainder = line.slice(name.length).trim();
        const state = (remainder.match(/^([^\\s]+)/) || [null, "idle"])[1];
        const health = (remainder.match(/\\bhealth=([^\\s]+)/) || [null, "-"])[1];
        setServiceCardState(name, state, health, {{ resolveProgress }});
      }});
      if (matched > 0) {{
        serviceStatusLoaded = true;
      }} else {{
        setAllServiceCardsUnavailable("status unavailable", {{ preserveProgress: isBusy }});
      }}
      if (serviceBoardStatus && activeProgressServices.size === 0) {{
        serviceBoardStatus.textContent = matched > 0 ? "status updated" : "status unavailable";
      }}
    }}

    function isServiceScopedActionButton(button) {{
      const action = button.dataset.action || "";
      return button.dataset.requiresService === "1"
        && (button.dataset.serviceOnly === "1" || ["restart", "recover"].includes(action));
    }}

    function updateActionButtons(isBusy = false) {{
      const selectedService = currentServiceName();
      const serviceActionBusy = activeActionServices.size > 0;
      buttons.forEach(button => {{
        const action = button.dataset.action || "";
        if (button.dataset.requiresWorkspace === "1" && !workspaceReady) {{
          button.disabled = true;
