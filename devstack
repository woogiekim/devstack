        # take just the basename. Fall back to ``devstack`` when the script
        # was invoked through a stream (no argv[0]).
        prog=(os.path.basename(sys.argv[0]) if sys.argv and sys.argv[0] else "devstack"),
        description="Start, stop, inspect, and open local MSA workspaces.",
        epilog=(
