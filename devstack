      }}
      if (outcome === "no_treatment_produced") {{
        return ["No treatment produced", "The host reported that remediation was not safe, not applicable, or not performed. Inspect the technical details below."];
      }}
      if (outcome === "treatment_available") {{
        return ["Treatment completed", "Review the host treatment/remediation outcome and verification details below."];
      }}
      if (state === "completed") {{
        return ["Doctor completed", "Review the technical details below before taking recovery action."];
      }}
      if (state === "host_failed" || state === "spawn_failed") {{
        return ["Diagnosis host failed", "Inspect the technical details below for the host failure and raw log tail."];
      }}
      if (state === "cancelled") {{
        return ["Diagnosis cancelled", "The diagnosis was cancelled before completing. Re-run when you are ready."];
      }}
      if (state === "running") {{
        return ["Diagnosis running", "The selected host is executing the Doctor workflow."];
      }}
      if (state === "spawned") {{
        return ["Diagnosis spawned", "Waiting for the selected host process to start running."];
      }}
      return ["Diagnosis status unknown", "Inspect the technical details below for the latest Doctor state."];
    }}

