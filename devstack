    function applyDoctorStatus(data) {{
      const state = data.doctor_state || "unknown";
      setDoctorStatus(data.status || state, data.status_class || "");
      const copy = doctorStateCopy(state, data.doctor_outcome || "");
      if (doctorOutcome) {{
        doctorOutcome.textContent = copy[0];
      }}
      if (doctorRecommendation) {{
        doctorRecommendation.textContent = copy[1];
      }}
      if (data.output) {{
        resetOutput(data.output);
      }}
      setDoctorTechnicalDetails(data);
      const isActive = state === "spawned" || state === "running";
      if (doctorCancelButton) {{
        doctorCancelButton.hidden = !isActive;
        doctorCancelButton.disabled = !isActive;
      }}
      // UIB-4: surface heartbeat (runtime_seconds + last_heartbeat_at) near
      // the doctorStatusPill so the user can tell a live run from a hung
      // run without opening the technical-details drawer. Use querySelector
      // to stay compatible with the existing JSDOM-light test shim.
      const heartbeatEl = document.querySelector("#doctorHeartbeat");
      if (heartbeatEl) {{
        if (isActive && data && (data.runtime_seconds != null || data.last_heartbeat_at)) {{
          const runtime = formatDoctorRuntime(data.runtime_seconds);
          const beat = formatDoctorHeartbeatAge(data.last_heartbeat_at);
          const parts = [];
          if (runtime) parts.push(runtime);
          if (beat) parts.push("heartbeat " + beat);
          heartbeatEl.textContent = parts.join(" · ");
          heartbeatEl.hidden = parts.length === 0;
        }} else {{
          heartbeatEl.textContent = "";
          heartbeatEl.hidden = true;
        }}
      }}
      if (state === "completed" || state === "host_failed" || state === "spawn_failed" || state === "cancelled") {{
        // UIB-5: terminal state — drop the run id so subsequent
        // poll/cancel clicks don't target a finished run.
        stopDoctorStatusPolling({{ clearRunId: true }});
        updateDoctorTargets();
        if (startDoctorWorkflowButton) {{
          startDoctorWorkflowButton.disabled = !workspaceReady;
        }}
      }}
    }}

    function formatDoctorRuntime(seconds) {{
      if (seconds == null) return "";
      const total = Math.max(0, Math.floor(Number(seconds) || 0));
      if (total < 60) return "running " + total + "s";
      const m = Math.floor(total / 60);
      const s = total % 60;
      if (m < 60) return "running " + m + "m" + (s ? " " + s + "s" : "");
      const h = Math.floor(m / 60);
      return "running " + h + "h " + (m % 60) + "m";
    }}

    function formatDoctorHeartbeatAge(iso) {{
      if (!iso) return "";
      const parsed = Date.parse(iso);
      if (Number.isNaN(parsed)) return "";
      const ageSec = Math.max(0, Math.floor((Date.now() - parsed) / 1000));
      if (ageSec < 60) return ageSec + "s ago";
      const m = Math.floor(ageSec / 60);
      if (m < 60) return m + "m ago";
      const h = Math.floor(m / 60);
      return h + "h ago";
    }}

    async function pollDoctorStatus() {{
      if (!doctorCurrentRunId) {{
        return;
      }}
      const params = new URLSearchParams({{
        action: "doctor_status",
        workspace: workspace.value,
        doctor_run_id: doctorCurrentRunId
      }});
      try {{
        const response = await fetch("/api/run", {{
          method: "POST",
          headers: {{ "Content-Type": "application/x-www-form-urlencoded" }},
          body: params.toString()
        }});
        const data = await response.json();
        if (data.ok) {{
          applyDoctorStatus(data);
        }} else {{
          setDoctorStatus("status unavailable", "fail");
          if (doctorOutcome) {{
            doctorOutcome.textContent = "Diagnosis status unavailable";
          }}
          if (doctorRecommendation) {{
            doctorRecommendation.textContent = "Inspect the technical details below for the status error.";
          }}
          resetOutput(data.output || "doctor status unavailable");
        }}
      }} catch (error) {{
        setDoctorStatus("status unavailable", "fail");
        resetOutput(String(error));
      }}
    }}

    function startDoctorStatusPolling(runId) {{
      doctorCurrentRunId = runId || "";
      stopDoctorStatusPolling();
      if (!doctorCurrentRunId) {{
        return;
