    function updateDoctorTargets() {{
      const selectedScope = doctorScope();
      const isFailedScope = selectedScope === "failed";
      let failedCount = 0;
      doctorTargetRows.forEach(row => {{
        const card = serviceCard(row.dataset.doctorService || "");
        const kind = card ? card.dataset.stateKind || "" : "";
        const isFailed = kind === "failed" || kind === "unhealthy";
        const checkbox = row.querySelector("input");
        row.hidden = !isFailed;
        if (checkbox) {{
          checkbox.disabled = !isFailedScope || !isFailed;
          if (isFailed && !doctorTargetTouched) {{
